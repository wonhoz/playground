<Window x:Class="AnsiForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ANSI.Forge" Height="720" Width="1200"
        Background="#1A1A1A" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="44"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="24"/>
    </Grid.RowDefinitions>

    <!-- 툴바 -->
    <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#333" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
        <TextBlock Text="⬛ ANSI.Forge" FontSize="15" FontWeight="Bold"
                   Foreground="#5B8AF0" VerticalAlignment="Center" Margin="0,0,16,0"/>
        <Button Content="📂 열기" Margin="0,0,4,0" Click="BtnOpen_Click"/>
        <Button Content="💾 저장" Margin="0,0,4,0" Click="BtnSave_Click"/>
        <Button Content="🖼️ PNG 내보내기" Margin="0,0,4,0" Click="BtnExportPng_Click"/>
        <Button Content="🌐 HTML 내보내기" Margin="0,0,16,0" Click="BtnExportHtml_Click"/>
        <Button Content="🗑️ 지우기" Margin="0,0,16,0" Click="BtnClear_Click"/>
        <TextBlock Text="전경:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <Border x:Name="FgColorBox" Width="20" Height="20" CornerRadius="4" BorderBrush="#666" BorderThickness="1"
                Cursor="Hand" MouseDown="FgColorBox_MouseDown"/>
        <TextBlock Text="배경:" Foreground="#888" VerticalAlignment="Center" Margin="10,0,4,0"/>
        <Border x:Name="BgColorBox" Width="20" Height="20" CornerRadius="4" BorderBrush="#666" BorderThickness="1"
                Cursor="Hand" MouseDown="BgColorBox_MouseDown"/>
      </StackPanel>
    </Border>

    <!-- 메인 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 팔레트 패널 -->
      <Border Grid.Column="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="8">
            <TextBlock Text="16색 팔레트" Foreground="#888" FontSize="11" Margin="0,0,0,6"/>
            <WrapPanel x:Name="Palette16" Margin="0,0,0,12"/>
            <TextBlock Text="256색 팔레트" Foreground="#888" FontSize="11" Margin="0,0,0,6"/>
            <WrapPanel x:Name="Palette256"/>

            <TextBlock Text="그리기 도구" Foreground="#888" FontSize="11" Margin="0,16,0,6"/>
            <StackPanel>
              <Button x:Name="BtnPen" Content="✏️ 펜" Margin="0,2" Click="DrawTool_Click" Tag="pen"/>
              <Button x:Name="BtnFill" Content="🪣 채우기" Margin="0,2" Click="DrawTool_Click" Tag="fill"/>
              <Button x:Name="BtnEraser" Content="🧹 지우개" Margin="0,2" Click="DrawTool_Click" Tag="eraser"/>
            </StackPanel>

            <TextBlock Text="블록 문자" Foreground="#888" FontSize="11" Margin="0,16,0,6"/>
            <WrapPanel x:Name="BlockChars" Margin="0,0,0,8"/>

            <TextBlock Text="현재 문자:" Foreground="#888" FontSize="11" Margin="0,8,0,4"/>
            <Border Background="#222" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8,4">
              <TextBlock x:Name="CurrentCharDisplay" FontFamily="Cascadia Code, Consolas"
                         FontSize="20" HorizontalAlignment="Center"
                         Foreground="#E0E0E0"/>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- 편집 영역 + 원시 텍스트 -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#151515" Padding="8,6" BorderBrush="#333" BorderThickness="0,0,0,1">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="그리드:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock x:Name="GridSizeText" FontSize="11" Foreground="#5B8AF0" VerticalAlignment="Center"/>
            <TextBlock Text="  문자:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBlock x:Name="PosText" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#0A0A0A">
          <Canvas x:Name="EditCanvas" Background="#0A0A0A"
                  MouseDown="EditCanvas_MouseDown"
                  MouseMove="EditCanvas_MouseMove"
                  MouseUp="EditCanvas_MouseUp"
                  Cursor="IBeam"/>
        </ScrollViewer>
      </Grid>

      <!-- 미리보기 + 원시 -->
      <Border Grid.Column="2" Background="#0A0A0A" BorderBrush="#333" BorderThickness="1,0,0,0">
        <TabControl Background="Transparent" BorderThickness="0">
          <TabItem Header="렌더링 미리보기">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          Background="#0A0A0A">
              <StackPanel x:Name="PreviewPanel" Margin="8"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="원시 ANSI 텍스트">
            <TextBox x:Name="RawTextBox" Background="#0A0A0A" Foreground="#66DD66"
                     BorderThickness="0" FontFamily="Cascadia Code, Consolas" FontSize="11"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextChanged="RawTextBox_TextChanged"/>
          </TabItem>
        </TabControl>
      </Border>
    </Grid>

    <!-- 상태바 -->
    <Border Grid.Row="2" Background="#111" Padding="12,0">
      <TextBlock x:Name="StatusBar" Foreground="#555" FontSize="11" VerticalAlignment="Center"/>
    </Border>
  </Grid>
</Window>
