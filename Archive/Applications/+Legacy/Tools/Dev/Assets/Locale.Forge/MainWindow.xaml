<Window x:Class="LocaleForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LocaleForge"
        xmlns:vm="clr-namespace:LocaleForge.ViewModels"
        Title="Locale.Forge — i18n 다국어 파일 관리자"
        Width="1200" Height="760"
        MinWidth="800" MinHeight="500"
        Background="#1A1A2E"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen"
>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── 툴바 ─── -->
        <Border Grid.Row="0" Background="#0F3460" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측 버튼들 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Click="BtnOpenFile_Click" ToolTip="파일 열기 (Ctrl+O)" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="파일 열기" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BtnSaveAll_Click" ToolTip="모두 저장 (Ctrl+S)" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="모두 저장" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="1" Background="#444466" Margin="4,0,10,0"/>
                    <Button Click="BtnAddKey_Click" ToolTip="새 키 추가" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="키 추가" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BtnDeleteKey_Click" ToolTip="선택 키 삭제" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="키 삭제" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="1" Background="#444466" Margin="4,0,10,0"/>
                    <Button Click="BtnScanSource_Click" ToolTip="소스 코드 폴더 스캔 → 미사용 키 탐지" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="미사용 탐지" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BtnExportAs_Click" ToolTip="다른 형식으로 내보내기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↗" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="변환 내보내기" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 중앙 검색 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🔎" FontSize="14" VerticalAlignment="Center" Foreground="#888" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtSearch" Width="280" Height="28"
                             VerticalContentAlignment="Center"
                             TextChanged="TxtSearch_TextChanged"
                             Margin="0,0,8,0"/>
                    <CheckBox x:Name="ChkMissingOnly" Content="누락만" Foreground="#FFB347"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"
                              VerticalAlignment="Center" Cursor="Hand" Margin="0,0,12,0">
                        <CheckBox.Template>
                            <ControlTemplate TargetType="CheckBox">
                                <StackPanel Orientation="Horizontal" Cursor="Hand">
                                    <Border Width="16" Height="16" CornerRadius="3" Margin="0,0,5,0"
                                            BorderBrush="#FFB347" BorderThickness="1"
                                            Background="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}, Converter={x:Static local:BoolToBgConverter.Instance}}">
                                        <TextBlock Text="✓" Foreground="#FFB347" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
                                    </Border>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                            </ControlTemplate>
                        </CheckBox.Template>
                    </CheckBox>
                    <CheckBox x:Name="ChkUnusedOnly" Content="미사용만" Foreground="#FFD700"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"
                              VerticalAlignment="Center" Cursor="Hand">
                        <CheckBox.Template>
                            <ControlTemplate TargetType="CheckBox">
                                <StackPanel Orientation="Horizontal" Cursor="Hand">
                                    <Border Width="16" Height="16" CornerRadius="3" Margin="0,0,5,0"
                                            BorderBrush="#FFD700" BorderThickness="1"
                                            Background="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}, Converter={x:Static local:BoolToBgConverter.Instance}}">
                                        <TextBlock Text="✓" Foreground="#FFD700" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
                                    </Border>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                            </ControlTemplate>
                        </CheckBox.Template>
                    </CheckBox>
                </StackPanel>

                <!-- 우측: 통계 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtStats" Text="키: 0  누락: 0  미사용: 0"
                               Foreground="#888888" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── 본문 ─── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 패널: 로드된 파일 목록 -->
            <Border Grid.Column="0" Background="#16213E" BorderBrush="#333355" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0F3460" Padding="10,8">
                        <TextBlock Text="📁 로드된 파일" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                    </Border>

                    <ListBox x:Name="LstFiles" Grid.Row="1"
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="LstFiles_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding LanguageCode}" FontWeight="Bold"
                                                   Foreground="#E94560" FontSize="12"/>
                                        <TextBlock FontSize="10" Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Text>
                                                <Binding Path="FilePath"
                                                         Converter="{x:Static local:FileNameConverter.Instance}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Background="Transparent"
                                            BorderThickness="0" Foreground="#666688" FontSize="10"
                                            Padding="4,2" Cursor="Hand"
                                            Tag="{Binding}"
                                            Click="BtnRemoveFile_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 드래그&드롭 안내 -->
                    <Border Grid.Row="2" Padding="10,12" BorderBrush="#333355" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="💡 파일을 여기에" Foreground="#555577" FontSize="11" TextAlignment="Center"/>
                            <TextBlock Text="드래그&amp;드롭 하세요" Foreground="#555577" FontSize="11" TextAlignment="Center"/>
                            <TextBlock Text="JSON · YAML · RESX · PO · Properties" Foreground="#444466" FontSize="10" TextAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#252545" ResizeDirection="Columns"/>

            <!-- 우측: 메인 DataGrid -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- DataGrid -->
                <DataGrid x:Name="DgEntries" Grid.Row="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          SelectionChanged="DgEntries_SelectionChanged"
                          CellEditEnding="DgEntries_CellEditEnding">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                    <Setter Property="Background" Value="#3A1A1A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUnused}" Value="True">
                                    <Setter Property="Background" Value="#2A2810"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- 하단 편집 패널 -->
                <Border Grid.Row="1" Background="#16213E" BorderBrush="#333355"
                        BorderThickness="0,1,0,0" Padding="12,8"
                        x:Name="PnlEdit" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,10,0">
                            <TextBlock Text="선택된 키:" Foreground="#888888" FontSize="11"/>
                            <TextBlock x:Name="TxtSelectedKey" Foreground="#E94560"
                                       FontWeight="Bold" TextWrapping="Wrap" FontSize="13" Margin="0,4,0,0"/>
                            <TextBlock x:Name="TxtKeyStatus" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto" MaxHeight="120">
                            <StackPanel x:Name="PnlLangEditors"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ─── 상태바 ─── -->
        <Border Grid.Row="2" Background="#0A0A1E" Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0"
                           Foreground="#888888" FontSize="11"
                           Text="파일을 드래그&amp;드롭하거나 열기 버튼으로 불러오세요."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Border Width="10" Height="10" CornerRadius="2" Background="#3A1A1A" Margin="0,0,4,0"/>
                        <TextBlock Text="누락 키" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" CornerRadius="2" Background="#2A2810" Margin="0,0,4,0"/>
                        <TextBlock Text="미사용 키" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
