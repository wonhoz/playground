<Window x:Class="ZipPeek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ZipPeek.Views"
        Title="Zip.Peek" Height="700" Width="1200" MinHeight="480" MinWidth="800"
        Background="#111118" Foreground="#E8E8F0"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 툴바 ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0D0D16" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1">
            <DockPanel Margin="12,8">
                <!-- 로고 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="Zip" Foreground="#F59E0B"/>
                        <Run Text=".Peek" Foreground="#E8E8F0"/>
                    </TextBlock>
                </StackPanel>

                <!-- 우측 액션 버튼 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnExtractSelected" Content="선택 추출" Width="90"
                            Click="BtnExtractSelected_Click" IsEnabled="False" Margin="0,0,6,0"
                            ToolTip="선택한 항목을 추출합니다"/>
                    <Button x:Name="BtnExtractAll" Content="전체 추출" Width="90"
                            Click="BtnExtractAll_Click" IsEnabled="False"
                            ToolTip="모든 항목을 추출합니다"/>
                </StackPanel>

                <!-- 검색바 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="📂  파일 열기" Width="110"
                            Click="BtnOpen_Click" Margin="0,0,10,0"
                            Background="#22223A" BorderBrush="#3A3A5A"/>
                    <TextBox Grid.Column="1" x:Name="TxtSearch" Height="30"
                             VerticalAlignment="Center" Margin="0,0,6,0"
                             Padding="8,2"
                             Text="파일 내용 또는 이름 검색..."
                             Foreground="#888899"
                             GotFocus="TxtSearch_GotFocus" LostFocus="TxtSearch_LostFocus"
                             KeyDown="TxtSearch_KeyDown"/>
                    <Button Grid.Column="2" Content="검색" Width="60" Height="30"
                            Click="BtnSearch_Click" Margin="0,0,6,0"/>
                    <CheckBox Grid.Column="3" x:Name="ChkContentSearch" Content="내용 검색"
                              VerticalAlignment="Center" Foreground="#888899"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ── 메인 콘텐츠 ─────────────────────────────────────────── -->
        <Border Grid.Row="1" x:Name="MainContent">
            <!-- 드롭 안내 (아카이브 미열림 시) -->
        </Border>

        <!-- ── 상태바 ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#0D0D16" BorderBrush="#2A2A3E" BorderThickness="0,1,0,0">
            <Grid Margin="12,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Text="파일을 드래그하거나 열기 버튼을 클릭하세요."
                           Foreground="#888899" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TxtStats" Foreground="#888899" FontSize="11"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="PbMain" Width="120" Height="4" Margin="12,0,0,0"
                                 Visibility="Collapsed" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
