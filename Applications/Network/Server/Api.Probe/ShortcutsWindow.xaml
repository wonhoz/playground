<Window x:Class="ApiProbe.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키 도움말" Width="460" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg1Brush}"
        Foreground="{StaticResource FgBrush}"
        Icon="pack://application:,,,/Resources/app.ico">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 헤더 -->
    <StackPanel Grid.Row="0">
      <TextBlock Text="단축키 도움말" FontSize="17" FontWeight="Bold"
                 Foreground="{StaticResource AccentBrush}"/>
      <TextBlock Text="Api.Probe 키보드 단축키 목록"
                 FontSize="12" Foreground="{StaticResource FgDimBrush}" Margin="0,4,0,0"/>
    </StackPanel>

    <!-- 구분선 -->
    <Separator Grid.Row="1" Margin="0"/>

    <!-- 단축키 목록 -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- 요청 -->
        <TextBlock Text="요청" FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource FgDimBrush}" Margin="0,0,0,6"/>
        <Border Background="{StaticResource Bg2Brush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
          <StackPanel>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                <TextBlock Text="Enter" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
              </Border>
              <TextBlock Grid.Column="1" Text="요청 전송 (URL 입력창에서)" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                <TextBlock Text="Escape" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
              </Border>
              <TextBlock Grid.Column="1" Text="진행 중인 요청 취소" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- 응답 검색 -->
        <TextBlock Text="응답 검색" FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource FgDimBrush}" Margin="0,0,0,6"/>
        <Border Background="{StaticResource Bg2Brush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
          <StackPanel>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                <TextBlock Text="Ctrl + F" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
              </Border>
              <TextBlock Grid.Column="1" Text="응답 바디 검색 열기" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                <TextBlock Text="F3  /  Enter" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
              </Border>
              <TextBlock Grid.Column="1" Text="다음 검색 결과" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                <TextBlock Text="Shift + F3" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
              </Border>
              <TextBlock Grid.Column="1" Text="이전 검색 결과" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                <TextBlock Text="Escape" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
              </Border>
              <TextBlock Grid.Column="1" Text="검색 닫기" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- 기타 -->
        <TextBlock Text="기타" FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource FgDimBrush}" Margin="0,0,0,6"/>
        <Border Background="{StaticResource Bg2Brush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,4">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
              <TextBlock Text="F1" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
            </Border>
            <TextBlock Grid.Column="1" Text="단축키 도움말 열기" FontSize="12" VerticalAlignment="Center"/>
          </Grid>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- 닫기 버튼 -->
    <Button Grid.Row="4" Content="닫기" Width="80" HorizontalAlignment="Right"
            Style="{StaticResource AccentButton}" Click="CloseBtn_Click"/>
  </Grid>
</Window>
