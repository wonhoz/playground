<Window x:Class="SnapDuel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snap.Duel — 반응속도 대전"
        Width="960" Height="680"
        MinWidth="800" MinHeight="580"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <TextBlock Text="⚡ Snap.Duel" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnTournament" Content="🏆 토너먼트" Click="BtnTournament_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnResetScore" Content="↺ 리셋" Click="BtnResetScore_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnSettings" Content="⚙️ 설정" Click="BtnSettings_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 3분할 -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- P1 패널 -->
            <Border Grid.Column="0" x:Name="P1Panel"
                    Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource P1Brush}" BorderThickness="2"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,8">
                        <TextBlock Text="PLAYER 1" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource P1Brush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="키: Q" FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- P1 버튼 -->
                    <Button Grid.Row="1" x:Name="BtnP1"
                            Click="BtnP1_Click" Margin="20,8,20,8"
                            Background="#0D1F2D" BorderBrush="{StaticResource P1Brush}"
                            BorderThickness="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Q" FontSize="64" FontWeight="Bold"
                                       Foreground="{StaticResource P1Brush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="P1LastTime" Grid.Row="1"
                                       Text="—" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        </Grid>
                    </Button>

                    <!-- P1 점수 -->
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="점수" FontSize="11" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="P1Score" Text="0" FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource P1Brush}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="P1Wins" Text="승: 0" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 중앙 신호 패널 -->
            <Border Grid.Column="2"
                    Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="2"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 신호 원 -->
                    <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Ellipse x:Name="SignalCircle" Width="110" Height="110"
                                 Fill="#2A2A2A" Stroke="#444" StrokeThickness="3"/>
                        <TextBlock x:Name="SignalEmoji" Text="⏸" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 신호 조건 텍스트 -->
                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="6"
                            Padding="8,4" Margin="8,0,8,8"
                            x:Name="ConditionBorder" Visibility="Collapsed">
                        <TextBlock x:Name="ConditionText" Text="" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </Border>

                    <!-- 상태 + 라운드 -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock x:Name="StatusText" Text="대기 중"
                                   FontSize="13" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="RoundText" Text="라운드 1 / 5"
                                   FontSize="11" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- 시작 버튼 -->
                    <Button Grid.Row="4" x:Name="BtnStart"
                            Content="▶ 시작 (Space)" Click="BtnStart_Click"
                            VerticalAlignment="Bottom" Margin="12,0,12,12"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White" FontWeight="Bold" FontSize="13"/>
                </Grid>
            </Border>

            <!-- P2 패널 -->
            <Border Grid.Column="4" x:Name="P2Panel"
                    Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource P2Brush}" BorderThickness="2"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,8">
                        <TextBlock Text="PLAYER 2" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource P2Brush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="키: P" FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- P2 버튼 -->
                    <Button Grid.Row="1" x:Name="BtnP2"
                            Click="BtnP2_Click" Margin="20,8,20,8"
                            Background="#2D1A0D" BorderBrush="{StaticResource P2Brush}"
                            BorderThickness="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="P" FontSize="64" FontWeight="Bold"
                                       Foreground="{StaticResource P2Brush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="P2LastTime" Grid.Row="1"
                                       Text="—" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        </Grid>
                    </Button>

                    <!-- P2 점수 -->
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="점수" FontSize="11" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="P2Score" Text="0" FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource P2Brush}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="P2Wins" Text="승: 0" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 힌트 -->
        <Border Grid.Row="2" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <TextBlock Text="Q: P1 반응  |  P: P2 반응  |  Space: 시작/다음 라운드  |  Esc: 중단"
                           Foreground="{StaticResource MutedBrush}" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="GameModeText" Text="● 일반 모드 (5라운드)"
                           Foreground="{StaticResource AccentBrush}" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
