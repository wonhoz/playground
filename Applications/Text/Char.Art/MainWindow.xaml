<Window x:Class="CharArt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Char.Art" Height="620" Width="1060" MinHeight="500" MinWidth="820"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#001A18"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00CEC9"/>
                                <Setter Property="Foreground" Value="#00CEC9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#002A22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#22222E"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
            <Setter Property="BorderBrush" Value="#2A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#002A22"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00B894"/>
                                <Setter Property="Foreground" Value="#00B894"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#003A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 ── -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Char" Foreground="{StaticResource AccentBrush}"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource SubTextBrush}"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Art" Foreground="{StaticResource TextBrush}"
                               FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 열기 그룹 -->
                    <Button x:Name="BtnOpen" Content="📂 열기"
                            Style="{StaticResource OutlineButtonStyle}"
                            Margin="0,0,2,0"
                            Click="BtnOpen_Click"/>
                    <Button x:Name="BtnRecentDrop" Content="▼"
                            Style="{StaticResource OutlineButtonStyle}"
                            Padding="6,6"
                            Margin="0,0,10,0"
                            Click="BtnRecentDrop_Click"
                            ToolTip="최근 파일">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="RecentMenu"
                                         Background="#1E1E28" BorderBrush="#2A3A3A"
                                         Foreground="#E8E8E0" FontSize="12"/>
                        </Button.ContextMenu>
                    </Button>

                    <!-- 저장 그룹 -->
                    <Button x:Name="BtnSave" Content="💾 .txt"
                            Style="{StaticResource OutlineButtonStyle}"
                            Margin="0,0,2,0"
                            IsEnabled="False" Click="BtnSave_Click"
                            ToolTip=".txt 저장 (Ctrl+S)"/>
                    <Button x:Name="BtnSavePng" Content="🖼 .png"
                            Style="{StaticResource OutlineButtonStyle}"
                            Margin="0,0,2,0"
                            IsEnabled="False" Click="BtnSavePng_Click"
                            ToolTip=".png 저장 (Ctrl+Shift+S)"/>
                    <Button x:Name="BtnSaveHtml" Content="🌐 .html"
                            Style="{StaticResource OutlineButtonStyle}"
                            Margin="0,0,10,0"
                            IsEnabled="False" Click="BtnSaveHtml_Click"
                            ToolTip="컬러 HTML 저장 (Ctrl+Shift+H)"/>

                    <!-- 복사 / 도움말 -->
                    <Button x:Name="BtnCopy" Content="📋 복사"
                            Style="{StaticResource OutlineButtonStyle}"
                            Margin="0,0,8,0"
                            IsEnabled="False" Click="BtnCopy_Click"
                            ToolTip="클립보드 복사 (Ctrl+C)"/>
                    <Button x:Name="BtnHelp" Content="?"
                            Style="{StaticResource OutlineButtonStyle}"
                            Padding="8,6"
                            Click="BtnHelp_Click"
                            ToolTip="단축키 도움말 (F1)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 본문 ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="360"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽 패널 ── -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14,14,14,14">

                        <!-- 이미지 미리보기 -->
                        <Border Height="190" Background="{StaticResource InputBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" ClipToBounds="True" Margin="0,0,0,2">
                            <Grid>
                                <TextBlock x:Name="TxtDropHint"
                                           Text="이미지를 드래그하거나&#x0a;열기 버튼을 누르세요"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontSize="12" TextAlignment="Center"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <Image x:Name="ImgPreview" Stretch="Uniform"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <Separator/>

                        <!-- 문자셋 -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="문자셋" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="CbCharSet" SelectionChanged="Setting_Changed"/>
                        </StackPanel>

                        <!-- 커스텀 입력 -->
                        <StackPanel x:Name="PanelCustom" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock Text="커스텀 문자 입력" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtCustomChars" Height="32"
                                     TextChanged="Setting_Changed_Text"/>
                        </StackPanel>

                        <!-- 출력 폰트 -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="출력 폰트" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="CbFont" SelectionChanged="Setting_Changed"/>
                        </StackPanel>

                        <!-- 폰트 크기 -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="폰트 크기" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="CbFontSize" SelectionChanged="Setting_Changed"/>
                        </StackPanel>

                        <!-- 열 수 슬라이더 -->
                        <StackPanel Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="열 수" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtColsValue" Text="80"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="SldCols" Minimum="20" Maximum="300" Value="80"
                                    SmallChange="1" LargeChange="10"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="SldCols_ValueChanged"/>
                        </StackPanel>

                        <!-- 열 수 프리셋 버튼 -->
                        <UniformGrid Columns="4" Margin="0,0,0,10">
                            <Button Content="40"  Tag="40"  Style="{StaticResource PresetButtonStyle}" Margin="0,0,2,0" Click="PresetCols_Click"/>
                            <Button Content="80"  Tag="80"  Style="{StaticResource PresetButtonStyle}" Margin="2,0,2,0" Click="PresetCols_Click"/>
                            <Button Content="120" Tag="120" Style="{StaticResource PresetButtonStyle}" Margin="2,0,2,0" Click="PresetCols_Click"/>
                            <Button Content="160" Tag="160" Style="{StaticResource PresetButtonStyle}" Margin="2,0,0,0" Click="PresetCols_Click"/>
                        </UniformGrid>

                        <!-- 반전 체크박스 -->
                        <CheckBox x:Name="ChkInvert" Content="반전 (밝은 영역 → 밀한 문자)"
                                  Margin="0,0,0,4"
                                  Checked="Setting_Changed_Check" Unchecked="Setting_Changed_Check"/>

                        <Separator/>

                        <!-- 생성 버튼 -->
                        <Button x:Name="BtnGenerate" Content="▶ 생성"
                                Height="36" Click="BtnGenerate_Click" IsEnabled="False"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 리사이저 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

            <!-- ── 오른쪽 패널 (텍스트 아트 출력) ── -->
            <Grid Grid.Column="2">
                <ScrollViewer x:Name="SvArt"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource BgBrush}">
                    <TextBox x:Name="TxtArt"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             FontFamily="Consolas"
                             FontSize="8"
                             Background="Transparent"
                             Foreground="{StaticResource TextBrush}"
                             BorderThickness="0"
                             Padding="12"
                             VerticalAlignment="Top"
                             HorizontalAlignment="Left"/>
                </ScrollViewer>

                <!-- 안내 오버레이 -->
                <TextBlock x:Name="TxtArtHint"
                           Text="이미지를 열어 텍스트 아트를 생성하세요"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- ── 상태바 ── -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="TxtStatus"
                           Text="이미지를 열거나 드래그하세요"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtZoomInfo"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="11" VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
