<Window x:Class="ImgCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Img.Cast"
        Width="480" Height="600"
        MinWidth="480" MinHeight="580"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

  <Window.Resources>

    <!-- ── ComboBox ControlTemplate ── -->
    <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
      <Grid>
        <ToggleButton x:Name="ToggleButton"
                      Focusable="False"
                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                      ClickMode="Press">
          <ToggleButton.Template>
            <ControlTemplate TargetType="ToggleButton">
              <Border x:Name="Border"
                      Background="{StaticResource SurfaceBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="28"/>
                  </Grid.ColumnDefinitions>
                  <ContentPresenter Grid.Column="0"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"/>
                  <Path Grid.Column="1"
                        Data="M 0 0 L 5 5 L 10 0"
                        Stroke="{StaticResource SubTextBrush}"
                        StrokeThickness="1.5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Grid>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </ToggleButton.Template>
        </ToggleButton>
        <ContentPresenter x:Name="ContentSite"
                          IsHitTestVisible="False"
                          Content="{TemplateBinding SelectionBoxItem}"
                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                          Margin="10,0,30,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left"/>
        <Popup x:Name="PART_Popup"
               Placement="Bottom"
               IsOpen="{TemplateBinding IsDropDownOpen}"
               AllowsTransparency="True"
               Focusable="False"
               PopupAnimation="Slide">
          <Border Background="{StaticResource Surface2Brush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  MinWidth="{TemplateBinding ActualWidth}"
                  MaxHeight="200"
                  Margin="0,2,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsPresenter/>
            </ScrollViewer>
          </Border>
        </Popup>
      </Grid>
    </ControlTemplate>

    <Style TargetType="ComboBox">
      <Setter Property="Height" Value="34"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
    </Style>

    <Style TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="4"
                    Margin="3,1">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDimBrush}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDimBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── CheckBox ControlTemplate ── -->
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal">
              <Border x:Name="Box"
                      Width="16" Height="16"
                      Background="{StaticResource SurfaceBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1.5"
                      CornerRadius="3"
                      VerticalAlignment="Center"
                      Margin="0,0,7,0">
                <Path x:Name="Check"
                      Data="M 2 8 L 6 12 L 14 4"
                      Stroke="{StaticResource AccentBrush}"
                      StrokeThickness="2"
                      Visibility="Collapsed"/>
              </Border>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Button ControlTemplate ── -->
    <Style x:Key="DarkButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDimBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
      <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
    </Style>

    <Style x:Key="LinkButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <TextBlock x:Name="Tb"
                         Text="{TemplateBinding Content}"
                         Foreground="{TemplateBinding Foreground}"
                         FontSize="{TemplateBinding FontSize}"
                         TextDecorations="Underline"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Tb" Property="Foreground" Value="{StaticResource TextBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── ProgressBar ── -->
    <Style TargetType="ProgressBar">
      <Setter Property="Height" Value="6"/>
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="3">
              <Border x:Name="PART_Track">
                <Border x:Name="PART_Indicator"
                        Background="{TemplateBinding Foreground}"
                        HorizontalAlignment="Left"
                        CornerRadius="3"/>
              </Border>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Slider ── -->
    <Style TargetType="Slider">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid>
              <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{StaticResource AccentBrush}" Height="4" CornerRadius="2"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Ellipse Width="14" Height="14"
                                 Fill="{StaticResource AccentBrush}"
                                 Stroke="{StaticResource SurfaceBrush}"
                                 StrokeThickness="2"/>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{StaticResource BorderBrush}" Height="4" CornerRadius="2"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── RadioButton ControlTemplate ── -->
    <Style TargetType="RadioButton">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <StackPanel Orientation="Horizontal">
              <Border x:Name="Box"
                      Width="16" Height="16"
                      Background="{StaticResource SurfaceBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1.5"
                      CornerRadius="8"
                      VerticalAlignment="Center"
                      Margin="0,0,7,0">
                <Ellipse x:Name="Dot"
                         Width="8" Height="8"
                         Fill="{StaticResource AccentBrush}"
                         Visibility="Collapsed"/>
              </Border>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── ScrollBar ── -->
    <Style TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid>
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource BorderBrush}"
                                CornerRadius="3"
                                Margin="2"/>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Grid Background="{StaticResource BgBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- 헤더 -->
      <RowDefinition Height="Auto"/>   <!-- 포맷 선택 -->
      <RowDefinition Height="Auto"/>   <!-- 옵션 -->
      <RowDefinition Height="*"/>      <!-- 드롭 존 -->
      <RowDefinition Height="Auto"/>   <!-- 진행 상황 -->
      <RowDefinition Height="Auto"/>   <!-- 상태 텍스트 -->
    </Grid.RowDefinitions>

    <!-- ── 헤더 ── -->
    <Border Grid.Row="0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,14">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="🎨"
                     FontSize="22"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     Foreground="#26C6DA"/>
          <StackPanel>
            <TextBlock Text="Img.Cast"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Text="이미지 포맷 변환기"
                       Foreground="{StaticResource SubTextBrush}"
                       FontSize="11"/>
          </StackPanel>
        </StackPanel>
        <!-- 도움말 버튼 -->
        <Button x:Name="BtnHelp"
                Content="?"
                Style="{StaticResource DarkButton}"
                Width="28" Height="28"
                Padding="0"
                FontSize="14"
                FontWeight="SemiBold"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                ToolTip="사용법 보기"
                Click="BtnHelp_Click"/>
        <!-- 도움말 팝업 -->
        <Popup x:Name="HelpPopup"
               PlacementTarget="{Binding ElementName=BtnHelp}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade">
          <Border Background="{StaticResource Surface2Brush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="18,14"
                  MinWidth="280"
                  Margin="0,4,0,0">
            <StackPanel>
              <TextBlock Text="사용법"
                         Foreground="{StaticResource AccentBrush}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Margin="0,0,0,10"/>
              <TextBlock Foreground="{StaticResource TextBrush}"
                         FontSize="12"
                         LineHeight="20"
                         TextWrapping="Wrap">
                <Run Text="① 출력 포맷을 선택합니다."/>
                <LineBreak/>
                <Run Text="② 옵션을 조정합니다 (품질, ICO 사이즈, SVG 크기 등)."/>
                <LineBreak/>
                <Run Text="③ 파일/폴더를 드래그&amp;드롭하거나 Ctrl+V로 붙여넣습니다."/>
                <LineBreak/>
                <Run Text="   폴더 드롭 시 하위 폴더까지 자동 수집됩니다."/>
                <LineBreak/>
                <Run Text="④ 변환이 완료되면 폴더 열기 버튼으로 확인합니다."/>
              </TextBlock>
              <Border BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="0,1,0,0"
                      Margin="0,10,0,10"/>
              <TextBlock Text="단축키"
                         Foreground="{StaticResource AccentBrush}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Margin="0,0,0,8"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition/>
                  <RowDefinition/>
                  <RowDefinition/>
                </Grid.RowDefinitions>
                <Border Grid.Column="0" Grid.Row="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="0,0,10,6">
                  <TextBlock Text="Esc"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </Border>
                <TextBlock Grid.Column="1" Grid.Row="0"
                           Text="변환 취소"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,0,6"/>
                <Border Grid.Column="0" Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="0,0,10,6">
                  <TextBlock Text="Ctrl+V"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </Border>
                <TextBlock Grid.Column="1" Grid.Row="1"
                           Text="클립보드 이미지 붙여넣기"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,0,6"/>
                <Border Grid.Column="0" Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="0,0,10,0">
                  <TextBlock Text="?"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </Border>
                <TextBlock Grid.Column="1" Grid.Row="2"
                           Text="이 도움말 표시"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
              </Grid>
              <Border BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="0,1,0,0"
                      Margin="0,10,0,10"/>
              <TextBlock Foreground="{StaticResource SubTextBrush}"
                         FontSize="11"
                         TextWrapping="Wrap">
                <Run Text="지원 포맷: SVG · PNG · JPG · BMP · WEBP · ICO"/>
                <LineBreak/>
                <Run Text="변환 결과는 원본 파일과 같은 폴더에 저장됩니다."/>
              </TextBlock>
            </StackPanel>
          </Border>
        </Popup>
      </Grid>
    </Border>

    <!-- ── 포맷 선택 ── -->
    <Border Grid.Row="1"
            Padding="20,14"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="입력 포맷"
                     Foreground="{StaticResource SubTextBrush}"
                     FontSize="11"
                     Margin="0,0,0,5"/>
          <ComboBox x:Name="CbInput">
            <ComboBoxItem Content="자동 감지 (전체)" Tag="All" IsSelected="True"/>
            <ComboBoxItem Content="SVG"  Tag="SVG"/>
            <ComboBoxItem Content="PNG"  Tag="PNG"/>
            <ComboBoxItem Content="JPG"  Tag="JPG"/>
            <ComboBoxItem Content="BMP"  Tag="BMP"/>
            <ComboBoxItem Content="WEBP" Tag="WEBP"/>
            <ComboBoxItem Content="ICO"  Tag="ICO"/>
          </ComboBox>
        </StackPanel>

        <TextBlock Grid.Column="1"
                   Text="→"
                   Foreground="{StaticResource AccentBrush}"
                   FontSize="20"
                   VerticalAlignment="Bottom"
                   Margin="14,0,14,6"/>

        <StackPanel Grid.Column="2">
          <TextBlock Text="출력 포맷"
                     Foreground="{StaticResource SubTextBrush}"
                     FontSize="11"
                     Margin="0,0,0,5"/>
          <ComboBox x:Name="CbOutput" SelectionChanged="CbOutput_SelectionChanged">
            <ComboBoxItem Content="ICO (멀티사이즈)" Tag="ICO" IsSelected="True"/>
            <ComboBoxItem Content="PNG"  Tag="PNG"/>
            <ComboBoxItem Content="JPG"  Tag="JPG"/>
            <ComboBoxItem Content="BMP"  Tag="BMP"/>
            <ComboBoxItem Content="WEBP" Tag="WEBP"/>
          </ComboBox>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── 옵션 ── -->
    <Border Grid.Row="2"
            Padding="20,12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <StackPanel>
        <!-- JPG 품질 (JPG 출력 시만 표시) -->
        <StackPanel x:Name="JpgQualityPanel" Visibility="Collapsed" Margin="0,0,0,10">
          <Grid Margin="0,0,0,6">
            <TextBlock x:Name="TbQualityLabel" Text="JPG 품질"
                       Foreground="{StaticResource SubTextBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="TbQualityVal"
                       Text="95"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="12"
                       FontFamily="Consolas"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
          </Grid>
          <Slider x:Name="SliderQuality"
                  Minimum="10" Maximum="100" Value="95"
                  TickFrequency="5"
                  ValueChanged="SliderQuality_ValueChanged"/>
        </StackPanel>

        <!-- ICO 사이즈 (ICO 출력 시만 표시) -->
        <StackPanel x:Name="IcoSizesPanel" Visibility="Visible" Margin="0,0,0,10">
          <TextBlock Text="ICO 포함 사이즈 (px)"
                     Foreground="{StaticResource SubTextBrush}"
                     FontSize="11"
                     Margin="0,0,0,7"/>
          <StackPanel Orientation="Horizontal">
            <CheckBox x:Name="ChkIco16"  Content="16"  IsChecked="True" Margin="0,0,14,0" Unchecked="ChkIco_Unchecked" Checked="ChkIco_Checked"/>
            <CheckBox x:Name="ChkIco32"  Content="32"  IsChecked="True" Margin="0,0,14,0" Unchecked="ChkIco_Unchecked" Checked="ChkIco_Checked"/>
            <CheckBox x:Name="ChkIco48"  Content="48"  IsChecked="True" Margin="0,0,14,0" Unchecked="ChkIco_Unchecked" Checked="ChkIco_Checked"/>
            <CheckBox x:Name="ChkIco64"  Content="64"  IsChecked="True" Margin="0,0,14,0" Unchecked="ChkIco_Unchecked" Checked="ChkIco_Checked"/>
            <CheckBox x:Name="ChkIco128" Content="128" IsChecked="True" Margin="0,0,14,0" Unchecked="ChkIco_Unchecked" Checked="ChkIco_Checked"/>
            <CheckBox x:Name="ChkIco256" Content="256" IsChecked="True"                    Unchecked="ChkIco_Unchecked" Checked="ChkIco_Checked"/>
          </StackPanel>
        </StackPanel>

        <!-- SVG 래스터 크기 (PNG/JPG/BMP 출력 시 표시) -->
        <StackPanel x:Name="SvgSizePanel" Visibility="Collapsed" Margin="0,0,0,10">
          <TextBlock Text="SVG 래스터 크기 (px)"
                     Foreground="{StaticResource SubTextBrush}"
                     FontSize="11"
                     Margin="0,0,0,7"/>
          <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="RbSvg256"  Content="256"  GroupName="SvgSize" Margin="0,0,14,0"/>
            <RadioButton x:Name="RbSvg512"  Content="512"  GroupName="SvgSize" Margin="0,0,14,0"/>
            <RadioButton x:Name="RbSvg1024" Content="1024" GroupName="SvgSize" IsChecked="True" Margin="0,0,14,0"/>
            <RadioButton x:Name="RbSvg2048" Content="2048" GroupName="SvgSize"/>
          </StackPanel>
        </StackPanel>

        <!-- 덮어쓰기 옵션 -->
        <CheckBox x:Name="ChkOverwrite"
                  Content="기존 파일 덮어쓰기"
                  IsChecked="True"/>
      </StackPanel>
    </Border>

    <!-- ── 드롭 존 ── -->
    <Border Grid.Row="3"
            Margin="20,16"
            x:Name="DropZone"
            Background="{StaticResource SurfaceBrush}"
            CornerRadius="10">
      <Border.BorderBrush>
        <SolidColorBrush x:Name="DropBorderBrush" Color="#3A3A48"/>
      </Border.BorderBrush>
      <Border.BorderThickness>
        <Thickness>1.5</Thickness>
      </Border.BorderThickness>

      <Grid>
        <!-- 초기 힌트 -->
        <StackPanel x:Name="DropHint"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <TextBlock x:Name="DropIcon"
                     Text="📂"
                     FontSize="48"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,12"
                     Foreground="#26C6DA"/>
          <TextBlock Text="파일 또는 폴더를 여기에 드롭"
                     Foreground="{StaticResource TextBrush}"
                     FontSize="15"
                     FontWeight="Medium"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,6"/>
          <TextBlock Text="SVG · PNG · JPG · BMP · WEBP · ICO 지원"
                     Foreground="{StaticResource SubTextBrush}"
                     FontSize="12"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 파일 로드 후 목록 요약 -->
        <StackPanel x:Name="FileSummary"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <TextBlock x:Name="TbFileCount"
                     Foreground="{StaticResource AccentBrush}"
                     FontSize="32"
                     FontWeight="Bold"
                     FontFamily="Consolas"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,6"/>
          <TextBlock x:Name="TbFileLabel"
                     Foreground="{StaticResource TextBrush}"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,4"/>
          <TextBlock x:Name="TbFileSample"
                     Foreground="{StaticResource SubTextBrush}"
                     FontSize="11"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"
                     MaxWidth="300"
                     TextAlignment="Center"/>
        </StackPanel>

        <!-- SVG 미리보기 -->
        <StackPanel x:Name="SvgPreviewPanel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <Border Background="{StaticResource Surface2Brush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="6"
                  Margin="0,0,0,8">
            <Image x:Name="SvgPreviewImage"
                   MaxWidth="180" MaxHeight="140"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
          </Border>
          <TextBlock x:Name="TbSvgFileName"
                     Foreground="{StaticResource AccentBrush}"
                     FontSize="13"
                     FontWeight="Medium"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,4"/>
          <TextBlock x:Name="TbSvgSubInfo"
                     Foreground="{StaticResource SubTextBrush}"
                     FontSize="11"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── ProgressBar + 취소 버튼 ── -->
    <Grid Grid.Row="4" Margin="20,0,20,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <ProgressBar x:Name="PBar"
                   Grid.Column="0"
                   Minimum="0" Maximum="100" Value="0"
                   Visibility="Collapsed"
                   VerticalAlignment="Center"/>
      <Button x:Name="BtnCancel"
              Grid.Column="1"
              Content="취소"
              Style="{StaticResource CancelButton}"
              Visibility="Collapsed"
              Margin="8,0,0,0"
              Click="BtnCancel_Click"/>
    </Grid>

    <!-- ── 상태 텍스트 + 폴더 열기 ── -->
    <Border Grid.Row="5"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="20,8">
      <Grid>
        <TextBlock x:Name="TbStatus"
                   Text="파일을 드롭하면 자동으로 변환을 시작합니다"
                   Foreground="{StaticResource SubTextBrush}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>
        <Button x:Name="BtnOpenFolder"
                Content="📁 폴더 열기"
                Style="{StaticResource LinkButton}"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="BtnOpenFolder_Click"/>
      </Grid>
    </Border>
  </Grid>
</Window>
