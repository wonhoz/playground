<Window x:Class="IconMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Icon.Maker" Height="660" Width="1020"
        Background="#1A1A2E" Foreground="#E0E0E0"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A1A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="#252538" BorderBrush="#444466"
                                BorderThickness="1" CornerRadius="3" Padding="8,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A3A6E"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5A7FD6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#303050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ─── 상단 툴바 ─── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Background="#1E1E30" Margin="-10,-10,-10,0">
            <Button x:Name="BtnOpen" Click="BtnOpen_Click" Margin="0,0,8,0">📂 열기 (SVG / PNG / ICO)</Button>
            <Button x:Name="BtnExportIco" Click="BtnExportIco_Click" Margin="0,0,8,0" IsEnabled="False">💾 ICO 저장</Button>
            <Button x:Name="BtnExportPng" Click="BtnExportPng_Click" Margin="0,0,16,0" IsEnabled="False">🖼️ PNG 추출</Button>
            <TextBlock Text="배경:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#9090BB"/>
            <RadioButton x:Name="RbDark" Content="Dark" IsChecked="True" GroupName="bg" Checked="BgChanged"/>
            <RadioButton x:Name="RbLight" Content="Light" GroupName="bg" Checked="BgChanged" Margin="6,0,0,0"/>
        </StackPanel>

        <!-- ─── 메인 3열 ─── -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽: 사이즈 선택 + 소스 미리보기 ── -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Border Background="#20203A" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="편집 사이즈" FontWeight="Bold" Foreground="#8888BB" Margin="0,0,0,8" FontSize="11"/>
                        <RadioButton x:Name="Sz16"  Content="16 × 16 px"  Tag="0" GroupName="sz" IsChecked="True" Checked="SizeSelected" FontFamily="Consolas" FontSize="12" Margin="0,2"/>
                        <RadioButton x:Name="Sz32"  Content="32 × 32 px"  Tag="1" GroupName="sz" Checked="SizeSelected" FontFamily="Consolas" FontSize="12" Margin="0,2"/>
                        <RadioButton x:Name="Sz48"  Content="48 × 48 px"  Tag="2" GroupName="sz" Checked="SizeSelected" FontFamily="Consolas" FontSize="12" Margin="0,2"/>
                        <RadioButton x:Name="Sz64"  Content="64 × 64 px"  Tag="3" GroupName="sz" Checked="SizeSelected" FontFamily="Consolas" FontSize="12" Margin="0,2"/>
                        <RadioButton x:Name="Sz128" Content="128 × 128 px" Tag="4" GroupName="sz" Checked="SizeSelected" FontFamily="Consolas" FontSize="12" Margin="0,2"/>
                        <RadioButton x:Name="Sz256" Content="256 × 256 px" Tag="5" GroupName="sz" Checked="SizeSelected" FontFamily="Consolas" FontSize="12" Margin="0,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#20203A" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="그리기 도구" FontWeight="Bold" Foreground="#8888BB" Margin="0,0,0,8" FontSize="11"/>
                        <RadioButton x:Name="ToolPencil" Content="✏️  연필" GroupName="tool" IsChecked="True" Checked="ToolChanged" Margin="0,2"/>
                        <RadioButton x:Name="ToolEraser" Content="🧹 지우개" GroupName="tool" Checked="ToolChanged" Margin="0,2"/>
                        <RadioButton x:Name="ToolFill"   Content="🪣  채우기" GroupName="tool" Checked="ToolChanged" Margin="0,2"/>
                        <Separator Background="#333355" Margin="0,8"/>
                        <TextBlock Text="색상" FontSize="11" Foreground="#8888BB" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="ColorSwatch" Width="36" Height="28" Background="White"
                                    BorderBrush="#666688" BorderThickness="1" CornerRadius="3"
                                    Cursor="Hand" MouseLeftButtonUp="ColorSwatch_Click" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ColorHex" Text="#FFFFFF" VerticalAlignment="Center"
                                       FontFamily="Consolas" FontSize="11" Foreground="#AAAACC"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#20203A" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Padding="8">
                    <StackPanel>
                        <TextBlock Text="소스 미리보기" FontWeight="Bold" Foreground="#8888BB" Margin="0,0,0,6" FontSize="11"/>
                        <Border x:Name="SrcBg" Background="#111120" Height="110" CornerRadius="3">
                            <Image x:Name="SourcePreview" Stretch="Uniform" Margin="4"/>
                        </Border>
                        <TextBlock x:Name="SourceLabel" Text="파일 없음" TextWrapping="Wrap"
                                   FontSize="10" Foreground="#666688" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── 가운데: 픽셀 에디터 ── -->
            <Border Grid.Column="1" Background="#20203A" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="EditorTitle" Text="픽셀 에디터 — 16×16" FontWeight="Bold"
                                   Foreground="#8888BB" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock x:Name="PosLabel" Text="" FontFamily="Consolas" FontSize="11"
                                   Foreground="#666688" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  Background="#111120" Padding="10">
                        <Grid>
                            <!-- 픽셀 비트맵 (WriteableBitmap) -->
                            <Image x:Name="EditorImage" Stretch="None"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <!-- 마우스 이벤트 캐처 -->
                            <Canvas x:Name="EditorOverlay" Background="Transparent"
                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                    MouseLeftButtonDown="Editor_MouseDown"
                                    MouseMove="Editor_MouseMove"
                                    MouseLeftButtonUp="Editor_MouseUp"
                                    MouseRightButtonDown="Editor_RightDown"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── 오른쪽: 전체 사이즈 미리보기 ── -->
            <Border Grid.Column="2" Background="#20203A" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Padding="10" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="미리보기" FontWeight="Bold" Foreground="#8888BB"
                               Margin="0,0,0,10" FontSize="11"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PreviewPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ─── 상태바 ─── -->
        <TextBlock x:Name="StatusBar" Grid.Row="2" VerticalAlignment="Center"
                   FontSize="11" Foreground="#666688"/>
    </Grid>
</Window>
