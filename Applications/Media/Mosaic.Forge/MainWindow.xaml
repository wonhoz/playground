<Window x:Class="Mosaic.Forge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Mosaic.Forge"
        Title="Mosaic.Forge"
        Width="1100" Height="700" MinWidth="860" MinHeight="520"
        Background="#1A1A2A"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ── 컨버터 ──────────────────────────────────────────────────────── -->
        <BooleanToVisibilityConverter              x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter   x:Key="InvBoolToVis"/>
        <local:BoolNegateConverter                x:Key="BoolNegate"/>

        <!-- ── 색상 ─────────────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgMain"    Color="#1A1A2A"/>
        <SolidColorBrush x:Key="BgPanel"   Color="#232336"/>
        <SolidColorBrush x:Key="BgCard"    Color="#2A2A40"/>
        <SolidColorBrush x:Key="BgInput"   Color="#1E1E30"/>
        <SolidColorBrush x:Key="Accent"    Color="#E07B00"/>
        <SolidColorBrush x:Key="AccentHov" Color="#FF9020"/>
        <SolidColorBrush x:Key="TxtMain"   Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TxtSub"    Color="#888899"/>
        <SolidColorBrush x:Key="Border"    Color="#333355"/>

        <!-- ── TextBlock ────────────────────────────────────────────────────── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TxtMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
        <Style x:Key="SecHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,14,0,6"/>
        </Style>
        <Style x:Key="SubText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TxtSub}"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

        <!-- ── TextBox ──────────────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"              Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"              Value="{StaticResource TxtMain}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="8,2"/>
            <Setter Property="Height"                  Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"              Value="{StaticResource TxtMain}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Button ───────────────────────────────────────────────────────── -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource TxtMain}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A55"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#28283F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHov}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C06800"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Slider ───────────────────────────────────────────────────────── -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" Background="{StaticResource Accent}" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" Background="{StaticResource BgCard}" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="14" Height="14"
                                                     Fill="{StaticResource Accent}"
                                                     Stroke="#1A1A2A" StrokeThickness="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ProgressBar ──────────────────────────────────────────────────── -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height"          Value="4"/>
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2" HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox ─────────────────────────────────────────────────────── -->
        <ControlTemplate x:Key="CbToggleBtn" TargetType="ToggleButton">
            <Border x:Name="bd" Background="{StaticResource BgInput}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    CornerRadius="4">
                <Path Data="M 0 0 L 5 5 L 10 0"
                      Stroke="{StaticResource TxtSub}" StrokeThickness="1.5"
                      HorizontalAlignment="Right" VerticalAlignment="Center"
                      Margin="0,0,8,0"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Height"     Value="30"/>
            <Setter Property="Foreground" Value="{StaticResource TxtMain}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource CbToggleBtn}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide" Placement="Bottom">
                                <Border Background="{StaticResource BgCard}"
                                        BorderBrush="{StaticResource Accent}"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TxtMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A55"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E07B0040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollBar ────────────────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#1E1E30" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555570" CornerRadius="4" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Width"  Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="#1E1E30" CornerRadius="4"/>
                                    <Track x:Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#555570" CornerRadius="4" Margin="0,1"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource Border}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0,4"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 메인 영역 ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽 컨트롤 패널 ──────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,10,14,16">

                        <!-- 앱 제목 -->
                        <StackPanel Margin="0,4,0,10">
                            <TextBlock Text="Mosaic.Forge"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="포토모자이크 생성기"
                                       Style="{StaticResource SubText}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Separator/>

                        <!-- 대상 이미지 -->
                        <TextBlock Text="▸  대상 이미지" Style="{StaticResource SecHeader}"/>

                        <Border x:Name="DropZone"
                                Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="6"
                                Height="130" Cursor="Hand"
                                AllowDrop="True"
                                Drop="DropZone_Drop"
                                DragOver="DropZone_DragOver"
                                MouseLeftButtonDown="DropZone_Click">
                            <Grid>
                                <StackPanel x:Name="PnlDropHint"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#x1F5BC;" FontSize="30"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="이미지 드래그 또는 클릭"
                                               Style="{StaticResource SubText}"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                                <Image x:Name="ImgThumb"
                                       Stretch="Uniform"
                                       Margin="6"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="TxtTargetInfo"
                                   Style="{StaticResource SubText}"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- 소스 이미지 폴더 -->
                        <TextBlock Text="▸  소스 폴더" Style="{StaticResource SecHeader}"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="74"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     IsReadOnly="True"
                                     Text="{Binding SourceFolderPath, Mode=OneWay}"
                                     ToolTip="{Binding SourceFolderPath}"/>
                            <Button Grid.Column="2"
                                    Content="폴더 선택"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"
                                    Click="SelectFolder_Click"/>
                        </Grid>

                        <TextBlock Text="{Binding SourceCountText}"
                                   Style="{StaticResource SubText}"
                                   Margin="0,2,0,0"/>

                        <!-- 설정 -->
                        <TextBlock Text="▸  설정" Style="{StaticResource SecHeader}"/>

                        <!-- 타일 크기 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="타일 크기" Style="{StaticResource SubText}"
                                           Margin="0,0,0,5"/>
                                <Slider Minimum="8" Maximum="128"
                                        SmallChange="4" IsSnapToTickEnabled="True"
                                        TickFrequency="4"
                                        Value="{Binding TileSize}"
                                        ValueChanged="Slider_ValueChanged"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TileSize, StringFormat={}{0}px}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource SubText}"/>
                        </Grid>

                        <!-- 최대 재사용 -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="최대 재사용 (0=무제한)"
                                           Style="{StaticResource SubText}"
                                           Margin="0,0,0,5"/>
                                <Slider Minimum="0" Maximum="50"
                                        SmallChange="1" IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        Value="{Binding MaxReuse}"
                                        ValueChanged="Slider_ValueChanged"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MaxReuse, StringFormat={}{0}회}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource SubText}"/>
                        </Grid>

                        <TextBlock Text="{Binding OutputSizeText}"
                                   Style="{StaticResource SubText}"
                                   Margin="0,0,0,12"/>

                        <Separator/>

                        <!-- 생성 버튼 -->
                        <Button Content="&#x1F3A8;  모자이크 생성"
                                Style="{StaticResource AccentBtn}"
                                Height="44" Margin="0,10,0,0"
                                IsEnabled="{Binding CanGenerate}"
                                Click="Generate_Click"/>

                        <!-- 취소 -->
                        <Button Content="취소" Margin="0,6,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                Click="Cancel_Click"/>

                        <Separator Margin="0,12"/>

                        <!-- 내보내기 -->
                        <TextBlock Text="▸  내보내기" Style="{StaticResource SecHeader}"
                                   Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="PNG 저장"
                                    IsEnabled="{Binding HasResult}"
                                    Click="ExportPng_Click"/>
                            <Button Grid.Column="2" Content="JPG 저장"
                                    IsEnabled="{Binding HasResult}"
                                    Click="ExportJpg_Click"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── 오른쪽 미리보기 ─────────────────────────────────────────── -->
            <Grid Grid.Column="1" Background="{StaticResource BgMain}">

                <!-- 플레이스홀더 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasResult, Converter={StaticResource InvBoolToVis}}">
                    <TextBlock Text="&#x1F3DE;" FontSize="72"
                               HorizontalAlignment="Center" Opacity="0.15"/>
                    <TextBlock Text="대상 이미지 + 소스 폴더 선택 후 생성"
                               Style="{StaticResource SubText}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" Opacity="0.4"/>
                </StackPanel>

                <!-- 결과 이미지 (스크롤 가능) -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                    <Image x:Name="ImgResult"
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="12"/>
                </ScrollViewer>

                <!-- 생성 진행 오버레이 -->
                <Border Background="#AA000015"
                        Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="15" HorizontalAlignment="Center"/>
                        <ProgressBar Value="{Binding Progress}"
                                     Maximum="{Binding ProgressMax}"
                                     Width="320" Height="6" Margin="0,14,0,0"
                                     Background="#333355" Foreground="{StaticResource Accent}"/>
                        <TextBlock x:Name="TxtProgressPct"
                                   Style="{StaticResource SubText}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>

        <!-- ── 상태 바 ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#13131F"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                Height="28">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource SubText}"
                           VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1"
                             Value="{Binding Progress}"
                             Maximum="{Binding ProgressMax}"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

    </Grid>
</Window>
