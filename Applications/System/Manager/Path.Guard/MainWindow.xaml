<Window x:Class="PathGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Path.Guard — PATH 환경변수 관리자"
        Width="980" Height="680" MinWidth="760" MinHeight="480"
        Background="#141414">

    <Window.Resources>
        <!-- ── 스크롤바 Thumb 스타일 ── -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBd"
                                Background="#3A3A3A"
                                CornerRadius="3"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="#5A5A6A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="#4FC3F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 스크롤바 RepeatButton (화살표 영역) 숨김 ── -->
        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" Width="0" Height="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 스크롤바 페이지 버튼 (Thumb 바깥 트랙 클릭) ── -->
        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollBar ControlTemplate ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <!-- 수직 스크롤바 -->
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="MinWidth" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="#0F0F0F" CornerRadius="3">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}"
                                                   Margin="1,2"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <!-- 수평 스크롤바 -->
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="#0F0F0F" CornerRadius="3">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}"
                                                   Margin="2,1"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 툴바 -->
            <RowDefinition Height="*"/>      <!-- 본문 -->
            <RowDefinition Height="Auto"/>   <!-- 상태 바 -->
        </Grid.RowDefinitions>

        <!-- ══ 툴바 ══ -->
        <Border Grid.Row="0" Background="#0E0E0E" BorderBrush="#252525" BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal" Margin="8,6">
                <Button x:Name="BtnReload"   Content="🔄 다시 불러오기" Padding="10,5" Click="BtnReload_Click"/>
                <Button x:Name="BtnSave"     Content="💾 변경 적용"    Padding="10,5" Margin="4,0,0,0"
                        Click="BtnSave_Click"/>
                <Separator Width="1" Background="#333333" Margin="8,2"/>
                <Button x:Name="BtnAddEntry" Content="➕ 항목 추가"    Padding="10,5" Margin="0,0,4,0"
                        Click="BtnAddEntry_Click"/>
                <Button x:Name="BtnDelete"   Content="🗑 삭제"         Padding="10,5" Margin="0,0,4,0"
                        IsEnabled="False" Click="BtnDelete_Click"/>
                <Button x:Name="BtnToggle"   Content="⏸ 비활성/활성"  Padding="10,5" Margin="0,0,4,0"
                        IsEnabled="False" Click="BtnToggle_Click"/>
                <Separator Width="1" Background="#333333" Margin="8,2"/>
                <Button x:Name="BtnSnapshot" Content="📷 스냅샷 저장" Padding="10,5" Margin="0,0,4,0"
                        Click="BtnSnapshot_Click"/>
                <Button x:Name="BtnRestore"  Content="↩ 롤백"         Padding="10,5"
                        Click="BtnRestore_Click"/>
            </WrapPanel>
        </Border>

        <!-- ══ 본문 ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 좌: PATH 목록 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 필터 + 검색 바 -->
                <Border Grid.Row="0" Background="#111111" BorderBrush="#252525" BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="보기:" Foreground="#555555" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="ChkSystem" Content="시스템" IsChecked="True" Margin="0,0,10,0"
                                      Checked="ChkFilter_Changed" Unchecked="ChkFilter_Changed"/>
                            <CheckBox x:Name="ChkUser"   Content="사용자" IsChecked="True" Margin="0,0,10,0"
                                      Checked="ChkFilter_Changed" Unchecked="ChkFilter_Changed"/>
                            <CheckBox x:Name="ChkBroken" Content="❌ 깨짐만" IsChecked="False"
                                      Checked="ChkFilter_Changed" Unchecked="ChkFilter_Changed"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtSummary" Grid.Column="1" Foreground="#444444"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 목록 -->
                <ListBox x:Name="LstPath" Grid.Row="1"
                         Background="#141414" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         AllowDrop="True" SelectionChanged="LstPath_SelectionChanged"
                         PreviewMouseLeftButtonDown="LstPath_MouseDown"
                         PreviewMouseMove="LstPath_MouseMove"
                         Drop="LstPath_Drop">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="RowBd" Padding="8,6" BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8"/>    <!-- 상태 색상 바 -->
                                        <ColumnDefinition Width="52"/>   <!-- 스코프 뱃지 -->
                                        <ColumnDefinition Width="*"/>    <!-- 경로 -->
                                        <ColumnDefinition Width="60"/>   <!-- 상태 텍스트 -->
                                    </Grid.ColumnDefinitions>

                                    <!-- 상태 컬러 바 -->
                                    <Rectangle Grid.Column="0" Width="4" RadiusX="2" RadiusY="2"
                                               Fill="{Binding StatusBrush}" Margin="0,2,6,2"/>

                                    <!-- 스코프 뱃지 -->
                                    <Border Grid.Column="1" CornerRadius="3" Padding="4,2"
                                            Background="#1A1A1A" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ScopeLabel}" Foreground="{Binding ScopeBrush}"
                                                   FontSize="10"/>
                                    </Border>

                                    <!-- 경로 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0">
                                        <TextBlock Text="{Binding RawValue}" Foreground="#E0E0E0"
                                                   FontSize="12" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ExpandedValue}" Foreground="#444444"
                                                   FontSize="10" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- 상태 텍스트 -->
                                    <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                                               Foreground="{Binding StatusBrush}" FontSize="10"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 이동 버튼 바 -->
                <Border Grid.Row="2" Background="#111111" BorderBrush="#252525" BorderThickness="0,1,0,0"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnMoveUp"   Content="▲ 위로" Padding="8,4" Margin="0,0,4,0"
                                IsEnabled="False" Click="BtnMoveUp_Click"/>
                        <Button x:Name="BtnMoveDown" Content="▼ 아래로" Padding="8,4"
                                IsEnabled="False" Click="BtnMoveDown_Click"/>
                        <TextBlock x:Name="TxtHits" Foreground="#4FC3F7" FontSize="11"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#252525" ResizeDirection="Columns"/>

            <!-- 우: 상세 / 검색 / 스냅샷 -->
            <Grid Grid.Column="2" Background="#0E0E0E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 선택 항목 편집 -->
                <Border Grid.Row="0" Background="#111111" BorderBrush="#252525" BorderThickness="0,0,0,1"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="경로 편집" Foreground="#4FC3F7" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtEditPath" Margin="0,0,0,6"
                                 TextChanged="TxtEditPath_TextChanged"/>
                        <TextBlock x:Name="TxtExpandPreview" Foreground="#444444" FontSize="10"
                                   FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <Button x:Name="BtnApplyEdit" Content="✓ 적용" Padding="8,4"
                                HorizontalAlignment="Right" Click="BtnApplyEdit_Click"/>
                    </StackPanel>
                </Border>

                <!-- 실행파일 검색 -->
                <Border Grid.Row="1" Background="#111111" BorderBrush="#252525" BorderThickness="0,0,0,1"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="실행파일 검색 (PATH 탐색)" Foreground="#4FC3F7"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSearch" Padding="6,4"
                                     KeyDown="TxtSearch_KeyDown"/>
                            <Button Grid.Column="1" Content="🔍" Padding="8,4" Margin="4,0,0,0"
                                    Click="BtnSearch_Click"/>
                        </Grid>
                        <TextBlock Text="예: python.exe, node.exe, git.exe" Foreground="#333333"
                                   FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 버전 충돌 경고 -->
                <Border Grid.Row="2" x:Name="BdrConflict" Background="#2A1A00"
                        BorderBrush="#4A3A00" BorderThickness="1" CornerRadius="4"
                        Margin="12,8,12,0" Padding="10,8" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠ 버전 충돌 감지" Foreground="#FFD700" FontSize="11" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtConflict" Foreground="#FFB800" FontSize="10"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 스냅샷 목록 -->
                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,4,12,4">
                        <TextBlock Text="스냅샷 이력" Foreground="#444444" FontSize="10"/>
                    </Border>
                    <ListBox x:Name="LstSnapshots" Grid.Row="1"
                             Background="#0A0A0A" BorderThickness="0"
                             MouseDoubleClick="LstSnapshots_DoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Foreground="#C0C0C0" FontSize="11"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM-dd HH:mm:ss}'}"
                                                   Foreground="#444444" FontSize="10"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

            </Grid>
        </Grid>

        <!-- ══ 상태 바 ══ -->
        <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#252525" BorderThickness="0,1,0,0">
            <Grid Margin="8,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0" Foreground="#444444"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtAdmin" Grid.Column="1" Foreground="#FF5555"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
