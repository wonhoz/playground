<Window x:Class="GolfCast.Views.ScoreCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="스코어카드" Height="600" Width="500"
        Background="#1A2E1A" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TxtCourse" FontSize="20" FontWeight="Bold"
                       Foreground="#4CAF50" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtResult" FontSize="14" Foreground="#E0E0E0"
                       HorizontalAlignment="Center" Margin="0,4"/>
        </StackPanel>

        <!-- 홀별 스코어 -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="HoleList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding HoleNum}" Foreground="#888" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding HoleName}" Foreground="#E0E0E0" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="{Binding Par}" Foreground="#888" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Score}" FontSize="13" FontWeight="SemiBold"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E0E0E0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUnderPar}" Value="True">
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOverPar}" Value="True">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsHoleIn1}" Value="True">
                                                <Setter Property="Foreground" Value="#FFD700"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="4" Text="{Binding ToPar}" Foreground="#888" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 합계 -->
        <Border Grid.Row="2" Background="#243424" CornerRadius="6" Padding="12,8" Margin="0,12,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="합계" FontSize="14" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TxtTotal" FontSize="16" FontWeight="Bold" Foreground="#4CAF50"/>
                    <TextBlock x:Name="TxtToPar" FontSize="13" Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 버튼 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="다시 플레이" Click="OnReplay" Padding="14,8" Margin="0,0,8,0"
                    Background="#243424" BorderBrush="#2E4A2E" Foreground="#E0E0E0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="닫기" IsDefault="True" Click="OnClose" Padding="14,8"
                    Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
