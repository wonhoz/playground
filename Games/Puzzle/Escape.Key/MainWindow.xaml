<Window x:Class="EscapeKey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Escape.Key — 암호학 방탈출" Height="700" Width="1000"
        Background="#0D0D1A" ResizeMode="CanResizeWithGrip"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 헤더 -->
    <Border Grid.Row="0" Background="#0A0A1E" Padding="16,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="🔐" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <TextBlock Text="ESCAPE.KEY" FontSize="18" FontWeight="Bold"
                     Foreground="#5B6FD6" FontFamily="Consolas" VerticalAlignment="Center"/>
          <TextBlock Text=" — 현대 암호학 방탈출" FontSize="13"
                     Foreground="#888" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="방:" Foreground="#888" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <TextBlock x:Name="RoomLabel" Text="1/5" Foreground="#5B6FD6"
                     FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
          <TextBlock Text="⏱" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
          <TextBlock x:Name="TimerLabel" Text="00:00" Foreground="#00FF88"
                     FontFamily="Consolas" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 메인 콘텐츠 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="300"/>
      </Grid.ColumnDefinitions>

      <!-- 방 캔버스 / 퍼즐 영역 -->
      <Border Background="#0D0D1A" Padding="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="PuzzlePanel">
            <!-- 방 제목 -->
            <Border Background="#1A1A2E" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock x:Name="RoomTitle" Text="방 1: 해시 금고"
                           FontSize="18" FontWeight="Bold" Foreground="#5B6FD6"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="RoomStory" Text=""
                           Foreground="#AAAACC" TextWrapping="Wrap" Margin="0,6,0,0"
                           FontSize="12" LineHeight="18"/>
              </StackPanel>
            </Border>

            <!-- 방 설명 / 개념 -->
            <Border Background="#121230" CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                    BorderBrush="#2A2A5A" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="💡 암호학 개념" Foreground="#FFD54F" FontFamily="Consolas"
                           FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock x:Name="ConceptText" Text="" Foreground="#CCCCEE"
                           TextWrapping="Wrap" FontSize="12" LineHeight="18"/>
              </StackPanel>
            </Border>

            <!-- 오브젝트 그리드 -->
            <WrapPanel x:Name="ObjectsPanel" Margin="0,0,0,12"/>

            <!-- 퍼즐 입력 영역 -->
            <Border x:Name="PuzzleInputArea" Background="#121230" CornerRadius="6"
                    Padding="14,12" BorderBrush="#3A3A6A" BorderThickness="1">
              <StackPanel>
                <TextBlock x:Name="PuzzleQuestion" Text=""
                           Foreground="#E0E0E0" TextWrapping="Wrap" FontFamily="Consolas"
                           FontSize="13" Margin="0,0,0,8" LineHeight="20"/>
                <TextBox x:Name="AnswerBox" Margin="0,0,0,8"
                         KeyDown="AnswerBox_KeyDown"
                         ToolTip="답을 입력하고 Enter 또는 확인 버튼을 누르세요"/>
                <StackPanel Orientation="Horizontal">
                  <Button Content="✓ 확인" Click="BtnCheck_Click" Margin="0,0,8,0"/>
                  <Button Content="💡 힌트" Click="BtnHint_Click" Background="#2A1A2A" BorderBrush="#AA44AA"/>
                  <Button x:Name="BtnSkip" Content="⏭ 건너뛰기 (개발)" Click="BtnSkip_Click"
                          Margin="8,0,0,0" Background="#1A2A1A" BorderBrush="#44AA44"
                          Visibility="Collapsed"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- 정답 메시지 -->
            <Border x:Name="SuccessBanner" Background="#0A2A0A" CornerRadius="6"
                    Padding="14,10" Margin="0,10,0,0"
                    BorderBrush="#00AA44" BorderThickness="1" Visibility="Collapsed">
              <StackPanel>
                <TextBlock Text="🔓 탈출 성공!" FontSize="16" FontWeight="Bold"
                           Foreground="#00FF88" FontFamily="Consolas"/>
                <TextBlock x:Name="LearnText" Text="" Foreground="#AADDAA"
                           TextWrapping="Wrap" FontSize="12" Margin="0,6,0,6" LineHeight="18"/>
                <Button Content="다음 방 →" Click="BtnNext_Click"
                        Background="#0A3A0A" BorderBrush="#00AA44" HorizontalAlignment="Left"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- 우측 패널: 도구 & 힌트 -->
      <Border Grid.Column="1" Background="#0A0A1E" BorderBrush="#1A1A3A"
              BorderThickness="1,0,0,0" Padding="12">
        <StackPanel>
          <!-- 도구 -->
          <TextBlock Text="🔧 도구" FontWeight="Bold" Foreground="#5B6FD6"
                     FontFamily="Consolas" Margin="0,0,0,8"/>
          <TabControl Background="#0D0D1A" BorderBrush="#2A2A4A" Foreground="#E0E0E0">
            <TabItem Header="HEX" Foreground="#AAA">
              <StackPanel Margin="4">
                <TextBlock Text="10진수 → 16진수" Foreground="#888" FontSize="11" Margin="0,4,0,2"/>
                <TextBox x:Name="HexInput" Tag="숫자 입력"/>
                <Button Content="변환" Click="BtnHexConvert_Click" Margin="0,4,0,4"/>
                <TextBlock x:Name="HexResult" Text="" Foreground="#00FF88" FontFamily="Consolas"
                           FontSize="12" TextWrapping="Wrap"/>
              </StackPanel>
            </TabItem>
            <TabItem Header="XOR" Foreground="#AAA">
              <StackPanel Margin="4">
                <TextBlock Text="값1 XOR 값2" Foreground="#888" FontSize="11" Margin="0,4,0,2"/>
                <TextBox x:Name="XorA" Tag="값1 (hex)"/>
                <TextBlock Text="XOR" Foreground="#5B6FD6" FontFamily="Consolas"
                           HorizontalAlignment="Center" Margin="0,2"/>
                <TextBox x:Name="XorB" Tag="값2 (hex)"/>
                <Button Content="계산" Click="BtnXor_Click" Margin="0,4,0,4"/>
                <TextBlock x:Name="XorResult" Text="" Foreground="#00FF88"
                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
              </StackPanel>
            </TabItem>
            <TabItem Header="B64" Foreground="#AAA">
              <StackPanel Margin="4">
                <TextBlock Text="Base64 디코딩" Foreground="#888" FontSize="11" Margin="0,4,0,2"/>
                <TextBox x:Name="B64Input" Tag="Base64 문자열"/>
                <Button Content="디코딩" Click="BtnB64Decode_Click" Margin="0,4,0,4"/>
                <TextBlock x:Name="B64Result" Text="" Foreground="#00FF88"
                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
              </StackPanel>
            </TabItem>
          </TabControl>

          <!-- 힌트 패널 -->
          <TextBlock Text="💡 힌트" FontWeight="Bold" Foreground="#AA44AA"
                     FontFamily="Consolas" Margin="0,16,0,6"/>
          <Border Background="#1A0A2A" CornerRadius="4" Padding="8"
                  BorderBrush="#44224A" BorderThickness="1">
            <TextBlock x:Name="HintText" Text="힌트 버튼을 눌러 힌트를 확인하세요."
                       Foreground="#CC88CC" TextWrapping="Wrap" FontSize="11" LineHeight="17"/>
          </Border>

          <!-- 진행 상황 -->
          <TextBlock Text="📊 진행 상황" FontWeight="Bold" Foreground="#5B6FD6"
                     FontFamily="Consolas" Margin="0,16,0,6"/>
          <ItemsControl x:Name="ProgressList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" Foreground="#888" FontFamily="Consolas"
                           FontSize="11" Margin="0,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- 학습 아카이브 -->
          <Button Content="📚 학습 아카이브" Click="BtnArchive_Click"
                  Margin="0,16,0,0" Background="#1A1A0A" BorderBrush="#886600"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- 상태바 -->
    <Border Grid.Row="2" Background="#050510" Padding="12,6">
      <TextBlock x:Name="StatusBar" Text="방 1에 입장했습니다. 주변을 조사하세요."
                 Foreground="#666" FontFamily="Consolas" FontSize="11"/>
    </Border>
  </Grid>
</Window>
