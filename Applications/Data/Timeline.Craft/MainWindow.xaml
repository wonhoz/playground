<Window x:Class="Timeline.Craft.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Timeline.Craft.Controls"
        Title="Timeline.Craft" Width="1100" Height="680"
        MinWidth="800" MinHeight="480"
        Background="#13131F" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen"
>

    <Window.Resources
        WindowStartupLocation="CenterScreen"
>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- 버튼 기본 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#C0C0D0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#303048"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 액센트 버튼 (녹색) -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#065F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 위험 버튼 -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3A1A1A"/>
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A2020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 텍스트박스 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#10B981"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 스크롤바 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A55" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A0A0BB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="chk" Width="15" Height="15" CornerRadius="3"
                                    Background="#1E1E2E" BorderBrush="#3A3A55" BorderThickness="1"
                                    Margin="0,0,6,0" VerticalAlignment="Center">
                                <Path x:Name="mark" Data="M2,7 L6,11 L13,3"
                                      Stroke="Transparent" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="chk"  Property="Background" Value="#10B981"/>
                                <Setter TargetName="chk"  Property="BorderBrush" Value="#10B981"/>
                                <Setter TargetName="mark" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBoxItem -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C0C0D0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1" BorderBrush="#1A1A2A"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0C3A24"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 툴바 ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0A0A14" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Timeline.Craft" FontSize="15" FontWeight="Bold"
                               Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="새로 만들기" Click="NewFile_Click"       Margin="0,0,6,0"/>
                    <Button Content="열기"        Click="OpenFile_Click"      Margin="0,0,6,0"/>
                    <Button Content="저장"        Click="SaveFile_Click"      Margin="0,0,6,0"/>
                    <Button Content="다른이름저장" Click="SaveAsFile_Click"   Margin="0,0,14,0"/>
                    <Button Content="+ 레인"      Click="AddLane_Click"   Style="{StaticResource AccentBtn}" Margin="0,0,6,0"/>
                    <Button Content="+ 이벤트"    Click="AddEvent_Click"  Style="{StaticResource AccentBtn}" Margin="0,0,14,0"/>
                </StackPanel>

                <!-- 줌 컨트롤 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding ZoomLabel}" Foreground="#555566"
                               VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>
                    <Button Content="−" Click="ZoomOut_Click" Padding="10,5" Margin="0,0,4,0"/>
                    <Button Content="+" Click="ZoomIn_Click"  Padding="10,5" Margin="0,0,14,0"/>
                    <Button Content="📷 PNG" Click="ExportPng_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 본문 ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- 타임라인 캔버스 영역 -->
            <ScrollViewer Grid.Column="0" x:Name="TimelineScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#13131F"
                          PreviewMouseWheel="TimelineScroll_Wheel">
                <ctrl:TimelineView x:Name="TLView" ViewModel="{Binding}"/>
            </ScrollViewer>

            <!-- 오른쪽: 속성 패널 -->
            <Border Grid.Column="1" Background="#0A0A14"
                    BorderBrush="#1A1A2A" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 이벤트 속성 (선택 시) -->
                    <StackPanel Grid.Row="0" Margin="12,10,12,0"
                                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="이벤트 속성" Foreground="#555566" FontSize="11" Margin="0,0,0,8"/>
                        <TextBlock Text="제목" Foreground="#888899" FontSize="11"/>
                        <TextBox x:Name="TxtEvTitle" Margin="0,3,0,8" Height="28"
                                 VerticalContentAlignment="Center"
                                 TextChanged="EvProp_Changed"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="시작일" Foreground="#888899" FontSize="11"/>
                                <TextBox x:Name="TxtEvStart" Margin="0,3,0,0" Height="28"
                                         VerticalContentAlignment="Center"
                                         TextChanged="EvProp_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="종료일" Foreground="#888899" FontSize="11"/>
                                <TextBox x:Name="TxtEvEnd" Margin="0,3,0,0" Height="28"
                                         VerticalContentAlignment="Center"
                                         TextChanged="EvProp_Changed"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="색상 (예: #3B82F6)" Foreground="#888899" FontSize="11"/>
                        <Grid Margin="0,3,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="TxtEvColor" Height="28"
                                     VerticalContentAlignment="Center"
                                     TextChanged="EvColor_Changed"/>
                            <Border Grid.Column="2" x:Name="ColorPreview"
                                    Width="28" Height="28" CornerRadius="4"/>
                        </Grid>
                        <CheckBox x:Name="ChkMilestone" Content="마일스톤"
                                  Checked="Milestone_Changed" Unchecked="Milestone_Changed"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="메모" Foreground="#888899" FontSize="11"/>
                        <TextBox x:Name="TxtEvNotes" Margin="0,3,0,12"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="EvProp_Changed"/>
                        <Button Content="이벤트 삭제" Style="{StaticResource DangerBtn}"
                                Click="DeleteEvent_Click"/>
                    </StackPanel>

                    <!-- 선택 없을 때 힌트 -->
                    <TextBlock Grid.Row="0" Margin="12,30,12,0"
                               Text="이벤트를 클릭하면&#10;속성을 편집할 수 있습니다."
                               Foreground="#333344" FontSize="12" TextWrapping="Wrap"
                               TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- 레인 목록 -->
                    <Border Grid.Row="1" BorderBrush="#1A1A2A" BorderThickness="0,1,0,0" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="레인 목록" Foreground="#555566"
                                       FontSize="11" Margin="12,8,12,4"/>
                            <ListBox Grid.Row="1" x:Name="LstLanes" Background="Transparent"
                                     BorderThickness="0" ItemsSource="{Binding Lanes}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="✕"
                                                    Background="Transparent"
                                                    Foreground="#555566" FontSize="10"
                                                    Padding="4,2" Cursor="Hand"
                                                    Click="RemoveLane_Click"
                                                    Tag="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- 하단 정보 -->
                    <Border Grid.Row="2" Background="#0F0F1A" Padding="12,6">
                        <TextBlock Foreground="#333344" FontSize="10" TextWrapping="Wrap"
                                   Text="드래그: 이벤트 생성&#10;마우스 휠: 스크롤&#10;Ctrl+휠: 줌 확대/축소"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── 상태 바 ────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#080812" Padding="12,4">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="#555566" FontSize="11"/>
                <TextBlock Text="{Binding Title}" HorizontalAlignment="Right"
                           Foreground="#444455" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>


</Window>
