<Window x:Class="KeyTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Key.Test — 키보드 진단 도구"
        Width="1000" Height="680" MinWidth="780" MinHeight="520"
        Background="#141414">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 툴바 -->
            <RowDefinition Height="*"/>     <!-- 본문 -->
            <RowDefinition Height="Auto"/>  <!-- 상태 바 -->
        </Grid.RowDefinitions>

        <!-- ══ 툴바 ══ -->
        <Border Grid.Row="0" Background="#0E0E0E" BorderBrush="#252525" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button x:Name="BtnClear" Content="🗑 초기화" Padding="10,5" Click="BtnClear_Click"/>
                <Button x:Name="BtnExport" Content="📄 리포트 저장" Padding="10,5" Margin="6,0,0,0"
                        Click="BtnExport_Click"/>
                <Separator Width="1" Background="#333333" Margin="8,2"/>
                <TextBlock Text="감지:" Foreground="#666666" VerticalAlignment="Center"
                           Margin="0,0,6,0" FontSize="11"/>
                <Border x:Name="BdrSticking" Background="#1A1A2A" BorderBrush="#3A3A5A"
                        BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="2,0">
                    <TextBlock Text="고착 감지 대기 중" Foreground="#7B68EE" FontSize="11"/>
                </Border>
                <Border x:Name="BdrChattering" Background="#1A1A2A" BorderBrush="#3A3A5A"
                        BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="4,0">
                    <TextBlock Text="채터링 정상" Foreground="#6EFF6E" FontSize="11"/>
                </Border>
                <Border x:Name="BdrGhosting" Background="#1A1A2A" BorderBrush="#3A3A5A"
                        BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="4,0">
                    <TextBlock x:Name="TxtGhosting" Text="동시 입력: 0키" Foreground="#888888" FontSize="11"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ 본문 ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- 키보드 레이아웃 (좌) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#111111" BorderBrush="#252525" BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="키보드 레이아웃" Foreground="#7B68EE"
                                   FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="  클릭한 키 → 초록 점등  |  문제 키 → 빨간 표시"
                                   Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto" Background="#141414">
                    <Canvas x:Name="KeyboardCanvas" Width="640" Height="280" Margin="16"/>
                </ScrollViewer>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#252525" ResizeDirection="Columns"/>

            <!-- 정보 패널 (우) -->
            <Grid Grid.Column="2" Background="#0E0E0E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 현재 키 정보 -->
                <Border Grid.Row="0" Background="#111111" BorderBrush="#252525" BorderThickness="0,0,0,1"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="현재 키" Foreground="#555555" FontSize="10"/>
                        <TextBlock x:Name="TxtCurrentKey" Text="——"
                                   Foreground="#7B68EE" FontSize="22" FontWeight="Bold"
                                   FontFamily="Consolas"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="VK 코드" Foreground="#444444" FontSize="10"/>
                                <TextBlock x:Name="TxtVkCode" Text="——"
                                           Foreground="#C0C0D0" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="스캔코드" Foreground="#444444" FontSize="10"/>
                                <TextBlock x:Name="TxtScanCode" Text="——"
                                           Foreground="#C0C0D0" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 통계 -->
                <Border Grid.Row="1" Background="#111111" BorderBrush="#252525" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="총 키 입력" Foreground="#444444" FontSize="10"/>
                            <TextBlock x:Name="TxtTotalPresses" Text="0"
                                       Foreground="#C0C0D0" FontSize="15" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="테스트 키" Foreground="#444444" FontSize="10"/>
                            <TextBlock x:Name="TxtTestedKeys" Text="0 / 104"
                                       Foreground="#6EFF6E" FontSize="15" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="문제 감지" Foreground="#444444" FontSize="10"/>
                            <TextBlock x:Name="TxtIssues" Text="없음"
                                       Foreground="#6EFF6E" FontSize="15" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 이벤트 로그 -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0E0E0E" Padding="12,6">
                        <TextBlock Text="이벤트 로그" Foreground="#444444" FontSize="10"/>
                    </Border>
                    <ListBox x:Name="LstLog" Grid.Row="1"
                             Background="#0A0A0A" BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,3" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Time}"
                                                   Foreground="#333344" FontSize="10" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Message}"
                                                   Foreground="{Binding Color}" FontSize="11"
                                                   FontFamily="Consolas" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══ 상태 바 ══ -->
        <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#252525" BorderThickness="0,1,0,0">
            <Grid Margin="8,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0" Foreground="#444444"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtNkro" Grid.Column="1" Foreground="#333344"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
