<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
         xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
         xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
         xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
         xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
         xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
         IgnorableNamespaces="rescap com desktop4 desktop5">

  <Identity Name="SmartCareworks.ClaudeCode.ContextMenu"
            Publisher="CN=SmartCareworks Inc., O=SmartCareworks Inc., L=Jung District, S=Seoul, C=KR"
            Version="2.4.0.0"
            ProcessorArchitecture="x64"/>

  <Properties>
    <DisplayName>Claude Code Context Menu</DisplayName>
    <PublisherDisplayName>SmartCareworks Inc.</PublisherDisplayName>
    <Description>Claude Code Shell Extension for Windows Explorer</Description>
    <Logo>logo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0"/>
  </Dependencies>

  <Resources>
    <Resource Language="ko-KR"/>
  </Resources>

  <Capabilities>
    <rescap:Capability Name="runFullTrust"/>
  </Capabilities>

  <Applications>
    <Application Id="App" Executable="placeholder.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements DisplayName="Claude Code Context Menu"
                          Description="Claude Code Shell Extension"
                          BackgroundColor="transparent"
                          Square150x150Logo="logo.png"
                          Square44x44Logo="logo44.png"/>
      <Extensions>

        <!-- Windows 11 new context menu (desktop5:ItemType supports Directory/Directory\Background) -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus" EntryPoint="Windows.FullTrustApplication">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="Directory">
              <desktop5:Verb Id="ClaudeCode"          Clsid="261B2913-8ABA-420B-9280-0061626EDA5A"/>
              <desktop5:Verb Id="ClaudeCodeDangerous" Clsid="261B2913-8ABA-420B-9280-0061626EDA5B"/>
            </desktop5:ItemType>
            <desktop5:ItemType Type="Directory\Background">
              <desktop5:Verb Id="ClaudeCode"          Clsid="261B2913-8ABA-420B-9280-0061626EDA5A"/>
              <desktop5:Verb Id="ClaudeCodeDangerous" Clsid="261B2913-8ABA-420B-9280-0061626EDA5B"/>
            </desktop5:ItemType>
            <desktop5:ItemType Type="Drive">
              <desktop5:Verb Id="ClaudeCode"          Clsid="261B2913-8ABA-420B-9280-0061626EDA5A"/>
              <desktop5:Verb Id="ClaudeCodeDangerous" Clsid="261B2913-8ABA-420B-9280-0061626EDA5B"/>
            </desktop5:ItemType>
            <desktop5:ItemType Type="*">
              <desktop5:Verb Id="ClaudeCode"          Clsid="261B2913-8ABA-420B-9280-0061626EDA5A"/>
              <desktop5:Verb Id="ClaudeCodeDangerous" Clsid="261B2913-8ABA-420B-9280-0061626EDA5B"/>
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>

        <!-- COM SurrogateServer: dllhost.exe loads DLL (ECF_DEFAULT, no sub-commands) -->
        <com:Extension Category="windows.comServer" EntryPoint="Windows.FullTrustApplication">
          <com:ComServer>
            <com:SurrogateServer AppId="261B2913-8ABA-420B-9280-0061626EDA5A"
                                 DisplayName="Claude Code Context Menu">
              <com:Class Id="261B2913-8ABA-420B-9280-0061626EDA5A"
                         Path="Claude.Shell.Native.dll"
                         ThreadingModel="STA"/>
              <com:Class Id="261B2913-8ABA-420B-9280-0061626EDA5B"
                         Path="Claude.Shell.Native.dll"
                         ThreadingModel="STA"/>
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

      </Extensions>
    </Application>
  </Applications>

</Package>
