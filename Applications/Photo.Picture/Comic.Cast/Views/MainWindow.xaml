<Window x:Class="ComicCast.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:ComicCast.Views"
        Title="Comic.Cast" Height="800" Width="1200"
        MinHeight="600" MinWidth="800"
        Background="{StaticResource Bg1}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 사이드 내비게이션 바 -->
        <Border Grid.Row="0" Background="{StaticResource Bg0}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,6">
                <TextBlock Text="Comic.Cast" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource Accent}" VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <Button Content="라이브러리" Command="{Binding ShowLibraryCommand}"
                        Margin="0,0,6,0" Padding="12,6">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLibraryTab}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="리더" Command="{Binding ShowReaderCommand}" Padding="12,6">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReaderTab}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- 콘텐츠 영역 -->
        <Grid Grid.Row="1">
            <!-- 라이브러리 뷰 -->
            <v:LibraryView DataContext="{Binding Library}"
                           Visibility="{Binding IsLibraryTab,
                               RelativeSource={RelativeSource AncestorType=Window},
                               Converter={StaticResource BoolToVis}}"/>
            <!-- 리더 뷰 -->
            <v:ReaderView DataContext="{Binding Reader}"
                          Visibility="{Binding IsReaderTab,
                              RelativeSource={RelativeSource AncestorType=Window},
                              Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>

    <Window.Resources>
        <v:BoolToVisConverter x:Key="BoolToVis"/>
    </Window.Resources>
</Window>
