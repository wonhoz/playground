<Window x:Class="DodgeCraft.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodge.Craft"
        Width="680" Height="760"
        ResizeMode="NoResize"
        Background="#080812"
        MouseMove="Window_MouseMove"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">

    <Grid>
        <!-- ══ 게임 캔버스 ══ -->
        <Canvas x:Name="GameCanvas" Background="#080812" ClipToBounds="True"/>

        <!-- ══ HUD ══ -->
        <Grid x:Name="HudPanel" Margin="12,8" VerticalAlignment="Top" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 점수/웨이브/라이프 -->
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TxtScore" Text="SCORE 0"
                           Foreground="#FF80FF" FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock x:Name="TxtWave" Text="WAVE 1"
                               Foreground="#888888" FontSize="12" FontFamily="Consolas"/>
                    <TextBlock x:Name="TxtLives" Text="  ♥ ♥ ♥"
                               Foreground="#FF4747" FontSize="12" FontFamily="Consolas"/>
                </StackPanel>
            </StackPanel>

            <!-- 오른쪽: 구조물 팔레트 -->
            <Border Grid.Column="1" Background="#0A0A1A" BorderBrush="#2A2A3A"
                    BorderThickness="1" CornerRadius="6" Padding="8,6">
                <StackPanel>
                    <TextBlock Text="배치 구조물" Foreground="#666688" FontSize="10" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" x:Name="PalettePanel"/>
                    <TextBlock x:Name="TxtCost" Text="" Foreground="#444466" FontSize="10" Margin="0,4,0,0"/>
                    <TextBlock Text="자원" Foreground="#444466" FontSize="10"/>
                    <TextBlock x:Name="TxtResource" Text="0"
                               Foreground="#FFD93D" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock x:Name="TxtSlots" Text="슬롯: 0/5"
                               Foreground="#444466" FontSize="10"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ 타이틀 패널 ══ -->
        <Border x:Name="TitlePanel"
                Background="#050510" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="40,28" CornerRadius="12"
                BorderBrush="#2A1A3A" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="DODGE" Foreground="#FF80FF" FontSize="52" FontWeight="Black"
                           FontFamily="Consolas" HorizontalAlignment="Center" LineHeight="50"/>
                <TextBlock Text="CRAFT" Foreground="#8040FF" FontSize="52" FontWeight="Black"
                           FontFamily="Consolas" HorizontalAlignment="Center"/>
                <TextBlock Text="탄막을 피하고 구조물로 역공하라!"
                           Foreground="#555577" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                <Border Margin="0,16,0,0" Background="#080818" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="조작법" Foreground="#8040FF" FontSize="11" FontWeight="Bold"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="마우스 이동" Foreground="#888888" FontSize="11" Margin="0,2,12,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="플레이어 조종" Foreground="#AAAACC" FontSize="11" Margin="0,2,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="1 키" Foreground="#888888" FontSize="11" Margin="0,2,12,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="🧱 벽 선택 (비용 2)" Foreground="#AAAACC" FontSize="11" Margin="0,2,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="2 키" Foreground="#888888" FontSize="11" Margin="0,2,12,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="🪞 거울 선택 (비용 3)" Foreground="#AAAACC" FontSize="11" Margin="0,2,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="3 키" Foreground="#888888" FontSize="11" Margin="0,2,12,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="💨 팬 선택 (비용 2)" Foreground="#AAAACC" FontSize="11" Margin="0,2,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="4 키" Foreground="#888888" FontSize="11" Margin="0,2,12,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="💥 폭탄 선택 (비용 4)" Foreground="#AAAACC" FontSize="11" Margin="0,2,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="클릭" Foreground="#888888" FontSize="11" Margin="0,2,12,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="선택 구조물 배치" Foreground="#AAAACC" FontSize="11" Margin="0,2,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="TxtBestTitle" Text="" Foreground="#FFD93D"
                           FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"
                           FontFamily="Consolas"/>
                <TextBlock Text="[ Enter ] 시작" Foreground="#FF80FF" FontSize="18"
                           HorizontalAlignment="Center" Margin="0,16,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>

        <!-- ══ 게임 오버 패널 ══ -->
        <Border x:Name="GameOverPanel" Visibility="Collapsed"
                Background="#050510" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="40,28" CornerRadius="12"
                BorderBrush="#3A1A1A" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="GAME OVER" Foreground="#FF4747" FontSize="36" FontWeight="Black"
                           FontFamily="Consolas" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtFinalScore" Text="" Foreground="#FF80FF"
                           FontSize="24" HorizontalAlignment="Center" Margin="0,14,0,4"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="TxtFinalWave" Text="" Foreground="#888888"
                           FontSize="14" HorizontalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock x:Name="TxtNewBest" Text="" Foreground="#FFD93D"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,0"
                           FontFamily="Consolas" Visibility="Collapsed"/>
                <TextBlock Text="[ Enter ] 다시 시작  [ Esc ] 타이틀" Foreground="#8040FF"
                           FontSize="13" HorizontalAlignment="Center" Margin="0,18,0,0"
                           FontFamily="Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
