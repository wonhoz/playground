<Window x:Class="TextForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TextForge.Views"
        Title="Text.Forge" Width="1000" Height="680"
        MinWidth="800" MinHeight="500"
        Background="#1A1A2E" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 좌측 네비게이션 항목 스타일 -->
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="16,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Indicator" Grid.Column="0"
                                        Background="Transparent" CornerRadius="2"
                                        Margin="0,4,0,4"/>
                                <ContentPresenter Grid.Column="1" Margin="10,0,0,0"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252538"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A48"/>
                                <Setter TargetName="Indicator" Property="Background" Value="#FFA000"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 네비게이션 ListBox 스타일 -->
        <Style x:Key="NavList" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource NavItem}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 좌측 사이드바 ═══ -->
        <Grid Grid.Column="0" Background="#131325">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 앱 타이틀 -->
            <StackPanel Grid.Row="0" Margin="16,20,16,16">
                <TextBlock Text="Text" FontSize="18" FontWeight="Bold"
                           Foreground="#FFA000"/>
                <TextBlock Text=".Forge" FontSize="18" FontWeight="Bold"
                           Foreground="#E0E0E0" Margin="0,-4,0,0"/>
                <TextBlock Text="Developer Tools" FontSize="10"
                           Foreground="#555566" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 구분선 -->
            <Border Grid.Row="0" Height="1" Background="#222238"
                    VerticalAlignment="Bottom" Margin="0,0,0,0"/>

            <!-- 도구 목록 -->
            <ListBox Grid.Row="1" x:Name="ToolNav"
                     Style="{StaticResource NavList}"
                     SelectionChanged="ToolNav_SelectionChanged"
                     Margin="0,8,0,8">
                <!-- 0: JSON / XML -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{}{ }" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="#FFA000" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="JSON / XML" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- 1: Encoding -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="enc" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="#4FC3F7" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Encoding" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- 2: Hash -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="#" FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                   Foreground="#CE93D8" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Hash" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- 3: JWT -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="JWT" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="#FFB74D" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="JWT Decode" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- 4: Regex -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text=".*" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="#EF9A9A" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Regex" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- 5: Timestamp -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱" FontSize="13" Width="28" VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Timestamp" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- 6: Case Convert -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Aa" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   Foreground="#80DEEA" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Case Convert" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- 7: Generator -->
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" FontSize="13" Width="28" VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Generator" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- 하단: 버전 + 도움말 버튼 -->
            <Grid Grid.Row="2" Margin="12,4,12,10">
                <TextBlock x:Name="VersionText" FontSize="10"
                           Foreground="#333355" VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
                <Button x:Name="HelpBtn" Content="?" FontSize="11" FontWeight="Bold"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="22" Height="22" Padding="0"
                        Foreground="#444466" Background="Transparent" BorderThickness="1"
                        BorderBrush="#333355" Cursor="Hand"
                        ToolTip="단축키 도움말"
                        Click="HelpBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#252538"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#555577"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>

        <!-- 구분선 -->
        <Border Grid.Column="1" Background="#222238"/>

        <!-- ═══ 컨텐츠 영역 ═══ -->
        <ContentControl Grid.Column="2" x:Name="ContentArea"/>

        <!-- ═══ 도움말 오버레이 ═══ -->
        <Grid x:Name="HelpOverlay" Grid.ColumnSpan="3"
              Visibility="Collapsed" Background="#CC000000">
            <Border Background="#1E1E32" BorderBrush="#333355" BorderThickness="1"
                    CornerRadius="8" Padding="28,24"
                    MaxWidth="480" MaxHeight="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="단축키 도움말" FontSize="16" FontWeight="Bold"
                                   Foreground="#FFA000"/>
                        <Button Content="✕" HorizontalAlignment="Right"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#888888" FontSize="14" Cursor="Hand"
                                Click="HelpClose_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock x:Name="T" Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="T" Property="Foreground" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- 탭 전환 -->
                    <TextBlock Text="탭 전환" FontSize="11" FontWeight="Bold"
                               Foreground="#666688" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+1" FontFamily="Consolas" Foreground="#FFA000" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="JSON / XML" Foreground="#AAAAAA" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+2" FontFamily="Consolas" Foreground="#4FC3F7" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Encoding" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+3" FontFamily="Consolas" Foreground="#CE93D8" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Hash" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+4" FontFamily="Consolas" Foreground="#FFB74D" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="JWT Decode" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+5" FontFamily="Consolas" Foreground="#EF9A9A" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Regex" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ctrl+6" FontFamily="Consolas" Foreground="#80DEEA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Timestamp" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Ctrl+7" FontFamily="Consolas" Foreground="#80DEEA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Case Convert" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Ctrl+8" FontFamily="Consolas" Foreground="#A5D6A7" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="Generator" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                    </Grid>

                    <!-- 일반 -->
                    <TextBlock Text="일반" FontSize="11" FontWeight="Bold"
                               Foreground="#666688" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="F1" FontFamily="Consolas" Foreground="#FFA000" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="도움말 열기/닫기" Foreground="#AAAAAA" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Esc" FontFamily="Consolas" Foreground="#FFA000" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="도움말 닫기" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
