<UserControl x:Class="HashCheck.Views.FolderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 폴더 선택 바 ─────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtFolder" Grid.Column="0" Height="32" IsReadOnly="True"
                         Text="폴더를 선택하세요..." Foreground="#888899"
                         VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="📁 폴더 선택" Width="100" Height="32"
                        Click="BtnPickFolder_Click" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="해시 계산" Width="90" Height="32"
                        Click="BtnCompute_Click" x:Name="BtnCompute" IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- ── 옵션 바 ───────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="알고리즘:" Foreground="#888899" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="CbAlgo" Width="110" Height="28"
                          SelectedIndex="2" Margin="0,0,20,0"
                          SelectionChanged="CbAlgo_SelectionChanged">
                    <ComboBoxItem Content="MD5"/>
                    <ComboBoxItem Content="SHA-1"/>
                    <ComboBoxItem Content="SHA-256"/>
                    <ComboBoxItem Content="SHA-512"/>
                </ComboBox>
                <TextBlock Text="파일 필터:" Foreground="#888899" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="TxtFilter" Width="120" Height="28" Text="*.*"
                         VerticalContentAlignment="Center" Margin="0,0,20,0"/>
                <CheckBox x:Name="ChkSubDir" Content="하위 폴더 포함" IsChecked="False"
                          VerticalAlignment="Center" Margin="0,0,20,0"/>
                <CheckBox x:Name="ChkCancelOnError" Content="오류 시 중단" IsChecked="False"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── 결과 ListView ──────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6">
            <ListView x:Name="LvFiles" Background="Transparent"
                      BorderThickness="0" Foreground="#D4D4D4">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="파일명" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}"
                                               ToolTip="{Binding FilePath}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="크기" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeText}" Foreground="#888899"
                                               HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="해시" Width="360">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Hash}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{Binding HashColor}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="경로" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RelativePath}"
                                               Foreground="#666677" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ── 하단 툴바 ──────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtSummary" Grid.Column="0" Foreground="#888899" FontSize="12"
                       VerticalAlignment="Center" Text="폴더를 선택하면 해시 계산이 가능합니다."/>
            <Button Grid.Column="1" Content="저장 (.txt)" Width="100" Height="30"
                    Click="BtnSaveTxt_Click" x:Name="BtnSaveTxt" IsEnabled="False" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="CSV 내보내기" Width="110" Height="30"
                    Click="BtnExport_Click" x:Name="BtnExport" IsEnabled="False"/>
        </Grid>
    </Grid>
</UserControl>
