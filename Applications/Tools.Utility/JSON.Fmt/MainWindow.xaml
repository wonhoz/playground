<Window x:Class="JsonFmt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JSON.Fmt" Height="640" Width="1000"
        Background="#1A1A2E" Foreground="#E0E0E0"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter"
        Loaded="Window_Loaded" Closing="Window_Closing"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252530"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#7a6420"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353525"/>
                                <Setter Property="BorderBrush" Value="#e6b800"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#5a4a18"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#5a4a18"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ─── 툴바 ─── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center"
                    Background="#14142A" Margin="-10,-10,-10,0">
            <Button x:Name="BtnPaste" Click="BtnPaste_Click" Margin="10,0,6,0">📋 붙여넣기</Button>
            <Button x:Name="BtnFormat" Click="BtnFormat_Click" Margin="0,0,6,0">✨ 포맷</Button>
            <Button x:Name="BtnMinify" Click="BtnMinify_Click" Margin="0,0,6,0">🗜 축소</Button>
            <Button x:Name="BtnCopy" Click="BtnCopy_Click" Margin="0,0,6,0" IsEnabled="False">📄 복사</Button>
            <Button x:Name="BtnSave" Click="BtnSave_Click" Margin="0,0,6,0" IsEnabled="False">💾 저장</Button>
            <Button x:Name="BtnClear" Click="BtnClear_Click" Margin="0,0,6,0">🗑 지우기</Button>
            <Rectangle Width="1" Fill="#5a4a18" Margin="4,8"/>
            <Button x:Name="BtnSortKeys" Click="BtnSortKeys_Click" Margin="6,0,6,0">🔤 키 정렬</Button>
            <Button x:Name="BtnFix" Click="BtnFix_Click" Margin="0,0,6,0" ToolTip="주석·trailing comma·단일따옴표 자동 수정">🔧 Lenient 수정</Button>
            <Rectangle Width="1" Fill="#5a4a18" Margin="4,8"/>
            <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}"
                     Width="160" Margin="6,0,4,0"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="키/값 검색 (Enter 확인)"/>
            <Button x:Name="BtnHelp" Click="BtnHelp_Click" Margin="0,0,10,0" ToolTip="단축키 및 도움말">❓</Button>
        </StackPanel>

        <!-- ─── 메인 (입력 / 출력) ─── -->
        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 입력 패널 -->
            <Border Grid.Column="0" BorderBrush="#5a4a18" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1A1A2A" CornerRadius="6,6,0,0">
                        <TextBlock Text="입력" Margin="10,0" VerticalAlignment="Center"
                                   FontSize="11" Foreground="#a08840"/>
                    </Border>
                    <TextBox x:Name="InputBox" Grid.Row="1"
                             BorderThickness="0"
                             TextChanged="InputBox_TextChanged"
                             PreviewKeyDown="InputBox_PreviewKeyDown"/>
                </Grid>
            </Border>

            <!-- 분리선 -->
            <GridSplitter Grid.Column="1" Width="6" Background="#5a4a18" HorizontalAlignment="Stretch"/>

            <!-- 출력 패널 -->
            <Border Grid.Column="2" BorderBrush="#5a4a18" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1A1A2A" CornerRadius="6,6,0,0">
                        <TextBlock Text="출력" Margin="10,0,0,0" VerticalAlignment="Center"
                                   FontSize="11" Foreground="#a08840"/>
                    </Border>
                    <RichTextBox x:Name="OutputBox" Grid.Row="1"
                                 BorderThickness="0"
                                 Background="#13132A" Foreground="#E0E0E0"
                                 FontFamily="Consolas" FontSize="13"
                                 Padding="8"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto">
                        <RichTextBox.Document>
                            <FlowDocument x:Name="OutputDoc" PageWidth="10000"/>
                        </RichTextBox.Document>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ─── 오류 패널 ─── -->
        <Border x:Name="ErrorPanel" Grid.Row="2" Margin="0,4,0,0"
                Background="#2A1020" BorderBrush="#883344" BorderThickness="1" CornerRadius="4"
                Visibility="Collapsed">
            <StackPanel Margin="10,6">
                <TextBlock x:Name="ErrorTitle" FontWeight="Bold" Foreground="#FF6666" FontSize="12"/>
                <TextBlock x:Name="ErrorDetail" Foreground="#CC8888" FontFamily="Consolas" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ─── 상태바 ─── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusBar" VerticalAlignment="Center" FontSize="11" Foreground="#666688"/>
            <TextBlock x:Name="StatsBar" Grid.Column="1" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="10" Foreground="#555577"/>
        </Grid>
    </Grid>
</Window>
