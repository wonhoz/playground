<Window x:Class="StockRush.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StockRush.Controls"
        Title="Stock.Rush — 주식 시뮬레이션"
        Width="1500" Height="920" MinWidth="1280" MinHeight="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
    <Grid>
        <!-- ───────────────────── 메인 레이아웃 ───────────────────── -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 상단 바 -->
            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="14,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="STOCK RUSH" FontWeight="Black" FontSize="16" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock x:Name="TxtClock" Text="Day 1 · 09:00:00" Margin="18,0,0,0" FontSize="14"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtIndex" Text="KOSPI 2,500.00" Margin="18,0,0,0" FontSize="13"
                                   Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="총자산" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtEquity" Text="10,000,000" Margin="6,0,0,0" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="평가손익" Foreground="{StaticResource DimBrush}" Margin="18,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtUnrealized" Text="0" Margin="6,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="실현손익" Foreground="{StaticResource DimBrush}" Margin="18,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtRealized" Text="0" Margin="6,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="수익률" Foreground="{StaticResource DimBrush}" Margin="18,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtReturn" Text="0.00%" Margin="6,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="예수금" Foreground="{StaticResource DimBrush}" Margin="18,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCash" Text="10,000,000" Margin="6,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                        <ToggleButton x:Name="Spd025" Style="{StaticResource TabToggle}" Content="0.25×" Margin="18,0,0,0"
                                      ToolTip="아주 천천히" Tag="0.25" Checked="Speed_Changed"/>
                        <ToggleButton x:Name="Spd05" Style="{StaticResource TabToggle}" Content="0.5×" Margin="4,0,0,0"
                                      ToolTip="천천히" Tag="0.5" Checked="Speed_Changed"/>
                        <ToggleButton x:Name="Spd1" Style="{StaticResource TabToggle}" Content="1×" Margin="4,0,0,0"
                                      ToolTip="기본 속도" Tag="1" IsChecked="True" Checked="Speed_Changed"/>
                        <ToggleButton x:Name="Spd2" Style="{StaticResource TabToggle}" Content="2×" Margin="4,0,0,0"
                                      ToolTip="2배속" Tag="2" Checked="Speed_Changed"/>
                        <ToggleButton x:Name="Spd4" Style="{StaticResource TabToggle}" Content="4×" Margin="4,0,0,0"
                                      ToolTip="4배속" Tag="4" Checked="Speed_Changed"/>
                        <ToggleButton x:Name="BtnMute" Style="{StaticResource TabToggle}" Content="🔔" Margin="12,0,0,0"
                                      ToolTip="알림음 켜기/끄기" Checked="BtnMute_Toggled" Unchecked="BtnMute_Toggled"/>
                        <Button x:Name="BtnMenu" Style="{StaticResource DarkButton}" Content="메인 메뉴" Margin="8,0,0,0"
                                Padding="10,4" Click="BtnMenu_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 본문 3단 -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- ── 좌: 관심종목 ── -->
                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="12,10,12,6">
                            <TextBlock Text="관심종목" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="종목 클릭 = 선택" Foreground="{StaticResource DimBrush}" FontSize="10"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4,0,2,6">
                            <ItemsControl x:Name="WatchList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="row" Padding="8,6" Margin="2,1" CornerRadius="6" Background="Transparent"
                                                Cursor="Hand" MouseLeftButtonDown="WatchRow_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                                        <Border Background="#3A2A12" CornerRadius="3" Padding="4,0" Margin="6,0,0,0"
                                                                Visibility="{Binding StateText, Converter={x:Static controls:Converters.NonEmptyToVisible}}">
                                                            <TextBlock Text="{Binding StateText}" FontSize="9" Foreground="#FFB000" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding VolumeText}" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding PriceText}" FontWeight="Bold" FontSize="12"
                                                               Foreground="{Binding TrendBrush}" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding ChangeRateText}" FontSize="10"
                                                               Foreground="{Binding TrendBrush}" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="#2A2A3A"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ── 중앙: 차트 + 뉴스 ── -->
                <Grid Grid.Column="1" Margin="10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="170"/>
                    </Grid.RowDefinitions>

                    <!-- 종목 헤더 -->
                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="14,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtStockName" Text="한빛전자" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtStockCode" Text="005430 · 반도체" FontSize="11"
                                           Foreground="{StaticResource DimBrush}" Margin="10,4,0,0" VerticalAlignment="Center"/>
                                <Border x:Name="StateBadge" Background="#5A1A1A" CornerRadius="4" Padding="6,2" Margin="12,0,0,0"
                                        Visibility="Collapsed" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtStockState" Text="VI 발동" FontSize="11" FontWeight="Bold" Foreground="#FFB000"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtOhlv" Text="시 0 · 고 0 · 저 0" FontSize="11"
                                           Foreground="{StaticResource DimBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock x:Name="TxtBigPrice" Text="72,400" FontSize="26" FontWeight="Black" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBigChange" Text="▲ 0 (+0.00%)" FontSize="13" FontWeight="Bold"
                                           Margin="12,6,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 차트 -->
                    <Border Grid.Row="1" Margin="0,8" CornerRadius="8" BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1" ClipToBounds="True">
                        <controls:CandleChart x:Name="Chart"/>
                    </Border>

                    <!-- 뉴스 피드 -->
                    <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="실시간 뉴스" FontWeight="Bold" FontSize="13" Margin="12,8,12,4"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4,0,2,6">
                                <ItemsControl x:Name="NewsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="42"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding TimeText}" FontSize="11"
                                                           Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Background="{Binding KindBrush}" CornerRadius="3"
                                                        Padding="0,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding KindBadge}" FontSize="10" FontWeight="Bold"
                                                               Foreground="#14141A" HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock x:Name="headline" Grid.Column="2" Text="{Binding Headline}" FontSize="12"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsBreaking}" Value="True">
                                                    <Setter TargetName="headline" Property="FontWeight" Value="Bold"/>
                                                    <Setter TargetName="headline" Property="Foreground" Value="#FFB000"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── 우: 호가 + 주문 + 잔고 ── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="218"/>
                    </Grid.RowDefinitions>

                    <!-- 호가창 -->
                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="12,8,12,4">
                                <TextBlock Text="호가" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="가격 클릭 = 지정가 입력" Foreground="{StaticResource DimBrush}" FontSize="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl x:Name="BookList" Grid.Row="1" Margin="8,0,8,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Cursor="Hand" MouseLeftButtonDown="BookRow_Click" Background="Transparent">
                                            <Grid Height="19">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="96"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="96"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 매도 잔량 (좌) -->
                                                <Grid Grid.Column="0" x:Name="askZone" Visibility="Visible">
                                                    <Border Background="#1E3050" CornerRadius="2" HorizontalAlignment="Right"
                                                            Width="{Binding BarWidth}" Margin="0,2"/>
                                                    <TextBlock Text="{Binding QtyText}" FontSize="11" HorizontalAlignment="Right"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                </Grid>
                                                <!-- 가격 (중앙) -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding PriceText}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{Binding RateBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding RateText}" FontSize="9" Foreground="{StaticResource DimBrush}"
                                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <!-- 매수 잔량 (우) -->
                                                <Grid Grid.Column="2" x:Name="bidZone" Visibility="Hidden">
                                                    <Border Background="#4A2030" CornerRadius="2" HorizontalAlignment="Left"
                                                            Width="{Binding BarWidth}" Margin="0,2"/>
                                                    <TextBlock Text="{Binding QtyText}" FontSize="11" HorizontalAlignment="Left"
                                                               Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsAsk}" Value="False">
                                                <Setter TargetName="askZone" Property="Visibility" Value="Hidden"/>
                                                <Setter TargetName="bidZone" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- 주문 패널 -->
                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Margin="0,8"
                            BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="BtnSideBuy" Grid.Column="0" Style="{StaticResource TabToggle}" Content="매수"
                                              Foreground="#F04452" FontWeight="Bold" IsChecked="True" Checked="OrderSide_Changed"/>
                                <ToggleButton x:Name="BtnSideSell" Grid.Column="1" Style="{StaticResource TabToggle}" Content="매도"
                                              Foreground="#3182F6" FontWeight="Bold" Checked="OrderSide_Changed"/>
                                <ToggleButton x:Name="BtnTypeMarket" Grid.Column="3" Style="{StaticResource TabToggle}" Content="시장가"
                                              IsChecked="True" Checked="OrderType_Changed"/>
                                <ToggleButton x:Name="BtnTypeLimit" Grid.Column="4" Style="{StaticResource TabToggle}" Content="지정가"
                                              Checked="OrderType_Changed"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="가격" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox x:Name="TxtPrice" Grid.Column="1" IsEnabled="False" FontSize="13" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="수량" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"
                                           FontSize="12" Margin="10,0,0,0"/>
                                <TextBox x:Name="TxtQty" Grid.Column="3" Text="10" FontSize="13" TextAlignment="Right"
                                         TextChanged="TxtQty_TextChanged"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource DarkButton}" Content="10%" Padding="0,4" Margin="0,0,4,0"
                                        Click="QtyPct_Click" Tag="0.10"/>
                                <Button Grid.Column="1" Style="{StaticResource DarkButton}" Content="25%" Padding="0,4" Margin="0,0,4,0"
                                        Click="QtyPct_Click" Tag="0.25"/>
                                <Button Grid.Column="2" Style="{StaticResource DarkButton}" Content="50%" Padding="0,4" Margin="0,0,4,0"
                                        Click="QtyPct_Click" Tag="0.50"/>
                                <Button Grid.Column="3" Style="{StaticResource DarkButton}" Content="최대" Padding="0,4"
                                        Click="QtyPct_Click" Tag="1.00"/>
                            </Grid>
                            <TextBlock x:Name="TxtOrderInfo" Text="매수가능 0주 · 예상금액 0원" FontSize="11"
                                       Foreground="{StaticResource DimBrush}" Margin="2,8,0,0"/>
                            <Button x:Name="BtnOrder" Style="{StaticResource BuyButton}" Content="매수" FontSize="15"
                                    Padding="0,9" Margin="0,8,0,0" Click="BtnOrder_Click"/>
                            <TextBlock x:Name="TxtOrderMsg" Text="" FontSize="11" Margin="2,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 잔고/주문/체결 탭 -->
                    <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8,10,4">
                                <ToggleButton x:Name="TabPos" Style="{StaticResource TabToggle}" Content="보유" IsChecked="True"
                                              Checked="Tab_Changed" FontSize="12"/>
                                <ToggleButton x:Name="TabOrd" Style="{StaticResource TabToggle}" Content="주문" Margin="6,0,0,0"
                                              Checked="Tab_Changed" FontSize="12"/>
                                <ToggleButton x:Name="TabTrd" Style="{StaticResource TabToggle}" Content="체결" Margin="6,0,0,0"
                                              Checked="Tab_Changed" FontSize="12"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4,0,2,6">
                                <Grid>
                                    <ItemsControl x:Name="PosList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,5" Margin="2,1" CornerRadius="6" Background="#20202B"
                                                        Cursor="Hand" MouseLeftButtonDown="PosRow_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding QtyText}" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                                <TextBlock Text="주 · 평단 " FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                                <TextBlock Text="{Binding AvgPriceText}" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding PnlText}" FontWeight="Bold" FontSize="12"
                                                                       Foreground="{Binding PnlBrush}" HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{Binding PnlRateText}" FontSize="10"
                                                                       Foreground="{Binding PnlBrush}" HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl x:Name="OrdList" Visibility="Collapsed">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,5" Margin="2,1" CornerRadius="6" Background="#20202B">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding SideText}" FontWeight="Bold" FontSize="11"
                                                                   Foreground="{Binding SideBrush}" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding PriceText}" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                                <TextBlock Text="원 × " FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                                <TextBlock Text="{Binding QtyText}" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                                <TextBlock Text="주" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Style="{StaticResource DarkButton}" Content="취소" FontSize="10"
                                                                Padding="8,2" Click="CancelOrder_Click" Tag="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl x:Name="TrdList" Visibility="Collapsed">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4" Margin="2,1" CornerRadius="6" Background="#20202B">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="38"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding TimeText}" FontSize="10"
                                                                   Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding SideText}" FontWeight="Bold" FontSize="11"
                                                                   Foreground="{Binding SideBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Summary}" FontSize="11" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ───────────────────── 효과·오버레이 ───────────────────── -->

        <!-- 화면 플래시 (속보·VI) -->
        <Border x:Name="FlashBorder" BorderThickness="6" CornerRadius="4" Opacity="0" IsHitTestVisible="False"/>

        <!-- 속보 배너 -->
        <Border x:Name="BreakingBanner" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,72,0,0"
                Background="#B01E1E28" BorderBrush="#FFB000" BorderThickness="2" CornerRadius="8"
                Padding="18,10" Visibility="Collapsed" IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚡ 속보" FontWeight="Black" FontSize="14" Foreground="#FFB000" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtBreaking" Text="" FontSize="14" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 튜토리얼 바 -->
        <Border x:Name="TutorialBar" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,24"
                Background="#E61B1B28" BorderBrush="#4AE89A" BorderThickness="2" CornerRadius="10"
                Padding="18,12" Visibility="Collapsed" MaxWidth="860">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtTutorialStep" Grid.Column="0" Text="1/4" FontWeight="Black" FontSize="14"
                           Foreground="#4AE89A" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTutorialText" Grid.Column="1" Text="" FontSize="13" FontWeight="SemiBold"
                           Margin="14,0" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Style="{StaticResource DarkButton}" Content="그만하기" FontSize="11" Padding="10,4"
                        Click="BtnTutorialQuit_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 장 마감 오버레이 -->
        <Grid x:Name="DayEndOverlay" Background="#D912121A" Visibility="Collapsed">
            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1"
                    CornerRadius="12" Padding="40,32" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="420">
                <StackPanel>
                    <TextBlock x:Name="TxtDayEndTitle" Text="장 마감" FontSize="24" FontWeight="Black" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtDayEndStats" Text="" FontSize="14" Margin="0,18,0,0" LineHeight="26" HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    <Button x:Name="BtnNextDay" Style="{StaticResource BuyButton}" Content="다음 날 개장 →" FontSize="15"
                            Padding="24,10" Margin="0,24,0,0" Click="BtnNextDay_Click"/>
                    <Button Style="{StaticResource DarkButton}" Content="메인 메뉴" FontSize="12" Padding="24,8"
                            Margin="0,8,0,0" Click="BtnMenu_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 튜토리얼 결과 오버레이 -->
        <Grid x:Name="ResultOverlay" Background="#D912121A" Visibility="Collapsed">
            <Border Background="{StaticResource PanelBrush}" BorderBrush="#4AE89A" BorderThickness="1"
                    CornerRadius="12" Padding="40,32" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                <StackPanel>
                    <TextBlock Text="🎓 튜토리얼 결과" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtResult" Text="" FontSize="13" Margin="0,18,0,0" LineHeight="22" TextWrapping="Wrap"/>
                    <Button Style="{StaticResource BuyButton}" Content="메인 메뉴로" FontSize="14" Padding="24,9"
                            Margin="0,24,0,0" Click="BtnMenu_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 시작 메뉴 오버레이 -->
        <Grid x:Name="StartOverlay" Background="#F012121A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                <TextBlock Text="STOCK RUSH" FontSize="44" FontWeight="Black" Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="실전처럼 긴장되는 주식 트레이딩 시뮬레이션" FontSize="14" Foreground="{StaticResource DimBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                <TextBlock x:Name="TxtRecord" Text="" FontSize="12" Foreground="{StaticResource DimBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>

                <Button x:Name="BtnStartReal" Style="{StaticResource BuyButton}" FontSize="16" Padding="0,13" Margin="0,28,0,0"
                        Click="BtnStartReal_Click">
                    <StackPanel>
                        <TextBlock Text="실전 투자 시작" FontWeight="Black" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="초기 자본 1,000만 원 · 하루 = 실제 4분 · 상하한가 ±30%" FontSize="11"
                                   Foreground="#FFD0D0" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="튜토리얼 — 식은땀 나기 전에 연습부터" FontSize="12" Foreground="{StaticResource DimBrush}"
                           Margin="0,26,0,6"/>
                <Button Style="{StaticResource DarkButton}" Margin="0,4,0,0" Padding="0,10" Click="BtnTutorial_Click" Tag="basic"
                        HorizontalContentAlignment="Stretch">
                    <StackPanel Margin="14,0">
                        <TextBlock Text="① 기초 매매" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="시장가 매수 → 수익 실현 매도의 기본 흐름을 익힙니다." FontSize="11" Foreground="{StaticResource DimBrush}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DarkButton}" Margin="0,6,0,0" Padding="0,10" Click="BtnTutorial_Click" Tag="news"
                        HorizontalContentAlignment="Stretch">
                    <StackPanel Margin="14,0">
                        <TextBlock Text="② 뉴스 트레이딩" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="호재 속보에 빠르게 올라타고, 꺾이기 전에 빠져나오는 연습." FontSize="11" Foreground="{StaticResource DimBrush}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DarkButton}" Margin="0,6,0,0" Padding="0,10" Click="BtnTutorial_Click" Tag="stoploss"
                        HorizontalContentAlignment="Stretch">
                    <StackPanel Margin="14,0">
                        <TextBlock Text="③ 손절 연습" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="악재 급락 시 손실을 -5% 이내로 끊어내는 훈련." FontSize="11" Foreground="{StaticResource DimBrush}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DarkButton}" Margin="0,6,0,0" Padding="0,10" Click="BtnTutorial_Click" Tag="candle"
                        HorizontalContentAlignment="Stretch">
                    <StackPanel Margin="14,0">
                        <TextBlock Text="④ 캔들·추세 읽기" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="망치형 반전, 추세 추종 — 캔들 차트로 매매 타이밍 잡는 법." FontSize="11" Foreground="{StaticResource DimBrush}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
