<Window x:Class="Stock.Fetch.PortfolioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Stock.Fetch.Converters"
        Title="내 자산" Height="740" Width="940"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:SignBrushConverter x:Key="PnlBrush"
                                 Positive="{StaticResource BullBrush}"
                                 Negative="{StaticResource BearBrush}"
                                 Zero="{StaticResource FgMuted}"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PnlCell" TargetType="TextBlock" BasedOn="{StaticResource NumCell}"/>
    </Window.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2.2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 + 경로 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="💼 내 자산" FontSize="19" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
                <TextBlock x:Name="PathText" FontSize="11" Foreground="{StaticResource FgMuted}" Margin="0,3,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📂 폴더 열기" Width="110" Click="OpenFolder_Click"/>
            </StackPanel>
        </Grid>

        <!-- 보유 현황 헤더 -->
        <Grid Grid.Row="1" Margin="0,16,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="보유 현황 (이동평균 평단)" Style="{StaticResource SectionHeader}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="AutoRefreshCheck" Content="자동 갱신" VerticalAlignment="Center"
                          Margin="0,0,10,0" Click="AutoRefresh_Click"/>
                <Button x:Name="RefreshBtn" Content="🔄 현재가 갱신" Width="130" Click="Refresh_Click"/>
            </StackPanel>
        </Grid>

        <!-- 보유 DataGrid -->
        <DataGrid Grid.Row="2" x:Name="HoldingsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  ColumnHeaderStyle="{StaticResource DarkColHeader}" CanUserAddRows="False"
                  SelectionMode="Single" Margin="0,0,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="종목" Binding="{Binding Display}" Width="*" MinWidth="180"/>
                <DataGridTextColumn Header="수량" Binding="{Binding Quantity, StringFormat={}{0:N0}}" Width="80" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="평단" Binding="{Binding AvgPrice, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="매입금액" Binding="{Binding Invested, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="현재가" Binding="{Binding Current, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="평가손익" Binding="{Binding EvalPL, StringFormat={}{0:+#,0;-#,0;0}}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource PnlCell}">
                            <Setter Property="Foreground" Value="{Binding EvalPL, Converter={StaticResource PnlBrush}}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="수익률" Binding="{Binding ReturnPct, StringFormat={}{0:+0.00%;-0.00%;0.00%}}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource PnlCell}">
                            <Setter Property="Foreground" Value="{Binding ReturnPct, Converter={StaticResource PnlBrush}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="실현손익" Binding="{Binding Realized, StringFormat={}{0:+#,0;-#,0;0}}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource PnlCell}">
                            <Setter Property="Foreground" Value="{Binding Realized, Converter={StaticResource PnlBrush}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="래더 알림" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding LadderAlert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      ToolTip="매수 1~4호가 도달·익절 돌파·갭다운 취소선 알림(국내)"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 보유 합계 -->
        <TextBlock Grid.Row="3" x:Name="SummaryText" Margin="0,8,0,0" Foreground="{StaticResource FgBrush}"
                   FontWeight="SemiBold" TextWrapping="Wrap"/>

        <!-- 매매 기록 헤더 + 버튼 -->
        <Grid Grid.Row="4" Margin="0,18,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="매매 기록 (롯)" Style="{StaticResource SectionHeader}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="＋ 매수" Width="84" Margin="0,0,6,0" Click="AddBuy_Click"/>
                <Button Content="－ 매도" Width="84" Margin="0,0,6,0" Click="AddSell_Click"/>
                <Button Content="✎ 수정" Width="76" Margin="0,0,6,0" Click="Edit_Click"/>
                <Button Content="🗑 삭제" Width="76" Click="Delete_Click"/>
            </StackPanel>
        </Grid>

        <!-- 매매 DataGrid -->
        <DataGrid Grid.Row="5" x:Name="TradesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  ColumnHeaderStyle="{StaticResource DarkColHeader}" CanUserAddRows="False"
                  SelectionMode="Extended" MouseDoubleClick="Edit_Click">
            <DataGrid.Columns>
                <DataGridTextColumn Header="날짜" Binding="{Binding DateText}" Width="100"/>
                <DataGridTextColumn Header="종목" Binding="{Binding Display}" Width="*" MinWidth="160"/>
                <DataGridTextColumn Header="구분" Binding="{Binding SideText}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{Binding SideSign, Converter={StaticResource PnlBrush}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="가격" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="수량" Binding="{Binding Quantity, StringFormat={}{0:N0}}" Width="80" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="금액" Binding="{Binding Amount, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="메모" Binding="{Binding Note}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단 -->
        <StackPanel Grid.Row="6" Margin="0,12,0,0">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource FgMuted}"
                       Text="※ 평단은 이동평균 매입가, 실현손익은 매도 시 (매도가−평단)×수량 누적입니다. 현재가는 네이버 최근 종가 기준(참고용)이며, 세금·수수료는 미반영입니다."/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="닫기" Width="90" Style="{StaticResource AccentButton}" Click="Close_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
