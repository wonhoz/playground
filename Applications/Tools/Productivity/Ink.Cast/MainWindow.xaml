<Window x:Class="InkCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:InkCast.Views"
        Title="Ink.Cast" Height="720" Width="1200" MinHeight="500" MinWidth="750"
        Background="#1A1A1A" Foreground="#CDD6F4"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 툴바 버튼 스타일 -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9399B2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E5A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 활성 토글 버튼 스타일 -->
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9399B2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E5A"/>
                                <Setter Property="Foreground" Value="#CBA6F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 검색 TextBox 스타일 -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#CBA6F7"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C6AF4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 에디터 TextBox -->
        <Style x:Key="EditorBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#CBA6F7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="SpellCheck.IsEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Background="{TemplateBinding Background}"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 제목 TextBox -->
        <Style x:Key="TitleBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CBA6F7"/>
            <Setter Property="CaretBrush" Value="#CBA6F7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12,16,8"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="255" MinWidth="180" MaxWidth="400"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 왼쪽 사이드바 ══ -->
        <Grid Grid.Column="0" Background="#111120">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 앱 이름 + 워크스페이스 -->
            <StackPanel Grid.Row="0" Margin="10,12,10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="✦ Ink.Cast"
                               FontSize="15" FontWeight="Bold" Foreground="#CBA6F7"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <Button Grid.Column="1" x:Name="BtnNewNote" Content="＋ 새 노트"
                            Style="{StaticResource ToolBtn}" FontSize="11"
                            Padding="8,4" Click="BtnNewNote_Click"/>
                </Grid>
                <!-- 워크스페이스 선택 -->
                <ComboBox x:Name="CmbWorkspace" Margin="0,8,0,0"
                          SelectionChanged="CmbWorkspace_SelectionChanged"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="+ 워크스페이스" Style="{StaticResource ToolBtn}"
                            FontSize="10" Padding="6,3" Click="BtnAddWorkspace_Click"/>
                    <Button x:Name="BtnDeleteWorkspace" Content="삭제" Style="{StaticResource ToolBtn}"
                            FontSize="10" Padding="6,3" Click="BtnDeleteWorkspace_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- 검색창 -->
            <Grid Grid.Row="1" Margin="10,0,10,6">
                <TextBox x:Name="TxtSearch" Style="{StaticResource SearchBox}"
                         TextChanged="TxtSearch_TextChanged"/>
                <TextBlock Text="🔍  노트 검색..." IsHitTestVisible="False"
                           Foreground="#585B70" FontSize="12" Margin="10,0,0,0"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- 노트 목록 -->
            <ListBox x:Name="LstNotes" Grid.Row="2"
                     Background="Transparent" BorderThickness="0"
                     Margin="0,0,0,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="LstNotes_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="6,6,6,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Title}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#CDD6F4" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="{Binding RelativeTime}"
                                           FontSize="10" Foreground="#585B70" Margin="4,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <!-- 태그 chips -->
                            <ItemsControl Grid.Row="2" ItemsSource="{Binding Tags}" Margin="0,3,0,0"
                                          Visibility="{Binding Tags.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2A2A4A" CornerRadius="8" Margin="0,0,3,0" Padding="5,1">
                                            <TextBlock Text="{Binding StringFormat='#{0}'}"
                                                       FontSize="10" Foreground="#7C6AF4"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 태그 필터 -->
            <StackPanel Grid.Row="3" Margin="10,0,10,10">
                <Border Background="#1A1A2E" CornerRadius="6" Padding="8,6">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="태그 필터" FontSize="11" Foreground="#585B70"/>
                            <Button x:Name="BtnClearTag" Content="전체" Style="{StaticResource ToolBtn}"
                                    FontSize="10" Padding="5,2" HorizontalAlignment="Right"
                                    Click="BtnClearTag_Click"/>
                        </Grid>
                        <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                            <WrapPanel x:Name="TagPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
                <!-- 일별 노트 버튼 -->
                <Button x:Name="BtnDailyNote" Content="📅  오늘 일별 노트"
                        Style="{StaticResource ToolBtn}" Margin="0,6,0,0"
                        HorizontalAlignment="Stretch" FontSize="12"
                        Click="BtnDailyNote_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1A1A2E" CornerRadius="6"
                                    BorderBrush="#333355" BorderThickness="1" Padding="10,8">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#252540"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7C6AF4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ GridSplitter ══ -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="#252535" Cursor="SizeWE"/>

        <!-- ══ 오른쪽 메인 영역 ══ -->
        <Grid Grid.Column="2" Background="#1E1E2E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 툴바 -->
            <Border Grid.Row="0" Background="#181828" BorderBrush="#252535" BorderThickness="0,0,0,1">
                <Grid Margin="8,4">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnNewNote2" Content="✦ 새 노트" Style="{StaticResource ToolBtn}"
                                Click="BtnNewNote_Click"/>
                        <Button x:Name="BtnDelete" Content="🗑 삭제" Style="{StaticResource ToolBtn}"
                                Click="BtnDelete_Click" IsEnabled="False"/>
                        <Separator Width="1" Background="#333355" Margin="4,4"/>
                        <ToggleButton x:Name="BtnPreviewToggle" Content="👁 미리보기"
                                      Style="{StaticResource ToggleBtn}" IsChecked="True"
                                      Checked="BtnPreviewToggle_Checked" Unchecked="BtnPreviewToggle_Unchecked"/>
                        <ToggleButton x:Name="BtnGraphToggle" Content="◈ 그래프"
                                      Style="{StaticResource ToggleBtn}"
                                      Checked="BtnGraphToggle_Checked" Unchecked="BtnGraphToggle_Unchecked"/>
                        <Separator Width="1" Background="#333355" Margin="4,4"/>
                        <Button x:Name="BtnExport" Content="↗ HTML 내보내기" Style="{StaticResource ToolBtn}"
                                Click="BtnExport_Click" IsEnabled="False"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtStatus" Text="" FontSize="11"
                                   Foreground="#585B70" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 노트 제목 입력 -->
            <TextBox x:Name="TxtTitle" Grid.Row="1"
                     Style="{StaticResource TitleBox}"
                     IsEnabled="False"
                     TextChanged="TxtTitle_TextChanged"/>

            <!-- 에디터 영역 (Editor + Preview split) -->
            <Grid x:Name="EditorArea" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" x:Name="ColEditor"/>
                    <ColumnDefinition Width="Auto" x:Name="ColSplitter"/>
                    <ColumnDefinition Width="*" x:Name="ColPreview"/>
                </Grid.ColumnDefinitions>

                <!-- 마크다운 에디터 -->
                <TextBox x:Name="TxtEditor" Grid.Column="0"
                         Style="{StaticResource EditorBox}"
                         IsEnabled="False"
                         TextChanged="TxtEditor_TextChanged"
                         KeyDown="TxtEditor_KeyDown"/>

                <!-- Editor / Preview 구분선 -->
                <GridSplitter x:Name="EditorSplitter" Grid.Column="1" Width="4"
                              HorizontalAlignment="Stretch" Background="#252535" Cursor="SizeWE"/>

                <!-- WebView2 미리보기 -->
                <wv2:WebView2 x:Name="Preview" Grid.Column="2"/>

                <!-- 그래프 뷰 (전체 오버레이) -->
                <local:GraphView x:Name="GraphPanel"
                                 Grid.Column="0" Grid.ColumnSpan="3"
                                 Visibility="Collapsed"
                                 NoteSelected="GraphPanel_NoteSelected"/>
            </Grid>

            <!-- 하단 상태바 -->
            <Border Grid.Row="3" Background="#181828" BorderBrush="#252535" BorderThickness="0,1,0,0" Padding="12,4">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtWordCount" FontSize="11" Foreground="#585B70"/>
                        <TextBlock Text=" · " FontSize="11" Foreground="#585B70"/>
                        <TextBlock x:Name="TxtTagCount" FontSize="11" Foreground="#7C6AF4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtBacklinks" FontSize="11" Foreground="#585B70"/>
                        <TextBlock Text=" · " FontSize="11" Foreground="#585B70"/>
                        <TextBlock x:Name="TxtNoteCount" FontSize="11" Foreground="#585B70"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- WikiLink 자동완성 팝업 -->
        <Popup x:Name="WikiPopup" PlacementTarget="{Binding ElementName=TxtEditor}"
               Placement="RelativePoint" AllowsTransparency="True" StaysOpen="False">
            <Border Background="#1A1A2E" BorderBrush="#555578" BorderThickness="1"
                    CornerRadius="6" MaxHeight="200">
                <ListBox x:Name="WikiList" Background="Transparent" BorderThickness="0"
                         MinWidth="180" MaxWidth="320"
                         SelectionChanged="WikiList_SelectionChanged"
                         KeyDown="WikiList_KeyDown"
                         MouseDoubleClick="WikiList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="12"
                                       Foreground="#CDD6F4" Padding="8,5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
    </Grid>
</Window>
