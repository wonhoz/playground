<Window x:Class="CaseForge.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Case.Forge 설정"
        Width="430" Height="540"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#000000"/>
    </Window.Effect>

    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 (드래그 가능) -->
            <Grid Grid.Row="0" Margin="16,12,12,0"
                  MouseLeftButtonDown="Header_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⚙  Case.Forge 설정"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Width="28" Height="28" Content="✕" FontSize="11"
                        Foreground="{StaticResource TextSecondary}" Background="Transparent"
                        BorderThickness="0" Style="{StaticResource DarkBtn}"
                        Click="CloseBtn_Click"/>
            </Grid>

            <!-- 콘텐츠 -->
            <ScrollViewer Grid.Row="1" Margin="14,12,14,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- 전역 단축키 섹션 -->
                    <TextBlock Text="전역 단축키" FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="HotkeyBorder"
                                Background="#252540" BorderBrush="#2A2A3E"
                                BorderThickness="1" CornerRadius="6" Padding="10,8">
                            <TextBlock x:Name="HotkeyDisplay"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Consolas, Segoe UI" FontSize="13"/>
                        </Border>
                        <Button Grid.Column="1" x:Name="CaptureBtn"
                                Content="변경" Margin="6,0,0,0" Width="56" Height="36"
                                Foreground="{StaticResource TextPrimary}"
                                Background="#252540" BorderBrush="#2A2A3E" BorderThickness="1"
                                FontSize="12" Style="{StaticResource DarkBtn}"
                                Click="CaptureBtn_Click"/>
                    </Grid>

                    <!-- 즐겨찾기 케이스 섹션 -->
                    <TextBlock Text="즐겨찾기 케이스 (팝업 상단 고정 / ↑↓ 순서 변경)"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>
                    <StackPanel x:Name="PinnedPanel" Margin="0,0,0,18"/>

                    <!-- 클립보드 자동 로드 섹션 -->
                    <CheckBox x:Name="AutoLoadClipboardCb"
                              Content="팝업 열 때 클립보드 텍스트 자동 입력"
                              FontFamily="Segoe UI" FontSize="12"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0,0,0,18"/>

                    <!-- 최근 이력 섹션 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="최근 입력 이력" FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="ClearBtn"
                                Content="전체 삭제" FontSize="11" Height="24" Padding="8,0"
                                Foreground="{StaticResource TextSecondary}"
                                Background="Transparent" BorderThickness="0"
                                Style="{StaticResource DarkBtn}"
                                Click="ClearHistory_Click"/>
                    </Grid>
                    <StackPanel x:Name="HistoryPanel" Margin="0,0,0,6"/>

                </StackPanel>
            </ScrollViewer>

            <!-- 푸터 -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="취소" Width="72" Height="32"
                            Margin="0,0,8,0" FontSize="12"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent" BorderBrush="#2A2A3E" BorderThickness="1"
                            Style="{StaticResource DarkBtn}"
                            Click="CancelBtn_Click"/>
                    <Button Grid.Column="2" Content="저장" Width="72" Height="32"
                            FontSize="12" Foreground="White"
                            Background="#6366F1" BorderThickness="0"
                            Style="{StaticResource DarkBtn}"
                            Click="SaveBtn_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
