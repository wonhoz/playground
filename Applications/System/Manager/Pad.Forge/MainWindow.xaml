<Window x:Class="PadForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PadForge.ViewModels"
        xmlns:views="clr-namespace:PadForge.Views"
        Title="Pad.Forge — 게임패드 매핑"
        Width="900" Height="640"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrBgBase}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!-- ── 헤더 ── -->
        <Border Grid.Row="0" Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎮" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Pad.Forge" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource BrAccent}" VerticalAlignment="Center" />
                    <TextBlock Text=" — 게임패드 매핑 관리자" FontSize="13"
                               Foreground="{StaticResource BrTextSecondary}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- ViGEm 상태 표시 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Fill>
                            <Binding Path="ViGEmAvailable">
                                <Binding.Converter>
                                    <views:BoolToBrushConverter TrueBrush="#4CAF50" FalseBrush="#888888" />
                                </Binding.Converter>
                            </Binding>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding ViGEmStatus}"
                               Foreground="{StaticResource BrTextSecondary}" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 메인 콘텐츠 ── -->
        <TabControl Grid.Row="1">

            <!-- 탭 1: 컨트롤러 -->
            <TabItem Header="컨트롤러">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="연결된 컨트롤러"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Controllers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorder}"
                                        BorderThickness="1" CornerRadius="8"
                                        Width="200" Margin="0,0,12,12" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="{Binding Battery}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="11" Margin="0,2,0,8" />

                                        <!-- D-pad -->
                                        <Grid Width="60" Height="60" Margin="0,0,0,8">
                                            <views:DpadVisual DataContext="{Binding}" />
                                        </Grid>

                                        <!-- 버튼 -->
                                        <views:ButtonVisual DataContext="{Binding}" />

                                        <!-- 트리거 바 -->
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                <TextBlock Text="LT" FontSize="10"
                                                           Foreground="{StaticResource BrTextSecondary}" />
                                                <ProgressBar Value="{Binding LeftTrigger}"
                                                             Maximum="1" Height="4"
                                                             Foreground="{StaticResource BrAccent}"
                                                             Background="{StaticResource BrBgDeep}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                <TextBlock Text="RT" FontSize="10"
                                                           Foreground="{StaticResource BrTextSecondary}" />
                                                <ProgressBar Value="{Binding RightTrigger}"
                                                             Maximum="1" Height="4"
                                                             Foreground="{StaticResource BrAccent}"
                                                             Background="{StaticResource BrBgDeep}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 컨트롤러 없을 때 -->
                    <TextBlock Grid.Row="1"
                               Text="연결된 컨트롤러가 없습니다."
                               Foreground="{StaticResource BrTextSecondary}"
                               FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Controllers.Count, Converter={views:ZeroToVisConverter}}" />
                </Grid>
            </TabItem>

            <!-- 탭 2: 매핑 -->
            <TabItem Header="매핑 에디터">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <!-- 프로파일 목록 -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="프로파일" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile}"
                                 DisplayMemberPath="Name" />

                        <StackPanel Grid.Row="2" Margin="0,8,0,0">
                            <Button Content="+ 새 프로파일" Command="{Binding NewProfileCommand}"
                                    Margin="0,0,0,4" Style="{StaticResource AccentButton}" />
                            <Button Content="저장" Command="{Binding SaveProfileCommand}"
                                    Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="내보내기" Command="{Binding ExportProfileCommand}" FontSize="11" />
                                <Button Grid.Column="2" Content="가져오기" Command="{Binding ImportProfileCommand}" FontSize="11" />
                            </Grid>
                            <Button Content="삭제" Command="{Binding DeleteProfileCommand}"
                                    Foreground="{StaticResource BrDanger}" Margin="0,4,0,0" FontSize="11" />
                        </StackPanel>
                    </Grid>

                    <!-- 구분선 -->
                    <Rectangle Grid.Column="1" Fill="{StaticResource BrBorder}" Width="1" />

                    <!-- 매핑 에디터 -->
                    <ContentControl Grid.Column="2" Content="{Binding MappingVm}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:MappingEditorViewModel}">
                                <views:MappingEditorView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Grid>
            </TabItem>

            <!-- 탭 3: 테스트 -->
            <TabItem Header="테스트 / 진동">
                <views:TestView DataContext="{Binding TestVm}" Margin="16" />
            </TabItem>

            <!-- 탭 4: 설정 (앱 자동 전환) -->
            <TabItem Header="앱 자동 전환">
                <views:AppProfileView DataContext="{Binding MappingVm}" Margin="16" />
            </TabItem>

        </TabControl>

        <!-- ── 상태바 ── -->
        <Border Grid.Row="2" Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource BrTextSecondary}">
                    <Run Text="연결된 컨트롤러: " />
                    <Run Text="{Binding Controllers.Count}" />
                </TextBlock>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource BrTextSecondary}"
                           Text="Pad.Forge v1.0.0" />
            </Grid>
        </Border>
    </Grid>
</Window>
