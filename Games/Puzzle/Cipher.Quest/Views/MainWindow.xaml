<Window x:Class="CipherQuest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cipher.Quest" Height="700" Width="800"
        Background="#1A1A1A" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 헤더 -->
            <RowDefinition Height="Auto"/>  <!-- 챕터 탭 -->
            <RowDefinition Height="Auto"/>  <!-- 암호문 -->
            <RowDefinition Height="Auto"/>  <!-- 복호화 미리보기 -->
            <RowDefinition Height="Auto"/>  <!-- 도구 패널 -->
            <RowDefinition Height="Auto"/>  <!-- 빈도 분석 (치환 챕터) -->
            <RowDefinition Height="*"/>     <!-- 여백 -->
            <RowDefinition Height="Auto"/>  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔐 Cipher.Quest" FontSize="20" FontWeight="Bold" Foreground="#FFC107"/>
                <TextBlock x:Name="TxtPuzzleInfo" FontSize="12" Foreground="#888"
                           VerticalAlignment="Bottom" Margin="12,0,0,2"/>
            </StackPanel>
            <TextBlock x:Name="TxtTimer" FontSize="18" FontFamily="Consolas"
                       Foreground="#4CAF50" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- 챕터 탭 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12"
                    x:Name="ChapterTabs"/>

        <!-- 암호문 -->
        <Border Grid.Row="2" Background="#0E1A0E" BorderBrush="#2A4A2A"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="암호문" FontSize="10" Foreground="#4CAF50" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtCipher" FontFamily="Consolas" FontSize="15"
                           Foreground="#E8E8E8" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 복호화 미리보기 -->
        <Border Grid.Row="3" Background="#0E0E1A" BorderBrush="#2A2A4A"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="복호화 미리보기" FontSize="10" Foreground="#7986CB" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtDecrypted" FontFamily="Consolas" FontSize="15"
                           Foreground="#9FA8DA" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 도구 패널 (code-behind에서 동적 생성) -->
        <Border Grid.Row="4" Background="#111" BorderBrush="#333"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel x:Name="ToolPanel"/>
        </Border>

        <!-- 빈도 분석 (치환 챕터만) -->
        <Border Grid.Row="5" x:Name="FreqBorder" Visibility="Collapsed"
                Background="#0E1422" BorderBrush="#2A3A4A"
                BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock FontSize="10" Foreground="#888" Margin="0,0,0,4">
                    <Run Text="빈도 분석  "/>
                    <Run Text="■" Foreground="#2196F3"/><Run Text=" 암호문  " Foreground="#888"/>
                    <Run Text="—" Foreground="#FFC107"/><Run Text=" 영어 평균" Foreground="#888"/>
                </TextBlock>
                <ContentPresenter x:Name="FreqPresenter"/>
            </StackPanel>
        </Border>

        <!-- 버튼 영역 -->
        <Grid Grid.Row="7">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnPrev" Content="◀ 이전" Padding="10,6" Click="OnPrev"/>
                <TextBlock x:Name="TxtPuzzleNum" FontSize="13" Foreground="#888"
                           VerticalAlignment="Center" Margin="10,0"/>
                <Button x:Name="BtnNextPuzzle" Content="다음 ▶" Padding="10,6" Click="OnNextPuzzle" Margin="0,0,8,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnHint" Content="💡 힌트" Padding="10,6" Click="OnHint" Margin="0,0,8,0"/>
                <Button x:Name="BtnConfirm" Content="✔ 정답 확인" Padding="14,6"
                        Background="#1B5E20" BorderBrush="#2E7D32"
                        Foreground="White" FontWeight="SemiBold" Click="OnConfirm"/>
            </StackPanel>
        </Grid>

        <!-- 상태 메시지 (하단 오버레이) -->
        <TextBlock Grid.Row="7" x:Name="TxtStatus" FontSize="11" Foreground="#888"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
    </Grid>
</Window>
