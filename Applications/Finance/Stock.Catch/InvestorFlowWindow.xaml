<Window x:Class="Stock.Catch.InvestorFlowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="실시간 수급·호가" Height="720" Width="860"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="Sect" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FlowLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="FlowVal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>
        <!-- 호가 한 줄 -->
        <DataTemplate x:Key="DepthRowTpl">
            <Grid Height="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="86"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource FlowLbl}" VerticalAlignment="Center"/>
                <Grid Grid.Column="1">
                    <Rectangle HorizontalAlignment="{Binding BarAlign}" Width="{Binding BarWidth}"
                               Fill="{Binding BarBrush}" Opacity="0.30" RadiusX="3" RadiusY="3" Margin="2,4"/>
                    <TextBlock Text="{Binding PriceText}" Foreground="{Binding PriceBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                               FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <TextBlock Grid.Column="2" Text="{Binding QtyText}" Foreground="{Binding PriceBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 즐겨찾기 -->
        <DockPanel Grid.Column="0" Margin="0,0,14,0">
            <TextBlock DockPanel.Dock="Top" Text="즐겨찾기 (국내)" Style="{StaticResource Sect}"/>
            <TextBlock DockPanel.Dock="Bottom" x:Name="PollText" Style="{StaticResource FlowLbl}" Margin="0,8,0,0"/>
            <ListBox x:Name="FavList" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}"
                     Foreground="{StaticResource FgBrush}" SelectionChanged="FavList_SelectionChanged"/>
        </DockPanel>

        <!-- 상세 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="NameText" Text="종목을 선택하세요" FontSize="17" FontWeight="Bold"
                           Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="PriceText" FontSize="17" FontWeight="Bold" Margin="14,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="RateText" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
            </StackPanel>

            <!-- 수급 -->
            <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="실시간 수급" Style="{StaticResource Sect}"/>
                    <UniformGrid Rows="1" Columns="6">
                        <StackPanel><TextBlock Text="외국인 순매수" Style="{StaticResource FlowLbl}"/><TextBlock x:Name="FrgnText" Style="{StaticResource FlowVal}"/></StackPanel>
                        <StackPanel><TextBlock Text="기관 순매수" Style="{StaticResource FlowLbl}"/><TextBlock x:Name="OrgnText" Style="{StaticResource FlowVal}"/></StackPanel>
                        <StackPanel><TextBlock Text="개인 순매수" Style="{StaticResource FlowLbl}"/><TextBlock x:Name="PrsnText" Style="{StaticResource FlowVal}"/></StackPanel>
                        <StackPanel><TextBlock Text="프로그램 순매수" Style="{StaticResource FlowLbl}"/><TextBlock x:Name="PgtrText" Style="{StaticResource FlowVal}"/></StackPanel>
                        <StackPanel><TextBlock Text="외국인 소진율" Style="{StaticResource FlowLbl}"/><TextBlock x:Name="EhrtText" Style="{StaticResource FlowVal}" Foreground="{StaticResource FgBrush}"/></StackPanel>
                        <StackPanel><TextBlock Text="체결강도" Style="{StaticResource FlowLbl}"/><TextBlock x:Name="ExecText" Style="{StaticResource FlowVal}"/></StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- 호가 -->
            <Border Grid.Row="2" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,10">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="호가 (10단)" Style="{StaticResource Sect}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="BidStrengthText" Style="{StaticResource FlowLbl}" HorizontalAlignment="Right"/>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl x:Name="AskList" ItemTemplate="{StaticResource DepthRowTpl}"/>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>
                            <ItemsControl x:Name="BidList" ItemTemplate="{StaticResource DepthRowTpl}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
