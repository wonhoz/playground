<Window x:Class="Dict.Cast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Dict.Cast.ViewModels"
        Title="Dict.Cast" Width="540" Height="500"
        MinWidth="420" MinHeight="380"
        Background="#13131F" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- 역 BooleanToVisibility -->
        <Style x:Key="InvVis" TargetType="FrameworkElement">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBuilding}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsBuilding}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 공통 TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#1E1E2E"/>
            <Setter Property="Foreground"   Value="#E0E0E0"/>
            <Setter Property="BorderBrush"  Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="CaretBrush"   Value="#60A5FA"/>
            <Setter Property="SelectionBrush" Value="#60A5FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="10,6" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 아이콘 버튼 -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#9CA3AF"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Width"            Value="34"/>
            <Setter Property="Height"           Value="34"/>
            <Setter Property="FontSize"         Value="16"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252535"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 즐겨찾기 버튼 (토글 색상 변경) -->
        <Style x:Key="FavBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInWordlist}" Value="True">
                    <Setter Property="Foreground" Value="#FBBF24"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 히스토리 필 버튼 -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#2A2A3E"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Margin"          Value="3,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"   Value="#252535"/>
                                <Setter Property="BorderBrush"  Value="#60A5FA"/>
                                <Setter Property="Foreground"   Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 제안 ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background"       Value="#1A1A2E"/>
            <Setter Property="BorderBrush"      Value="#2A2A3E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground"  Value="#C0C0D0"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252535"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 메뉴 -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="BorderBrush"     Value="#2A2A3E"/>
            <Setter Property="Foreground"      Value="#E0E0E0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground"  Value="#E0E0E0"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252535"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>     <!-- 검색바 -->
            <RowDefinition Height="Auto"/>   <!-- 단어 헤더 -->
            <RowDefinition Height="*"/>      <!-- 결과 / 제안 / 빌드 / 힌트 -->
            <RowDefinition Height="Auto"/>   <!-- 구분선 -->
            <RowDefinition Height="38"/>     <!-- 히스토리 -->
        </Grid.RowDefinitions>

        <!-- ── 검색바 ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch"
                         Grid.Column="0"
                         VerticalAlignment="Center"
                         FontSize="15"
                         TextChanged="TxtSearch_TextChanged"
                         KeyDown="TxtSearch_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="단어를 입력하세요... (Win+Shift+D)"
                                                               Foreground="#3A3A5A"
                                                               FontFamily="Segoe UI" FontSize="14"
                                                               Margin="10,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="1" Style="{StaticResource IconBtn}"
                        ToolTip="발음 듣기" Margin="4,0,0,0"
                        Click="Speak_Click">
                    <TextBlock Text="🔊" FontFamily="Segoe UI Emoji"/>
                </Button>

                <Button x:Name="BtnFav" Grid.Column="2" Style="{StaticResource FavBtn}"
                        Content="{Binding FavLabel}"
                        ToolTip="단어장에 추가/제거"
                        Click="Fav_Click"/>

                <Button Grid.Column="3" Style="{StaticResource IconBtn}"
                        ToolTip="단어장 내보내기" Content="⋮" FontSize="20"
                        Click="WordlistMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="CtxWordlist">
                            <MenuItem Header="📄  CSV 내보내기"  Click="ExportCsv_Click"/>
                            <MenuItem Header="📚  Anki 내보내기" Click="ExportAnki_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>

        <!-- ── 단어 헤더 (결과 있을 때만) ────────────────────────── -->
        <Border Grid.Row="1"
                Visibility="{Binding HasResult, Converter={StaticResource BoolVis}}"
                Background="#16162A" Padding="14,8,14,8"
                BorderBrush="#1E1E2E" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding WordHeading}"
                           FontSize="22" FontWeight="Bold" Foreground="#E0E0E0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus"
                           Text="{Binding StatusText}"
                           Foreground="#888899" FontSize="12"
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── 메인 콘텐츠 영역 ──────────────────────────────────── -->
        <Grid Grid.Row="2">

            <!-- 1) 사전 빌드 진행 오버레이 -->
            <Border Visibility="{Binding IsBuilding, Converter={StaticResource BoolVis}}"
                    Background="#13131F" Padding="32">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380">
                    <TextBlock Text="📖  사전 초기화 (최초 1회)"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#60A5FA" TextAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="WordNet 3.1 데이터를 다운로드하고 사전 DB를 빌드합니다."
                               Foreground="#9CA3AF" TextAlignment="Center" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="이후에는 완전 오프라인으로 동작합니다."
                               Foreground="#555566" TextAlignment="Center" FontSize="12"
                               Margin="0,0,0,24"/>

                    <Border Background="#1E1E2E" CornerRadius="6" Height="8" Margin="0,0,0,10">
                        <Border.Clip>
                            <RectangleGeometry Rect="0,0,10000,8" RadiusX="6" RadiusY="6"/>
                        </Border.Clip>
                        <Grid>
                            <Border x:Name="ProgressFill" HorizontalAlignment="Left"
                                    Background="#60A5FA" CornerRadius="6"
                                    Height="8"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding BuildMessage}"
                               Foreground="#888899" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 2) 제안 드롭다운 -->
            <Border x:Name="SuggestionPanel"
                    Visibility="Collapsed"
                    Background="#13131F"
                    Panel.ZIndex="10">
                <ListBox x:Name="LstSuggestions"
                         ItemsSource="{Binding Suggestions}"
                         MaxHeight="220"
                         MouseDoubleClick="Suggestion_DoubleClick"
                         KeyDown="Suggestion_KeyDown"
                         SelectionChanged="Suggestion_SelectionChanged">
                </ListBox>
            </Border>

            <!-- 3) 결과 스크롤 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,4">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBuilding}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <StackPanel>
                    <!-- 힌트 (입력 없을 때) -->
                    <Border Visibility="{Binding ShowHint, Converter={StaticResource BoolVis}}"
                            Padding="32,40" HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📖" FontFamily="Segoe UI Emoji" FontSize="48"
                                       TextAlignment="Center" Opacity="0.3" Margin="0,0,0,16"/>
                            <TextBlock Text="영어 단어를 입력하고 Enter를 누르세요"
                                       Foreground="#3A3A5A" FontSize="14" TextAlignment="Center"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="WordNet 3.1 · 155,000+ 단어"
                                       Foreground="#2A2A3E" FontSize="11" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 상태 텍스트 (결과 없음 등) -->
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#555566" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,32,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasResult}"    Value="False"/>
                                            <Condition Binding="{Binding IsBuilding}"   Value="False"/>
                                            <Condition Binding="{Binding ShowHint}"     Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- 결과 Senses -->
                    <ItemsControl ItemsSource="{Binding Senses}" Margin="12,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SenseViewModel}">
                                <Border Margin="0,3" Padding="14,10"
                                        Background="#1A1A2A" CornerRadius="6">
                                    <StackPanel>
                                        <!-- POS 뱃지 + 뜻 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Border Padding="5,2" CornerRadius="4" Margin="0,0,8,0"
                                                    Background="#13131F">
                                                <TextBlock Text="{Binding PosDisplay}"
                                                           FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{Binding PosColor}"/>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding NumberedDefinition}"
                                                       Foreground="#E0E0E0" TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- 예문 -->
                                        <TextBlock Text="{Binding ExamplesText}"
                                                   Foreground="#6B7280" FontStyle="Italic"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasExamples}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 유의어 -->
                                        <TextBlock Text="{Binding SynonymsText}"
                                                   Foreground="#4B83C4" FontSize="12"
                                                   TextWrapping="Wrap" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSynonyms}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 반의어 -->
                                        <TextBlock Text="{Binding AntonymsText}"
                                                   Foreground="#B45555" FontSize="12"
                                                   TextWrapping="Wrap" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAntonyms}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── 구분선 ─────────────────────────────────────────────── -->
        <Border Grid.Row="3" Height="1" Background="#1E1E2E"/>

        <!-- ── 히스토리 바 ───────────────────────────────────────── -->
        <Border Grid.Row="4" Padding="10,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="최근" Foreground="#333344" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ItemsControl ItemsSource="{Binding History}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource PillBtn}"
                                        Content="{Binding}"
                                        Click="History_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
