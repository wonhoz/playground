<Window x:Class="Prompt.Forge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Prompt.Forge"
        Title="Prompt.Forge" Width="1000" Height="680"
        MinWidth="800" MinHeight="500"
        Background="#13131F" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen"
>

    <Window.Resources>

        <!-- 액센트 버튼 -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 위험 버튼 -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3A1A1A"/>
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A2020"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 즐겨찾기 버튼 -->
        <Style x:Key="FavBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 목록 아이템 -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C0C0D0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1" BorderBrush="#1E1E2E"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#251A3E"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 상단 툴바 ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0F0F1A" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Prompt.Forge"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#7C3AED" VerticalAlignment="Center"/>
                <Grid Grid.Column="1" Margin="16,0">
                    <TextBox x:Name="TxtSearch"
                             Height="30" Padding="8,5,28,5"
                             Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="프롬프트 검색..."
                                                                   Foreground="#555566"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button x:Name="BtnClearSearch" Width="22" Height="22"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,3,0" Visibility="Collapsed"
                            Click="ClearSearch_Click" ToolTip="검색 및 필터 초기화">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="✕" FontSize="10" Foreground="#888899"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                        <Setter Property="Foreground" Value="#C0C0D0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="↑ 내보내기" Click="Export_Click" Margin="0,0,6,0"/>
                    <Button Content="↓ 가져오기" Click="Import_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnHelp" Content="?" ToolTip="단축키 도움말" Click="Help_Click" Margin="0,0,8,0" Padding="8,6"/>
                    <Button Content="+ 새 프롬프트" Style="{StaticResource AccentBtn}"
                            Click="NewPrompt_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 본문 ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="480"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 필터 + 목록 -->
            <Grid Grid.Column="0" Background="#0F0F1A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 필터 -->
                <StackPanel Grid.Row="0" Margin="10,10,10,6">
                    <ComboBox x:Name="CbTag" Margin="0,0,0,6"
                              SelectionChanged="Filter_Changed"/>
                    <ComboBox x:Name="CbService" Margin="0,0,0,6"
                              SelectionChanged="Filter_Changed"/>
                    <CheckBox x:Name="ChkFav" Content="즐겨찾기만"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"
                              Margin="0,0,0,6"/>
                    <ComboBox x:Name="CbSort" SelectedIndex="0"
                              SelectionChanged="Sort_Changed">
                        <ComboBoxItem Content="최근 수정순"/>
                        <ComboBoxItem Content="자주 사용순"/>
                    </ComboBox>
                </StackPanel>

                <!-- 목록 -->
                <ListBox Grid.Row="1" x:Name="LstItems"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         SelectionChanged="LstItems_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Tags}" FontSize="11"
                                               Foreground="#A78BFA"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"
                                               Cursor="Hand"
                                               ToolTip="Ctrl+클릭하여 태그 필터 적용"
                                               MouseLeftButtonDown="TagLabel_Click"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="★" FontSize="14"
                                           Foreground="#F59E0B" VerticalAlignment="Center"
                                           Margin="6,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 스플리터 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#1A1A2A"/>

            <!-- 오른쪽: 상세 편집 -->
            <Grid Grid.Column="2" Background="#13131F">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 제목 행 -->
                <Grid Grid.Row="0" Margin="16,14,16,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtTitle" FontSize="15" FontWeight="SemiBold"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="BtnFav" Content="☆"
                            Style="{StaticResource FavBtn}" Margin="8,0,0,0"
                            Click="Fav_Click" IsEnabled="{Binding HasSelection}"/>
                </Grid>

                <!-- 메타 행 (태그 · 서비스) -->
                <Grid Grid.Row="1" Margin="16,0,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtTags" Height="30">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="태그 (쉼표 구분)"
                                                                   Foreground="#555566"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBox Grid.Column="2" x:Name="TxtService" Height="30">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="대상 서비스"
                                                                   Foreground="#555566"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>

                <!-- 콘텐츠 에디터 -->
                <TextBox Grid.Row="2" x:Name="TxtContent"
                         Margin="16,0,16,8"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="13">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                <VisualBrush.Visual>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="12"
                                                               Foreground="#555566" Margin="10,10">
                                                        <Run Text="프롬프트 내용을 입력하세요."/>
                                                        <LineBreak/>
                                                        <Run Text="{}{{변수명}} 형식으로 변수를 삽입하면"/>
                                                        <LineBreak/>
                                                        <Run Text="▶ 변수 채우기 버튼으로 값을 대입한 뒤 클립보드에 복사됩니다."/>
                                                    </TextBlock>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 메모 -->
                <TextBox Grid.Row="3" x:Name="TxtNotes"
                         Margin="16,0,16,8"
                         MaxHeight="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="12">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="메모 (선택)"
                                                               Foreground="#555566"
                                                               Margin="10,8"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 액션 버튼 바 -->
                <Border Grid.Row="4" Background="#0F0F1A" Padding="16,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾  저장 (Ctrl+S)" Click="Save_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="⧉  복제 (Ctrl+D)" Click="Duplicate_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="🕐  버전 저장" Click="SaveVersion_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="📜  히스토리 (Ctrl+H)" Click="ShowHistory_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="▶  변수 채우기 (Ctrl+Enter)" Style="{StaticResource AccentBtn}"
                                    IsEnabled="{Binding HasSelection}" Click="FillVars_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="복사" Click="Copy_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="삭제" Style="{StaticResource DangerBtn}"
                                    IsEnabled="{Binding HasSelection}" Click="Delete_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ── 상태 바 ────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#0A0A14" Padding="12,4">
            <TextBlock Text="{Binding StatusText}" Foreground="#888899" FontSize="11"/>
        </Border>

        <!-- ── 태그 자동완성 팝업 ──────────────────────────────────── -->
        <Popup x:Name="TagPopup" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=TxtTags}"
               Placement="Bottom" VerticalOffset="2">
            <Border Background="#1E1E2E" BorderBrush="#3A3A55" BorderThickness="1" CornerRadius="4"
                    MinWidth="{Binding ElementName=TxtTags, Path=ActualWidth}">
                <ListBox x:Name="LstTagSuggestions" MaxHeight="160"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="TagSuggestion_Selected">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#C0C0D0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252540"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>

        <!-- ── 단축키 도움말 팝업 ──────────────────────────────────── -->
        <Popup x:Name="HelpPopup" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=BtnHelp}"
               Placement="Bottom" VerticalOffset="4">
            <Border Background="#1A1A2A" BorderBrush="#3A3A55" BorderThickness="1" CornerRadius="8"
                    Padding="20,16">
                <StackPanel>
                    <TextBlock Text="단축키" FontWeight="SemiBold" FontSize="12"
                               Foreground="#7C3AED" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+N" Foreground="#A78BFA" FontFamily="Consolas" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="새 프롬프트" Foreground="#C0C0D0" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+S" Foreground="#A78BFA" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="저장" Foreground="#C0C0D0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+D" Foreground="#A78BFA" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="복제" Foreground="#C0C0D0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+Enter" Foreground="#A78BFA" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="변수 채우기" Foreground="#C0C0D0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+H" Foreground="#A78BFA" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="버전 히스토리" Foreground="#C0C0D0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Win+Shift+P" Foreground="#A78BFA" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="창 표시/숨기기" Foreground="#C0C0D0" FontSize="12" Margin="0,5,0,0"/>
                    </Grid>
                    <Separator Background="#2A2A3E" Margin="0,14,0,12"/>
                    <TextBlock Text="사용 팁" FontWeight="SemiBold" FontSize="12"
                               Foreground="#7C3AED" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#888899" FontSize="11"
                               MaxWidth="300" LineHeight="20">
                        <Run Text="• {{변수명}} 형식으로 변수 삽입 → 변수 채우기로 복사"/>
                        <LineBreak/>
                        <Run Text="• 태그 입력 시 자동완성 드롭다운 표시"/>
                        <LineBreak/>
                        <Run Text="• 태그 Ctrl+클릭 → 해당 태그로 필터링"/>
                        <LineBreak/>
                        <Run Text="• ★ 클릭 → 즐겨찾기 토글"/>
                        <LineBreak/>
                        <Run Text="• '버전 저장' → 히스토리에 현재 버전 보관"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
