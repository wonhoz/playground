<Window x:Class="SvcGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="Svc.Guard — Windows 서비스 관리자"
        Width="1200" Height="720" MinWidth="900" MinHeight="560"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🛡️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Svc.Guard" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Windows 서비스 관리자" FontSize="13"
                               Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🎮 게이밍 모드" Click="BtnGaming_Click" Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="💻 개발 모드" Click="BtnDev_Click" Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="🔄 새로고침" Click="BtnRefresh_Click" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 필터 바 -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="검색:" VerticalAlignment="Center" Foreground="{StaticResource DimBrush}" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtSearch" Width="250" Height="32"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" Margin="0,0,12,0"/>

                <TextBlock Text="분류:" VerticalAlignment="Center" Foreground="{StaticResource DimBrush}" Margin="0,0,6,0"/>
                <ComboBox Width="140" Margin="0,0,12,0"
                          ItemsSource="{Binding CategoryFilters}"
                          SelectedItem="{Binding FilterCategory}"/>

                <TextBlock Text="상태:" VerticalAlignment="Center" Foreground="{StaticResource DimBrush}" Margin="0,0,6,0"/>
                <ComboBox Width="100"
                          ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding FilterStatus}"/>
            </StackPanel>
        </Border>

        <!-- 메인 컨텐츠 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 서비스 목록 -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding FilteredServices}"
                      SelectedItem="{Binding SelectedService, Mode=TwoWay}"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="상태" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="10" Height="10"
                                         Fill="{Binding StatusColor}"
                                         HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="서비스 이름" Binding="{Binding DisplayName}" Width="240"/>
                    <DataGridTextColumn Header="내부 이름" Binding="{Binding Name}" Width="160"/>
                    <DataGridTemplateColumn Header="분류" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding CategoryColor}" CornerRadius="3"
                                        Padding="6,2" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding CategoryLabel}" FontSize="10"
                                               Foreground="#12131C" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="시작 유형" Binding="{Binding StartType}" Width="90"/>
                    <DataGridTextColumn Header="실행 계정" Binding="{Binding Account}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- 상세 패널 -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" DataContext="{Binding SelectedService}">

                        <!-- 서비스 없을 때 -->
                        <TextBlock Text="서비스를 선택하세요"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center" Margin="0,40,0,0"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.SelectedService,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 서비스 정보 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.SelectedService,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Name}" FontSize="11"
                                       Foreground="{StaticResource DimBrush}" Margin="0,2,0,8"/>

                            <Border Background="{Binding CategoryColor}" CornerRadius="3"
                                    Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="{Binding CategoryLabel}" FontSize="11"
                                           Foreground="#12131C" FontWeight="SemiBold"/>
                            </Border>

                            <TextBlock Text="{Binding Description}" FontSize="11"
                                       Foreground="{StaticResource DimBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <!-- 상태 정보 -->
                            <Border Background="#0E1525" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="상태" Foreground="{StaticResource DimBrush}" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Status}"
                                                   Foreground="{Binding StatusColor}" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="시작 유형" Foreground="{StaticResource DimBrush}" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StartType}" FontSize="11"/>
                                    </Grid>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="실행 계정" Foreground="{StaticResource DimBrush}" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Account}"
                                                   FontSize="10" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 제어 버튼 -->
                            <TextBlock Text="서비스 제어" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource DimBrush}" Margin="0,0,0,8"/>
                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <Button Content="▶ 시작" Click="BtnStart_Click" Margin="0,0,4,4"/>
                                <Button Content="■ 중지" Click="BtnStop_Click" Margin="4,0,0,4"/>
                                <Button Content="↺ 재시작" Click="BtnRestart_Click" Margin="0,0,4,0"/>
                            </UniformGrid>

                            <!-- 시작 유형 변경 -->
                            <TextBlock Text="시작 유형 변경" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource DimBrush}" Margin="0,12,0,8"/>
                            <UniformGrid Columns="2">
                                <Button Content="자동" Click="BtnAuto_Click" Margin="0,0,4,4" FontSize="11"/>
                                <Button Content="수동" Click="BtnManual_Click" Margin="4,0,0,4" FontSize="11"/>
                                <Button Content="비활성화" Click="BtnDisable_Click" Margin="0,0,4,0" FontSize="11"/>
                                <Button Content="자동(지연)" Click="BtnDelayed_Click" Margin="4,0,0,0" FontSize="11"/>
                            </UniformGrid>

                            <!-- 의존성 -->
                            <TextBlock Text="이 서비스에 의존" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource DimBrush}" Margin="0,16,0,6"/>
                            <ItemsControl ItemsSource="{Binding DataContext.DependsOnList,
                                RelativeSource={RelativeSource AncestorType=Window}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="(없음)" FontSize="11" Foreground="{StaticResource DimBrush}"
                                       Margin="0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.DependsOnList.Count,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="이 서비스에 의존하는 서비스" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource DimBrush}" Margin="0,12,0,6"/>
                            <ItemsControl ItemsSource="{Binding DataContext.DependentList,
                                RelativeSource={RelativeSource AncestorType=Window}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{StaticResource WarnBrush}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="(없음)" FontSize="11" Foreground="{StaticResource DimBrush}"
                                       Margin="0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.DependentList.Count,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource DimBrush}" FontSize="11" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Width="120" Height="4"
                             IsIndeterminate="{Binding IsBusy}"
                             Background="#2A3050" Foreground="{StaticResource AccentBrush}">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </Grid>
        </Border>
    </Grid>
</Window>
