<Window x:Class="HotkeyMap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkey.Map" Height="700" Width="1100"
        Background="#1A1A1A" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="24"/>
    </Grid.RowDefinitions>

    <!-- 툴바 -->
    <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#333" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
        <TextBlock Text="⌨️ Hotkey.Map" FontSize="16" FontWeight="Bold"
                   Foreground="#5B8AF0" VerticalAlignment="Center" Margin="0,0,20,0"/>
        <TextBlock Text="수식키:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#888"/>
        <ComboBox x:Name="ModifierCombo" Width="130" VerticalAlignment="Center"
                  SelectionChanged="ModifierCombo_SelectionChanged"/>
        <Button Content="🔍 스캔" Margin="10,0,0,0" Click="BtnScan_Click"
                Background="#5B8AF0" Foreground="White"/>
        <Button Content="🔑 테스트" Margin="6,0,0,0" Click="BtnTest_Click"/>
        <Button Content="🗑️ 초기화" Margin="6,0,0,0" Click="BtnClear_Click"/>
        <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0"
                   Foreground="#888" FontSize="12"/>
      </StackPanel>
    </Border>

    <!-- 메인 콘텐츠 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="280"/>
      </Grid.ColumnDefinitions>

      <!-- 키보드 다이어그램 -->
      <Border Grid.Column="0" Margin="12" Background="#111" CornerRadius="8"
              BorderBrush="#333" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- 범례 -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,10">
            <Ellipse Width="12" Height="12" Fill="#3D5A80" Margin="0,0,4,0" VerticalAlignment="Center"/>
            <TextBlock Text="점유됨" Foreground="#888" FontSize="11" Margin="0,0,16,0" VerticalAlignment="Center"/>
            <Ellipse Width="12" Height="12" Fill="#2E4A2E" Margin="0,0,4,0" VerticalAlignment="Center"/>
            <TextBlock Text="사용가능" Foreground="#888" FontSize="11" Margin="0,0,16,0" VerticalAlignment="Center"/>
            <Ellipse Width="12" Height="12" Fill="#4A2E2E" Margin="0,0,4,0" VerticalAlignment="Center"/>
            <TextBlock Text="시스템 예약" Foreground="#888" FontSize="11" Margin="0,0,16,0" VerticalAlignment="Center"/>
            <Ellipse Width="12" Height="12" Fill="#333" Margin="0,0,4,0" VerticalAlignment="Center"/>
            <TextBlock Text="미검사" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- 키보드 캔버스 -->
          <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Canvas x:Name="KeyboardCanvas" Width="900" Height="360" Margin="16"/>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- 오른쪽 패널 -->
      <Border Grid.Column="1" Margin="0,12,12,12" Background="#111" CornerRadius="8"
              BorderBrush="#333" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- 검색 -->
          <Border Grid.Row="0" Padding="10,8" BorderBrush="#333" BorderThickness="0,0,0,1">
            <TextBox x:Name="SearchBox" Background="#1E1E2E" Foreground="#E0E0E0"
                     BorderBrush="#444" BorderThickness="1" Padding="6,4" FontSize="12"
                     TextChanged="SearchBox_TextChanged">
              <TextBox.Style>
                <Style TargetType="TextBox">
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                          <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </TextBox.Style>
            </TextBox>
          </Border>

          <!-- 단축키 목록 -->
          <ListBox x:Name="HotkeyList" Grid.Row="1"
                   Background="Transparent" BorderThickness="0"
                   SelectionChanged="HotkeyList_SelectionChanged"
                   Foreground="#E0E0E0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8,6" Background="Transparent">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding DisplayKey}" FontWeight="Bold" FontSize="12"/>
                      <TextBlock Text="{Binding Owner}" FontSize="10" Foreground="#888"/>
                    </StackPanel>
                    <Ellipse Grid.Column="1" Width="10" Height="10"
                             Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="#222"/>
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E2E"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252540"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>

          <!-- 통계 -->
          <Border Grid.Row="2" Padding="10,8" Background="#151515" BorderBrush="#333" BorderThickness="0,1,0,0">
            <StackPanel>
              <TextBlock x:Name="StatTotal" FontSize="11" Foreground="#888"/>
              <TextBlock x:Name="StatOccupied" FontSize="11" Foreground="#5B8AF0"/>
              <TextBlock x:Name="StatFree" FontSize="11" Foreground="#66BB6A"/>
              <TextBlock x:Name="StatSystem" FontSize="11" Foreground="#EF5350"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- 선택된 단축키 정보 -->
    <Border Grid.Row="2" Background="#151515" Padding="12,8" BorderBrush="#333" BorderThickness="0,1,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <TextBlock Text="선택:" Foreground="#888" Margin="0,0,8,0"/>
          <TextBlock x:Name="SelectedInfo" Foreground="#E0E0E0" FontWeight="Bold"/>
        </StackPanel>
        <Button Grid.Column="1" Content="📋 AHK 내보내기" Click="BtnExport_Click"/>
      </Grid>
    </Border>

    <!-- 상태바 -->
    <Border Grid.Row="3" Background="#111" Padding="12,0">
      <TextBlock x:Name="StatusBar" Foreground="#555" FontSize="11" VerticalAlignment="Center"/>
    </Border>
  </Grid>
</Window>
