<UserControl x:Class="Stock.Watch.Views.Controls.RuleSetEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FF21212E" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
        <StackPanel>
            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                <TextBlock x:Name="TitleText" Text="매수 조건" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                <CheckBox x:Name="EnabledCheck" Content="활성화" DockPanel.Dock="Right" VerticalAlignment="Center"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="결합" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF888888"/>
                <ComboBox x:Name="CombineCombo" Width="150" HorizontalAlignment="Left"/>
            </DockPanel>
            <StackPanel x:Name="RowsHost"/>
            <Button x:Name="AddBtn" Content="+ 조건 추가" HorizontalAlignment="Left" Margin="0,6,0,0" Padding="10,4"/>
        </StackPanel>
    </Border>
</UserControl>
