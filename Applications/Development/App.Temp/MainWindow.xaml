<Window x:Class="AppTemp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App.Temp — 임시 실행 샌드박스"
        Width="820" Height="680"
        MinWidth="680" MinHeight="520"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid Height="38">
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="📦" FontSize="15" Margin="0,0,8,0"/>
                    <TextBlock Text="App.Temp" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text=" — 임시 실행 샌드박스"
                               Foreground="{StaticResource Fg3Brush}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="─" Width="40" Height="38" BorderThickness="0"
                            Background="Transparent" Click="MinBtn_Click"/>
                    <Button Content="✕" Width="40" Height="38" BorderThickness="0"
                            Background="Transparent" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ① EXE 선택 패널 -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="14,10" AllowDrop="True"
                DragOver="DropZone_DragOver" Drop="DropZone_Drop">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtExePath" Grid.Column="0"
                         Text="EXE 파일을 드래그하거나 찾아보기 버튼을 클릭하세요..."
                         Foreground="{StaticResource Fg3Brush}"
                         IsReadOnly="True" VerticalAlignment="Center"
                         Background="{StaticResource CardBrush}"/>
                <Button Grid.Column="1" Content="찾아보기" Margin="8,0,0,0"
                        Click="BrowseBtn_Click"/>
                <Button x:Name="BtnLaunch" Grid.Column="2" Content="▶ 실행 시작"
                        Margin="6,0,0,0" Background="{StaticResource AccentBrush}"
                        IsEnabled="False" Click="LaunchBtn_Click"/>
            </Grid>
        </Border>

        <!-- ② 상태바 -->
        <Border Grid.Row="2" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{StaticResource Fg3Brush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus" Text="대기 중"
                               Foreground="{StaticResource Fg2Brush}" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource Fg3Brush}" FontSize="11" Margin="0,0,6,0">파일:</TextBlock>
                    <TextBlock x:Name="TxtFileCount" Text="0"
                               Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource Fg3Brush}" FontSize="11" Margin="16,0,6,0">레지스트리:</TextBlock>
                    <TextBlock x:Name="TxtRegCount" Text="0"
                               Foreground="{StaticResource OrangeBrush}" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource Fg3Brush}" FontSize="11" Margin="16,0,6,0">경과:</TextBlock>
                    <TextBlock x:Name="TxtElapsed" Text="─"
                               Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                </StackPanel>

                <Button x:Name="BtnStop" Grid.Column="2" Content="■ 중지"
                        Background="#3A1A1A" BorderBrush="#FF4040"
                        IsEnabled="False" Click="StopBtn_Click"/>
            </Grid>
        </Border>

        <!-- ③ 변경 목록 TabControl -->
        <TabControl Grid.Row="3" Background="Transparent" BorderThickness="0">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁 파일 변경"/>
                        <TextBlock x:Name="TxtFileTab" Text=" (0)"
                                   Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="10,4,10,0">
                    <ListView x:Name="FileList" VirtualizingPanel.IsVirtualizing="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="시간" Width="70"
                                    DisplayMemberBinding="{Binding TimestampStr}"/>
                                <GridViewColumn Header="유형" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TypeLabel}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TypeLabel}" Value="생성">
                                                                <Setter Property="Foreground" Value="#50DC78"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TypeLabel}" Value="수정">
                                                                <Setter Property="Foreground" Value="#FF9040"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TypeLabel}" Value="삭제">
                                                                <Setter Property="Foreground" Value="#FF5060"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TypeLabel}" Value="이름변경">
                                                                <Setter Property="Foreground" Value="#A0A0FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="경로" Width="600"
                                    DisplayMemberBinding="{Binding DisplayPath}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔑 레지스트리 변경"/>
                        <TextBlock x:Name="TxtRegTab" Text=" (0)"
                                   Foreground="{StaticResource OrangeBrush}" FontSize="11"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="10,4,10,0">
                    <ListView x:Name="RegList" VirtualizingPanel.IsVirtualizing="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="유형"  Width="70"
                                    DisplayMemberBinding="{Binding TypeLabel}"/>
                                <GridViewColumn Header="키 경로" Width="320"
                                    DisplayMemberBinding="{Binding Path}"/>
                                <GridViewColumn Header="값 이름" Width="140"
                                    DisplayMemberBinding="{Binding ValueName}"/>
                                <GridViewColumn Header="변경 내용" Width="200"
                                    DisplayMemberBinding="{Binding NewValue}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ④ 하단 액션 버튼 -->
        <Border Grid.Row="4" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtActionHint"
                           Text="실행 종료 후 변경 사항을 롤백하거나 유지할 수 있습니다."
                           Foreground="{StaticResource Fg3Brush}" FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnExport" Content="📄 리포트 내보내기"
                            IsEnabled="False" Margin="0,0,8,0"
                            Click="ExportBtn_Click"/>
                    <Button x:Name="BtnRollback" Content="↩ 모두 롤백"
                            Background="#3A1A1A" BorderBrush="#FF4040"
                            IsEnabled="False" Margin="0,0,8,0"
                            Click="RollbackBtn_Click"/>
                    <Button x:Name="BtnKeep" Content="✅ 변경 유지"
                            Background="#1A3A1A" BorderBrush="#50DC78"
                            IsEnabled="False"
                            Click="KeepBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
