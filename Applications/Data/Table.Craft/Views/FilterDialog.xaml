<Window x:Class="TableCraft.Views.FilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="필터 설정"
        Width="740" Height="440"
        MinWidth="600" MinHeight="300"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#181825"
                BorderBrush="#313244" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="고급 필터 조건" Foreground="#A6E3A1"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="  •  AND 조건으로 결합됩니다"
                           Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 필터 행 영역 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FilterStack" Margin="8,6"/>
        </ScrollViewer>

        <!-- 하단 버튼 -->
        <Border Grid.Row="2" Background="#181825"
                BorderBrush="#313244" BorderThickness="0,1,0,0" Padding="8,6">
            <Grid>
                <Button HorizontalAlignment="Left" Content="+ 조건 추가"
                        Width="90" Foreground="#A6E3A1" Click="BtnAdd_Click"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="적용" Width="70" Margin="4,0"
                            Click="BtnOk_Click" Background="#313244"/>
                    <Button Content="취소" Width="70" Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
