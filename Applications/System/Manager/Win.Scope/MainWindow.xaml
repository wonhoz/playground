<Window x:Class="WinScope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win.Scope" Height="640" Width="900"
        Background="#0F0F1E" Foreground="#E0E0E0"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#50C8DC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Border Background="Transparent" SnapsToDevicePixels="True" Height="20">
                            <Grid>
                                <!-- 트랙 배경 (전체 회색 라인) -->
                                <Border Height="4" VerticalAlignment="Center"
                                        Background="#333355" CornerRadius="2" Margin="7,0"/>
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="4" VerticalAlignment="Center"
                                                            Background="#50C8DC" CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="Transparent" Height="4"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="14" Height="14">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse x:Name="ThumbCircle" Width="14" Height="14"
                                                             Fill="#50C8DC"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbCircle" Property="Fill" Value="#70E8F4"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbCircle" Property="Fill" Value="#70E8F4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="14" Height="14"
                                    Background="#252538" BorderBrush="#444466" BorderThickness="1"
                                    CornerRadius="2">
                                <Path x:Name="chk" Data="M2,7 L5,10 L12,3" Stroke="#50C8DC" StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#50C8DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2A45"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E38"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- 툴바 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center"
                    Background="#14142A" Margin="-10,-10,-10,0">
            <Button x:Name="BtnRefresh" Click="BtnRefresh_Click" Margin="10,0,6,0">↺ 새로고침</Button>
            <Rectangle Width="1" Fill="#333355" Margin="4,8"/>
            <TextBox x:Name="TxtSearch" Width="180" Margin="6,0"
                     VerticalContentAlignment="Center"
                     TextChanged="TxtSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍 창 이름 / 프로세스 검색" Foreground="#555577" Margin="6,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <CheckBox x:Name="ChkAutoRefresh" Content="자동 새로고침 (3s)" Margin="6,0" Click="ChkAutoRefresh_Click"/>
        </StackPanel>

        <!-- 메인 2열 분할 -->
        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 창 목록 -->
            <Border Grid.Column="0" BorderBrush="#333355" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1A1A30" CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <TextBlock x:Name="LblWindowCount" Text="창 목록" FontSize="11"
                                       Foreground="#7777AA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="WindowList" Grid.Row="1" BorderThickness="0"
                             SelectionChanged="WindowList_SelectionChanged"
                             FontFamily="Consolas" FontSize="11"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="#333355" HorizontalAlignment="Stretch"/>

            <!-- 속성 패널 -->
            <Border Grid.Column="2" BorderBrush="#333355" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1A1A30" CornerRadius="6,6,0,0">
                        <TextBlock Text="창 속성" FontSize="11" Foreground="#7777AA"
                                   VerticalAlignment="Center" Margin="8,0"/>
                    </Border>

                    <StackPanel x:Name="PropPanel" Grid.Row="1" Margin="12,8" IsEnabled="False">
                        <!-- 창 정보 -->
                        <TextBlock x:Name="LblTitle" Text="(창 선택)" FontSize="12"
                                   Foreground="#50C8DC" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock x:Name="LblProcess" Text="" FontSize="10"
                                   Foreground="#666688" Margin="0,0,0,10"/>

                        <!-- 투명도 -->
                        <TextBlock Text="투명도 (Opacity)" FontSize="11" Foreground="#AAAACC" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderOpacity" Minimum="20" Maximum="100" Value="100"
                                    ValueChanged="SliderOpacity_ValueChanged"
                                    TickFrequency="10" IsSnapToTickEnabled="True"/>
                            <TextBlock x:Name="LblOpacity" Grid.Column="1" Text="100%"
                                       FontSize="11" Foreground="#AAAACC" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>

                        <!-- 항상 위 -->
                        <CheckBox x:Name="ChkTopMost" Content="항상 위 (Always on Top)"
                                  Click="ChkTopMost_Click" Margin="0,0,0,12"/>

                        <!-- Z-Order 이동 -->
                        <TextBlock Text="Z-Order 이동" FontSize="11" Foreground="#AAAACC" Margin="0,0,0,6"/>
                        <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                            <Button x:Name="BtnZTop" Click="BtnZTop_Click" Margin="0,0,4,0" Padding="4,4">⏫ 맨 위</Button>
                            <Button x:Name="BtnZUp" Click="BtnZUp_Click" Margin="0,0,4,0" Padding="4,4">▲ 위로</Button>
                            <Button x:Name="BtnZDown" Click="BtnZDown_Click" Margin="0,0,4,0" Padding="4,4">▼ 아래로</Button>
                            <Button x:Name="BtnZBottom" Click="BtnZBottom_Click" Padding="4,4">⏬ 맨 아래</Button>
                        </UniformGrid>

                        <!-- 창 상태 -->
                        <TextBlock Text="창 상태" FontSize="11" Foreground="#AAAACC" Margin="0,0,0,6"/>
                        <UniformGrid Rows="1" Columns="3" Margin="0,0,0,12">
                            <Button x:Name="BtnRestore" Click="BtnRestore_Click" Margin="0,0,4,0" Padding="4,4">↗ 복원</Button>
                            <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Margin="0,0,4,0" Padding="4,4">— 최소화</Button>
                            <Button x:Name="BtnClose" Click="BtnClose_Click" Padding="4,4"
                                    Background="#3A1A1A" BorderBrush="#664444">✕ 닫기</Button>
                        </UniformGrid>

                        <!-- 포커스 -->
                        <Button x:Name="BtnFocus" Click="BtnFocus_Click" HorizontalAlignment="Stretch"
                                Padding="4,6">🎯 이 창에 포커스</Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <TextBlock x:Name="StatusBar" Grid.Row="2" VerticalAlignment="Center"
                   FontSize="11" Foreground="#666688"/>
    </Grid>
</Window>
