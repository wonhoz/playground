<Window x:Class="ScreenRecorder.HudOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        IsHitTestVisible="True"
        Opacity="0.85">

    <Border Background="#CC1A1A2E" CornerRadius="8" Padding="10,6"
            BorderBrush="#555555" BorderThickness="1">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- 상태 표시등 -->
            <Ellipse x:Name="HudDot" Width="8" Height="8" Fill="#E74C3C"
                     VerticalAlignment="Center" Margin="0,0,6,0"/>

            <!-- 경과 시간 -->
            <TextBlock x:Name="HudTime" Text="00:00"
                       FontSize="13" FontFamily="Consolas" FontWeight="Bold"
                       Foreground="#E0E0E0" VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <!-- 일시정지 버튼 -->
            <Button x:Name="HudPauseBtn" Content="⏸" FontSize="11"
                    Foreground="#E0E0E0" Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Padding="4,2" Margin="0,0,4,0"
                    Click="HudPause_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- 정지 버튼 -->
            <Button x:Name="HudStopBtn" Content="⏹" FontSize="11"
                    Foreground="#E0E0E0" Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Padding="4,2"
                    Click="HudStop_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>
