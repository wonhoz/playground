<UserControl x:Class="DeepDiff.Views.ImageCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F0F1E"
             KeyDown="UserControl_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 경로 선택 -->
        <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1" CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtLeftPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Padding="4,3"
                                 KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                Click="BtnLeftBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>
                <Button Grid.Column="1" Content="⇆" Width="36" FontSize="14" Margin="6,0" Click="BtnSwap_Click"/>
                <Border Grid.Column="2" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1" CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtRightPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Padding="4,3"
                                 KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                Click="BtnRightBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>
                <Button Grid.Column="3" Content="비교" Padding="14,6" Margin="6,0,0,0"
                        Background="#1E2E50" BorderBrush="#5B8FFF" Foreground="#5B8FFF"
                        Click="BtnCompare_Click" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- 툴바 -->
        <Border Grid.Row="1" Background="#0F0F1E" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="10,6">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="뷰 모드:" Foreground="#8888AA" FontSize="12" VerticalAlignment="Center"/>
                <RadioButton x:Name="RbSideBySide" Content="나란히" GroupName="ViewMode" IsChecked="True"
                             VerticalAlignment="Center" Checked="ViewMode_Changed"/>
                <RadioButton x:Name="RbOverlay"    Content="오버레이" GroupName="ViewMode"
                             VerticalAlignment="Center" Checked="ViewMode_Changed"/>
                <RadioButton x:Name="RbPixelDiff"  Content="픽셀 Diff" GroupName="ViewMode"
                             VerticalAlignment="Center" Checked="ViewMode_Changed"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <TextBlock Text="줌:" Foreground="#8888AA" FontSize="12" VerticalAlignment="Center"/>
                <Button Content="−" Width="28" Click="BtnZoomOut_Click" ToolTip="-"/>
                <TextBlock x:Name="TbZoom" Text="100%" Foreground="#E8E8F0" FontSize="12"
                           VerticalAlignment="Center" Width="45" TextAlignment="Center"/>
                <Button Content="+" Width="28" Click="BtnZoomIn_Click" ToolTip="+"/>
                <Button Content="맞춤" Width="45" Click="BtnZoomFit_Click" ToolTip="F"/>
                <Button Content="1:1"  Width="45" Click="BtnZoom100_Click"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <TextBlock x:Name="TbDiffStats" Foreground="#F0B030" FontSize="12" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- 이미지 뷰어 -->
        <ScrollViewer Grid.Row="2" x:Name="MainScroll"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#0A0A0F">
            <Grid x:Name="ImagePanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 나란히 모드 -->
                <StackPanel x:Name="SideBySidePanel" Orientation="Horizontal">
                    <Border BorderBrush="#2E2E55" BorderThickness="1" Margin="4">
                        <Image x:Name="LeftImage" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                    <Border BorderBrush="#2E2E55" BorderThickness="1" Margin="4">
                        <Image x:Name="RightImage" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                </StackPanel>
                <!-- 오버레이/픽셀Diff 모드 -->
                <Border x:Name="SinglePanel" BorderBrush="#2E2E55" BorderThickness="1" Margin="4" Visibility="Collapsed">
                    <Image x:Name="SingleImage" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TbStatus" Foreground="#8888AA" FontSize="12" VerticalAlignment="Center"
                           Text="이미지 파일을 선택하고 비교를 시작하세요."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TbLeftSize"  Foreground="#5B8FFF" FontSize="11"/>
                    <TextBlock x:Name="TbRightSize" Foreground="#3FC878" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
