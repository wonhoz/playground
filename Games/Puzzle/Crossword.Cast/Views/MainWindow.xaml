<Window x:Class="CrosswordCast.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crossword.Cast" Height="640" Width="960"
        Background="#1A1A1A" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="✏ Crossword.Cast" FontSize="20" FontWeight="Bold"
                           Foreground="#FFEE58"/>
                <TextBlock x:Name="TxtTimer" Text="00:00" FontSize="12" Foreground="#888888"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="새 퍼즐"   Padding="12,6" Click="OnNew"/>
                <Button Content="공개"      Padding="12,6" Click="OnReveal"   Margin="8,0,0,0"/>
                <Button Content="정답 확인" Padding="12,6" Click="OnCheck"    Margin="8,0,0,0"/>
                <Button Content="↺ 초기화" Padding="12,6" Click="OnClear"    Margin="8,0,0,0"/>
                <Button Content="씨드 복사" Padding="12,6" Click="OnCopySeed" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 본문: 힌트 + 격자 + 힌트 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="195"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="195"/>
            </Grid.ColumnDefinitions>

            <!-- 가로 힌트 -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="가로 (Across)" FontSize="12" FontWeight="Bold"
                           Foreground="#FFEE58" Margin="0,0,0,6"/>
                <ListBox x:Name="LstAcross" FontSize="11" Height="500"
                         SelectionChanged="OnClueSelected"/>
            </StackPanel>

            <!-- 격자 (code-behind에서 삽입) -->
            <Border Grid.Column="1" x:Name="GridBorder"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    BorderBrush="#333" BorderThickness="1" CornerRadius="4"
                    Padding="1"/>

            <!-- 세로 힌트 -->
            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                <TextBlock Text="세로 (Down)" FontSize="12" FontWeight="Bold"
                           Foreground="#FFEE58" Margin="0,0,0,6"/>
                <ListBox x:Name="LstDown" FontSize="11" Height="500"
                         SelectionChanged="OnClueSelected"/>
            </StackPanel>
        </Grid>

        <!-- 상태바 -->
        <TextBlock Grid.Row="2" x:Name="TxtStatus"
                   Text="새 퍼즐 버튼을 눌러 시작하세요."
                   FontSize="11" Foreground="#888"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
    </Grid>
</Window>
