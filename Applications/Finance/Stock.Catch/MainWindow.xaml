<Window x:Class="Stock.Catch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock.Catch — 시세 조회 · 시그널 포착" Height="780" Width="1040"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 조회 입력 패널 ── -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 종목 (코드 또는 이름 검색) -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="종목" VerticalAlignment="Center"
                           Margin="0,0,12,0" Foreground="{StaticResource FgMuted}"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="CodeBox" Width="160" Text="005930"
                             FontSize="14" FontWeight="SemiBold"/>
                    <Button x:Name="LookupBtn" Content="🔍 검색" Style="{StaticResource ChipButton}"
                            Margin="8,0,0,0" Click="Search_Click"/>
                    <TextBlock x:Name="NameText" Text="" VerticalAlignment="Center" Margin="12,0,0,0"
                               FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                </StackPanel>

                <!-- 즐겨찾기 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="즐겨찾기" VerticalAlignment="Center"
                           Margin="0,12,12,0" Foreground="{StaticResource FgMuted}"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <ComboBox x:Name="FavCombo" Width="230" SelectionChanged="Fav_SelectionChanged"/>
                    <Button x:Name="FavAddBtn" Content="⭐ 현재 추가" Style="{StaticResource ChipButton}"
                            Margin="8,0,0,0" Click="FavAdd_Click"/>
                    <Button x:Name="FavRemoveBtn" Content="🗑 제거" Style="{StaticResource ChipButton}"
                            Margin="6,0,0,0" Click="FavRemove_Click"/>
                    <Button x:Name="FavUpBtn" Content="▲" Style="{StaticResource ChipButton}" Width="34"
                            Margin="10,0,0,0" Click="FavUp_Click" ToolTip="선택 즐겨찾기를 위로"/>
                    <Button x:Name="FavDownBtn" Content="▼" Style="{StaticResource ChipButton}" Width="34"
                            Margin="4,0,0,0" Click="FavDown_Click" ToolTip="선택 즐겨찾기를 아래로"/>
                </StackPanel>

                <!-- 기간 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="기간" VerticalAlignment="Center"
                           Margin="0,12,12,0" Foreground="{StaticResource FgMuted}"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBox x:Name="FromBox" Width="110"/>
                    <TextBlock Text="~" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBox x:Name="ToBox" Width="110"/>
                    <Button Content="−1일" Style="{StaticResource ChipButton}" Margin="12,0,0,0" Tag="-1" Click="DayShift_Click"/>
                    <Button Content="+1일" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="1" Click="DayShift_Click"/>
                    <TextBlock Text="(기간 전체 이동)" VerticalAlignment="Center" Margin="10,0,0,0"
                               FontSize="11" Foreground="{StaticResource FgMuted}"/>
                </StackPanel>

                <!-- 빠른 기간 프리셋 -->
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="1개월" Style="{StaticResource ChipButton}" Tag="1M" Click="Preset_Click"/>
                    <Button Content="3개월" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="3M" Click="Preset_Click"/>
                    <Button Content="6개월" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="6M" Click="Preset_Click"/>
                    <Button Content="1년" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="1Y" Click="Preset_Click"/>
                    <Button Content="3년" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="3Y" Click="Preset_Click"/>
                    <Button Content="올해" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="YTD" Click="Preset_Click"/>
                </StackPanel>

                <!-- 데이터 소스 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="데이터 소스" VerticalAlignment="Center"
                           Margin="0,12,12,0" Foreground="{StaticResource FgMuted}"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <ComboBox x:Name="SourceCombo" Width="230"/>
                    <TextBlock x:Name="SourceNote" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{StaticResource FgMuted}"/>
                </StackPanel>

                <!-- 우측 액션 (조회 강조 + 2컬럼 그리드) -->
                <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="5" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button x:Name="FetchBtn" Content="조회" Style="{StaticResource AccentButton}"
                            Width="256" Height="46" FontSize="15" FontWeight="SemiBold" Click="Fetch_Click"/>
                    <UniformGrid Columns="2" Width="256" Margin="0,4,0,0">
                        <Button x:Name="ChartBtn" Content="📈 차트" Margin="0,4,4,0"
                                Click="Chart_Click"/>
                        <Button x:Name="LadderBtn" Content="📊 매수/익절" Margin="4,4,0,0"
                                IsEnabled="False" Click="Ladder_Click"
                                ToolTip="매수 4호가·익절 4방식 래더 계산 (조회 후 사용 가능)"/>
                        <Button x:Name="MinuteCsvBtn" Content="🕐 분봉 CSV" Margin="0,4,4,0"
                                Click="MinuteCsv_Click"
                                ToolTip="특정 날짜의 1분봉(09:00~15:30)을 CSV로 저장합니다 (KIS 키 필요 · 과거 영업일 지원)"/>
                        <Button x:Name="SignalCsvBtn" Content="🧪 분봉 시그널" Margin="4,4,0,0"
                                Click="SignalCsv_Click"
                                ToolTip="저장한 1분봉 CSV에서 바닥 반등·고점 경고 시그널 시점을 라이브와 동일 조건으로 추출해 '_시그널.csv'로 저장합니다"/>
                        <Button x:Name="PortfolioBtn" Content="💼 내 자산" Margin="0,4,4,0"
                                Click="Portfolio_Click"/>
                        <Button x:Name="WatchlistBtn" Content="⭐ 관심 종목" Margin="4,4,0,0"
                                Click="Watchlist_Click"/>
                        <Button x:Name="SettingsBtn" Content="⚙ KIS 키 설정" Margin="0,4,4,0"
                                Click="Settings_Click"/>
                        <Button x:Name="HelpBtn" Content="📖 시그널 도움말" Margin="4,4,0,0"
                                Click="Help_Click"
                                ToolTip="시그널 종류·등급·컨텍스트 용어(갭/당일/저점比/일봉추세)·운용 가이드"/>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 요약 줄 ── -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg2}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6" Padding="14,9" Margin="0,12,0,0">
            <TextBlock x:Name="SummaryText" Text="종목코드·기간·소스를 선택한 뒤 [조회]를 누르세요."
                       Foreground="{StaticResource FgMuted}" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ── 데이터 미리보기 ── -->
        <DataGrid x:Name="Grid" Grid.Row="2" Margin="0,12,0,0"
                  ColumnHeaderStyle="{StaticResource DarkColHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="날짜" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="120"/>
                <DataGridTextColumn Header="시가" Binding="{Binding Open, StringFormat=N0}" Width="*"
                                    ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="종가" Binding="{Binding Close, StringFormat=N0}" Width="*"
                                    ElementStyle="{StaticResource NumCellBold}"/>
                <DataGridTextColumn Header="저가" Binding="{Binding Low, StringFormat=N0}" Width="*"
                                    ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="고가" Binding="{Binding High, StringFormat=N0}" Width="*"
                                    ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="거래량" Binding="{Binding Volume, StringFormat=N0}" Width="1.4*"
                                    ElementStyle="{StaticResource NumCell}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── 내보내기 바 ── -->
        <Border Grid.Row="3" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,12,0,0">
            <StackPanel>
                <!-- 컬럼 선택 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,11">
                    <TextBlock Text="내보낼 컬럼" VerticalAlignment="Center"
                               Margin="0,0,14,0" Foreground="{StaticResource FgMuted}"/>
                    <CheckBox x:Name="ColDate"   Content="날짜"   IsChecked="True" Margin="0,0,14,0"/>
                    <CheckBox x:Name="ColOpen"   Content="시가"   IsChecked="True" Margin="0,0,14,0"/>
                    <CheckBox x:Name="ColClose"  Content="종가"   IsChecked="True" Margin="0,0,14,0"/>
                    <CheckBox x:Name="ColLow"    Content="저가"   IsChecked="True" Margin="0,0,14,0"/>
                    <CheckBox x:Name="ColHigh"   Content="고가"   IsChecked="True" Margin="0,0,14,0"/>
                    <CheckBox x:Name="ColVolume" Content="거래량" IsChecked="True" Margin="0,0,18,0"/>
                    <Button Content="전체" Style="{StaticResource ChipButton}" Margin="0,0,6,0" Click="ColAll_Click"/>
                    <Button Content="해제" Style="{StaticResource ChipButton}" Click="ColNone_Click"/>
                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="18,2,18,2"/>
                    <CheckBox x:Name="IncludeHeaderCheck" Content="헤더 포함" IsChecked="True"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 포맷 + 내보내기 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="출력 포맷" VerticalAlignment="Center"
                               Margin="0,0,12,0" Foreground="{StaticResource FgMuted}"/>
                    <ComboBox x:Name="FormatCombo" Grid.Column="1" Width="200"/>

                    <Button x:Name="CopyBtn" Grid.Column="3" Content="📋 클립보드 복사" Width="140"
                            Margin="0,0,8,0" IsEnabled="False" Click="Copy_Click"/>
                    <Button x:Name="SaveBtn" Grid.Column="4" Content="💾 파일로 저장" Width="150"
                            Style="{StaticResource AccentButton}" IsEnabled="False" Click="Save_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
