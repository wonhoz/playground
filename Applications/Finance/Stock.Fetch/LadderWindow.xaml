<Window x:Class="Stock.Fetch.LadderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="매수/익절 래더" Height="800" Width="520"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style x:Key="Val" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" FontSize="19" FontWeight="Bold"
                       Foreground="{StaticResource FgBrush}"/>
            <TextBlock x:Name="SubText" FontSize="12" Foreground="{StaticResource FgMuted}" Margin="0,3,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
            <!-- 우측 마진: 우측 정렬 값이 스크롤바에 붙지 않도록 띄움 -->
            <StackPanel Margin="0,0,16,0">
                <!-- 기준값 -->
                <TextBlock Text="기준값 (마지막 거래일)" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="전일 저가" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="PrevLowText" Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="전일 고가" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="PrevHighText" Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="전일 종가 (정규)" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="PrevCloseText" Grid.Row="2" Grid.Column="1" Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="갭다운 취소선 (정규 −5%)" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="GapText" Grid.Row="3" Grid.Column="1" Style="{StaticResource Val}"
                               Foreground="{StaticResource BearBrush}"/>
                </Grid>

                <!-- 매수 래더 -->
                <TextBlock Text="매수 래더 (지정가 · 각 1주 · 앵커=전일 저가)" Style="{StaticResource SectionHeader}"/>
                <Grid x:Name="BuyGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="호가" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="오프셋" Style="{StaticResource Lbl}" Margin="20,3,16,3"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="매수가" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="평단 (4주 평균)" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="AvgText" Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="전량금액 (4주 합)" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="TotalText" Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}"/>
                </Grid>

                <!-- 리스크 -->
                <TextBlock Text="리스크 (4주 전량 보유 시)" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="손절가 (평단 −8%)" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="StopText" Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}"
                               Foreground="{StaticResource BearBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="손해 (손절 시)" Style="{StaticResource Lbl}"/>
                    <TextBlock x:Name="LossText" Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}"
                               Foreground="{StaticResource BearBrush}"/>
                </Grid>

                <!-- 익절 (4방식 제안) -->
                <TextBlock Text="익절 제안 (4방식 · 평단 대비 수익)" Style="{StaticResource SectionHeader}"/>
                <Grid x:Name="SellGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="방식" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="익절가" Style="{StaticResource Lbl}" Margin="20,3,16,3" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="수익" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                </Grid>

                <!-- 운용 규칙 -->
                <TextBlock Text="운용 규칙" Style="{StaticResource SectionHeader}"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource FgMuted}" FontSize="11.5" LineHeight="19">
                    <Run Text="1. 갭다운 가드(수동·최우선): 08:59 예상체결가 &lt; 갭다운취소선이면 당일 매수 전량 취소."/><LineBreak/>
                    <Run Text="2. 손절: 보유 평단 −8% 이탈 마감 시 정리."/><LineBreak/>
                    <Run Text="3. 익절: 보유분에 한해 익절가 지정가 매도. 안 팔리면 다음날 전일고가 갱신해 재설정."/><LineBreak/>
                    <Run Text="4. 호가구조: 1=정상디핑 / 2=일반조정 / 3=중간조정 안전망 / 4=폭락 줍줍."/><LineBreak/>
                    <Run Text="5. 갭 방향은 밤사이 미국 반도체(SOX/엔비디아/마이크론/ASML)·환율이 결정 → 약세 다음날 아침 예상체결가 필수 확인."/>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <!-- 하단: 면책 + 버튼 -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="DisclaimerText" TextWrapping="Wrap" FontSize="11"
                       Foreground="{StaticResource FgMuted}"
                       Text="※ 이 계산은 사용자가 정의한 규칙대로 숫자를 재계산한 것으로 투자 조언이 아닙니다. 최종 판단·책임은 사용자에게 있습니다."/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="CopyBtn" Content="📋 복사" Width="100" Margin="0,0,8,0" Click="Copy_Click"/>
                <Button Content="닫기" Width="90" Style="{StaticResource AccentButton}" Click="Close_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
