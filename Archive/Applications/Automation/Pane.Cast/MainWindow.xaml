<Window x:Class="PaneCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pane.Cast" Height="680" Width="980"
        Background="#0F0F1E" Foreground="#E0E0E0"
        Closing="Window_Closing"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        Margin="6,3,0,3" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#888888"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True">
                                <Border Background="#1E1E38" BorderBrush="#444466" BorderThickness="1"
                                        MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#6666AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#1E1E38"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#353558"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0F0F1E"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252545"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E38"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#14142A" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬛ Pane.Cast" FontSize="16" FontWeight="Bold" Foreground="#50C8DC" Margin="0,0,16,0"/>
                    <TextBlock Text="Windows Terminal 세션 레이아웃 저장 / 복원기" FontSize="11" Foreground="#666688" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnExport" Click="BtnExport_Click" Margin="0,0,6,0">📤 내보내기</Button>
                    <Button x:Name="BtnImport" Click="BtnImport_Click">📥 가져오기</Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 영역 -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 세션 목록 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="세션 목록" FontSize="11" FontWeight="Bold"
                           Foreground="#AAAACC" Margin="0,0,0,6"/>

                <ListBox Grid.Row="1" x:Name="SessionList"
                         SelectionChanged="SessionList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" FontSize="10"
                                           Foreground="#666688" Margin="0,1,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 세션 조작 버튼 -->
                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="BtnAddSession_Click" FontSize="11">+ 추가</Button>
                    <Button Grid.Column="2" Click="BtnDeleteSession_Click" FontSize="11"
                            Background="#2A1A1A" BorderBrush="#6A3A3A">🗑 삭제</Button>
                </Grid>
            </Grid>

            <!-- 구분선 -->
            <Rectangle Grid.Column="1" Fill="#1E1E38"/>

            <!-- 오른쪽: 세션 편집기 -->
            <Grid Grid.Column="2" x:Name="EditorPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 세션 이름 -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="세션 이름:" FontSize="11" Foreground="#AAAACC"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" x:Name="TxtSessionName" FontSize="13" FontWeight="SemiBold"
                             TextChanged="TxtSessionName_TextChanged"/>
                    <Button Grid.Column="2" x:Name="BtnLaunch" Click="BtnLaunch_Click"
                            Margin="10,0,0,0" Background="#1A3A2A" BorderBrush="#2A6A4A"
                            Padding="16,6" FontSize="13" FontWeight="Bold">
                        ▶ 실행
                    </Button>
                </Grid>

                <!-- 탭 / 패인 헤더 -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="탭 &amp; 패인 구성" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAACC" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Click="BtnAddTab_Click" Padding="8,4" FontSize="11">+ 탭 추가</Button>
                        <Button Click="BtnAddPane_Click" Padding="8,4" FontSize="11" Margin="6,0,0,0">+ 패인 추가</Button>
                    </StackPanel>
                </Grid>

                <!-- 탭/패인 목록 -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TabPaneList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 동적으로 코드에서 생성 -->
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 생성될 wt 명령어 미리보기 -->
                <Border Grid.Row="3" Background="#13132A" BorderBrush="#1E1E38" BorderThickness="1"
                        CornerRadius="4" Padding="10,8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="wt 명령어 미리보기:" FontSize="10" Foreground="#666688"/>
                            <Button x:Name="BtnCopyCmd" Click="BtnCopyCmd_Click"
                                    Padding="6,2" Margin="8,0,0,0" FontSize="10">📋 복사</Button>
                        </StackPanel>
                        <TextBox Grid.Row="1" x:Name="TxtWtCommand" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"
                                 Background="#0A0A18" Foreground="#A0D8A0"
                                 BorderThickness="0" Padding="0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#0A0A1A" BorderBrush="#1A1A30" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar" Margin="10,0" VerticalAlignment="Center"
                       FontSize="10" Foreground="#666688"/>
        </Border>
    </Grid>
</Window>
