<Window x:Class="Stock.Catch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정" Height="720" Width="540"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,18,0,4"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,14,0">
                <!-- KIS -->
                <TextBlock Text="한국투자증권 OpenAPI 키" Style="{StaticResource Section}" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="KIS 소스·실시간 모니터링에 필요합니다. 네이버·Yahoo·다음 소스는 키 없이 동작합니다. 키는 이 PC의 %LocalAppData%에만 저장됩니다."/>
                <TextBlock Text="APP KEY" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="KeyBox" Margin="0,0,0,10"/>
                <TextBlock Text="APP SECRET" Style="{StaticResource FieldLbl}"/>
                <PasswordBox x:Name="SecretBox" Margin="0,0,0,10"/>
                <CheckBox x:Name="MockCheck" Content="모의투자 서버 사용 (테스트용 · 시세는 실전 권장)" Margin="0,0,0,10"/>
                <TextBlock Text="국내 현재가 시장 구분 (장 마감 후 NXT 시세 수신)" Style="{StaticResource FieldLbl}"/>
                <ComboBox x:Name="MarketDivCombo" Width="280" HorizontalAlignment="Left">
                    <ComboBoxItem Content="통합 KRX+NXT (권장 · ~20:00)" Tag="UN"/>
                    <ComboBoxItem Content="NXT 넥스트레이드만" Tag="NX"/>
                    <ComboBoxItem Content="KRX만 (09:00~15:30)" Tag="J"/>
                </ComboBox>

                <!-- 포트폴리오 경로 -->
                <TextBlock Text="자산 포트폴리오 저장 경로" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="매수/매도 기록(평단·실현손익)을 저장할 JSON 경로. Dropbox 등 동기화 폴더를 지정하면 어느 PC에서든 같은 자산 내역을 불러옵니다. 비워두면 문서\StockCatch\portfolio.json."/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PortfolioPathBox"/>
                    <Button Grid.Column="1" Content="찾기" Width="80" Margin="8,0,0,0" Click="BrowsePortfolio_Click"/>
                </Grid>

                <!-- 해외 실시간 시세 키 -->
                <TextBlock Text="해외 실시간 시세 키 (관심 종목 · 미국)" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="미국 종목 실시간 시세 소스입니다. 무료 키만 발급해 넣으면 됩니다(Yahoo는 키 없이 동작하나 약 15분 지연). 키는 이 PC의 %LocalAppData%에만 저장됩니다."/>
                <TextBlock Text="Finnhub API Key (finnhub.io · 실시간)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="FinnhubKeyBox" Margin="0,0,0,10"/>
                <TextBlock Text="Alpaca API Key ID (alpaca.markets · 실시간 IEX)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="AlpacaKeyIdBox" Margin="0,0,0,10"/>
                <TextBlock Text="Alpaca API Secret Key" Style="{StaticResource FieldLbl}"/>
                <PasswordBox x:Name="AlpacaSecretBox" Margin="0,0,0,10"/>
                <TextBlock Text="Databento API Key (databento.com · 프로 실시간/히스토리)" Style="{StaticResource FieldLbl}"/>
                <PasswordBox x:Name="DatabentoKeyBox" Margin="0,0,0,10"/>
                <TextBlock Text="Databento 데이터셋 (기본 DBEQ.BASIC · 예: XNAS.ITCH)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="DatabentoDatasetBox" Margin="0,0,0,10"/>

                <!-- Slack -->
                <TextBlock Text="Slack 알림" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="보유 종목이 평단 대비 임계값에 도달하면 Slack Incoming Webhook으로 알림을 보냅니다."/>
                <TextBlock Text="Webhook URL" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="SlackUrlBox" Margin="0,0,0,10"/>
                <TextBlock Text="기본 채널 (예: #stock · 비우면 webhook 기본 채널 · 관심 종목별 채널이 우선)" Style="{StaticResource FieldLbl}"/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="SlackChannelBox"/>
                    <Button Grid.Column="1" x:Name="TestBtn" Content="테스트 전송" Width="100" Margin="8,0,0,0" Click="Test_Click"/>
                </Grid>
                <TextBlock x:Name="TestResult" Foreground="{StaticResource FgMuted}" FontSize="11" Margin="0,4,0,0"/>

                <!-- 모니터링 -->
                <TextBlock Text="보유 종목 모니터링" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="트레이 상주 상태로 보유 종목 현재가를 주기 조회해, 평단 대비 수익률이 임계값을 새로 넘을 때 알림합니다(엣지 트리거)."/>
                <CheckBox x:Name="MonitorCheck" Content="모니터링 활성화 (트레이 상주)" Margin="0,0,0,8"/>
                <CheckBox x:Name="MarketHoursCheck" Content="장 시간(평일 09:00~15:30)에만 조회" Margin="0,0,0,10"/>
                <TextBlock Text="폴링 주기 (초 · 최소 10)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="IntervalBox" Margin="0,0,0,10" Width="120" HorizontalAlignment="Left"/>
                <TextBlock Text="알림 임계값 (% · 쉼표 구분 · 상승/하락 양방향)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="ThresholdsBox" Margin="0,0,0,10"/>
                <TextBlock Text="시세 조회 실패 알림 (연속 N회 · 0=끔 · 보유·관심 공통)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="FailAlertBox" Width="120" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                <CheckBox x:Name="ScheduleCheck"
                          Content="장 시작·마감 5분 전 알림 (한국·미국 · 서머타임 자동)"/>
                <TextBlock Style="{StaticResource Hint}" Margin="0,4,0,10"
                           Text="한국: 프리 08:00·동시호가 08:50·정규 09:00·마감동시 15:20·시간외단일가 18:00·애프터마감 20:00. 미국(ET 앵커): 프리 17:00·정규 22:30·애프터 05:00·데이마켓 09:00(KST, 서머타임). 평일만·공휴일 미반영."/>

                <CheckBox x:Name="ReversalCheck" Margin="0,0,0,10"
                          Content="추세 알림에 반등 확률 추정 첨부 (RSI·볼린저 등 · 휴리스틱)"/>

                <CheckBox x:Name="MuteKrOpenCheck"
                          Content="한국 개장 직후 상승/하락 알림 음소거 (프리 08:00·정규 09:00 직후)"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="음소거 구간(분)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="KrOpenMuteBox" Width="80"/>
                </StackPanel>

                <!-- 바닥 반등 시그널 -->
                <TextBlock Text="바닥 반등 시그널 (관심 종목 · 국내 1분봉)" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="급락 후 볼린저(20,2σ) 하단 터치 → 밴드 복귀 마감 + RSI 과매도 상승 전환 + 거래량 급증이면 알림하고, 이후 MA5가 MA20을 상향 돌파하면 확인 알림합니다. 완만한 지속 하락(하단 밴드워킹)과 약한 반등(%b 미달)은 자동으로 걸러냅니다. 종목별 사용 여부는 관심 종목 편집에서 켭니다(KIS 키 필요)."/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="RSI 과매도 상한" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="BottomRsiBox" Width="56"/>
                    <TextBlock Text="거래량 배수" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <TextBox x:Name="BottomVolBox" Width="56"/>
                    <TextBlock Text="쿨다운(분)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <TextBox x:Name="BottomCooldownBox" Width="56"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="밴드워킹 상한(봉)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="0,0,8,0"
                               ToolTip="최근 10봉 중 하단 터치 봉이 이 수를 초과하면 '지속 하락 중'으로 보고 시그널을 건너뜁니다. 깊은 급락 V바닥은 터치가 5~7봉이므로 7 권장(실측)."/>
                    <TextBox x:Name="BottomWalkBox" Width="56"
                             ToolTip="권장 7 — 4 이하면 깊은 급락 후 대반등(터치 5~7봉)까지 걸러질 수 있습니다."/>
                    <TextBlock Text="%b 회복 하한" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"
                               ToolTip="트리거 봉 종가의 최소 %b(하단 0~상단 1). 이 이상 회복 마감해야 시그널. 권장 0.15."/>
                    <TextBox x:Name="BottomPbBox" Width="56"/>
                    <TextBlock Text="GC 모멘텀(%)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"
                               ToolTip="골든크로스 시점에 1차 시그널 대비 이 비율 이상 올라 있어야 '반등 확인(강)'. 미달이면 '약한 확인(횡보성 크로스)'으로 구분 알림. 실측: 가짜 +0.51% vs 진짜 +0.90~6.73% → 권장 0.8."/>
                    <TextBox x:Name="BottomGcRiseBox" Width="56"/>
                    <TextBlock Text="강력🔥(%)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"
                               ToolTip="이 이상이면 '강력 확인 🔥' 최상위 등급. 실측: 건당 기대수익이 모멘텀 구간별 단조 증가(0.8~1.5% +0.11 → 2.5%+ +0.41%/건) → 권장 2.0."/>
                    <TextBox x:Name="BottomGcStrongBox" Width="56"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="타임프레임(분)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="0,0,8,0"
                               ToolTip="시그널을 판정할 봉 단위 목록(쉼표 구분·1~60). 1=원본 1분봉, 그 외는 1분봉을 롤링(convolution) 집계한 N분 봉으로 거시 추세를 독립 판정. 알림에 [N분] 접두로 구분. 쿨다운·확인 창은 N에 비례."/>
                    <TextBox x:Name="SignalTfBox" Width="160"/>
                    <TextBlock Text="거래량 창(봉)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"
                               ToolTip="거래량 급증(배수)을 찾는 최근 완성봉 수. 0=하단 터치 구간만(구 방식). 투매 거래량 피크가 RSI 상승 전환보다 몇 분 이른 V바닥을 놓치지 않도록 10 권장(14일 A/B 실측: 반등 승률 48→50% · 확인GC 55→56% · 07-02 인버스 진짜 바닥 포착)."/>
                    <TextBox x:Name="BottomVolWinBox" Width="56"/>
                </StackPanel>
                <CheckBox x:Name="BottomCrossCheck" Content="골든크로스(MA5↗MA20) 확인 알림 (1차 시그널 후 20분 내)"/>
                <CheckBox x:Name="BottomFollowCheck" Margin="0,6,0,0"
                          Content="직후 양봉 지속 확인 알림 (골든크로스보다 빠른 조기 확인)"
                          ToolTip="1차 시그널 직후 첫 완성봉이 양봉이면 '반등 지속' 알림. 실측: 진짜 반등 3/4 직후 양봉 vs 가짜 2/3 직후 음봉 — 강/약 반등 구분 힌트."/>
                <CheckBox x:Name="BottomTrendGateCheck" Margin="0,6,0,0"
                          Content="일봉 추세 컨텍스트 표기 (반등·GC 알림에 추세점수 −1~+1 첨부)"
                          ToolTip="강등이 아닌 판단 재료 — 극단 음수(폭락 직후)는 오히려 V바닥 기회일 수 있음(실측 07-03 10:05 추세 -1.00에서 +6.73% 대박). 사람이 보고 판단."/>

                <!-- 고점 경고 시그널 -->
                <TextBlock Text="고점 경고 시그널 (관심 종목 · 국내 1분봉)" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="상단 밴드워킹(2봉 이상) + RSI 과매수 도달 후, 밴드 안 복귀 하락봉 + RSI 하향 전환 + 소진 증거(긴 윗꼬리 또는 거래량 클라이맥스)면 익절 경고를 알림하고, 이후 MA5가 MA20을 하향 돌파하면 확인 알림합니다. 종목별 사용 여부는 관심 종목 편집에서 켭니다(KIS 키 필요)."/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="RSI 과매수 하한" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TopRsiBox" Width="56"/>
                    <TextBlock Text="거래량 배수" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <TextBox x:Name="TopVolBox" Width="56"/>
                    <TextBlock Text="쿨다운(분)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <TextBox x:Name="TopCooldownBox" Width="56"/>
                </StackPanel>
                <CheckBox x:Name="TopCrossCheck" Content="데드크로스(MA5↘MA20) 확인 알림 (고점 경고 후 20분 내)"/>

                <!-- 🔊 거래량 급증 알림 -->
                <TextBlock Text="거래량 급증 알림 (관심 종목 · 국내 1분봉)" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="완성 1분봉 거래량이 직전 20봉 평균의 RVOL 배수 이상이면 방향 무관 '수급 관심' 알림 — 분봉 등락·당일 등락률을 병기합니다. 직전 봉 단순 비교는 한산 구간 오탐이 커서 20봉 평균(RVOL)을 기준으로 합니다. 독립 알림이므로 배수는 보수적으로(기본 5×). 종목별 사용 여부·배수 override는 관심 종목 편집에서(KIS 키 필요)."/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="RVOL 배수" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="0,0,8,0"
                               ToolTip="직전 20봉 평균 거래량 대비 배수. 높일수록 더 확실한 급증만 알림. 권장 4~6."/>
                    <TextBox x:Name="VolSurgeRvolBox" Width="56"/>
                    <TextBlock Text="쿨다운(분)" Style="{StaticResource FieldLbl}" VerticalAlignment="Center" Margin="16,0,8,0"
                               ToolTip="같은 종목 재알림 금지 시간 — 뉴스 직후 연속 봉 급증의 도배 방지."/>
                    <TextBox x:Name="VolSurgeCooldownBox" Width="56"/>
                </StackPanel>

                <!-- 반등 캘리브레이션(백테스트) -->
                <TextBlock Text="반등 확률 캘리브레이션 (백테스트)" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="관심 종목 과거 일봉으로 반등 점수의 실제 적중률(향후 5거래일 내 반등 방향 2% 이동)을 학습해 확률을 보정합니다. 표본이 많을수록 정확해지며, 통계 근사일 뿐 미래 수익 보장이 아닙니다."/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="CalibResult" VerticalAlignment="Center" Foreground="{StaticResource FgMuted}" FontSize="11.5"/>
                    <Button Grid.Column="1" x:Name="CalibBtn" Content="지금 실행" Width="100" Margin="8,0,0,0" Click="Calibrate_Click"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="취소" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="저장" Width="90" Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
