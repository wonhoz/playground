<Window x:Class="OAuthPeek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OAuth.Peek" Height="720" Width="1100"
        Background="#0F0F1E" Foreground="#E0E0E0"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <!-- TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <!-- TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#0F0F1E"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <!-- TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0" Margin="0,0,2,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#50C8DC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#202038"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="RowBackground" Value="#13132A"/>
            <Setter Property="AlternatingRowBackground" Value="#16162E"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E1E35"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#7777AA"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2A45"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <!-- ScrollViewer -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- 툴바 -->
        <Border Grid.Row="0" Background="#14142A" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="🔑 OAuth.Peek" FontSize="14" FontWeight="Bold"
                           Foreground="#50C8DC" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock Text="JWT · OIDC · OAuth2 로컬 분석기" FontSize="11"
                           Foreground="#666688" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 메인 레이아웃 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 입력 + 히스토리 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- 토큰 입력 -->
                <Border Grid.Row="0" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Margin="6,6,3,3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#1A1A30" CornerRadius="6,6,0,0">
                            <TextBlock Text="토큰 / URL 입력" FontSize="11" Foreground="#7777AA"
                                       VerticalAlignment="Center" Margin="8,0"/>
                        </Border>
                        <TextBox x:Name="TxtInput" Grid.Row="1"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 BorderThickness="0" Background="#13132A"
                                 TextChanged="TxtInput_TextChanged"
                                 ToolTip="JWT 토큰, Issuer URL, Base64URL 문자열 붙여넣기"/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="6,4">
                            <Button x:Name="BtnAnalyze" Click="BtnAnalyze_Click"
                                    Padding="8,4" FontSize="11">🔍 분석</Button>
                            <Button x:Name="BtnClear" Click="BtnClear_Click"
                                    Margin="4,0,0,0" Padding="8,4" FontSize="11">✕ 지우기</Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 히스토리 -->
                <Border Grid.Row="1" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Margin="6,3,3,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#1A1A30" CornerRadius="6,6,0,0">
                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                <TextBlock Text="히스토리" FontSize="11" Foreground="#7777AA" VerticalAlignment="Center"/>
                                <Button x:Name="BtnClearHistory" Click="BtnClearHistory_Click"
                                        Margin="8,0,0,0" Padding="4,2" FontSize="10">지우기</Button>
                            </StackPanel>
                        </Border>
                        <ListBox x:Name="HistoryList" Grid.Row="1" BorderThickness="0"
                                 Background="#13132A" FontFamily="Consolas" FontSize="10"
                                 SelectionChanged="HistoryList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis"
                                               Foreground="#AAAACC" ToolTip="{Binding Raw}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="6" Background="#1A1A30" HorizontalAlignment="Stretch"/>

            <!-- 오른쪽: 탭 결과 -->
            <Border Grid.Column="2" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Margin="3,6,6,6">
                <TabControl x:Name="ResultTabs" BorderThickness="0">

                    <!-- ── 탭 1: JWT 디코더 ── -->
                    <TabItem Header="🔐 JWT">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- JWT 상태 바 -->
                            <Border Grid.Row="0" Background="#161628" Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="LblJwtAlg" Text="알고리즘: —" FontSize="11" Foreground="#AAAACC" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="LblJwtExp" Text="만료: —" FontSize="11" Foreground="#AAAACC" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="LblJwtValid" Text="서명: 미확인" FontSize="11" Foreground="#888888"/>
                                </StackPanel>
                            </Border>

                            <!-- Header / Payload 나란히 -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 헤더 -->
                                <Border Grid.Column="0" BorderBrush="#222240" BorderThickness="0,0,1,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Background="#1A1A30">
                                            <TextBlock Text="Header" FontSize="11" Foreground="#7EC8E3"
                                                       VerticalAlignment="Center" Margin="10,0"/>
                                        </Border>
                                        <DataGrid x:Name="GridHeader" Grid.Row="1">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="키" Binding="{Binding Key}" Width="80" FontFamily="Consolas"/>
                                                <DataGridTextColumn Header="값" Binding="{Binding Value}" Width="*" FontFamily="Consolas"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <!-- 페이로드 클레임 -->
                                <Border Grid.Column="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Background="#1A1A30">
                                            <TextBlock Text="Payload Claims" FontSize="11" Foreground="#A0E080"
                                                       VerticalAlignment="Center" Margin="10,0"/>
                                        </Border>
                                        <DataGrid x:Name="GridClaims" Grid.Row="1">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="클레임" Binding="{Binding Key}" Width="100" FontFamily="Consolas"/>
                                                <DataGridTextColumn Header="값" Binding="{Binding Value}" Width="*" FontFamily="Consolas"/>
                                                <DataGridTextColumn Header="설명" Binding="{Binding Description}" Width="120" Foreground="#666688"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- JWK 서명 검증 -->
                            <Border Grid.Row="2" Background="#14142A" Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="JWK URI:" FontSize="11" Foreground="#7777AA" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtJwkUri" Width="300" FontFamily="Consolas" FontSize="11"
                                             VerticalContentAlignment="Center"/>
                                    <Button x:Name="BtnVerifyJwk" Click="BtnVerifyJwk_Click"
                                            Margin="6,0,0,0" Padding="8,4" FontSize="11">🔒 서명 검증</Button>
                                    <TextBlock x:Name="LblVerifyResult" Margin="10,0,0,0"
                                               FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ── 탭 2: OIDC Discovery ── -->
                    <TabItem Header="🌐 OIDC">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#14142A" Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Issuer URL:" FontSize="11" Foreground="#7777AA"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtIssuerUrl" Width="350" FontFamily="Consolas" FontSize="11"
                                             VerticalContentAlignment="Center"/>
                                    <Button x:Name="BtnFetchOidc" Click="BtnFetchOidc_Click"
                                            Margin="6,0,0,0" Padding="8,4" FontSize="11">↓ Discovery 조회</Button>
                                    <TextBlock x:Name="LblOidcStatus" Margin="10,0" FontSize="11"
                                               VerticalAlignment="Center" Foreground="#AAAACC"/>
                                </StackPanel>
                            </Border>
                            <DataGrid x:Name="GridOidc" Grid.Row="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="항목" Binding="{Binding Key}" Width="220" FontFamily="Consolas"/>
                                    <DataGridTextColumn Header="값" Binding="{Binding Value}" Width="*" FontFamily="Consolas"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ── 탭 3: OAuth2 Flow ── -->
                    <TabItem Header="🔄 OAuth Flow">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#14142A" Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="플로 선택:" FontSize="11" Foreground="#7777AA"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="CmbFlow" Width="220"
                                              SelectionChanged="CmbFlow_SelectionChanged"
                                              Background="#252538" Foreground="#E0E0E0">
                                        <ComboBoxItem Content="Authorization Code" IsSelected="True"/>
                                        <ComboBoxItem Content="Authorization Code + PKCE"/>
                                        <ComboBoxItem Content="Client Credentials"/>
                                        <ComboBoxItem Content="Device Code (Device Flow)"/>
                                        <ComboBoxItem Content="Implicit (Legacy)"/>
                                        <ComboBoxItem Content="Resource Owner Password (Legacy)"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" Background="#0D0D1E">
                                <Canvas x:Name="FlowCanvas" Background="Transparent"
                                        Width="800" Height="600" Margin="20"/>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ── 탭 4: Auth Header 생성기 ── -->
                    <TabItem Header="📋 Auth Header">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16">
                                <TextBlock Text="인증 헤더 생성기" FontSize="13" FontWeight="Bold"
                                           Foreground="#50C8DC" Margin="0,0,0,16"/>

                                <!-- Bearer Token -->
                                <Border Background="#16162C" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Bearer Token" FontSize="11" Foreground="#7EC8E3" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TxtBearerToken" Width="400" FontFamily="Consolas" FontSize="11"
                                                     VerticalContentAlignment="Center"/>
                                            <Button x:Name="BtnCopyBearer" Click="BtnCopyBearer_Click"
                                                    Margin="6,0,0,0" Padding="8,4" FontSize="11">📋 복사</Button>
                                        </StackPanel>
                                        <TextBox x:Name="LblBearerResult" Margin="0,6,0,0" IsReadOnly="True"
                                                 FontFamily="Consolas" FontSize="11" Background="#0D0D1E"
                                                 Foreground="#A0E080" BorderThickness="0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Basic Auth -->
                                <Border Background="#16162C" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Basic Auth" FontSize="11" Foreground="#E0A040" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Username:" FontSize="11" Foreground="#AAAACC" VerticalAlignment="Center" Width="80"/>
                                            <TextBox x:Name="TxtBasicUser" Width="200" FontFamily="Consolas" FontSize="11"
                                                     VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Password:" FontSize="11" Foreground="#AAAACC" VerticalAlignment="Center" Width="80"/>
                                            <TextBox x:Name="TxtBasicPass" Width="200" FontFamily="Consolas" FontSize="11"
                                                     VerticalContentAlignment="Center"/>
                                            <Button x:Name="BtnCopyBasic" Click="BtnCopyBasic_Click"
                                                    Margin="6,0,0,0" Padding="8,4" FontSize="11">📋 복사</Button>
                                        </StackPanel>
                                        <TextBox x:Name="LblBasicResult" IsReadOnly="True"
                                                 FontFamily="Consolas" FontSize="11" Background="#0D0D1E"
                                                 Foreground="#E0A040" BorderThickness="0"/>
                                    </StackPanel>
                                </Border>

                                <!-- API Key -->
                                <Border Background="#16162C" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="API Key" FontSize="11" Foreground="#A080E0" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="헤더 이름:" FontSize="11" Foreground="#AAAACC" VerticalAlignment="Center" Width="80"/>
                                            <TextBox x:Name="TxtApiKeyHeader" Width="160" FontFamily="Consolas" FontSize="11"
                                                     Text="X-API-Key" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="API Key:" FontSize="11" Foreground="#AAAACC" VerticalAlignment="Center" Width="80"/>
                                            <TextBox x:Name="TxtApiKeyValue" Width="300" FontFamily="Consolas" FontSize="11"
                                                     VerticalContentAlignment="Center"/>
                                            <Button x:Name="BtnCopyApiKey" Click="BtnCopyApiKey_Click"
                                                    Margin="6,0,0,0" Padding="8,4" FontSize="11">📋 복사</Button>
                                        </StackPanel>
                                        <TextBox x:Name="LblApiKeyResult" IsReadOnly="True"
                                                 FontFamily="Consolas" FontSize="11" Background="#0D0D1E"
                                                 Foreground="#A080E0" BorderThickness="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ── 탭 5: Base64URL ── -->
                    <TabItem Header="🔤 Base64URL">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="입력" FontSize="11" Foreground="#7777AA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button x:Name="BtnB64Encode" Click="BtnB64Encode_Click" Padding="8,4" FontSize="11" Margin="0,0,4,0">⬇ Encode</Button>
                                <Button x:Name="BtnB64Decode" Click="BtnB64Decode_Click" Padding="8,4" FontSize="11">⬆ Decode</Button>
                            </StackPanel>
                            <TextBox x:Name="TxtB64Input" Grid.Row="1" AcceptsReturn="True"
                                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="결과" FontSize="11" Foreground="#7777AA" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtB64Output" Grid.Row="3" AcceptsReturn="True" IsReadOnly="True"
                                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                                     Background="#0D0D1E" Foreground="#A0E080" BorderThickness="1" BorderBrush="#333355"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#0A0A1A" BorderBrush="#1A1A30" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar" Margin="10,0" VerticalAlignment="Center"
                       FontSize="10" Foreground="#666688"/>
        </Border>
    </Grid>
</Window>
