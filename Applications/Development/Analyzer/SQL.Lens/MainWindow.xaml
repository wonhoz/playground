<Window x:Class="SqlLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL.Lens — 쿼리 실행 계획 시각화" Height="700" Width="1100"
        Background="#0F0F1E" ResizeMode="CanResizeWithGrip"
        MinWidth="900" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter"
        Loaded="Window_Loaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 헤더 -->
    <Border Grid.Row="0" Background="#090918" Padding="16,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <TextBlock Text="SQL.LENS" FontSize="18" FontWeight="Bold"
                     Foreground="#4A7FD6" FontFamily="Consolas" VerticalAlignment="Center"/>
          <TextBlock Text=" — SQLite 쿼리 실행 계획 시각화" FontSize="12" Foreground="#888"
                     VerticalAlignment="Center" Margin="6,0,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="📂 DB 열기" Click="BtnOpenDb_Click" Margin="0,0,6,0"/>
          <TextBlock x:Name="DbLabel" Text="DB 없음" Foreground="#888"
                     FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 메인 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 좌측: 스키마 탐색 -->
      <Border Background="#0A0A1A" BorderBrush="#1A1A3A" BorderThickness="0,0,1,0" Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
          </Grid.RowDefinitions>

          <TextBlock Text="📊 스키마" FontWeight="Bold" Foreground="#4A7FD6"
                     FontFamily="Consolas" Margin="0,0,0,6"/>

          <TreeView x:Name="SchemaTree" Grid.Row="1"
                    Background="#0A0A1A" Foreground="#D4D4D4"
                    BorderBrush="#1A1A3A" Margin="0,0,0,8">
            <TreeView.ItemContainerStyle>
              <Style TargetType="TreeViewItem">
                <Setter Property="Foreground" Value="#D4D4D4"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="12"/>
              </Style>
            </TreeView.ItemContainerStyle>
          </TreeView>

          <!-- 인덱스 현황 -->
          <TextBlock Grid.Row="2" Text="📑 인덱스 현황" FontWeight="Bold" Foreground="#4A7FD6"
                     FontFamily="Consolas" Margin="0,0,0,6"/>
          <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="IndexInfo" Text="DB를 연결하면 인덱스 목록이 표시됩니다."
                       Foreground="#888" FontFamily="Consolas" FontSize="11"
                       TextWrapping="Wrap" LineHeight="17"/>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- 우측: SQL 에디터 + 결과 -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="160"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SQL 에디터 -->
        <Border Background="#0D0D1A" Padding="12,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,6">
              <TextBlock Text="SQL 쿼리" FontWeight="Bold" Foreground="#4A7FD6"
                         FontFamily="Consolas" VerticalAlignment="Center"/>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="▶ 실행 (F5)" Click="BtnRun_Click" Margin="0,0,6,0"/>
                <Button Content="📋 실행 계획" Click="BtnExplain_Click" Margin="0,0,6,0"
                        Background="#1A2A1A" BorderBrush="#44AA44"/>
                <Button Content="💅 포맷" Click="BtnFormat_Click"
                        Background="#1A1A2A" BorderBrush="#4444AA"/>
              </StackPanel>
            </Grid>
            <TextBox x:Name="SqlEditor" Grid.Row="1"
                     Background="#050510" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                     FontFamily="Consolas" FontSize="13"
                     AcceptsReturn="True" AcceptsTab="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     BorderBrush="#2A2A4A" BorderThickness="1"
                     Padding="8"
                     KeyDown="SqlEditor_KeyDown"
                     Text="SELECT * FROM sqlite_master WHERE type='table';"/>
          </Grid>
        </Border>

        <!-- 탭 컨트롤 -->
        <TabControl Grid.Row="1" Grid.RowSpan="2" Background="#0D0D1A"
                    BorderBrush="#1A1A3A" Foreground="#E0E0E0">
          <TabItem Header="📋 결과" Foreground="#AAA">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <DataGrid x:Name="ResultGrid"
                        AutoGenerateColumns="True" IsReadOnly="True"
                        SelectionMode="Single" HeadersVisibility="All"/>
              <Border Grid.Row="1" Background="#090918" Padding="8,4">
                <TextBlock x:Name="ResultInfo" Text="" Foreground="#888"
                           FontFamily="Consolas" FontSize="11"/>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="🌳 실행 계획 트리" Foreground="#AAA">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
              </Grid.RowDefinitions>
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                            Background="#080815">
                <Canvas x:Name="PlanCanvas" Background="#080815" MinHeight="200"/>
              </ScrollViewer>

              <!-- 이슈 패널 -->
              <Border Grid.Row="1" Background="#0A0A18" Padding="10,8"
                      BorderBrush="#1A1A3A" BorderThickness="0,1,0,0">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <TextBlock Text="💡 최적화 힌트" FontWeight="Bold" Foreground="#FFD54F"
                             FontFamily="Consolas" Margin="0,0,0,4"/>
                  <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="IssueList">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="4,3" Margin="0,1">
                            <StackPanel>
                              <TextBlock Text="{Binding Message}" Foreground="#FFDD44"
                                         FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                              <TextBlock Text="{Binding Suggestion}" Foreground="#AAAAAA"
                                         FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                                         Margin="16,0,0,0"/>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="📜 히스토리" Foreground="#AAA">
            <ListBox x:Name="HistoryList"
                     Background="#080815" Foreground="#D4D4D4"
                     BorderBrush="#1A1A3A" FontFamily="Consolas" FontSize="11"
                     SelectionChanged="HistoryList_Selected">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel>
                    <TextBlock Text="{Binding Sql}" TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                    <TextBlock Text="{Binding Info}" Foreground="#666" FontSize="10"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </TabItem>
        </TabControl>
      </Grid>
    </Grid>

    <!-- 상태바 -->
    <Border Grid.Row="2" Background="#060610" Padding="12,5">
      <TextBlock x:Name="StatusBar"
                 Text="SQLite DB 파일을 드래그&amp;드롭하거나 '파일 열기' 버튼을 누르세요."
                 Foreground="#666" FontFamily="Consolas" FontSize="11"/>
    </Border>
  </Grid>
</Window>
