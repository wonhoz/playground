<Window x:Class="NetScan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NetScan.Views"
        Title="Net.Scan" Height="680" Width="1080" MinHeight="520" MinWidth="800"
        Background="#111118" Foreground="#E8E8F0"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#0D0D16" BorderBrush="#2A2A3E"
                BorderThickness="0,0,0,1" Padding="20,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                    <Run Text="Net" Foreground="#06B6D4"/>
                    <Run Text=".Scan" Foreground="#E8E8F0"/>
                </TextBlock>
                <TextBlock Text="LAN 네트워크 기기 스캐너" FontSize="12"
                           Foreground="#555566" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 메인 뷰 -->
        <views:ScanView Grid.Row="1" x:Name="ScanView"/>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#0D0D16" BorderBrush="#2A2A3E"
                BorderThickness="0,1,0,0" Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Text="준비"
                           Foreground="#888899" FontSize="11" VerticalAlignment="Center"/>
                <ProgressBar x:Name="PbMain" Grid.Column="1" Width="180" Height="4"
                             Visibility="Collapsed" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
