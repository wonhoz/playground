<Window x:Class="InkCast.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ink.Cast" Height="150" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#1A1A2E" Foreground="#CDD6F4"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="TxtPrompt" FontSize="13" Foreground="#CDD6F4" TextWrapping="Wrap"/>
        <TextBox Grid.Row="2" x:Name="TxtInput"
                 Background="#252535" Foreground="#CDD6F4" CaretBrush="#CBA6F7"
                 BorderBrush="#555578" BorderThickness="1" Padding="8,6" FontSize="13"
                 KeyDown="TxtInput_KeyDown"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인" Width="70" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="#2E2E5A" Foreground="#CBA6F7" BorderThickness="0" Padding="8,5"/>
            <Button Content="취소" Width="70" Click="BtnCancel_Click"
                    Background="#1A1A2E" Foreground="#9399B2" BorderThickness="1"
                    BorderBrush="#555578" Padding="8,5"/>
        </StackPanel>
    </Grid>
</Window>
