<Window x:Class="MarkView.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MarkView"
        Title="단축키 도움말"
        Width="900" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}">
  <Window.Resources>

    <!-- 단축키 행 템플릿 -->
    <DataTemplate x:Key="RowTpl" DataType="{x:Type local:ShortcutEntry}">
      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="155"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Background="{StaticResource Surface2Brush}" CornerRadius="4"
                Padding="8,3" HorizontalAlignment="Left">
          <TextBlock Text="{Binding Key}"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     FontSize="10.5" FontWeight="SemiBold"
                     Foreground="{StaticResource AccentBrush}"/>
        </Border>
        <TextBlock Grid.Column="1" Text="{Binding Desc}"
                   FontSize="11.5" Foreground="{StaticResource TextBrush}"
                   VerticalAlignment="Center" Margin="8,0,0,0"
                   TextWrapping="Wrap"/>
      </Grid>
    </DataTemplate>

    <!-- 카테고리 헤더 -->
    <Style x:Key="Cat" TargetType="TextBlock">
      <Setter Property="FontSize"   Value="10"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Margin"     Value="0,14,0,5"/>
      <Setter Property="Opacity"    Value="0.75"/>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- 타이틀 -->
      <RowDefinition Height="*"/>      <!-- 스크롤 콘텐츠 -->
    </Grid.RowDefinitions>

    <!-- 타이틀 -->
    <Border Grid.Row="0" Padding="24,18,24,14">
      <Grid>
        <TextBlock Text="단축키 도움말" FontSize="14" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"/>
        <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                IsCancel="True" Click="CloseButton_Click" Padding="6,2">
          <TextBlock Text="✕" FontSize="11" Foreground="{StaticResource TextDimBrush}"/>
        </Button>
      </Grid>
    </Border>

    <!-- 구분선 -->
    <Border Grid.Row="0" VerticalAlignment="Bottom"
            Height="1" Background="{StaticResource BorderBrush}" Margin="24,0"/>

    <!-- 스크롤 콘텐츠 영역 -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0,0,4,0">
      <Border Padding="24,12,20,20">

        <!-- 2컬럼 본문 -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- ── 왼쪽 컬럼: 파일 조작 계열 ── -->
          <StackPanel Grid.Column="0">

            <!-- 파일 -->
            <TextBlock Text="파일" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="Ctrl + O"         Desc="파일 열기"/>
                <local:ShortcutEntry Key="Ctrl + N"         Desc="새 파일 (새 탭)"/>
                <local:ShortcutEntry Key="Ctrl + S"         Desc="저장"/>
                <local:ShortcutEntry Key="Ctrl + Shift + S" Desc="다른 이름으로 저장"/>
                <local:ShortcutEntry Key="Ctrl + W"         Desc="현재 탭 닫기"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 탐색 -->
            <TextBlock Text="탐색" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="Ctrl + P"           Desc="Quick Open — 열린 탭 + 최근 파일 통합 검색 (↑↓ 탐색, Enter 열기)"/>
                <local:ShortcutEntry Key="Ctrl + Tab"         Desc="다음 탭"/>
                <local:ShortcutEntry Key="Ctrl + Shift + Tab" Desc="이전 탭"/>
                <local:ShortcutEntry Key="Ctrl + T"           Desc="목차 (TOC) 패널 토글"/>
                <local:ShortcutEntry Key="TOC 항목 클릭"      Desc="해당 섹션으로 부드럽게 이동"/>
                <local:ShortcutEntry Key="TOC 검색창"         Desc="TOC 패널 상단 검색창으로 헤딩 실시간 필터링"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 내보내기 -->
            <TextBlock Text="내보내기" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="Ctrl + Shift + E" Desc="HTML로 내보내기 (마지막 경로 기억)"/>
                <local:ShortcutEntry Key="Ctrl + Shift + P"  Desc="PDF로 내보내기 (마지막 경로 기억)"/>
                <local:ShortcutEntry Key="PDF 버튼 우클릭" Desc="PDF 용지 크기(A4/Letter/Legal) 및 여백 설정"/>
                <local:ShortcutEntry Key="Ctrl + Shift + C" Desc="현재 문서 HTML을 클립보드에 복사"/>
                <local:ShortcutEntry Key="Ctrl + Shift + M" Desc="현재 문서 Markdown 원문을 클립보드에 복사"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 기타 -->
            <TextBlock Text="기타" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="F1"               Desc="단축키 도움말"/>
                <local:ShortcutEntry Key="F5"               Desc="현재 파일 새로고침"/>
                <local:ShortcutEntry Key="F11"              Desc="집중 모드 (툴바/상태바 숨김)"/>
                <local:ShortcutEntry Key="📌 버튼"          Desc="최근 파일 즐겨찾기 고정/해제"/>
                <local:ShortcutEntry Key="✕ 버튼 (최근)"   Desc="최근 파일 목록에서 해당 항목 제거"/>
                <local:ShortcutEntry Key="Ctrl + 클릭 (최근)" Desc="최근 파일을 새 탭으로 열기"/>
                <local:ShortcutEntry Key="최근 파일 검색창" Desc="파일명/폴더명으로 최근 파일 실시간 필터링"/>
                <local:ShortcutEntry Key="상태바 경로"      Desc="클릭 시 파일 탐색기에서 위치 열기"/>
                <local:ShortcutEntry Key="상태바 ↩ 표시"   Desc="편집 모드에서 실행 취소(Ctrl+Z) 가능 상태 표시"/>
                <local:ShortcutEntry Key="자동 저장"        Desc="편집 중단 후 자동 저장 (기본 30초) — 상태바 우클릭으로 30초/1분/2분 변경 가능"/>
                <local:ShortcutEntry Key="커서·스크롤 기억" Desc="파일별 마지막 커서 위치 및 에디터 스크롤 위치 저장 — 앱 재시작 후 해당 파일을 열면 마지막 위치로 자동 이동"/>
                <local:ShortcutEntry Key="내보내기 경로"    Desc="HTML/PDF 저장 완료 후 상태바에 파일명 표시 — 클릭 시 탐색기에서 파일 위치 열기 (5초간 유지)"/>
                <local:ShortcutEntry Key="탭 더블클릭"     Desc="탭 이름 인라인 편집 — Enter 확정, Esc 취소"/>
                <local:ShortcutEntry Key="탭 우클릭"       Desc="경로 복사 · 탐색기에서 열기 · 탭 복제 · 오른쪽 탭 모두 닫기 · 다른 탭 모두 닫기"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 찾기 / 바꾸기 -->
            <TextBlock Text="찾기 / 바꾸기" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="Ctrl + F"      Desc="찾기 포커스"/>
                <local:ShortcutEntry Key="Enter"         Desc="다음 결과로 이동"/>
                <local:ShortcutEntry Key="Shift + Enter" Desc="이전 결과로 이동"/>
                <local:ShortcutEntry Key="▲ / ▼ 버튼"   Desc="이전/다음 찾기 결과 이동 — 현재 결과는 주황색 강조, 자동 스크롤"/>
                <local:ShortcutEntry Key="검색 하이라이트" Desc="검색어 입력 시 뷰어에서 모든 일치 항목을 황색으로 표시, 현재 결과는 주황색"/>
                <local:ShortcutEntry Key="Ctrl + H"      Desc="찾기/바꾸기 바 토글 (편집 모드)"/>
                <local:ShortcutEntry Key="Alt + C"       Desc="대소문자 구분 검색 켜기/끄기 (Aa 버튼 — 켜짐 시 파란색)"/>
                <local:ShortcutEntry Key="Esc"           Desc="찾기 초기화 및 하이라이트 제거"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 동기 스크롤 / TOC -->
            <TextBlock Text="동기 스크롤 / TOC" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="편집 모드 스크롤" Desc="에디터 스크롤 → 뷰어 자동 동기화 (헤딩 기준 정밀 동기화)"/>
                <local:ShortcutEntry Key="TOC 켜짐 상태"   Desc="뷰어 스크롤 → 현재 섹션 자동 하이라이트"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 상태바 -->
            <TextBlock Text="상태바" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="줄:컬럼"              Desc="에디터 커서 위치 (편집 모드에서 표시)"/>
                <local:ShortcutEntry Key="N줄 · N단어 · 약 Nm" Desc="줄 수 / 단어 수 / 예상 읽기 시간 — 단어 수에 마우스 오버 시 헤딩·이미지·링크 수 툴팁 표시"/>
                <local:ShortcutEntry Key="선택: Nchar · N단어" Desc="텍스트 선택 시 상태바에 선택 글자 수 및 단어 수 표시"/>
                <local:ShortcutEntry Key="상태바 경로"          Desc="클릭 시 파일 탐색기에서 위치 열기"/>
              </ItemsControl.Items>
            </ItemsControl>

          </StackPanel>

          <!-- ── 컬럼 구분선 ── -->
          <Border Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                  HorizontalAlignment="Center" Margin="0,4,0,0"/>

          <!-- ── 오른쪽 컬럼: 편집/뷰어 계열 ── -->
          <StackPanel Grid.Column="2">

            <!-- 에디터 -->
            <TextBlock Text="에디터" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="Ctrl + E"           Desc="편집 모드 전환 (서식 도구모음 + 줄 번호 표시)"/>
                <local:ShortcutEntry Key="Ctrl + G"           Desc="줄 이동 — 번호 입력 후 Enter, 해당 줄로 커서 이동 (편집 모드)"/>
                <local:ShortcutEntry Key="Ctrl + B"           Desc="굵게 (선택 텍스트를 **bold** 처리)"/>
                <local:ShortcutEntry Key="Ctrl + I"           Desc="기울임 (선택 텍스트를 *italic* 처리)"/>
                <local:ShortcutEntry Key="Ctrl + K"           Desc="링크 삽입 [텍스트]() — 괄호 안에 URL 입력"/>
                <local:ShortcutEntry Key="Ctrl + +"           Desc="에디터 폰트 크기 증가"/>
                <local:ShortcutEntry Key="Ctrl + -"           Desc="에디터 폰트 크기 감소"/>
                <local:ShortcutEntry Key="Ctrl + 0"           Desc="에디터/프리뷰 폰트 크기 초기화 (13/15px)"/>
                <local:ShortcutEntry Key="Ctrl + 휠 (에디터)" Desc="에디터 위에서 폰트 크기 조절"/>
                <local:ShortcutEntry Key="Ctrl + 휠 (프리뷰)" Desc="프리뷰 위에서 글꼴 크기 조절"/>
                <local:ShortcutEntry Key="Alt + Z"            Desc="줄바꿈 토글 — 긴 줄 편집 시 wrap 끄기"/>
                <local:ShortcutEntry Key="Tab"                Desc="들여쓰기 (4칸) / 범위 들여쓰기"/>
                <local:ShortcutEntry Key="Shift + Tab"        Desc="내어쓰기 / 범위 내어쓰기"/>
                <local:ShortcutEntry Key="Ctrl + Enter"       Desc="즉시 미리보기 갱신 (편집 모드 — 300ms 타이머 없이 바로 반영)"/>
                <local:ShortcutEntry Key="Enter (목록 줄)"    Desc="- / * / 1. / &gt; 로 시작하는 줄에서 Enter → 같은 목록 항목 자동 계속. 내용 없는 빈 항목에서 Enter → 목록 종료"/>
                <local:ShortcutEntry Key="Ctrl + Shift + V"   Desc="서식 없는 붙여넣기 — 탭을 공백 4개로 변환 후 삽입"/>
                <local:ShortcutEntry Key="이미지 파일 D&amp;D" Desc="편집 모드에서 이미지 드래그 → ![alt](path) 자동 삽입"/>
                <local:ShortcutEntry Key="줄 번호"            Desc="편집 모드 진입 시 에디터 왼쪽에 줄 번호 자동 표시 (스크롤 동기화)"/>
                <local:ShortcutEntry Key="현재 줄 하이라이트"  Desc="편집 모드에서 커서가 위치한 줄을 미묘하게 강조 표시"/>
                <local:ShortcutEntry Key="커서 툴팁"          Desc="줄:컬럼 표시에 마우스 오버 → 현재 위치의 헤딩 구조(Breadcrumb) 표시"/>
                <local:ShortcutEntry Key="선택 후 [ ( &quot;"  Desc="선택 영역을 [ ] · ( ) · &quot; &quot; 로 자동 감싸기"/>
                <local:ShortcutEntry Key="선택 후 * 또는 `"   Desc="선택 영역을 * 또는 ` 로 자동 감싸기 (Ctrl+B/I 와 동일 효과)"/>
                <local:ShortcutEntry Key="탭 드래그 앤 드롭"   Desc="탭을 드래그하여 순서 재배치"/>
                <local:ShortcutEntry Key="에디터 우클릭"       Desc="잘라내기 · 복사 · 붙여넣기 · 전체 선택 + 굵게/기울임/코드/링크 서식 메뉴 (편집 모드)"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 서식 도구모음 -->
            <TextBlock Text="서식 도구모음 (편집 모드)" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="H1 / H2 / H3"   Desc="현재 줄을 헤딩으로 변환"/>
                <local:ShortcutEntry Key="B / I"           Desc="선택 텍스트 굵게/기울임 — 이미 서식 적용 시 재클릭으로 제거 (토글)"/>
                <local:ShortcutEntry Key="`C` 버튼"        Desc="선택 텍스트를 인라인 코드로 감쌈 (토글 지원)"/>
                <local:ShortcutEntry Key="``` 버튼"        Desc="코드 블록 삽입"/>
                <local:ShortcutEntry Key="🔗 버튼"         Desc="링크 삽입"/>
                <local:ShortcutEntry Key="❮ / •• / 1."     Desc="인용문 / 목록 / 번호 목록 삽입"/>
                <local:ShortcutEntry Key="── 버튼"         Desc="가로 구분선 삽입"/>
                <local:ShortcutEntry Key="표 버튼"         Desc="3×2 Markdown 표 템플릿 삽입 (제목행 + 구분행 + 내용행)"/>
                <local:ShortcutEntry Key="🖼 버튼"         Desc="이미지 파일 선택 다이얼로그 → ![alt](상대경로) 자동 삽입"/>
              </ItemsControl.Items>
            </ItemsControl>

            <!-- 뷰어 기능 -->
            <TextBlock Text="뷰어 기능" Style="{StaticResource Cat}"/>
            <ItemsControl ItemTemplate="{StaticResource RowTpl}">
              <ItemsControl.Items>
                <local:ShortcutEntry Key="코드 블록 hover"   Desc="Copy 버튼 표시 — 클릭 시 코드 클립보드 복사 (테마 색상 자동 적용)"/>
                <local:ShortcutEntry Key="이미지 클릭"       Desc="라이트박스로 원본 크기 확대 — ESC/클릭으로 닫기 · ← → 또는 ❮ ❯ 버튼으로 이전/다음 이미지"/>
                <local:ShortcutEntry Key="▲ 플로팅 버튼"    Desc="맨 위로 부드럽게 스크롤 (150px 이상 내리면 표시)"/>
                <local:ShortcutEntry Key="↩ 플로팅 버튼"    Desc="TOC 클릭 전 위치로 되돌아가기"/>
                <local:ShortcutEntry Key=".md 링크 클릭"     Desc="연결된 Markdown 파일을 앱 내 새 탭으로 열기"/>
                <local:ShortcutEntry Key="뷰어 우클릭"       Desc="텍스트 복사 · 링크 열기 · 링크 주소 복사 · 이미지 저장 · 모두 선택"/>
                <local:ShortcutEntry Key="```mermaid 블록"   Desc="Mermaid 다이어그램 렌더링 (플로우차트·시퀀스·간트 등)"/>
              </ItemsControl.Items>
            </ItemsControl>

          </StackPanel>
        </Grid>

      </Border>
    </ScrollViewer>
  </Grid>
</Window>
