<Window x:Class="StackCrash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stack.Crash" Height="680" Width="900"
        MinHeight="500" MinWidth="700"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>    <!-- 툴바 -->
      <RowDefinition Height="*"/>     <!-- 게임 영역 -->
      <RowDefinition Height="36"/>    <!-- 상태바 -->
    </Grid.RowDefinitions>

    <!-- ══ 툴바 ══════════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid Margin="10,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 레벨 선택 -->
        <TextBlock Grid.Column="0" Text="레벨:" Foreground="{StaticResource DimBrush}"
                   VerticalAlignment="Center" FontSize="13"/>
        <ComboBox  Grid.Column="2" x:Name="CmbLevel" Width="160" VerticalAlignment="Center"
                   SelectionChanged="CmbLevel_SelectionChanged"/>

        <!-- 이동 수 / 최대 -->
        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="이동:" Foreground="{StaticResource DimBrush}" FontSize="13" Margin="0,0,4,0"/>
          <TextBlock x:Name="TxtMoves" Text="0" Foreground="{StaticResource AccentBrush}"
                     FontSize="15" FontWeight="Bold" Margin="0,0,2,0"/>
          <TextBlock x:Name="TxtMaxMoves" Text="/ ∞" Foreground="{StaticResource DimBrush}" FontSize="13"/>
        </StackPanel>

        <!-- 버튼들 -->
        <Button Grid.Column="6" x:Name="BtnSimulate" Content="▶ 시뮬레이션"
                Click="BtnSimulate_Click" Width="110"/>
        <Button Grid.Column="8" x:Name="BtnReset" Content="↺ 리셋"
                Click="BtnReset_Click" Width="70"/>
      </Grid>
    </Border>

    <!-- ══ 게임 영역 ══════════════════════════════════════════════════ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="200"/>
      </Grid.ColumnDefinitions>

      <!-- 게임 캔버스 -->
      <Border Grid.Column="0" ClipToBounds="True">
        <!-- 하늘 배경 그라디언트 -->
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0D1117" Offset="0"/>
            <GradientStop Color="#161B22" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>

        <Canvas x:Name="GameCanvas" Background="Transparent"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                SizeChanged="Canvas_SizeChanged"/>
      </Border>

      <!-- 우측 패널 -->
      <Border Grid.Column="1" Background="{StaticResource PanelBrush}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
        <StackPanel Margin="14,14,14,10">

          <!-- 레벨 정보 -->
          <TextBlock x:Name="TxtLevelName" Text="레벨 이름"
                     Foreground="{StaticResource TextBrush}"
                     FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
          <TextBlock x:Name="TxtLevelDesc" Text="설명"
                     Foreground="{StaticResource DimBrush}"
                     FontSize="11" TextWrapping="Wrap" Margin="0,4,0,12"/>

          <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

          <!-- 별 조건 -->
          <TextBlock Text="별 조건" Foreground="{StaticResource DimBrush}" FontSize="11" Margin="0,0,0,6"/>
          <StackPanel x:Name="StarPanel" Margin="0,0,0,14"/>

          <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

          <!-- 재질 범례 -->
          <TextBlock Text="재질" Foreground="{StaticResource DimBrush}" FontSize="11" Margin="0,0,0,6"/>
          <StackPanel x:Name="LegendPanel"/>

          <Separator Background="{StaticResource BorderBrush}" Margin="0,14,0,12"/>

          <!-- 게임 결과 -->
          <Border x:Name="ResultPanel" Visibility="Collapsed"
                  Background="#1F6FEB22" BorderBrush="{StaticResource GreenBrush}"
                  BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel>
              <TextBlock x:Name="TxtResult"   Text="결과"
                         Foreground="{StaticResource GreenBrush}"
                         FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtStars"    Text="★★★"
                         Foreground="{StaticResource YellowBrush}"
                         FontSize="28" HorizontalAlignment="Center" Margin="0,4,0,0"/>
              <Button    x:Name="BtnNext"     Content="다음 레벨 →"
                         Click="BtnNext_Click" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border x:Name="LosePanel" Visibility="Collapsed"
                  Background="#F7816622" BorderBrush="{StaticResource AccentBrush}"
                  BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel>
              <TextBlock Text="실패!" Foreground="{StaticResource AccentBrush}"
                         FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock Text="다시 도전해보세요" Foreground="{StaticResource DimBrush}"
                         FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
              <Button Content="↺ 다시 시도" Click="BtnReset_Click" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </Border>
    </Grid>

    <!-- ══ 상태바 ══════════════════════════════════════════════════════ -->
    <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
      <Grid Margin="12,0">
        <TextBlock x:Name="TxtStatus" Text="레벨을 선택하고 블록을 클릭해 제거하세요."
                   Foreground="{StaticResource DimBrush}" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock x:Name="TxtBlockCount" HorizontalAlignment="Right"
                   Foreground="{StaticResource DimBrush}" VerticalAlignment="Center" FontSize="12"/>
      </Grid>
    </Border>

  </Grid>
</Window>
