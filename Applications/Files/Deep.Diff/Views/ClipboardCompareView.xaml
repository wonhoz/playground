<UserControl x:Class="DeepDiff.Views.ClipboardCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DeepDiff.Views"
             Background="#0F0F1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📋 클립보드 비교" FontSize="15" FontWeight="SemiBold"
                           Foreground="#E8E8F0" VerticalAlignment="Center"/>
                <TextBlock Text="두 패널에 텍스트를 직접 붙여넣거나 입력하면 실시간으로 비교합니다."
                           Foreground="#8888AA" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 툴바 -->
        <Border Grid.Row="1" Background="#0F0F1E" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="10,6">
            <WrapPanel Orientation="Horizontal">
                <Button Content="📋 왼쪽에 붙여넣기" Click="BtnPasteLeft_Click" ToolTip="클립보드 내용을 왼쪽에 붙여넣기"/>
                <Button Content="📋 오른쪽에 붙여넣기" Click="BtnPasteRight_Click" ToolTip="클립보드 내용을 오른쪽에 붙여넣기"/>
                <Button Content="⇆ 교환" Click="BtnSwap_Click"/>
                <Button Content="🗑 지우기" Click="BtnClear_Click"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <Button Content="◀ 이전 차이" Click="BtnPrevDiff_Click"/>
                <Button Content="다음 차이 ▶" Click="BtnNextDiff_Click"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <CheckBox x:Name="ChkLiveUpdate" Content="실시간 업데이트" IsChecked="True"
                          VerticalAlignment="Center"/>
                <CheckBox x:Name="ChkIgnoreWS" Content="공백 무시"
                          VerticalAlignment="Center" Checked="ChkOption_Changed" Unchecked="ChkOption_Changed"/>
            </WrapPanel>
        </Border>

        <!-- 편집 + diff 뷰 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.4*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="0.6*"/>
            </Grid.RowDefinitions>

            <!-- 입력 영역 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#0A0A1A" Padding="8,4" BorderBrush="#2E2E55" BorderThickness="0,0,0,1">
                        <TextBlock Text="왼쪽 텍스트" Foreground="#5B8FFF" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <TextBox x:Name="TxtLeft" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="#0D0D20" Foreground="#E8E8F0"
                             BorderThickness="0" Padding="8"
                             TextWrapping="NoWrap"
                             TextChanged="TxtInput_Changed"/>
                </Grid>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#0A0A1A" Padding="8,4" BorderBrush="#2E2E55" BorderThickness="0,0,0,1">
                        <TextBlock Text="오른쪽 텍스트" Foreground="#3FC878" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <TextBox x:Name="TxtRight" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="#0D0D20" Foreground="#E8E8F0"
                             BorderThickness="0" Padding="8"
                             TextWrapping="NoWrap"
                             TextChanged="TxtInput_Changed"/>
                </Grid>
            </Grid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"/>

            <!-- diff 결과 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#0A0A1A" Padding="8,4" BorderBrush="#2E2E55" BorderThickness="0,0,0,1">
                        <TextBlock Text="Diff 결과 — 왼쪽" Foreground="#8888AA" FontSize="11"/>
                    </Border>
                    <ScrollViewer x:Name="DiffLeftScroll" Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden"
                                  ScrollChanged="DiffLeftScroll_ScrollChanged">
                        <ItemsControl x:Name="DiffLeftList"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Background="{Binding LeftBg}" MinHeight="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding LeftLineNumText}"
                                                   Foreground="#55556A" FontFamily="Consolas" FontSize="11"
                                                   HorizontalAlignment="Right" Padding="0,1,4,1"/>
                                        <Border Grid.Column="1" Background="{Binding StatusBarColor}"/>
                                        <local:HighlightedTextBlock Grid.Column="2"
                                                   Segments="{Binding LeftSegments}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="#E8E8F0" Padding="4,1"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#0A0A1A" Padding="8,4" BorderBrush="#2E2E55" BorderThickness="0,0,0,1">
                        <TextBlock Text="Diff 결과 — 오른쪽" Foreground="#8888AA" FontSize="11"/>
                    </Border>
                    <ScrollViewer x:Name="DiffRightScroll" Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  ScrollChanged="DiffRightScroll_ScrollChanged">
                        <ItemsControl x:Name="DiffRightList"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Background="{Binding RightBg}" MinHeight="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding RightLineNumText}"
                                                   Foreground="#55556A" FontFamily="Consolas" FontSize="11"
                                                   HorizontalAlignment="Right" Padding="0,1,4,1"/>
                                        <Border Grid.Column="1" Background="{Binding StatusBarColor}"/>
                                        <local:HighlightedTextBlock Grid.Column="2"
                                                   Segments="{Binding RightSegments}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="#E8E8F0" Padding="4,1"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TbStatus" Foreground="#8888AA" FontSize="12"
                           Text="위에 텍스트를 입력하면 자동으로 비교됩니다."/>
                <TextBlock x:Name="TbDiffInfo" Grid.Column="1" Foreground="#F0B030" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
