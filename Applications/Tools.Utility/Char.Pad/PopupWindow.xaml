<Window x:Class="CharPad.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Char.Pad"
        Width="575" Height="420"
        MinWidth="420" MinHeight="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <Style x:Key="KeyStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#E0E0E0"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,4,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DescStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#B0B0B0"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,4,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#000000"/>
    </Window.Effect>

    <Border x:Name="RootBorder"
            Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 헤더 -->
                <RowDefinition Height="Auto"/>   <!-- 검색 -->
                <RowDefinition Height="Auto"/>   <!-- 탭 -->
                <RowDefinition Height="*"/>      <!-- 문자 그리드 -->
                <RowDefinition Height="Auto"/>   <!-- 상태바 -->
            </Grid.RowDefinitions>

            <!-- ── 헤더 ── -->
            <Grid Grid.Row="0" Margin="16,12,12,0"
                  MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⌨ Char.Pad"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button x:Name="AddCustomBtn"
                        Grid.Column="1" Width="28" Height="28"
                        Content="+" FontSize="14" FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        Click="AddCustomBtn_Click"
                        ToolTip="사용자 정의 문자 추가"/>
                <Button x:Name="PinBtn"
                        Grid.Column="2" Width="28" Height="28"
                        Content="📌" FontSize="11"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        Click="PinBtn_Click"
                        ToolTip="핀 고정 — 삽입 후 팝업 유지 (이전 창에 자동 붙여넣기)"/>
                <Button Grid.Column="3" Width="28" Height="28"
                        Content="?" FontSize="12" FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        Click="HelpBtn_Click"
                        ToolTip="단축키 안내"/>
                <Button Grid.Column="4" Width="28" Height="28"
                        Content="✕" FontSize="11"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        Click="CloseBtn_Click"
                        ToolTip="닫기 (Esc)"/>
            </Grid>

            <!-- ── 검색 ── -->
            <Grid Grid.Row="1" Margin="12,10,12,0">
                <TextBox x:Name="SearchBox"
                         Height="34"
                         Text=""
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"/>
                <TextBlock x:Name="SearchPlaceholder"
                           Text="🔍  문자 이름으로 검색… (예: arrow, copyright, 😀)"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="Segoe UI" FontSize="12"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>

            <!-- ── 카테고리 탭 ── -->
            <ScrollViewer Grid.Row="2" Margin="12,8,12,0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TabPanel" Orientation="Horizontal" Height="32">
                    <!-- 탭은 코드에서 동적 생성 -->
                </StackPanel>
            </ScrollViewer>

            <!-- ── 문자 그리드 ── -->
            <Grid Grid.Row="3" Margin="12,8,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="CharGrid"
                               Orientation="Horizontal"
                               ItemWidth="52" ItemHeight="52"/>
                </ScrollViewer>

                <!-- 결과 없음 안내 -->
                <TextBlock x:Name="EmptyText"
                           Text="검색 결과가 없습니다"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="Segoe UI" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- 도움말 오버레이 (? 버튼 클릭 시 표시) -->
                <Border x:Name="HelpOverlay"
                        Background="#F01A1A2E"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Panel.ZIndex="10"
                        PreviewMouseDown="HelpOverlay_MouseDown">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,6,0">
                    <StackPanel HorizontalAlignment="Center"
                                Margin="24,16,24,16">
                        <TextBlock Text="⌨ 단축키 안내"
                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 단축키 행들 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Win+Shift+;"       Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="팝업 열기/닫기"    Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Esc"                Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="검색어 지우기 / 팝업 닫기" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Enter"              Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="첫 번째 문자 삽입"  Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Alt+1~9"            Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="탭 바로 이동 (최근·즐겨찾기·화살표 …)" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="↓ / Tab"            Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="검색창 → 문자 그리드로 포커스 이동" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="← → ↑ ↓"           Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="그리드 내 문자 이동" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Esc (그리드)"       Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="검색창으로 포커스 복귀" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="좌클릭"              Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="7" Grid.Column="2" Text="문자 삽입 (클립보드 → 이전 창에 붙여넣기)" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Shift+클릭"          Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="8" Grid.Column="2" Text="클립보드 복사만 (붙여넣기 없음)" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="우클릭 / F (그리드)" Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="9" Grid.Column="2" Text="즐겨찾기 추가/제거 (사용자 탭: 삭제)" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Ctrl+휠"            Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="10" Grid.Column="2" Text="문자 크기 조절 (14~36px)" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="+ 버튼"             Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="11" Grid.Column="2" Text="사용자 정의 문자 추가"  Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="12" Grid.Column="0" Text="📌 버튼"            Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="12" Grid.Column="2" Text="핀 고정 — 삽입 후 팝업 유지 (테두리 강조)" Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="13" Grid.Column="0" Text="⠿ 핸들 드래그"     Style="{StaticResource KeyStyle}"/>
                            <TextBlock Grid.Row="13" Grid.Column="2" Text="팝업 크기 조절 (크기 자동 저장)"  Style="{StaticResource DescStyle}"/>

                            <TextBlock Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="3"
                                       Text="아무 곳이나 클릭하면 닫힙니다"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="Segoe UI" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        </Grid>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── 상태바 ── -->
            <Border Grid.Row="4"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="14,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Win+Shift+;"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Segoe UI" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <!-- 크기 조절 핸들 (우측 하단) -->
                        <TextBlock Text="⠿"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Cursor="SizeNWSE"
                                   ToolTip="드래그하여 크기 조절"
                                   MouseLeftButtonDown="ResizeGrip_MouseDown"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>


</Window>
