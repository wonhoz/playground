<Window x:Class="SchemaMock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schema.Mock" Height="680" Width="1100"
        Background="#0F0F1E" Foreground="#E0E0E0"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <!-- TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Padding="{TemplateBinding Padding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                    Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#888888"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#252538" BorderBrush="#444466" BorderThickness="1" CornerRadius="4">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A2A50"/>
                                <Setter Property="Foreground" Value="#50C8DC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#0F0F1E"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <!-- TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0" Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#50C8DC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#202038"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="RowBackground" Value="#13132A"/>
            <Setter Property="AlternatingRowBackground" Value="#16162E"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E1E35"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#7777AA"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2A45"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- 툴바 -->
        <Border Grid.Row="0" Background="#14142A" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="🎲 Schema.Mock" FontSize="14" FontWeight="Bold"
                           Foreground="#50C8DC" Margin="0,0,20,0"/>
                <TextBlock Text="JSON Schema / OpenAPI 3.x → 가짜(Faker) 데이터 생성기" FontSize="11"
                           Foreground="#666688" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 메인 레이아웃 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 입력 패널 -->
            <Border Grid.Column="0" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Margin="6,6,3,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <Border Background="#1A1A30" CornerRadius="6,6,0,0">
                        <TextBlock Text="스키마 / OpenAPI 입력" FontSize="11" Foreground="#7777AA"
                                   VerticalAlignment="Center" Margin="8,0"/>
                    </Border>

                    <!-- 스키마 입력 -->
                    <TextBox x:Name="TxtSchema" Grid.Row="1"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="#13132A" BorderThickness="0"
                             TextChanged="TxtSchema_TextChanged"
                             ToolTip="JSON Schema 또는 OpenAPI 3.x YAML/JSON을 붙여넣기"/>

                    <!-- URL 가져오기 -->
                    <Border Grid.Row="2" Background="#14142A" Padding="6,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="URL:" FontSize="11" Foreground="#7777AA"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtUrl" Width="180" FontFamily="Consolas" FontSize="11"
                                     VerticalContentAlignment="Center" Padding="4,2"
                                     ToolTip="OpenAPI/Schema URL을 입력하고 가져오기"/>
                            <Button x:Name="BtnFetchUrl" Click="BtnFetchUrl_Click"
                                    Margin="4,0,0,0" Padding="6,3" FontSize="10">↓ 가져오기</Button>
                        </StackPanel>
                    </Border>

                    <!-- OpenAPI 스키마 선택 -->
                    <Border x:Name="PanelOapiSelector" Grid.Row="3"
                            Background="#16162C" Padding="6,4" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="스키마:" FontSize="11" Foreground="#A0C0FF"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CmbOapiSchema" Width="200" FontSize="11"
                                      SelectionChanged="CmbOapiSchema_SelectionChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- 분석 버튼 -->
                    <Border Grid.Row="4" Background="#14142A" Padding="6,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LblDetected" Text="형식: —" FontSize="10"
                                       Foreground="#888888" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button x:Name="BtnAnalyze" Click="BtnAnalyze_Click"
                                    Padding="8,4" FontSize="11">🔍 분석</Button>
                            <Button x:Name="BtnClearInput" Click="BtnClearInput_Click"
                                    Margin="4,0,0,0" Padding="6,4" FontSize="11">✕</Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="#1A1A30" HorizontalAlignment="Stretch"/>

            <!-- 오른쪽: 탭 결과 -->
            <Border Grid.Column="2" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Margin="3,6,6,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="44"/>
                    </Grid.RowDefinitions>

                    <TabControl x:Name="ResultTabs" BorderThickness="0">

                        <!-- 탭 1: 필드 설정 -->
                        <TabItem Header="🔧 필드 설정">
                            <DataGrid x:Name="GridFields">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="필드명" Binding="{Binding Name}"
                                                        Width="160" FontFamily="Consolas" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="타입" Binding="{Binding TypeDisplay}"
                                                        Width="70" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="형식" Binding="{Binding Format}"
                                                        Width="80" IsReadOnly="True" Foreground="#7777AA"/>
                                    <!-- Faker 전략 ComboBox는 코드에서 추가 -->
                                    <DataGridTextColumn Header="샘플 미리보기" Binding="{Binding Preview}"
                                                        Width="*" IsReadOnly="True" FontFamily="Consolas"
                                                        Foreground="#A0E080"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- 탭 2: 출력 -->
                        <TabItem Header="📄 출력">
                            <TextBox x:Name="TxtOutput" AcceptsReturn="True"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas" FontSize="11"
                                     Background="#0D0D1E" Foreground="#A0E080"
                                     BorderThickness="0"/>
                        </TabItem>

                    </TabControl>

                    <!-- 하단 컨트롤 바 -->
                    <Border Grid.Row="1" Background="#14142A" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="건수:" FontSize="11" Foreground="#7777AA"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtCount" Text="10" Width="55"
                                     FontFamily="Consolas" FontSize="11"
                                     VerticalContentAlignment="Center" Padding="4,2"/>

                            <TextBlock Text="출력 형식:" FontSize="11" Foreground="#7777AA"
                                       VerticalAlignment="Center" Margin="10,0,4,0"/>
                            <ComboBox x:Name="CmbFormat" Width="120" FontSize="11">
                                <ComboBoxItem Content="JSON Array" IsSelected="True"/>
                                <ComboBoxItem Content="NDJSON"/>
                                <ComboBoxItem Content="CSV"/>
                            </ComboBox>

                            <Button x:Name="BtnGenerate" Click="BtnGenerate_Click"
                                    Margin="10,0,0,0" Padding="10,4" FontSize="11"
                                    Background="#1A3A2A" BorderBrush="#2A6A4A">🎲 생성</Button>
                            <Button x:Name="BtnCopy" Click="BtnCopy_Click"
                                    Margin="4,0,0,0" Padding="8,4" FontSize="11">📋 복사</Button>
                            <Button x:Name="BtnSave" Click="BtnSave_Click"
                                    Margin="4,0,0,0" Padding="8,4" FontSize="11">💾 저장</Button>

                            <TextBlock x:Name="LblOutputInfo" Margin="12,0,0,0"
                                       FontSize="10" Foreground="#666688"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#0A0A1A" BorderBrush="#1A1A30" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar" Margin="10,0" VerticalAlignment="Center"
                       FontSize="10" Foreground="#666688"/>
        </Border>
    </Grid>
</Window>
