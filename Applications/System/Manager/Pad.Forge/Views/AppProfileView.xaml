<UserControl x:Class="PadForge.Views.AppProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="앱별 자동 프로파일 전환" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Foreground="{StaticResource BrTextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16">
            특정 앱 실행 시 자동으로 지정된 프로파일로 전환됩니다.
            프로세스 이름 예시: sekiro.exe, notepad.exe
        </TextBlock>

        <ItemsControl ItemsSource="{Binding Profile.AppProfiles}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource BrBgCard}"
                            BorderBrush="{StaticResource BrBorder}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition /><ColumnDefinition Width="16" /><ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="프로세스 이름 (예: sekiro.exe)" />
                            <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrTextSecondary}" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding ProfileId, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="프로파일 ID" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="+ 앱 추가" Margin="0,8,0,0"
                HorizontalAlignment="Left"
                Click="AddApp_Click" />
    </StackPanel>
</UserControl>
