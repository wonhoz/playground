<UserControl x:Class="HashCheck.Views.WatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 폴더 감시 설정 바 ──────────────────────────────────── -->
        <Border Grid.Row="0" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtWatchFolder" Grid.Column="0" Height="32" IsReadOnly="True"
                         Text="감시할 폴더를 선택하세요..." Foreground="#888899"
                         VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="📁 폴더 선택" Width="100" Height="32"
                        Click="BtnPickFolder_Click" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="▶ 감시 시작" Width="100" Height="32"
                        Click="BtnStartWatch_Click" x:Name="BtnStartWatch"
                        IsEnabled="False" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="⏹ 감시 중단" Width="100" Height="32"
                        Click="BtnStopWatch_Click" x:Name="BtnStopWatch"
                        IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- ── 파일 추가 바 ───────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="알고리즘:" Foreground="#888899" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1" x:Name="CbAlgo" Width="110" Height="28"
                          SelectedIndex="2" Margin="0,0,20,0"
                          SelectionChanged="CbAlgo_SelectionChanged">
                    <ComboBoxItem Content="MD5"/>
                    <ComboBoxItem Content="SHA-1"/>
                    <ComboBoxItem Content="SHA-256"/>
                    <ComboBoxItem Content="SHA-512"/>
                </ComboBox>
                <TextBlock Grid.Column="2" Text="파일을 드래그하거나 아래 버튼으로 추가하세요."
                           Foreground="#555566" FontSize="12" VerticalAlignment="Center"
                           AllowDrop="True" Drop="Files_Drop" DragOver="Files_DragOver"/>
                <Button Grid.Column="3" Content="파일 추가" Width="90" Height="30"
                        Click="BtnAddFile_Click" Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="지금 검증" Width="90" Height="30"
                        Click="BtnVerifyNow_Click" x:Name="BtnVerifyNow"
                        IsEnabled="False" Margin="0,0,8,0"/>
                <Button Grid.Column="5" Content="목록 지우기" Width="90" Height="30"
                        Click="BtnClearAll_Click"/>
            </Grid>
        </Border>

        <!-- ── 감시 목록 ──────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6">
            <ListView x:Name="LvWatch" Background="Transparent"
                      BorderThickness="0" Foreground="#D4D4D4"
                      AllowDrop="True" Drop="Files_Drop" DragOver="Files_DragOver">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="36">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusIcon}"
                                               Foreground="{Binding StatusColor}"
                                               FontSize="16" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="파일명" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}"
                                               ToolTip="{Binding FilePath}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="알고리즘" Width="72">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AlgoText}" Foreground="#888899"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="스냅샷 해시" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding BaseHash}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="#888899"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="현재 해시" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CurrentHash}"
                                               Foreground="{Binding StatusColor}"
                                               FontFamily="Consolas" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="마지막 확인" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LastCheckedText}"
                                               Foreground="#888899" FontSize="11"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="선택 항목 제거" Click="MenuRemove_Click"/>
                        <MenuItem Header="스냅샷 갱신" Click="MenuRefreshSnapshot_Click"/>
                    </ContextMenu>
                </ListView.ContextMenu>
            </ListView>
        </Border>

        <!-- ── 상태 바 ────────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" x:Name="WatchIndicator"
                    Background="#2A2A3E" CornerRadius="10" Padding="8,4" Margin="0,0,10,0">
                <TextBlock x:Name="TxtWatchStatus" Text="● 감시 중단"
                           Foreground="#888899" FontSize="12"/>
            </Border>
            <TextBlock Grid.Column="1" x:Name="TxtChangedCount" Foreground="#EF4444"
                       FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="2" x:Name="TxtSummary" Foreground="#888899"
                       FontSize="12" VerticalAlignment="Center"
                       Text="파일을 추가하여 무결성 감시를 시작하세요."/>
        </Grid>
    </Grid>
</UserControl>
