<Window x:Class="Tag.Forge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Tag.Forge.ViewModels"
        Title="Tag.Forge — 음악 태그 편집기"
        Width="1080" Height="620"
        MinWidth="800" MinHeight="480"
        Background="#13131F" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="12"
        AllowDrop="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- 버튼 스타일 -->
        <Style x:Key="TbBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderBrush"     Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="11,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252535"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Background"  Value="#1E3A5E"/>
            <Setter Property="Foreground"  Value="#60A5FA"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Background"  Value="#14432A"/>
            <Setter Property="Foreground"  Value="#4ADE80"/>
            <Setter Property="BorderBrush" Value="#166534"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
        </Style>

        <!-- TextBox 다크 -->
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#1A1A2A"/>
            <Setter Property="Foreground"   Value="#D0D0D0"/>
            <Setter Property="BorderBrush"  Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,3"/>
            <Setter Property="CaretBrush"   Value="#60A5FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid 다크 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="#E0E0E0"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1A1A2E"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#0C0C18"/>
            <Setter Property="SelectionMode"            Value="Extended"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="ColumnHeaderHeight"       Value="32"/>
            <Setter Property="RowHeight"                Value="32"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A2A4A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C1C2C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="7,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#16162A"/>
            <Setter Property="Foreground"      Value="#888899"/>
            <Setter Property="Padding"         Value="7,0"/>
            <Setter Property="BorderBrush"     Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 스크롤바 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="Width"      Value="8"/>
            <Setter Property="MinWidth"   Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Bd" Background="#3A3A55" CornerRadius="4" Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#5A5A7A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>  <!-- 툴바 -->
            <RowDefinition Height="*"/>   <!-- 메인 콘텐츠 -->
            <RowDefinition Height="Auto"/><!-- 파일명↔태그 패턴 바 -->
            <RowDefinition Height="34"/>  <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ── 툴바 ────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#16162A" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="10,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnOpen"   Style="{StaticResource AccentBtn}" Content="📂 폴더 열기"  Click="BtnOpen_Click"/>
                <Button x:Name="BtnSaveAll" Style="{StaticResource GreenBtn}" Content="💾 전체 저장"  Margin="6,0,0,0"
                        Click="BtnSaveAll_Click"/>
                <Button x:Name="BtnSaveSel" Style="{StaticResource TbBtn}" Content="💾 선택 저장"  Margin="4,0,0,0"
                        Click="BtnSaveSel_Click"/>
                <Separator Background="#2A2A3E" Width="1" Height="20" Margin="8,0"/>
                <Button x:Name="BtnRemove"  Style="{StaticResource DangerBtn}" Content="✕ 제거"      Margin="0,0,4,0"
                        Click="BtnRemove_Click"/>
                <Button x:Name="BtnClear"   Style="{StaticResource DangerBtn}" Content="🗑 전체 삭제" Click="BtnClear_Click"/>
                <Separator Background="#2A2A3E" Width="1" Height="20" Margin="8,0"/>
                <Button x:Name="BtnAutoNum" Style="{StaticResource TbBtn}" Content="🔢 자동 번호"   Click="BtnAutoNum_Click"/>
                <Button x:Name="BtnMB"      Style="{StaticResource TbBtn}" Content="🌐 MusicBrainz" Margin="4,0,0,0"
                        IsEnabled="{Binding IsNotBusy}" Click="BtnMB_Click"/>
                <Button x:Name="BtnCancel"  Style="{StaticResource DangerBtn}" Content="■ 취소" Margin="4,0,0,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>

        <!-- ── 메인 콘텐츠 (DataGrid + 앨범아트) ──────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <DataGrid Grid.Column="0" x:Name="TrackGrid"
                      ItemsSource="{Binding Tracks}"
                      SelectionChanged="TrackGrid_SelectionChanged"
                      CellEditEnding="TrackGrid_CellEditEnding">
                <DataGrid.Columns>
                    <!-- 수정 표시 스트라이프 -->
                    <DataGridTemplateColumn Width="4" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:TrackViewModel}">
                                <Border Background="{Binding RowColor}" Width="4"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="#"      Binding="{Binding Track}"       Width="42"  IsReadOnly="False"/>
                    <DataGridTextColumn Header="파일명"  Binding="{Binding FileName}"    Width="180" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#888899"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="제목"   Binding="{Binding Title,   UpdateSourceTrigger=LostFocus}" Width="200" IsReadOnly="False"/>
                    <DataGridTextColumn Header="아티스트" Binding="{Binding Artist,  UpdateSourceTrigger=LostFocus}" Width="150" IsReadOnly="False"/>
                    <DataGridTextColumn Header="앨범"   Binding="{Binding Album,   UpdateSourceTrigger=LostFocus}" Width="160" IsReadOnly="False"/>
                    <DataGridTextColumn Header="연도"   Binding="{Binding Year,    UpdateSourceTrigger=LostFocus}" Width="56"  IsReadOnly="False"/>
                    <DataGridTextColumn Header="장르"   Binding="{Binding Genre,   UpdateSourceTrigger=LostFocus}" Width="*"   IsReadOnly="False"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu Background="#1E1E2E" BorderBrush="#2A2A3E" Foreground="#E0E0E0">
                        <MenuItem Header="💾 선택 저장"    Click="BtnSaveSel_Click"/>
                        <MenuItem Header="🔢 자동 번호"   Click="BtnAutoNum_Click"/>
                        <MenuItem Header="🌐 MusicBrainz 조회" Click="BtnMB_Click"/>
                        <Separator Background="#2A2A3E"/>
                        <MenuItem Header="📁 파일 위치 열기" Click="OpenFileLocation_Click"/>
                        <Separator Background="#2A2A3E"/>
                        <MenuItem Header="✕ 목록에서 제거"  Click="BtnRemove_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <!-- 앨범아트 패널 -->
            <Border Grid.Column="1" Width="160" Background="#0E0E1C" BorderBrush="#1E1E2E" BorderThickness="1,0,0,0" Padding="12">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="앨범 아트" Foreground="#555566" FontSize="10" Margin="0,0,0,8"/>
                    <Border x:Name="ArtBorder" Width="136" Height="136"
                            Background="#1A1A2A" BorderBrush="#2A2A3E" BorderThickness="1" CornerRadius="4">
                        <Image x:Name="ArtImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Button x:Name="BtnArt" Style="{StaticResource TbBtn}" Content="🖼 아트 변경"
                            Margin="0,8,0,0" HorizontalAlignment="Stretch" Click="BtnArt_Click"/>
                    <Button x:Name="BtnArtClear" Style="{StaticResource DangerBtn}" Content="✕ 아트 삭제"
                            Margin="0,4,0,0" HorizontalAlignment="Stretch" Click="BtnArtClear_Click"/>
                    <Separator Background="#1E1E2E" Margin="0,12"/>
                    <TextBlock Text="선택 정보" Foreground="#555566" FontSize="10" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtSelCount" Text="선택 없음" Foreground="#666677" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── 파일명↔태그 패턴 바 ──────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#16162A" BorderBrush="#1E1E2E" BorderThickness="0,1,0,1" Padding="10,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="패턴:" Foreground="#666677" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtPattern" Width="280" Text="{}{track} - {artist} - {title}"
                         VerticalAlignment="Center" FontFamily="Consolas" FontSize="11"/>
                <Button Style="{StaticResource TbBtn}" Content="파일명 → 태그" Margin="6,0,0,0"
                        Click="BtnFilenameToTag_Click"/>
                <Button Style="{StaticResource TbBtn}" Content="태그 → 파일명" Margin="4,0,0,0"
                        Click="BtnTagToFilename_Click"/>
                <TextBlock Foreground="#555566" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="10"
                           Text="토큰: {track} {artist} {title} {album} {year} {genre}"/>
            </StackPanel>
        </Border>

        <!-- ── 상태바 ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#16162A" Padding="12,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Foreground="#555566" FontSize="10" VerticalAlignment="Center"
                           Text="드래그&amp;드롭으로 파일/폴더 추가" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Status}" Foreground="#555566" VerticalAlignment="Center" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>


</Window>
