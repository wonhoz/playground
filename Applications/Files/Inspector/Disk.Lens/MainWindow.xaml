<Window x:Class="DiskLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DiskLens"
        xmlns:models="clr-namespace:DiskLens.Models"
        Title="Disk.Lens"
        Width="1200" Height="760" MinWidth="800" MinHeight="500"
        Background="#1A1A1A"
        FontFamily="Segoe UI" FontSize="13"
        Icon="Resources/app.ico"
        WindowStartupLocation="CenterScreen"
>

    <Window.Resources
>
        <!-- 컨버터 -->
        <local:PercentToWidthConverter x:Key="PctToWidthConv" ColumnWidth="150"/>


        <!-- 크기 바 색상 그라데이션 -->
        <LinearGradientBrush x:Key="SizeBarBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2979FF" Offset="0"/>
            <GradientStop Color="#4FC3F7" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SizeBarBrushFile" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1B5E20" Offset="0"/>
            <GradientStop Color="#66BB6A" Offset="1"/>
        </LinearGradientBrush>

        <!-- 트리 아이템 행 템플릿 -->
        <HierarchicalDataTemplate x:Key="TreeItemTemplate"
                                  DataType="{x:Type models:DiskItem}"
                                  ItemsSource="{Binding Children}">
            <Grid Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="150"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <!-- 이름 컬럼 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0">
                    <TextBlock Text="{Binding Icon}" Margin="0,0,5,0" FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TbName" Text="{Binding Name}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Foreground="#E0E0E0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter Property="Foreground" Value="#B3E5FC"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccessDenied}" Value="True">
                                        <Setter Property="Foreground" Value="#EF5350"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- 크기 바 -->
                <Grid Grid.Column="1" Margin="4,3">
                    <Border Background="#252525" CornerRadius="2"/>
                    <Border x:Name="SizeBarFill" HorizontalAlignment="Left" CornerRadius="2"
                            Height="10" VerticalAlignment="Center"
                            Width="{Binding PercentOfParent, Converter={StaticResource PctToWidthConv}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource SizeBarBrushFile}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SizeBarBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>

                <!-- 크기 텍스트 -->
                <TextBlock Grid.Column="2" Text="{Binding SizeText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#E0E0E0"/>

                <!-- 할당 크기 -->
                <TextBlock Grid.Column="3" Text="{Binding AllocatedText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#666"/>

                <!-- % -->
                <TextBlock Grid.Column="4" Text="{Binding PercentText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#888"/>

                <!-- 파일 수 -->
                <TextBlock Grid.Column="5" Text="{Binding FileCountText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#888"/>

                <!-- 수정일 -->
                <TextBlock Grid.Column="6" Text="{Binding LastModifiedText}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="8,0,4,0" Foreground="#666"/>
            </Grid>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 툴바 -->
            <RowDefinition Height="Auto"/>  <!-- 브레드크럼 -->
            <RowDefinition Height="Auto"/>  <!-- 탭 & 드라이브 정보 -->
            <RowDefinition Height="*"/>     <!-- 메인 콘텐츠 -->
            <RowDefinition Height="Auto"/>  <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: 툴바
        ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 드라이브 선택 -->
                <TextBlock Grid.Column="0" Text="드라이브:" VerticalAlignment="Center"
                           Margin="0,0,6,0" Foreground="#888"/>
                <ComboBox Grid.Column="1" x:Name="CbDrive" Width="140"
                          SelectionChanged="CbDrive_SelectionChanged"/>

                <!-- 경로 입력 -->
                <TextBox Grid.Column="2" x:Name="TxtPath" Margin="8,0"
                         VerticalAlignment="Center"
                         KeyDown="TxtPath_KeyDown"
                         ToolTip="경로를 직접 입력하고 Enter"/>

                <!-- 스캔 버튼 -->
                <Button Grid.Column="3" x:Name="BtnScan" Content="▶  스캔"
                        Margin="0,0,4,0" Click="BtnScan_Click"
                        Background="#1E4A6A" Foreground="#4FC3F7"
                        BorderBrush="#2979FF"/>

                <!-- 중지 버튼 -->
                <Button Grid.Column="4" x:Name="BtnCancel" Content="■  중지"
                        Margin="0,0,4,0" Click="BtnCancel_Click"
                        IsEnabled="False" Foreground="#EF5350"/>

                <!-- 새로고침 -->
                <Button Grid.Column="5" x:Name="BtnRefresh" Content="↺  새로고침" Margin="0,0,4,0"
                        Click="BtnRefresh_Click" ToolTip="현재 경로 재스캔 (F5)"/>

                <!-- CSV 내보내기 -->
                <Button Grid.Column="6" Content="📊  CSV 내보내기"
                        Click="BtnExportCsv_Click" Foreground="#66BB6A"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: 브레드크럼 네비게이션
        ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="8,4" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                <ItemsControl x:Name="Breadcrumb">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding Name}" Tag="{Binding}"
                                        Click="Breadcrumb_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#4FC3F7" Padding="2,2"
                                        FontSize="12" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       FontSize="{TemplateBinding FontSize}"
                                                       Padding="{TemplateBinding Padding}"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Tb" Property="TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock Text=" › " Foreground="#555" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: 뷰 모드 탭 + 스캔 진행률
        ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Background="#1E1E1E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 뷰 모드 탭 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0">
                <Button x:Name="BtnViewTree"   Content="🌲  트리 보기"   Tag="Tree"   Click="ViewMode_Click" Margin="2,4" Padding="10,5"/>
                <Button x:Name="BtnViewMap"    Content="🗺  트리맵"       Tag="Map"    Click="ViewMode_Click" Margin="2,4" Padding="10,5"/>
                <Button x:Name="BtnViewTop"    Content="🏆  상위 파일"    Tag="Top"    Click="ViewMode_Click" Margin="2,4" Padding="10,5"/>
                <Button x:Name="BtnViewExt"    Content="🔤  확장자 분석"  Tag="Ext"    Click="ViewMode_Click" Margin="2,4" Padding="10,5"/>
            </StackPanel>

            <!-- 스캔 진행률 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,4" VerticalAlignment="Center">
                <ProgressBar x:Name="PbScan" Width="200" Height="8"
                             Visibility="Collapsed" Margin="0,0,8,0"
                             IsIndeterminate="True"/>
                <TextBlock x:Name="TbScanStatus" Text="" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 3: 메인 콘텐츠
        ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <!-- ── 트리 뷰 ──────────────────────────────────────────── -->
            <Grid x:Name="PanelTree" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 컬럼 헤더 -->
                    <RowDefinition Height="*"/>     <!-- 트리 본문 -->
                </Grid.RowDefinitions>

                <!-- 컬럼 헤더 (헤더 클릭 = 정렬) -->
                <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="150"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="HdrName"     Content="이름 ↕"         Tag="Name"      Click="Header_Click" Style="{StaticResource {x:Type Button}}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left"  Padding="8,6" Foreground="#888" FontSize="12"/>
                        <Button Grid.Column="1" x:Name="HdrBar"      Content="크기 바"                         Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left"  Padding="4,6" Foreground="#888" FontSize="12" IsEnabled="False"/>
                        <Button Grid.Column="2" x:Name="HdrSize"     Content="크기 ↕"         Tag="Size"      Click="Header_Click" Style="{StaticResource {x:Type Button}}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Right" Padding="0,6,8,6" Foreground="#888" FontSize="12"/>
                        <Button Grid.Column="3" x:Name="HdrAlloc"    Content="할당 ↕"         Tag="Alloc"     Click="Header_Click" Style="{StaticResource {x:Type Button}}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Right" Padding="0,6,8,6" Foreground="#888" FontSize="12"/>
                        <Button Grid.Column="4" x:Name="HdrPct"      Content="% ↕"            Tag="Pct"       Click="Header_Click" Style="{StaticResource {x:Type Button}}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Right" Padding="0,6,8,6" Foreground="#888" FontSize="12"/>
                        <Button Grid.Column="5" x:Name="HdrFiles"    Content="파일 수 ↕"      Tag="Files"     Click="Header_Click" Style="{StaticResource {x:Type Button}}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Right" Padding="0,6,8,6" Foreground="#888" FontSize="12"/>
                        <Button Grid.Column="6" x:Name="HdrModified" Content="수정일 ↕"       Tag="Modified"  Click="Header_Click" Style="{StaticResource {x:Type Button}}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left"  Padding="8,6" Foreground="#888" FontSize="12"/>
                    </Grid>
                </Border>

                <!-- 트리 본문 (TreeView 내장 ScrollViewer 사용 → 마우스 휠 정상 동작) -->
                <TreeView x:Name="MainTree" Grid.Row="1"
                          Background="#1A1A1A" BorderThickness="0"
                          ItemTemplate="{StaticResource TreeItemTemplate}"
                          MouseDoubleClick="Tree_MouseDoubleClick"
                          PreviewMouseRightButtonDown="MainTree_PreviewMouseRightButtonDown"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="MnuOpen"       Header="📂  탐색기에서 열기" Click="MnuOpen_Click"/>
                                <MenuItem x:Name="MnuDrillDown"  Header="🔍  이 폴더 분석"    Click="MnuDrillDown_Click"/>
                                <Separator/>
                                <MenuItem x:Name="MnuCopyPath"   Header="📋  경로 복사"       Click="MnuCopyPath_Click"/>
                                <MenuItem x:Name="MnuCopySize"   Header="📋  크기 복사"       Click="MnuCopySize_Click"/>
                                <Separator/>
                                <MenuItem x:Name="MnuDelete"     Header="🗑  삭제..."          Click="MnuDelete_Click" Foreground="#EF5350"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                </TreeView>
            </Grid>

            <!-- ── 트리맵 뷰 ───────────────────────────────────────── -->
            <Grid x:Name="PanelMap" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#1E1E1E" Padding="8,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💡 클릭: 드릴다운 | 우클릭: 상위로" Foreground="#888" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Canvas x:Name="TreeMapCanvas" Grid.Row="1" Background="#111"
                        MouseDown="TreeMap_MouseDown" Cursor="Hand"
                        SizeChanged="TreeMapCanvas_SizeChanged">
                    <TextBlock x:Name="TbMapHint" Canvas.Left="20" Canvas.Top="20"
                               Text="스캔 후 트리맵이 표시됩니다." Foreground="#555" FontSize="16"/>
                </Canvas>
            </Grid>

            <!-- ── 상위 파일 뷰 ────────────────────────────────────── -->
            <Grid x:Name="PanelTop" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#1E1E1E" Padding="8,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="상위 200개 파일  |  더블클릭: 탐색기에서 열기" Foreground="#888" FontSize="12"/>
                    </StackPanel>
                </Border>
                <ListView x:Name="TopFilesList" Grid.Row="1"
                          MouseDoubleClick="TopFiles_DoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="파일명" Width="320">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="크기" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeText}" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="수정일" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LastModifiedText}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="경로" Width="500">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FullPath}" Foreground="#888"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="📂  탐색기에서 열기" Click="TopMnuOpen_Click"/>
                            <MenuItem Header="📋  경로 복사"       Click="TopMnuCopyPath_Click"/>
                            <Separator/>
                            <MenuItem Header="🗑  삭제..."          Click="TopMnuDelete_Click" Foreground="#EF5350"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>
            </Grid>

            <!-- ── 확장자 분석 뷰 ─────────────────────────────────── -->
            <Grid x:Name="PanelExt" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#1E1E1E" Padding="8,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <TextBlock Text="확장자별 사용량 분석" Foreground="#888" FontSize="12"/>
                </Border>
                <ListView x:Name="ExtList" Grid.Row="1">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="확장자" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Extension}" FontFamily="Consolas"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="크기 바" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Height="12" Width="190">
                                            <Border Background="#252525" CornerRadius="2"/>
                                            <Border x:Name="Bar" HorizontalAlignment="Left"
                                                    CornerRadius="2" Background="{StaticResource SizeBarBrush}"
                                                    Tag="{Binding TotalSize}"/>
                                        </Grid>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="전체 크기" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeText}" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="파일 수" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileCount, StringFormat={}{0:N0}}" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="평균 크기" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding AverageSizeText}" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 4: 상태바
        ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="드라이브: " Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="StDrive" Text="-" Foreground="#E0E0E0" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="전체: " Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="StTotal" Text="-" Foreground="#E0E0E0" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="여유: " Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="StFree" Text="-" Foreground="#66BB6A" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <TextBlock Text="파일: " Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="StFiles" Text="-" Foreground="#E0E0E0" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <TextBlock Text="폴더: " Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="StFolders" Text="-" Foreground="#E0E0E0" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
