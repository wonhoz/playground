<Window x:Class="Layout.Forge.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layout.Forge" Width="340" Height="150"
        Background="#1A1A2E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtLabel" Grid.Row="0" Foreground="#9CA3AF"/>
        <TextBox x:Name="TxtInput" Grid.Row="2"
                 Background="#13131F" Foreground="#E0E0E0" BorderBrush="#2A2A3E"
                 Padding="8,4" KeyDown="TxtInput_KeyDown"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인" Width="72" Height="30"
                    Background="#1E3A5E" Foreground="#60A5FA" BorderBrush="#2563EB" BorderThickness="1"
                    Cursor="Hand" Click="Ok_Click"/>
            <Button Content="취소" Width="72" Height="30"
                    Background="#1E1E2E" Foreground="#9CA3AF" BorderBrush="#2A2A3E" BorderThickness="1"
                    Cursor="Hand" Margin="6,0,0,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
