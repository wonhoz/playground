<Window x:Class="HookCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hook.Cast — 플라이 피싱"
        Width="820" Height="640"
        MinWidth="700" MinHeight="520"
        Background="{StaticResource UiBgBrush}"
        Foreground="{StaticResource FgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <Border Grid.Row="0" Background="#0A1420"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid Height="36">
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="🎣" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Hook.Cast" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtWeather" Text="  ☀️ 맑음"
                               Foreground="{StaticResource Fg2Brush}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="─" Width="38" Height="36" BorderThickness="0"
                            Background="Transparent" Click="MinBtn_Click"/>
                    <Button Content="✕" Width="38" Height="36" BorderThickness="0"
                            Background="Transparent" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 게임 캔버스 -->
        <Canvas x:Name="GameCanvas" Grid.Row="1"
                Background="Transparent"
                MouseLeftButtonDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseUp"
                Cursor="Cross"
                ClipToBounds="True">

            <!-- 하늘 그라디언트 -->
            <Rectangle x:Name="SkyRect" Canvas.Left="0" Canvas.Top="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0A1830" Offset="0"/>
                        <GradientStop Color="#1A3A60" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 수면 -->
            <Rectangle x:Name="WaterRect" Canvas.Left="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0A4060" Offset="0"/>
                        <GradientStop Color="#031020" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 수면 하이라이트 라인 -->
            <Line x:Name="WaterLine" Stroke="#4090C0" StrokeThickness="1.5" Opacity="0.6"/>

            <!-- 낚싯줄 (코드에서 동적 생성) -->
            <!-- 물고기 (코드에서 동적 생성) -->

            <!-- 낚싯대 -->
            <Line x:Name="RodLine" Stroke="#C8A860" StrokeThickness="3"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

            <!-- 조준 화살표 -->
            <Line x:Name="AimArrow" Stroke="#60A0FF" StrokeThickness="1.5"
                  StrokeDashArray="4,3" Opacity="0.7" Visibility="Collapsed"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

            <!-- 입질 표시기 -->
            <Border x:Name="BiteIndicator" Visibility="Collapsed"
                    Background="#AA1A3050" BorderBrush="#3DB8FF" BorderThickness="1"
                    CornerRadius="6" Padding="12,6">
                <TextBlock Text="🐟 입질! — Space 또는 클릭으로 챔질!"
                           Foreground="#3DB8FF" FontSize="13" FontWeight="SemiBold"/>
            </Border>

            <!-- 릴링 진행바 -->
            <Border x:Name="ReelPanel" Visibility="Collapsed"
                    Background="#AA0A1A2A" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="10,6">
                <StackPanel>
                    <TextBlock Text="릴링 중 — Space 홀드!" Foreground="{StaticResource FgBrush}"
                               FontSize="11" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <Border Height="10" Width="200" Background="#1A2A3A"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="5">
                        <Border x:Name="ReelBar" HorizontalAlignment="Left" Height="10"
                                CornerRadius="5" Background="#3DB8FF" Width="0"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 결과 패널 -->
            <Border x:Name="ResultPanel" Visibility="Collapsed"
                    Background="#CC0A1520" BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="2" CornerRadius="10" Padding="20,14">
                <StackPanel>
                    <TextBlock x:Name="TxtResult" Text="🎉 낚시 성공!"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource GoldBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtCatchDetail" Text=""
                               FontSize="13" Foreground="{StaticResource FgBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 힌트 텍스트 -->
            <TextBlock x:Name="TxtHint"
                       Text="🎣 드래그로 낚싯줄을 던지세요 (당기는 방향 반대로 날아갑니다)"
                       Foreground="{StaticResource Fg2Brush}" FontSize="11"
                       Canvas.Bottom="10" Canvas.Left="0"/>
        </Canvas>

        <!-- 하단 HUD -->
        <Border Grid.Row="2" Background="#0A1420"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 도감 요약 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🐠 낚은 물고기: " Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                    <TextBlock x:Name="TxtCatchCount" Text="0마리"
                               Foreground="{StaticResource GoldBrush}" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtLastCatch" Text=""
                               Foreground="{StaticResource Fg2Brush}" FontSize="11" Margin="20,0,0,0"/>
                </StackPanel>

                <!-- 버튼 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📖 도감" Click="CatchLogBtn_Click" Margin="0,0,8,0"/>
                    <Button Content="🔄 재시작" Click="RestartBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
