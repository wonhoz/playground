<Window x:Class="MangaView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manga.View" Height="800" Width="1100"
        Background="#0A0A0A" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="44"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="40"/>
    </Grid.RowDefinitions>

    <!-- 툴바 -->
    <Border Grid.Row="0" Background="#111" BorderBrush="#222" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
        <Button Content="📂 열기" Margin="0,0,6,0" Click="BtnOpen_Click"/>
        <Button Content="📚 라이브러리" Margin="0,0,16,0" Click="BtnLibrary_Click"/>
        <TextBlock Text="뷰:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <ComboBox x:Name="ViewModeCombo" Width="100" VerticalAlignment="Center"
                  SelectionChanged="ViewModeCombo_SelectionChanged"/>
        <TextBlock Text="배경:" Foreground="#888" VerticalAlignment="Center" Margin="10,0,6,0"/>
        <ComboBox x:Name="BgCombo" Width="80" VerticalAlignment="Center"
                  SelectionChanged="BgCombo_SelectionChanged"/>
        <TextBlock Text="방향:" Foreground="#888" VerticalAlignment="Center" Margin="10,0,6,0"/>
        <ComboBox x:Name="DirectionCombo" Width="130" VerticalAlignment="Center"
                  SelectionChanged="DirectionCombo_SelectionChanged"/>
        <Separator Width="1" Margin="10,4" Background="#333"/>
        <Button Content="🔍+" Margin="0,0,2,0" Width="34" Click="BtnZoomIn_Click"/>
        <Button Content="🔍-" Margin="0,0,6,0" Width="34" Click="BtnZoomOut_Click"/>
        <Button Content="⟳" Margin="0,0,6,0" Width="34" Click="BtnFitWidth_Click" ToolTip="너비 맞춤"/>
        <TextBlock x:Name="PageText" VerticalAlignment="Center" Foreground="#888" FontSize="12" Margin="4,0"/>
      </StackPanel>
    </Border>

    <!-- 리더 영역 -->
    <ScrollViewer x:Name="MainScroll" Grid.Row="1"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Background="#0A0A0A"
                  PreviewMouseWheel="MainScroll_PreviewMouseWheel">
      <StackPanel x:Name="PagePanel" HorizontalAlignment="Center"/>
    </ScrollViewer>

    <!-- 하단 탐색 -->
    <Border Grid.Row="2" Background="#111" BorderBrush="#222" BorderThickness="0,1,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
          <Button Content="◀◀" Margin="0,0,4,0" Click="BtnFirst_Click"/>
          <Button Content="◀" Margin="0,0,4,0" Click="BtnPrev_Click"/>
        </StackPanel>

        <Slider x:Name="PageSlider" Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                Minimum="0" SmallChange="1" LargeChange="1"
                ValueChanged="PageSlider_ValueChanged"
                Foreground="#5B8AF0"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
          <Button Content="▶" Margin="0,0,4,0" Click="BtnNext_Click"/>
          <Button Content="▶▶" Margin="0,0,4,0" Click="BtnLast_Click"/>
          <Button Content="🔖" Margin="0,0,4,0" Click="BtnBookmark_Click" ToolTip="북마크"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
