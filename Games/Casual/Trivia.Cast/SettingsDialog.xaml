<Window x:Class="TriviaCast.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="400" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- ── 토글 스위치 CheckBox ── -->
        <Style TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 트랙 -->
                            <Border x:Name="Track"
                                    Width="42" Height="24" CornerRadius="12"
                                    Background="#3A3410"
                                    BorderBrush="#5A5428" BorderThickness="1">
                                <!-- 노브 -->
                                <Ellipse x:Name="Knob"
                                         Width="18" Height="18"
                                         Fill="#6A6040"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0"/>
                            </Border>
                            <!-- 레이블 -->
                            <ContentPresenter Margin="9,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Knob"  Property="Fill"        Value="White"/>
                                <Setter TargetName="Knob"  Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob"  Property="Margin"      Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 모던 Slider ── -->
        <Style TargetType="Slider">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="22" VerticalAlignment="Center">
                            <!-- 전체 트랙 배경 -->
                            <Border Height="4" CornerRadius="2"
                                    Background="#3A3410"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <!-- 채워진 부분 (좌측) -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{StaticResource AccentBrush}"
                                                        VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <!-- 노브 -->
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Width="20" Height="20">
                                                    <Ellipse x:Name="knob"
                                                             Fill="{StaticResource AccentBrush}"
                                                             Stroke="#2A2400" StrokeThickness="1.5">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="Black" BlurRadius="5"
                                                                              Opacity="0.35" ShadowDepth="1"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="White" Opacity="0.55"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="knob" Property="Fill" Value="{StaticResource GoldBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="knob" Property="Fill" Value="{StaticResource GoldBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <!-- 빈 부분 (우측, 투명) -->
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Button (App.xaml 상속 유지용 재정의) ── -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="28,22,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 섹션: 사운드 -->
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>  <!-- BGM / SFX 토글 -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>  <!-- 구분선 -->
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>  <!-- 섹션: 피드백 딜레이 -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- 정답 슬라이더 -->
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>  <!-- 오답 슬라이더 -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- 섹션: 사운드 -->
        <TextBlock Grid.Row="0"
                   Text="사운드"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondary}"/>

        <!-- BGM / SFX 토글 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,6,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,12">
                <CheckBox x:Name="BgmCheck" Content="🎵  배경음악"/>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,12">
                <CheckBox x:Name="SfxCheck" Content="🔊  효과음"/>
            </Border>
        </Grid>

        <!-- 구분선 -->
        <Border Grid.Row="4" Height="1" Background="{StaticResource BorderBrush}"/>

        <!-- 섹션: 피드백 딜레이 -->
        <TextBlock Grid.Row="6"
                   Text="피드백 딜레이"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondary}"/>

        <!-- 정답 피드백 슬라이더 -->
        <Border Grid.Row="8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="정답 피드백 시간"
                               FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="CorrectHint"
                               FontSize="11" Foreground="{StaticResource AccentBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <Slider Grid.Column="1"
                        x:Name="CorrectSlider"
                        Minimum="500" Maximum="2000"
                        IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="CorrectSlider_ValueChanged"/>
            </Grid>
        </Border>

        <!-- 오답 피드백 슬라이더 -->
        <Border Grid.Row="10"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="오답 피드백 시간"
                               FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="WrongHint"
                               FontSize="11" Foreground="{StaticResource AccentBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <Slider Grid.Column="1"
                        x:Name="WrongSlider"
                        Minimum="1000" Maximum="3000"
                        IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="WrongSlider_ValueChanged"/>
            </Grid>
        </Border>

        <!-- 버튼 -->
        <Grid Grid.Row="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="취소" Click="CancelBtn_Click"/>
            <Button Grid.Column="2" Content="저장" Click="SaveBtn_Click"/>
        </Grid>
    </Grid>
</Window>
