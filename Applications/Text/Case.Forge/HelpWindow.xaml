<Window x:Class="CaseForge.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Case.Forge 도움말"
        Width="400" Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#000000"/>
    </Window.Effect>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 (드래그) -->
            <Grid Grid.Row="0" Margin="16,12,12,0"
                  MouseLeftButtonDown="Header_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="?  Case.Forge 도움말"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Width="28" Height="28" Content="✕" FontSize="11"
                        Foreground="{StaticResource TextSecondary}" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1E3426"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 도움말 내용 -->
            <ScrollViewer Grid.Row="1" Margin="18,14,18,16"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 단축키 -->
                    <TextBlock Text="전역 단축키" FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,16">
                        <TextBlock x:Name="HotkeyText"
                                   FontFamily="Consolas, Segoe UI" FontSize="13"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </Border>

                    <!-- 사용 방법 -->
                    <TextBlock Text="사용 방법" FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>
                    <StackPanel x:Name="StepsPanel"/>

                    <!-- 키보드 단축키 -->
                    <TextBlock Text="키보드 단축키" FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,14,0,8"/>
                    <StackPanel x:Name="KeysPanel"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
