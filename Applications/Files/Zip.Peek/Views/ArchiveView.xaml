<UserControl x:Class="ZipPeek.Views.ArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 좌측: 트리 패널 -->
            <ColumnDefinition Width="340" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- ── 좌측: 트리 패널 ────────────────────────────────────── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 트리 헤더 -->
            <Border Grid.Row="0" Background="#16161F" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="아카이브 구조" FontSize="12" FontWeight="SemiBold"
                               Foreground="#888899" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtEntryCount" FontSize="11" Foreground="#555566"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- 트리뷰 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TreeView x:Name="ArchiveTree" Margin="8"
                          SelectedItemChanged="ArchiveTree_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="{Binding Icon}" FontSize="13" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="#E8E8F0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SizeLabel" FontSize="10" Foreground="#666677"
                                               Margin="0,1,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}  →  {1}  ({2})">
                                                <Binding Path="CompressedText"/>
                                                <Binding Path="SizeText"/>
                                                <Binding Path="RatioText"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </ScrollViewer>
        </Grid>

        <!-- ── 분리선 ─────────────────────────────────────────────── -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#1C1C28"/>

        <!-- ── 우측: 미리보기 패널 ────────────────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 미리보기 헤더 -->
            <Border Grid.Row="0" Background="#16161F" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtPreviewTitle" Text="미리보기" FontSize="12"
                               FontWeight="SemiBold" Foreground="#888899" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtPreviewMeta" Grid.Column="1" FontSize="11"
                               Foreground="#555566" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 탭 패널 (텍스트 / 이미지 / Hex / 검색결과) -->
            <TabControl Grid.Row="1" x:Name="PreviewTabs" Background="#111118" BorderThickness="0">

                <!-- 텍스트 미리보기 -->
                <TabItem x:Name="TabText" Header="텍스트">
                    <ScrollViewer Background="#0D0D16" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="TxtPreview" IsReadOnly="True" TextWrapping="NoWrap"
                                 Background="Transparent" Foreground="#D4D4D4"
                                 FontFamily="Consolas, 'Courier New'" FontSize="12"
                                 BorderThickness="0" Padding="16"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </TabItem>

                <!-- 이미지 미리보기 -->
                <TabItem x:Name="TabImage" Header="이미지">
                    <ScrollViewer Background="#0D0D16" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Image x:Name="ImgPreview" Stretch="Uniform" Margin="16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </ScrollViewer>
                </TabItem>

                <!-- Hex 미리보기 -->
                <TabItem x:Name="TabHex" Header="Hex">
                    <ScrollViewer Background="#0D0D16" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="TxtHex" IsReadOnly="True" TextWrapping="NoWrap"
                                 Background="Transparent" Foreground="#9CDCFE"
                                 FontFamily="Consolas, 'Courier New'" FontSize="11"
                                 BorderThickness="0" Padding="16"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </TabItem>

                <!-- 검색 결과 -->
                <TabItem x:Name="TabSearch" Header="검색 결과">
                    <Grid Background="#111118">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#16161F" Padding="12,6">
                            <TextBlock x:Name="TxtSearchSummary" FontSize="11"
                                       Foreground="#888899"/>
                        </Border>
                        <ListBox Grid.Row="1" x:Name="SearchResultList"
                                 Background="Transparent" BorderThickness="0" Margin="4"
                                 SelectionChanged="SearchResult_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                   FontSize="12" Margin="0,0,8,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}" FontSize="11"
                                                       Foreground="#F59E0B" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Snippet}" FontSize="11"
                                                       Foreground="#888899" TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas"/>
                                            <TextBlock FontSize="10" Foreground="#555566">
                                                <TextBlock.Text>
                                                    <Binding Path="Line" StringFormat="줄 {0}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
