<Window x:Class="MemLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mem.Lens — 프로세스 메모리 분석기"
        Width="1200" Height="720" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 툴바 -->
            <RowDefinition Height="*"/>     <!-- 본문 -->
            <RowDefinition Height="Auto"/>  <!-- 상태 바 -->
        </Grid.RowDefinitions>

        <!-- ══ 툴바 ══ -->
        <Border Grid.Row="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BtnRefresh" Content="⟳ 새로 고침" Padding="10,5" Click="BtnRefresh_Click" ToolTip="프로세스 목록 새로 고침 (F5)"/>
                    <Button x:Name="BtnTrimWs" Content="🧹 WorkingSet 정리" Padding="10,5" Margin="6,0,0,0"
                            Style="{StaticResource DangerBtn}" Click="BtnTrimWs_Click"
                            ToolTip="선택 프로세스의 WorkingSet을 OS에 반환 (비파괴적)"/>
                    <Button x:Name="BtnExport" Content="📄 리포트" Padding="10,5" Margin="6,0,0,0"
                            Style="{StaticResource SecondaryBtn}" Click="BtnExport_Click"/>
                    <Separator Width="1" Background="#333333" Margin="8,2"/>
                    <TextBlock Text="자동 새로 고침:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                    <ComboBox x:Name="CbRefreshInterval" Width="80" SelectedIndex="1"
                              SelectionChanged="CbRefreshInterval_Changed">
                        <ComboBoxItem Content="꺼짐" Tag="0"/>
                        <ComboBoxItem Content="3초" Tag="3"/>
                        <ComboBoxItem Content="5초" Tag="5"/>
                        <ComboBoxItem Content="10초" Tag="10"/>
                        <ComboBoxItem Content="30초" Tag="30"/>
                    </ComboBox>
                </StackPanel>

                <!-- 검색 -->
                <Grid Grid.Column="2" Width="200">
                    <TextBox x:Name="TxtSearch" Padding="6,4" TextChanged="TxtSearch_Changed"/>
                    <TextBlock Text="🔍 프로세스 검색..." Foreground="#444444" IsHitTestVisible="False"
                               Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ 본문: 프로세스 목록 + 상세 ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="260"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 프로세스 목록 -->
            <Border Grid.Column="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 컬럼 헤더 -->
                    <Border Grid.Row="0" Background="#161616" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                        <Grid Margin="4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="프로세스"    Foreground="#666666" FontSize="10" Padding="4,0"/>
                            <TextBlock Grid.Column="1" Text="Private"   Foreground="#666666" FontSize="10" Padding="4,0" TextAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="WS"        Foreground="#666666" FontSize="10" Padding="4,0" TextAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="↑↓"        Foreground="#666666" FontSize="10" Padding="2,0" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox x:Name="LstProcesses" Grid.Row="1"
                             Background="#141414" BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="LstProcesses_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1E1E1E" BorderThickness="0,0,0,1" Padding="0">
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Foreground="#E0E0E0"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Pid, StringFormat='PID: {0}'}"
                                                       Foreground="#555555" FontSize="10"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding PrivateDisplay}"
                                                   Foreground="#6EFF6E" FontSize="11" FontFamily="Consolas"
                                                   VerticalAlignment="Center" TextAlignment="Right" Padding="0,0,4,0"/>

                                        <TextBlock Grid.Column="2" Text="{Binding WorkingSetDisplay}"
                                                   Foreground="#888888" FontSize="11" FontFamily="Consolas"
                                                   VerticalAlignment="Center" TextAlignment="Right" Padding="0,0,4,0"/>

                                        <TextBlock Grid.Column="3" Text="{Binding TrendIndicator}"
                                                   Foreground="{Binding TrendBrush}"
                                                   FontSize="13" FontWeight="Bold"
                                                   VerticalAlignment="Center" TextAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#2A2A2A" ResizeDirection="Columns"/>

            <!-- 상세 패널 -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          Background="#1A1A1A">
                <Grid x:Name="PnlDetail" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 프로세스 이름 -->
                    <Border Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="TxtDetailName" Text="프로세스를 선택하세요"
                                       Foreground="#E0E0E0" FontSize="20" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtDetailPid" Text=""
                                       Foreground="#555555" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 메모리 요약 카드들 -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1E2E1E" BorderBrush="#3A6A3A"
                                BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Private Bytes" Foreground="#888888" FontSize="10"/>
                                <TextBlock x:Name="TxtPrivate" Text="──" Foreground="#6EFF6E"
                                           FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="전용 메모리" Foreground="#444444" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#1A1E2A" BorderBrush="#3A4A6A"
                                BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Working Set" Foreground="#888888" FontSize="10"/>
                                <TextBlock x:Name="TxtWS" Text="──" Foreground="#6EA8FE"
                                           FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="물리 메모리 사용량" Foreground="#444444" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="#2A1A1A" BorderBrush="#6A2A2A"
                                BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Virtual" Foreground="#888888" FontSize="10"/>
                                <TextBlock x:Name="TxtVirtual" Text="──" Foreground="#FF6B6B"
                                           FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="가상 주소 공간" Foreground="#444444" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 추가 정보 -->
                    <Border Grid.Row="2" Background="#1C1C1C" BorderBrush="#2A2A2A"
                            BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Paged Pool" Foreground="#555555" FontSize="10"/>
                                <TextBlock x:Name="TxtPaged" Text="──" Foreground="#C0C0C0" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Non-Paged Pool" Foreground="#555555" FontSize="10"/>
                                <TextBlock x:Name="TxtNonPaged" Text="──" Foreground="#C0C0C0" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Page Faults" Foreground="#555555" FontSize="10"/>
                                <TextBlock x:Name="TxtPageFaults" Text="──" Foreground="#C0C0C0" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="메모리 추세" Foreground="#555555" FontSize="10"/>
                                <TextBlock x:Name="TxtTrend" Text="──" Foreground="#C0C0C0" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- .NET GC 힙 (관리 프로세스만) -->
                    <Border x:Name="BdrGcHeap" Grid.Row="3"
                            Background="#1C1C1C" BorderBrush="#2A2A2A"
                            BorderThickness="1" CornerRadius="6" Padding="12"
                            Margin="0,0,0,16" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text=".NET 관리 힙" Foreground="#6EFF6E" FontSize="12"
                                       FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Gen 0" Foreground="#555555" FontSize="10"/>
                                    <TextBlock x:Name="TxtGen0" Text="──" Foreground="#6EFF6E" FontSize="12" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Gen 1" Foreground="#555555" FontSize="10"/>
                                    <TextBlock x:Name="TxtGen1" Text="──" Foreground="#6EA8FE" FontSize="12" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Gen 2" Foreground="#555555" FontSize="10"/>
                                    <TextBlock x:Name="TxtGen2" Text="──" Foreground="#FFD93D" FontSize="12" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="LOH" Foreground="#555555" FontSize="10"/>
                                    <TextBlock x:Name="TxtLoh" Text="──" Foreground="#FF6B6B" FontSize="12" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="합계" Foreground="#555555" FontSize="10"/>
                                    <TextBlock x:Name="TxtGcTotal" Text="──" Foreground="#E0E0E0" FontSize="12" FontFamily="Consolas"/>
                                </StackPanel>
                            </Grid>
                            <!-- GC 힙 비율 바 -->
                            <Grid Margin="0,8,0,0" Height="12">
                                <Border Background="#2A2A2A" CornerRadius="3"/>
                                <Grid x:Name="GcBarGrid" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="ColGen0" Width="0*"/>
                                        <ColumnDefinition x:Name="ColGen1" Width="0*"/>
                                        <ColumnDefinition x:Name="ColGen2" Width="0*"/>
                                        <ColumnDefinition x:Name="ColLoh"  Width="0*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#6EFF6E" CornerRadius="3,0,0,3"/>
                                    <Border Grid.Column="1" Background="#6EA8FE"/>
                                    <Border Grid.Column="2" Background="#FFD93D"/>
                                    <Border Grid.Column="3" Background="#FF6B6B" CornerRadius="0,3,3,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 메모리 타임라인 그래프 -->
                    <Border Grid.Row="4" Background="#1C1C1C" BorderBrush="#2A2A2A"
                            BorderThickness="1" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <TextBlock Text="메모리 타임라인 (최근 30분)" Foreground="#888888"
                                       FontSize="11" Margin="0,0,0,8"/>
                            <Canvas x:Name="TimelineCanvas" Height="120" Background="#161616"
                                    ClipToBounds="True"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="10" Height="3" Background="#6EFF6E" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Private Bytes" Foreground="#555555" FontSize="10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="10" Height="3" Background="#6EA8FE" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Working Set" Foreground="#555555" FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ══ 상태 바 ══ -->
        <Border Grid.Row="2" Background="#111111" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
            <Grid Margin="8,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0" Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtRefreshTime" Grid.Column="1" Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
