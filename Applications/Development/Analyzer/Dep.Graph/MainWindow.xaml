<Window x:Class="DepGraph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Dep.Graph" Height="720" Width="1200"
        Background="#0F0F1E" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Padding="{TemplateBinding Padding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                    Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#888888"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#252538" BorderBrush="#444466" BorderThickness="1" CornerRadius="4">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A2A50"/>
                                <Setter Property="Foreground" Value="#50C8DC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#202038"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2A50"/>
                    <Setter Property="Foreground" Value="#50C8DC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- 툴바 -->
        <Border Grid.Row="0" Background="#14142A" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="🕸 Dep.Graph" FontSize="14" FontWeight="Bold"
                           Foreground="#50C8DC" Margin="0,0,20,0"/>
                <TextBlock Text="NuGet / npm / pip 의존성 충돌 그래프 시각화기" FontSize="11"
                           Foreground="#666688" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 메인 레이아웃 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 패널 -->
            <Border Grid.Column="0" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Margin="6,6,3,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <Border Background="#1A1A30" CornerRadius="6,6,0,0">
                        <TextBlock Text="프로젝트 / 패키지 파일" FontSize="11" Foreground="#7777AA"
                                   VerticalAlignment="Center" Margin="8,0"/>
                    </Border>

                    <!-- 생태계 선택 -->
                    <Border Grid.Row="1" Background="#16162C" Padding="8,6">
                        <StackPanel>
                            <TextBlock Text="생태계" FontSize="10" Foreground="#666688" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CmbEcosystem" FontSize="11" SelectionChanged="CmbEcosystem_SelectionChanged">
                                <ComboBoxItem Content="NuGet (.csproj / packages.config)" IsSelected="True"/>
                                <ComboBoxItem Content="npm (package.json)"/>
                                <ComboBoxItem Content="pip (requirements.txt)"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- 파일 입력 -->
                    <Border Grid.Row="2" Padding="8,6" Background="#14142A">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button x:Name="BtnBrowseFile" Click="BtnBrowseFile_Click"
                                        Padding="8,3" FontSize="10">📂 파일 선택</Button>
                                <Button x:Name="BtnBrowseFolder" Click="BtnBrowseFolder_Click"
                                        Margin="4,0,0,0" Padding="8,3" FontSize="10">📁 폴더 스캔</Button>
                            </StackPanel>
                            <TextBox x:Name="TxtFilePath" FontSize="10" FontFamily="Consolas"
                                     IsReadOnly="True" Padding="4,2"
                                     ToolTip="선택된 파일/폴더 경로"/>
                        </StackPanel>
                    </Border>

                    <!-- 패키지 목록 -->
                    <Border Grid.Row="3" BorderThickness="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#16162E" Padding="8,4">
                                <TextBlock x:Name="LblPkgCount" Text="패키지 0개" FontSize="10" Foreground="#666688"/>
                            </Border>
                            <ListBox x:Name="LstPackages" Grid.Row="1"
                                     SelectionChanged="LstPackages_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontFamily="Consolas"/>
                                            <TextBlock Text="{Binding StatusText}" FontSize="9"
                                                       Foreground="{Binding StatusColor}" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- 분석 버튼 -->
                    <Border Grid.Row="4" Background="#14142A" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnAnalyze" Click="BtnAnalyze_Click"
                                    Padding="10,4" FontSize="11"
                                    Background="#1A3A2A" BorderBrush="#2A6A4A">🔍 분석</Button>
                            <Button x:Name="BtnCheckLatest" Click="BtnCheckLatest_Click"
                                    Margin="4,0,0,0" Padding="8,4" FontSize="11">🔄 최신 확인</Button>
                            <Button x:Name="BtnExport" Click="BtnExport_Click"
                                    Margin="4,0,0,0" Padding="8,4" FontSize="11">💾</Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="#1A1A30" HorizontalAlignment="Stretch"/>

            <!-- 오른쪽: WebView2 그래프 -->
            <Border Grid.Column="2" BorderBrush="#333355" BorderThickness="1" CornerRadius="6" Margin="3,6,6,6">
                <Grid>
                    <wv2:WebView2 x:Name="WebGraph"/>
                    <Border x:Name="PanelEmpty" Background="#0F0F1E" CornerRadius="6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🕸" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"
                                       Foreground="#333355"/>
                            <TextBlock Text="의존성 파일을 선택하고 분석을 실행하세요" FontSize="14"
                                       Foreground="#444466" HorizontalAlignment="Center"/>
                            <TextBlock Text="NuGet · npm · pip 지원" FontSize="11"
                                       Foreground="#333355" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#0A0A1A" BorderBrush="#1A1A30" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar" Margin="10,0" VerticalAlignment="Center"
                       FontSize="10" Foreground="#666688"/>
        </Border>
    </Grid>
</Window>
