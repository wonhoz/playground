<Window x:Class="AutoBuild.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto.Build"
        Width="1060" Height="680"
        ResizeMode="NoResize"
        Background="#0F1A0F"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- ── 헤더 타이틀바 ─────────────────────────────────── -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="#0A120A"
                BorderBrush="#1A3A1A" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"
                               Foreground="#80E080"/>
                    <TextBlock Text="Auto.Build" FontSize="15" FontWeight="Bold"
                               Foreground="#80E080" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TbStageName" Margin="16,0,0,0"
                               Foreground="#507050" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="속도:" Foreground="#507050" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TbSpeed" Text="1×" Foreground="#80E080"
                               VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="Bold"/>
                    <TextBlock x:Name="TbTick" Foreground="#304030"
                               VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 도구 팔레트 (왼쪽) ───────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#0A120A"
                BorderBrush="#1A3A1A" BorderThickness="0,0,1,0">
            <StackPanel Margin="8,10,8,8">
                <TextBlock Text="도구" Foreground="#507050" FontSize="11"
                           FontWeight="SemiBold" Margin="2,0,0,6"/>

                <!-- 도구 버튼들 -->
                <Button x:Name="BtnToolBeltR"  Content="→ 벨트 (우)" Tag="BeltR"  Margin="0,2" Click="Tool_Click"/>
                <Button x:Name="BtnToolBeltD"  Content="↓ 벨트 (하)" Tag="BeltD"  Margin="0,2" Click="Tool_Click"/>
                <Button x:Name="BtnToolBeltL"  Content="← 벨트 (좌)" Tag="BeltL"  Margin="0,2" Click="Tool_Click"/>
                <Button x:Name="BtnToolBeltU"  Content="↑ 벨트 (상)" Tag="BeltU"  Margin="0,2" Click="Tool_Click"/>

                <Separator Margin="0,6" Background="#1A3A1A" Height="1"/>

                <Button x:Name="BtnToolProc"   Content="⚙ 가공기"    Tag="Proc"   Margin="0,2" Click="Tool_Click"/>
                <Button x:Name="BtnToolSort"   Content="⊕ 분류기"    Tag="Sort"   Margin="0,2" Click="Tool_Click"/>
                <Button x:Name="BtnToolMerge"  Content="✕ 합성기"    Tag="Merge"  Margin="0,2" Click="Tool_Click"/>

                <Separator Margin="0,6" Background="#1A3A1A" Height="1"/>

                <Button x:Name="BtnToolDel"    Content="✕ 삭제"      Tag="Del"    Margin="0,2" Click="Tool_Click"
                        Foreground="#CC4040"/>

                <Separator Margin="0,10" Background="#1A3A1A" Height="1"/>

                <!-- 범례 -->
                <TextBlock Text="범례" Foreground="#507050" FontSize="11"
                           FontWeight="SemiBold" Margin="2,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="2,2">
                    <Ellipse Width="10" Height="10" Fill="#FF5050" VerticalAlignment="Center"/>
                    <TextBlock Text=" 빨강" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2,2">
                    <Ellipse Width="10" Height="10" Fill="#50FF50" VerticalAlignment="Center"/>
                    <TextBlock Text=" 초록" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2,2">
                    <Ellipse Width="10" Height="10" Fill="#5080FF" VerticalAlignment="Center"/>
                    <TextBlock Text=" 파랑" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2,2">
                    <Ellipse Width="10" Height="10" Fill="#FFD050" VerticalAlignment="Center"/>
                    <TextBlock Text=" 노랑(가공)" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2,2">
                    <Ellipse Width="10" Height="10" Fill="#FF80FF" VerticalAlignment="Center"/>
                    <TextBlock Text=" 보라(합성)" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── 게임 캔버스 (중앙) ────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#0D170D"
                ClipToBounds="True">
            <Canvas x:Name="GameCanvas"
                    MouseLeftButtonDown="Canvas_MouseLeft"
                    MouseRightButtonDown="Canvas_MouseRight"
                    MouseMove="Canvas_MouseMove"
                    Cursor="Hand"/>
        </Border>

        <!-- ── 정보 패널 (오른쪽) ────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="2"
                Background="#0A120A"
                BorderBrush="#1A3A1A" BorderThickness="1,0,0,0">
            <StackPanel Margin="10,10,10,8">
                <!-- 스테이지 정보 -->
                <TextBlock Text="스테이지" Foreground="#507050" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Background="#0D200D" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="TbStageNum" Text="Stage 1 / 5"
                                   Foreground="#80E080" FontWeight="Bold" FontSize="13"/>
                        <TextBlock x:Name="TbStageGoal" Text=""
                                   Foreground="#A0C0A0" FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 진행 -->
                <TextBlock Text="진행" Foreground="#507050" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Background="#0D200D" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="TbProgress" Text="0 / 0"
                                   Foreground="#FFD080" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TbProgressLabel" Text="수집됨"
                                   Foreground="#507050" FontSize="11"
                                   HorizontalAlignment="Center"/>
                        <!-- 진행 바 -->
                        <Border Background="#1A3A1A" Height="8" CornerRadius="4" Margin="0,6,0,0">
                            <Border x:Name="ProgressBar" Background="#50E050"
                                    HorizontalAlignment="Left" Height="8"
                                    CornerRadius="4" Width="0"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 처리량 -->
                <TextBlock Text="통계" Foreground="#507050" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Background="#0D200D" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="처리량" Foreground="#507050" FontSize="11"/>
                            <TextBlock x:Name="TbThroughput" Grid.Column="1"
                                       Text="0 /min" Foreground="#80E080" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="경과" Foreground="#507050" FontSize="11"/>
                            <TextBlock x:Name="TbElapsed" Grid.Column="1"
                                       Text="0s" Foreground="#80E080" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="배치 기계" Foreground="#507050" FontSize="11"/>
                            <TextBlock x:Name="TbMachineCount" Grid.Column="1"
                                       Text="0" Foreground="#80E080" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 조작 안내 -->
                <TextBlock Text="조작" Foreground="#507050" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Background="#0D200D" CornerRadius="4" Padding="8,6">
                    <StackPanel>
                        <TextBlock Text="좌클릭: 배치" Foreground="#507050" FontSize="11"/>
                        <TextBlock Text="우클릭: 삭제" Foreground="#507050" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="Space: 시작/정지" Foreground="#507050" FontSize="11"/>
                        <TextBlock Text="R: 리셋" Foreground="#507050" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="+/-: 속도 조절" Foreground="#507050" FontSize="11"/>
                        <TextBlock Text="1~5: 분류기 색상" Foreground="#507050" FontSize="11" Margin="0,2"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── 하단 컨트롤 바 ───────────────────────────────── -->
        <Border Grid.Row="2" Grid.ColumnSpan="3"
                Background="#0A120A"
                BorderBrush="#1A3A1A" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 컨트롤 버튼 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnPlay" Content="▶ 시작" Width="80"
                            Click="BtnPlay_Click" Margin="0,0,6,0"/>
                    <Button x:Name="BtnReset" Content="↺ 리셋" Width="70"
                            Click="BtnReset_Click" Margin="0,0,6,0"/>
                    <Button x:Name="BtnSpeedUp" Content="+" Width="32"
                            Click="BtnSpeedUp_Click" Margin="0,0,2,0" ToolTip="속도 증가"/>
                    <Button x:Name="BtnSpeedDn" Content="-" Width="32"
                            Click="BtnSpeedDn_Click" ToolTip="속도 감소"/>
                </StackPanel>

                <!-- 스테이지 선택 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="◀" Width="28" Click="BtnPrevStage_Click" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TbStageBtn" Text="Stage 1" VerticalAlignment="Center"
                               Foreground="#507050" Margin="4,0" FontSize="12"/>
                    <Button Content="▶" Width="28" Click="BtnNextStage_Click" Margin="4,0,0,0"/>
                    <Button Content="샌드박스" Width="72" Click="BtnSandbox_Click" Margin="8,0,0,0"
                            Foreground="#FFD080"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
