<Window x:Class="Stock.Fetch.MinuteCsvWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="분봉 CSV 다운로드" Height="235" Width="400"
        Background="{StaticResource WindowBg}" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🕐 1분봉 CSV 다운로드" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBlock Text="날짜" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{StaticResource FgMuted}"/>
            <TextBox x:Name="DateBox" Width="120" FontSize="14" FontWeight="SemiBold"/>
            <Button Content="−1일" Style="{StaticResource ChipButton}" Margin="10,0,0,0" Tag="-1" Click="Shift_Click"/>
            <Button Content="+1일" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="1" Click="Shift_Click"/>
            <Button Content="오늘" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Click="Today_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource FgMuted}"
                   VerticalAlignment="Top" Margin="0,10,0,0"
                   Text="※ KIS 일별분봉으로 해당 영업일의 1분봉(09:00~15:30)을 조회해 CSV로 저장합니다. 휴장일·보관 기간 초과 시 데이터가 없을 수 있습니다."/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource BearBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="취소" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="CSV 저장" Width="100" Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
