<Window x:Class="TableCraft.Views.PivotView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="피벗 테이블"
        Width="860" Height="560"
        MinWidth="600" MinHeight="400"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 설정 영역 -->
            <RowDefinition Height="*"/>     <!-- 결과 DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- 상태 -->
        </Grid.RowDefinitions>

        <!-- 설정 영역 -->
        <Border Grid.Row="0" Background="#181825"
                BorderBrush="#313244" BorderThickness="0,0,0,1" Padding="12,8">
            <WrapPanel Orientation="Horizontal">
                <!-- 행 필드 -->
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="행 필드" Foreground="#6C7086" FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbRow" Width="140" Height="28"
                              DisplayMemberPath="Name"
                              SelectionChanged="Config_Changed"/>
                </StackPanel>
                <!-- 열 필드 -->
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="열 필드" Foreground="#6C7086" FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbCol" Width="140" Height="28"
                              DisplayMemberPath="Name"
                              SelectionChanged="Config_Changed"/>
                </StackPanel>
                <!-- 값 필드 -->
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="값 필드 (선택)" Foreground="#6C7086" FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbVal" Width="140" Height="28"
                              DisplayMemberPath="Name"
                              SelectionChanged="Config_Changed"/>
                </StackPanel>
                <!-- 집계 방식 -->
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="집계 방식" Foreground="#6C7086" FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbAgg" Width="100" Height="28"
                              SelectionChanged="Config_Changed">
                        <ComboBoxItem Content="COUNT"/>
                        <ComboBoxItem Content="SUM"/>
                        <ComboBoxItem Content="AVG"/>
                        <ComboBoxItem Content="MIN"/>
                        <ComboBoxItem Content="MAX"/>
                    </ComboBox>
                </StackPanel>
                <!-- 실행 버튼 -->
                <StackPanel VerticalAlignment="Bottom" Margin="8,0,0,0">
                    <Button Content="피벗 실행" Width="90" Height="28"
                            Background="#313244" Foreground="#A6E3A1"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- 피벗 결과 DataGrid -->
        <DataGrid x:Name="PivotGrid"
                  Grid.Row="1"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  AutoGenerateColumns="True"
                  SelectionMode="Single"
                  SelectionUnit="Cell"
                  Margin="0"/>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#181825"
                BorderBrush="#313244" BorderThickness="0,1,0,0" Padding="10,4">
            <TextBlock x:Name="TxtPivotStatus"
                       Foreground="#6C7086" FontSize="11"
                       Text="행/열 필드를 선택하고 피벗 실행을 클릭하세요"/>
        </Border>
    </Grid>
</Window>
