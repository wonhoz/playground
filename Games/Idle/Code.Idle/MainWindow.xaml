<Window x:Class="CodeIdle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Code.Idle — 개발자 스타트업 방치형 게임"
        Width="980" Height="660" MinWidth="780" MinHeight="520"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ─── 왼쪽: 게임 상태 ─── -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="16">

                <!-- 타이틀 -->
                <TextBlock Text="💻 Code.Idle" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding State.StageLabel}" FontSize="12"
                           Foreground="{StaticResource DimBrush}" Margin="0,0,0,16"/>

                <!-- 핵심 수치 -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{Binding State.LinesDisplay}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="코드 라인" FontSize="11"
                                   Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding State.LpsDisplay}" FontSize="13"
                                   Foreground="{StaticResource GreenBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 사용자 & 수익 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="{Binding State.UsersDisplay}" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource YellowBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="사용자" FontSize="10"
                                       Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="{Binding State.RevenueDisplay}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="수익" FontSize="10"
                                       Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 기술 부채 -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="🦠 기술 부채" FontSize="11" Foreground="{StaticResource DimBrush}"/>
                            <TextBlock Text="{Binding State.TechDebt, StringFormat={}{0:F0}%}"
                                       FontSize="11" Foreground="{StaticResource RedBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <ProgressBar Height="6" Value="{Binding State.TechDebt}"
                                     Maximum="100" Background="#374151" Foreground="{StaticResource RedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- 버그 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="8"
                            Padding="14,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🐛" FontSize="16" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding State.Bugs}" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource RedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="버그" FontSize="11" Foreground="{StaticResource DimBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="1" Content="🔧" Click="BtnFixBug_Click"
                            FontSize="16" Padding="8" Margin="4,0,0,0"
                            ToolTip="버그 수정 (클릭당 1개)"/>
                </Grid>

                <!-- 클릭 버튼 -->
                <Button Style="{StaticResource ClickButton}" Click="BtnCode_Click"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⌨️" FontSize="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="코딩하기" FontSize="12" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding State.ClickPower, StringFormat=+{0:F0} 라인}"
                                   FontSize="10" Foreground="#A5B4FC"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 프레스티지 -->
                <Button Content="⭐ 회사 매각 (프레스티지)" Click="BtnPrestige_Click"
                        IsEnabled="{Binding CanPrestige}"
                        Margin="0,0,0,4"/>
                <TextBlock Text="IPO 달성 시 활성화" FontSize="10"
                           Foreground="{StaticResource DimBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ─── 중앙: 업그레이드 ─── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="16,12">
                <TextBlock Text="🛒 업그레이드" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
                <ItemsControl ItemsSource="{Binding Upgrades}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="card" Background="{StaticResource CardBrush}"
                                    CornerRadius="8" Padding="14,10" Margin="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Emoji}"
                                               FontSize="22" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="{StaticResource DimBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Tag="{Binding Id}"
                                            Click="BtnBuy_Click" VerticalAlignment="Center"
                                            Padding="10,6" MinWidth="80">
                                        <StackPanel>
                                            <TextBlock Text="{Binding CostLines, StringFormat=💎 {0:N0}}"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                            <TextBlock Text="구매" FontSize="10"
                                                       Foreground="{StaticResource DimBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ─── 오른쪽: 이벤트 로그 ─── -->
        <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="16,12">
                    <TextBlock Text="📰 이벤트 로그" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding EventLog}" Margin="0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,5">
                                    <TextBlock Text="{Binding}" FontSize="11"
                                               Foreground="{StaticResource DimBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
