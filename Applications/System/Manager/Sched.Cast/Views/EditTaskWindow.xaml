<Window x:Class="Sched.Cast.Views.EditTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="새 작업 등록" Width="500" Height="500"
        Background="#1A1A2E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="#13131F"/>
            <Setter Property="Foreground"       Value="#E0E0E0"/>
            <Setter Property="BorderBrush"      Value="#2A2A3E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="#13131F"/>
            <Setter Property="Foreground"       Value="#E0E0E0"/>
            <Setter Property="BorderBrush"      Value="#2A2A3E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/></Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding SelectionBoxItem}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▾" Foreground="#555566" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom">
                                    <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                                <ToggleButton Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent" BorderThickness="0" Opacity="0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#252535"/></Trigger>
                            <Trigger Property="IsSelected"  Value="True"><Setter Property="Background" Value="#1E3A5E"/><Setter Property="Foreground" Value="#60A5FA"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Bd" Width="16" Height="16" CornerRadius="3"
                                    Background="#1E1E2E" BorderBrush="#2A2A3E" BorderThickness="1"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock x:Name="Chk" Text="✓" FontSize="11" Foreground="#60A5FA"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chk" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Bd"  Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="새 예약 작업 등록" FontSize="16" FontWeight="Bold"
                   Foreground="#60A5FA" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 이름 -->
                <TextBlock Text="작업 이름 *" Foreground="#888899" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtName" Margin="0,0,0,12"/>

                <!-- 설명 -->
                <TextBlock Text="설명 (선택)" Foreground="#888899" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDesc" Margin="0,0,0,12"/>

                <!-- 실행 파일 -->
                <TextBlock Text="실행 파일 경로 *" Foreground="#888899" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtExe" Grid.Column="0"/>
                    <Button Grid.Column="1" Content="찾기" Margin="6,0,0,0"
                            Background="#1E1E2E" Foreground="#9CA3AF" BorderBrush="#2A2A3E" BorderThickness="1"
                            Padding="8,4" Cursor="Hand" Click="Browse_Click"/>
                </Grid>
                <TextBlock Text="*.exe, *.cmd, *.bat, *.ps1 지원"
                           Foreground="#3A3A5A" FontSize="11" Margin="0,0,0,12"/>

                <!-- 인수 -->
                <TextBlock Text="인수 (선택)" Foreground="#888899" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtArgs" Margin="0,0,0,12"/>

                <!-- 작업 폴더 -->
                <TextBlock Text="작업 디렉터리 (선택)" Foreground="#888899" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtWorkDir" Margin="0,0,0,12"/>

                <!-- 트리거 -->
                <TextBlock Text="실행 시점" Foreground="#888899" Margin="0,0,0,4"/>
                <ComboBox x:Name="CmbTrigger" Margin="0,0,0,8" SelectionChanged="CmbTrigger_Changed">
                    <ComboBoxItem Content="1회 실행"   Tag="Once"/>
                    <ComboBoxItem Content="매일"       Tag="Daily"    IsSelected="True"/>
                    <ComboBoxItem Content="매주"       Tag="Weekly"/>
                    <ComboBoxItem Content="로그인 시"  Tag="AtLogon"/>
                    <ComboBoxItem Content="시작 시"    Tag="AtStartup"/>
                </ComboBox>

                <!-- 시간 설정 (동적 표시) -->
                <StackPanel x:Name="PnlTime" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="시간:" Foreground="#888899" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtTime" Width="100" Text="09:00"/>
                    <TextBlock Text="(HH:mm)" Foreground="#3A3A5A" FontSize="11"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel x:Name="PnlWeekday" Orientation="Horizontal"
                            Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="요일:" Foreground="#888899" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbWeekday" Width="100">
                        <ComboBoxItem Content="월요일" IsSelected="True"/>
                        <ComboBoxItem Content="화요일"/>
                        <ComboBoxItem Content="수요일"/>
                        <ComboBoxItem Content="목요일"/>
                        <ComboBoxItem Content="금요일"/>
                        <ComboBoxItem Content="토요일"/>
                        <ComboBoxItem Content="일요일"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel x:Name="PnlOnce" Orientation="Horizontal"
                            Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="날짜:" Foreground="#888899" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtDate" Width="120" Text="{Binding Source={x:Static sys:DateTime.Today}, StringFormat=yyyy-MM-dd}"
                             xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                </StackPanel>

                <!-- 옵션 -->
                <CheckBox x:Name="ChkHighest" Content="최고 권한으로 실행" Margin="0,0,0,8"/>
                <CheckBox x:Name="ChkEnabled" Content="즉시 활성화" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 버튼 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="등록" Width="80" Height="34"
                    Background="#1E3A5E" Foreground="#60A5FA" BorderBrush="#2563EB" BorderThickness="1"
                    Cursor="Hand" Click="Ok_Click"/>
            <Button Content="취소" Width="80" Height="34"
                    Background="#1E1E2E" Foreground="#9CA3AF" BorderBrush="#2A2A3E" BorderThickness="1"
                    Cursor="Hand" Margin="8,0,0,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
