<Window x:Class="FileUnlocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File.Unlocker" Height="660" Width="1000"
        MinHeight="500" MinWidth="780"
        Background="#1A1A1A" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <!-- Brushes -->
        <SolidColorBrush x:Key="BgBrush"         Color="#1A1A1A"/>
        <SolidColorBrush x:Key="PanelBrush"       Color="#242424"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="#333333"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#4B9EFF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#6AB4FF"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#888888"/>
        <SolidColorBrush x:Key="DangerBrush"      Color="#C0392B"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#E74C3C"/>
        <SolidColorBrush x:Key="WarnBrush"        Color="#E67E22"/>
        <SolidColorBrush x:Key="GreenBrush"       Color="#27AE60"/>
        <SolidColorBrush x:Key="DropHlBrush"      Color="#1A2A3A"/>

        <!-- 기본 버튼 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#333333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarnButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource WarnBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F39C12"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder" Width="15" Height="15" CornerRadius="3"
                                    Background="#2A2A2A" BorderBrush="#555555" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark" Text="&#10003;" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#0A1A2A"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GridViewColumnHeader -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="#222222"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush"     Value="#333333"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <Thumb x:Name="PART_HeaderGripper"
                                   HorizontalAlignment="Right" Width="6"
                                   Cursor="SizeWE" Opacity="0">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border x:Name="GripBd" Background="Transparent" Width="6">
                                            <Rectangle x:Name="GripLine" Width="1" HorizontalAlignment="Center"
                                                       Fill="#555566" Opacity="0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="GripLine" Property="Opacity" Value="1"/>
                                                <Setter TargetName="GripBd" Property="Background" Value="#33334A"/>
                                            </Trigger>
                                            <Trigger Property="IsDragging" Value="True">
                                                <Setter TargetName="GripLine" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="GripLine" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="PART_HeaderGripper" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListViewItem -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground"                Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding"                   Value="4,3"/>
            <Setter Property="FontSize"                  Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderThickness="0,0,0,1" BorderBrush="#2A2A2A"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter
                                Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}"
                                Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2A3A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#222232"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 왼쪽 패널 (검사 대상 목록) ═══ -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="File.Unlocker" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="잠긴 파일 · 프로세스 탐색기" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- 드롭 영역 + 파일 목록 -->
                <Border Grid.Row="1" x:Name="DropZone"
                        BorderBrush="#444455" BorderThickness="1" CornerRadius="6"
                        Background="#1E1E28" Margin="0,0,0,8">
                    <Grid>
                        <!-- 빈 상태 힌트 -->
                        <StackPanel x:Name="DropHint"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="Visible">
                            <TextBlock Text="&#128196;" FontSize="32"
                                       HorizontalAlignment="Center" Foreground="#444455"/>
                            <TextBlock Text="파일·폴더를&#x0a;여기에 드롭"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       FontSize="12" Foreground="#555566" Margin="0,6,0,0"/>
                        </StackPanel>

                        <ListBox x:Name="FileListBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextPrimary}" FontSize="11"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="FileList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,5"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="Transparent"
                                                        BorderThickness="0,0,0,1" BorderBrush="#2A2A38"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1A2A3A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#222232"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Path}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding Path}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="9" Foreground="#555565"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="3" Padding="5,2" Margin="4,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A3A1A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                            <Setter Property="Background" Value="#3A1A1A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding LockCountText}" FontSize="9" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 파일 목록 버튼 -->
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="RemoveFileBtn" Content="선택 제거"
                            Style="{StaticResource GhostButton}" Padding="8,5"
                            Click="RemoveFile_Click" IsEnabled="False"/>
                    <Button Grid.Column="2" Content="모두 제거"
                            Style="{StaticResource GhostButton}" Padding="8,5"
                            Click="ClearAll_Click"/>
                </Grid>

                <!-- 통계 -->
                <Border Grid.Row="3" Background="#1E1E28" CornerRadius="6" Padding="10,8">
                    <StackPanel>
                        <Grid Margin="0,1">
                            <TextBlock Text="검사 대상" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="StatFiles" Text="0개" FontSize="10"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,1">
                            <TextBlock Text="잠금 프로세스" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="StatProcs" Text="0개" FontSize="10"
                                       Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,1">
                            <TextBlock Text="선택된 프로세스" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="StatSelected" Text="0개" FontSize="10"
                                       Foreground="{StaticResource WarnBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ 오른쪽 패널 (프로세스 목록) ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 툴바 -->
            <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Text="파일·폴더를 왼쪽 영역이나 창에 드래그 앤 드롭하세요."
                                   FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="SelectAllBtn" Content="전체 선택"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0" Padding="10,5"
                                Click="SelectAll_Click" IsEnabled="False"/>
                        <Button x:Name="SelectNoneBtn" Content="선택 해제"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0" Padding="10,5"
                                Click="SelectNone_Click" IsEnabled="False"/>
                        <Button x:Name="RefreshBtn" Content="새로고침"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0" Padding="10,5"
                                Click="Refresh_Click" IsEnabled="False"/>
                        <Button x:Name="KillSelectedBtn" Content="선택 종료"
                                Style="{StaticResource WarnButton}" Margin="0,0,6,0" Padding="10,5"
                                Click="KillSelected_Click" IsEnabled="False"/>
                        <Button x:Name="KillAllBtn" Content="전체 종료"
                                Style="{StaticResource DangerButton}" Padding="10,5"
                                Click="KillAll_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 프로세스 목록 -->
            <Grid Grid.Row="1">
                <!-- 빈 상태 안내 -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#128274;" FontSize="52"
                               HorizontalAlignment="Center" Foreground="#333344"/>
                    <TextBlock Text="검사된 프로세스가 없습니다."
                               FontSize="14" Foreground="#444455"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="파일이나 폴더를 드래그 앤 드롭하세요."
                               FontSize="12" Foreground="#333344"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 잠금 없음 상태 -->
                <StackPanel x:Name="NoLockState"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="&#128275;" FontSize="52"
                               HorizontalAlignment="Center" Foreground="#1A3A1A"/>
                    <TextBlock Text="파일을 잠근 프로세스가 없습니다."
                               FontSize="14" Foreground="#2A5A2A"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="삭제나 이동이 자유롭게 가능합니다."
                               FontSize="12" Foreground="#1A4A1A"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 프로세스 ListView -->
                <ListView x:Name="ProcessListView"
                          Background="{StaticResource BgBrush}"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Visibility="Collapsed"
                          SelectionMode="Extended">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="프로세스 종료" Click="CtxKill_Click"/>
                            <Separator/>
                            <MenuItem Header="탐색기에서 열기" Click="CtxOpenInExplorer_Click"/>
                            <MenuItem Header="경로 복사" Click="CtxCopyPath_Click"/>
                            <MenuItem Header="프로세스 이름 복사" Click="CtxCopyName_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <!-- 체크박스 -->
                            <GridViewColumn Width="36">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Checked="Process_CheckChanged"
                                                  Unchecked="Process_CheckChanged"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- 아이콘 + 이름 -->
                            <GridViewColumn Header="프로세스" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding Icon}" Width="16" Height="16"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Name}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- PID -->
                            <GridViewColumn Header="PID" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Pid}"
                                                   Foreground="{StaticResource TextSecondary}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- 유형 -->
                            <GridViewColumn Header="유형" Width="64">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="5,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2A2A3A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AppType}" Value="서비스">
                                                            <Setter Property="Background" Value="#1A2A3A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AppType}" Value="탐색기">
                                                            <Setter Property="Background" Value="#1A3A2A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AppType}" Value="시스템">
                                                            <Setter Property="Background" Value="#3A1A1A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding AppType}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#AAAACC"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- 재시작 가능 -->
                            <GridViewColumn Header="재시작" Width="56">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#10007;"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestartable}" Value="True">
                                                            <Setter Property="Text" Value="&#10003;"/>
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- 경로 -->
                            <GridViewColumn Header="실행 파일 경로" Width="360">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ShortPath}"
                                                   ToolTip="{Binding ExecutablePath}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <!-- 결과 메시지 패널 -->
            <Border Grid.Row="2" x:Name="ResultPanel"
                    BorderBrush="#2A4A2A" BorderThickness="0,1,0,0"
                    Padding="14,8" Visibility="Collapsed" MaxHeight="80">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ResultIcon" Grid.Column="0" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="ResultText" Grid.Column="1" FontSize="12"
                               Foreground="#A0D0A0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Grid.Column="2" Content="닫기"
                            Style="{StaticResource GhostButton}"
                            Padding="8,4" Margin="10,0,0,0"
                            Click="CloseResult_Click" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 하단 진행 표시 -->
            <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="14,6" x:Name="ProgressPanel" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="ScanProgress" Grid.Column="0" Height="4"
                                 IsIndeterminate="True"
                                 Background="#333333" Foreground="{StaticResource AccentBrush}"
                                 BorderThickness="0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="ProgressLabel"
                               Text="검사 중..." FontSize="11"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
