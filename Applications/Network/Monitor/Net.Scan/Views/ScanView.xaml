<UserControl x:Class="NetScan.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118" Foreground="#E8E8F0">
    <UserControl.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555566"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 툴바 ═════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0D0D16" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 어댑터 선택 -->
                <TextBlock Grid.Column="0" Text="어댑터" FontSize="11"
                           Foreground="#888899" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="2" x:Name="CbAdapter" Width="200" Height="28"
                          SelectionChanged="CbAdapter_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 범위 (CIDR) -->
                <TextBlock Grid.Column="4" x:Name="TxtSubnet" FontSize="11"
                           Foreground="#888899" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="4" x:Name="TxtRange" Height="28"
                         FontFamily="Consolas" FontSize="12"
                         Background="#1A1A28" BorderBrush="#2A2A3E"
                         VerticalContentAlignment="Center" Padding="6,0"
                         Visibility="Collapsed"/>

                <!-- 스캔/중단 버튼 -->
                <Button Grid.Column="6" x:Name="BtnScan" Content="▶  스캔" Width="90" Height="30"
                        Style="{StaticResource AccentButton}" Click="BtnScan_Click"/>
                <Button Grid.Column="8" x:Name="BtnStop" Content="⏹  중단" Width="90" Height="30"
                        IsEnabled="False" Click="BtnStop_Click"/>

                <!-- 우측 요약 -->
                <TextBlock Grid.Column="10" x:Name="TxtSummary"
                           FontSize="11" Foreground="#888899" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ 스캔 진행 바 ════════════════════════════════════════ -->
        <ProgressBar Grid.Row="1" x:Name="PbScan" Minimum="0" Maximum="100" Value="0"
                     Background="#1A1A28" Foreground="#06B6D4"/>

        <!-- ═══ 메인 콘텐츠: 목록 + 상세 ════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- ─── 기기 목록 ──────────────────────────────────────── -->
            <ListView Grid.Column="0" x:Name="LvDevices"
                      SelectionChanged="LvDevices_SelectionChanged"
                      Background="#111118" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="32">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusDot}"
                                               Foreground="{Binding StatusColor}"
                                               FontSize="10" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="IP" Width="120"
                                        DisplayMemberBinding="{Binding IpAddress}"/>
                        <GridViewColumn Header="호스트명 / 별칭" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="제조사" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DeviceType}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Vendor}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="핑" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PingText}"
                                               HorizontalAlignment="Right"
                                               Foreground="#06B6D4" FontFamily="Consolas"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- ─── 구분선 ──────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#1E1E2E" ShowsPreview="False"/>

            <!-- ─── 상세 패널 ──────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2" Background="#0D0D16"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="PanelDetail" Margin="16,14,16,20">

                    <!-- 빈 상태 -->
                    <TextBlock x:Name="TxtNoSelection" Text="기기를 선택하세요"
                               FontSize="13" Foreground="#444455"
                               HorizontalAlignment="Center" Margin="0,60,0,0"/>

                    <!-- 기기 상세 (선택 시 표시) -->
                    <StackPanel x:Name="PanelDeviceDetail" Visibility="Collapsed">

                        <!-- 헤더: 아이콘 + 이름 + 상태 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock x:Name="TxtDetailIcon" FontSize="28" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtDetailName" FontSize="16" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtDetailStatus" FontSize="11"
                                               Margin="0,2,6,0"/>
                                    <TextBlock x:Name="TxtDetailPing" FontSize="11"
                                               Foreground="#06B6D4" FontFamily="Consolas" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Separator Background="#2A2A3E" Margin="0,0,0,10"/>

                        <!-- 기본 정보 -->
                        <Grid x:Name="GridInfo">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtDetailIp" FontFamily="Consolas" FontSize="12" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="MAC" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtDetailMac" FontFamily="Consolas" FontSize="12" Margin="0,2"
                                       Foreground="#888899"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="제조사" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtDetailVendor" FontSize="12" Margin="0,2"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="최근 응답" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtDetailLastSeen" FontSize="11" Margin="0,2"
                                       Foreground="#888899"/>
                        </Grid>

                        <Separator Background="#2A2A3E" Margin="0,10"/>

                        <!-- 별칭 편집 -->
                        <TextBlock Text="별칭" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="TxtAlias" Height="28"
                                     Background="#1A1A28" BorderBrush="#2A2A3E"
                                     VerticalContentAlignment="Center" Padding="6,0"
                                     FontSize="12"/>
                            <Button Grid.Column="2" Content="저장" Width="50" Height="28"
                                    Style="{StaticResource AccentButton}" Click="BtnSaveAlias_Click"/>
                        </Grid>

                        <Separator Background="#2A2A3E" Margin="0,10"/>

                        <!-- 포트 스캔 -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="포트 스캔" FontSize="12"
                                       Foreground="#CCCCDD" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" x:Name="BtnPortScan" Content="스캔" Width="50" Height="26"
                                    Click="BtnPortScan_Click"/>
                        </Grid>

                        <ItemsControl x:Name="IcPorts">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A2A2E" BorderBrush="#0E4A55"
                                            BorderThickness="1" CornerRadius="3"
                                            Margin="0,0,4,4" Padding="5,2">
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="#06B6D4"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtPortScanStatus" FontSize="11"
                                   Foreground="#888899" Margin="0,4,0,0"/>

                        <Separator Background="#2A2A3E" Margin="0,10"/>

                        <!-- 핑 히스토리 그래프 -->
                        <TextBlock Text="핑 히스토리" FontSize="12" Foreground="#CCCCDD" Margin="0,0,0,6"/>
                        <Border Background="#0A0A14" BorderBrush="#2A2A3E"
                                BorderThickness="1" CornerRadius="4" Height="80">
                            <Canvas x:Name="CvPingGraph" ClipToBounds="True"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="TxtGraphMin" FontSize="10" Foreground="#555566" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtGraphAvg" FontSize="10" Foreground="#888899" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtGraphMax" FontSize="10" Foreground="#555566"/>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>

</UserControl>
