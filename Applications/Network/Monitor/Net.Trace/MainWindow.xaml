<Window x:Class="Net.Trace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Net.Trace — 시각적 트레이스라우트"
        Width="1120" Height="720"
        MinWidth="800" MinHeight="520"
        Background="#0A0A18" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="12"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="TbBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderBrush"     Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Background"  Value="#0E3A6E"/>
            <Setter Property="Foreground"  Value="#60A5FA"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
        </Style>
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Background"  Value="#3A1014"/>
            <Setter Property="Foreground"  Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#0C0C20"/>
            <Setter Property="Foreground"      Value="#D0D0E0"/>
            <Setter Property="BorderBrush"     Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="CaretBrush"      Value="#60A5FA"/>
            <Setter Property="SelectionBrush"  Value="#2563EB"/>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#0A0A18"/>
            <Setter Property="Width"      Value="6"/>
            <Setter Property="MinWidth"   Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Bd" Background="#2A2A4A" CornerRadius="3" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#4A4A7A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="Foreground"           Value="#C0C0D0"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1A1A30"/>
            <Setter Property="RowBackground"        Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#06060F"/>
            <Setter Property="ColumnHeaderHeight"   Value="28"/>
            <Setter Property="RowHeight"            Value="26"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="IsReadOnly"           Value="True"/>
            <Setter Property="SelectionMode"        Value="Single"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="#0E0E22"/>
            <Setter Property="Foreground"       Value="#6A6A9A"/>
            <Setter Property="Padding"          Value="8,0"/>
            <Setter Property="FontSize"         Value="10"/>
            <Setter Property="BorderBrush"      Value="#1A1A30"/>
            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0E2040"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0A1828"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── 툴바 ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0C0C22" BorderBrush="#1A1A30" BorderThickness="0,0,0,1" Padding="10,0">
            <DockPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TbTarget" Width="280" Margin="0,0,8,0"
                             Text="{Binding Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="Target_KeyDown"
                             FontFamily="Consolas" FontSize="13"/>
                    <Button Style="{StaticResource AccBtn}" Content="▶ 추적 시작"
                            Command="{Binding StartCmd}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource RedBtn}"  Content="■ 중지"
                            Command="{Binding StopCmd}"  Margin="0,0,4,0"/>
                    <Button Style="{StaticResource TbBtn}"  Content="✕ 초기화"
                            Command="{Binding ClearCmd}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource TbBtn}"  Content="📋 CSV 내보내기"
                            Command="{Binding ExportCsvCmd}"/>
                </StackPanel>

                <!-- 진행 표시 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="추적 중" Foreground="#3B82F6" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                               Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                    <ProgressBar IsIndeterminate="{Binding IsRunning}" Width="100" Height="4"
                                 Background="#1A1A30" Foreground="#3B82F6"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── 메인 (지도 + 그리드) ─────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!-- 세계 지도 캔버스 -->
            <Border Grid.Row="0" Background="#04080F" ClipToBounds="True">
                <Canvas x:Name="MapCanvas"
                        SizeChanged="MapCanvas_SizeChanged"/>
            </Border>

            <!-- 홉 정보 DataGrid -->
            <Border Grid.Row="1" Background="#06060F" BorderBrush="#1A1A30" BorderThickness="0,1,0,0">
                <DataGrid x:Name="HopGrid"
                          ItemsSource="{Binding Hops}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="홉 #"  Binding="{Binding HopNumber}"  Width="50"/>
                        <DataGridTextColumn Header="IP 주소" Binding="{Binding Ip, TargetNullValue='* * *'}" Width="130" FontFamily="Consolas"/>
                        <DataGridTextColumn Header="호스트명"  Binding="{Binding HostDisplay}" Width="200"/>
                        <DataGridTextColumn Header="위치"    Binding="{Binding Location}"   Width="*"/>
                        <DataGridTextColumn Header="RTT (평균)"  Binding="{Binding RttText}"  Width="90"/>
                        <DataGridTextColumn Header="RTT 최소"    Binding="{Binding RttMin, StringFormat={}{0:F1} ms, TargetNullValue=—}" Width="90"/>
                        <DataGridTextColumn Header="RTT 최대"    Binding="{Binding RttMax, StringFormat={}{0:F1} ms, TargetNullValue=—}" Width="90"/>
                        <DataGridTextColumn Header="손실"    Binding="{Binding LossText}"  Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ── 상태바 ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#0C0C22" BorderBrush="#1A1A30" BorderThickness="0,1,0,0" Padding="12,0">
            <TextBlock Text="{Binding Status}" Foreground="#555577"
                       VerticalAlignment="Center" FontSize="11"/>
        </Border>
    </Grid>
</Window>
