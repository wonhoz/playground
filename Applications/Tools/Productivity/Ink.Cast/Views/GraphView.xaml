<UserControl x:Class="InkCast.Views.GraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#12121E">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9399B2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 그래프 툴바 -->
        <Border Grid.Row="0" Background="#181828" Padding="8,6" BorderBrush="#252535" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="◈ 노트 연결 그래프" FontSize="13" FontWeight="SemiBold"
                           Foreground="#CBA6F7" VerticalAlignment="Center" Margin="4,0,12,0"/>
                <Button x:Name="BtnZoomIn"  Content="＋ 확대" Click="BtnZoomIn_Click"
                        Padding="8,4" Margin="0,0,4,0"/>
                <Button x:Name="BtnZoomOut" Content="－ 축소" Click="BtnZoomOut_Click"
                        Padding="8,4" Margin="0,0,4,0"/>
                <Button x:Name="BtnFit"     Content="⊞ 맞춤" Click="BtnFit_Click"
                        Padding="8,4" Margin="0,0,4,0"/>
                <Button x:Name="BtnReset"   Content="↺ 재배치" Click="BtnReset_Click"
                        Padding="8,4"/>
                <TextBlock x:Name="TxtGraphInfo" FontSize="11" Foreground="#585B70"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 줌/팬 캔버스 -->
        <Border Grid.Row="1" ClipToBounds="True" x:Name="GraphBorder">
            <Canvas x:Name="GraphCanvas" Background="Transparent"
                    MouseWheel="GraphCanvas_MouseWheel"
                    MouseLeftButtonDown="GraphCanvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="GraphCanvas_MouseLeftButtonUp"
                    MouseMove="GraphCanvas_MouseMove"
                    Cursor="Hand">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ScaleT" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="TranslateT" X="0" Y="0"/>
                    </TransformGroup>
                </Canvas.RenderTransform>
            </Canvas>
        </Border>
    </Grid>
</UserControl>
