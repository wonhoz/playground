<Window x:Class="PdfForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PdfForge.Views"
        Title="PDF.Forge" Height="720" Width="1100" MinHeight="500" MinWidth="800"
        Background="#111118" Foreground="#E8E8F0"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 사이드바 -->
        <Border Grid.Column="0" Background="#0D0D16" BorderBrush="#2E2E50" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 로고 -->
                <Border DockPanel.Dock="Top" Padding="16,20,16,12"
                        BorderBrush="#2E2E50" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="Bold" HorizontalAlignment="Center">
                            <Run Text="PDF" Foreground="#E05555"/>
                            <Run Text=".Forge" Foreground="#E8E8F0"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 내비게이션 -->
                <StackPanel DockPanel.Dock="Top" Margin="8,12,8,0">
                    <Button x:Name="BtnMerge"     Content="🔗  병합"     Click="NavBtn_Click" Tag="Merge"
                            HorizontalContentAlignment="Left" Padding="12,10" Margin="0,1"
                            Background="Transparent" BorderBrush="Transparent"/>
                    <Button x:Name="BtnSplit"     Content="✂  분리"     Click="NavBtn_Click" Tag="Split"
                            HorizontalContentAlignment="Left" Padding="12,10" Margin="0,1"
                            Background="Transparent" BorderBrush="Transparent"/>
                    <Button x:Name="BtnPage"      Content="📄  페이지"   Click="NavBtn_Click" Tag="Page"
                            HorizontalContentAlignment="Left" Padding="12,10" Margin="0,1"
                            Background="Transparent" BorderBrush="Transparent"/>
                    <Button x:Name="BtnCompress"  Content="🗜  압축"     Click="NavBtn_Click" Tag="Compress"
                            HorizontalContentAlignment="Left" Padding="12,10" Margin="0,1"
                            Background="Transparent" BorderBrush="Transparent"/>
                    <Button x:Name="BtnWatermark" Content="💧  워터마크" Click="NavBtn_Click" Tag="Watermark"
                            HorizontalContentAlignment="Left" Padding="12,10" Margin="0,1"
                            Background="Transparent" BorderBrush="Transparent"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 콘텐츠 영역 -->
        <Border Grid.Column="1" x:Name="ContentArea" Background="#111118"/>
    </Grid>
</Window>
