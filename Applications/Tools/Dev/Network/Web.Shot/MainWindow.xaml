<Window x:Class="WebShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Web.Shot" Height="800" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- 툴바 -->
      <RowDefinition Height="Auto"/>  <!-- 옵션 바 -->
      <RowDefinition Height="Auto"/>  <!-- 프로그레스 -->
      <RowDefinition Height="*"/>     <!-- 메인 콘텐츠 -->
      <RowDefinition Height="Auto"/>  <!-- 상태바 -->
    </Grid.RowDefinitions>

    <!-- ── 툴바 ─────────────────────────────────────────── -->
    <Border Grid.Row="0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 앱 이름 -->
        <TextBlock Grid.Column="0" Text="Web.Shot"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   VerticalAlignment="Center" Margin="0,0,16,0"/>

        <!-- URL 입력 -->
        <Grid Grid.Column="1">
          <TextBox x:Name="TxtUrl"
                   VerticalContentAlignment="Center"
                   KeyDown="TxtUrl_KeyDown"
                   TextChanged="TxtUrl_TextChanged"/>
          <TextBlock x:Name="TxtUrlPlaceholder"
                     Text="URL 또는 파일 경로 (예: https://example.com)"
                     Foreground="{StaticResource TextDimBrush}"
                     FontSize="12" IsHitTestVisible="False"
                     VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>

        <!-- 캡처 버튼 -->
        <Button Grid.Column="2" x:Name="BtnCapture"
                Content="📷 캡처" Height="32" MinWidth="80"
                Margin="8,0,0,0" Style="{StaticResource AccentButton}"
                Click="BtnCapture_Click"/>

        <!-- 배치 캡처 버튼 -->
        <Button Grid.Column="3" x:Name="BtnBatch"
                Content="📋 배치" Height="32" MinWidth="70"
                Margin="6,0,0,0"
                Click="BtnBatch_Click"
                ToolTip="TXT 파일에서 URL 목록을 읽어 일괄 캡처"/>

        <!-- 출력 폴더 열기 -->
        <Button Grid.Column="4" x:Name="BtnOpenFolder"
                Content="📁" Height="32" Width="36"
                Margin="6,0,0,0"
                Click="BtnOpenFolder_Click"
                ToolTip="캡처 저장 폴더 열기"/>

        <!-- 히스토리 패널 토글 -->
        <Button Grid.Column="5" x:Name="BtnHistory"
                Content="🕐" Height="32" Width="36"
                Margin="6,0,0,0"
                Click="BtnHistory_Click"
                ToolTip="히스토리 패널 토글"/>
      </Grid>
    </Border>

    <!-- ── 옵션 바 ──────────────────────────────────────── -->
    <Border Grid.Row="1"
            Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,6">
      <WrapPanel Orientation="Horizontal">

        <!-- 뷰포트 너비 -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
          <TextBlock Text="뷰포트:" Foreground="{StaticResource TextDimBrush}"
                     VerticalAlignment="Center" Margin="0,0,6,0"/>
          <ComboBox x:Name="CboViewport" Width="110" Height="28"
                    SelectionChanged="CboViewport_SelectionChanged">
            <ComboBoxItem Content="375 (모바일)"  Tag="375"/>
            <ComboBoxItem Content="768 (태블릿)" Tag="768"/>
            <ComboBoxItem Content="1280 (데스크톱)" Tag="1280" IsSelected="True"/>
            <ComboBoxItem Content="1440 (풀HD)"  Tag="1440"/>
            <ComboBoxItem Content="커스텀"        Tag="0"/>
          </ComboBox>
          <TextBox x:Name="TxtCustomWidth" Width="60" Height="28"
                   Margin="6,0,0,0" Visibility="Collapsed"
                   Text="1280"/>
        </StackPanel>

        <!-- 딜레이 -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
          <TextBlock Text="딜레이:" Foreground="{StaticResource TextDimBrush}"
                     VerticalAlignment="Center" Margin="0,0,6,0"/>
          <ComboBox x:Name="CboDelay" Width="100" Height="28">
            <ComboBoxItem Content="500ms"  Tag="500"/>
            <ComboBoxItem Content="1초"    Tag="1000" IsSelected="True"/>
            <ComboBoxItem Content="1.5초"  Tag="1500"/>
            <ComboBoxItem Content="2초"    Tag="2000"/>
            <ComboBoxItem Content="3초"    Tag="3000"/>
            <ComboBoxItem Content="5초"    Tag="5000"/>
          </ComboBox>
        </StackPanel>

        <!-- PDF 출력 -->
        <CheckBox x:Name="ChkPdf" Content="PDF 저장"
                  VerticalAlignment="Center" Margin="0,0,16,0"/>

        <!-- 미리보기 숨기기 -->
        <CheckBox x:Name="ChkHidePreview" Content="미리보기 숨기기"
                  VerticalAlignment="Center"
                  Checked="ChkHidePreview_Changed"
                  Unchecked="ChkHidePreview_Changed"/>
      </WrapPanel>
    </Border>

    <!-- ── 진행 바 ──────────────────────────────────────── -->
    <Border Grid.Row="2" x:Name="ProgressPanel"
            Background="{StaticResource Surface2Brush}"
            Padding="12,6" Visibility="Collapsed">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock x:Name="TxtProgressLabel"
                     Foreground="{StaticResource TextDimBrush}" FontSize="11"
                     Margin="0,0,0,3"/>
          <ProgressBar x:Name="PrgBatch" Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>
        <Button Grid.Column="1" Content="취소" Height="24"
                Margin="12,0,0,0" Style="{StaticResource DangerButton}"
                Click="BtnCancelBatch_Click"/>
      </Grid>
    </Border>

    <!-- ── 메인 콘텐츠 ──────────────────────────────────── -->
    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto" x:Name="HistoryColumn"/>
      </Grid.ColumnDefinitions>

      <!-- WebView2 미리보기 -->
      <Border Grid.Column="0"
              Background="{StaticResource BgBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0">
        <Grid>
          <!-- 빈 상태 메시지 -->
          <StackPanel x:Name="EmptyState"
                      VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="📷" FontSize="64" HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>
            <TextBlock Text="URL을 입력하고 캡처 버튼을 누르세요"
                       FontSize="16" Foreground="{StaticResource TextDimBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="전체 페이지를 PNG 또는 PDF로 저장합니다"
                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
          </StackPanel>

          <!-- WebView2 -->
          <wv2:WebView2 x:Name="WebView"
                        Visibility="Collapsed"/>
        </Grid>
      </Border>

      <!-- 히스토리 패널 -->
      <Border Grid.Column="1" x:Name="HistoryPanel"
              Width="280" Visibility="Collapsed"
              Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1,0,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- 히스토리 헤더 -->
          <Border Grid.Row="0"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="12,8">
            <Grid>
              <TextBlock Text="캡처 히스토리"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextBrush}"
                         VerticalAlignment="Center"/>
              <Button x:Name="BtnClearHistory"
                      Content="지우기" HorizontalAlignment="Right"
                      Height="24" Padding="8,2"
                      Style="{StaticResource DangerButton}"
                      Click="BtnClearHistory_Click"/>
            </Grid>
          </Border>

          <!-- 히스토리 목록 -->
          <ListBox Grid.Row="1" x:Name="LstHistory"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   SelectionChanged="LstHistory_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,4">
                  <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Text="{Binding ShortUrl}"
                             FontSize="11" TextWrapping="Wrap"
                             Foreground="{StaticResource TextBrush}"/>
                  <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Text="{Binding DisplayTime}"
                               FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                    <TextBlock Text=" · " FontSize="10"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <TextBlock Text="{Binding ViewportWidth}"
                               FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                    <TextBlock Text="px" FontSize="10"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <TextBlock Text=" · " FontSize="10"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <TextBlock Text="{Binding FileType}"
                               FontSize="10" Foreground="{StaticResource AccentBrush}"
                               FontWeight="SemiBold"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- 히스토리 항목 액션 -->
          <Border Grid.Row="2"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="0,1,0,0"
                  Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button x:Name="BtnOpenFile" Content="📂 열기"
                      Height="28" Padding="8,3" Margin="0,0,6,0"
                      IsEnabled="False"
                      Click="BtnOpenFile_Click"/>
              <Button x:Name="BtnDeleteEntry" Content="🗑 삭제"
                      Height="28" Padding="8,3"
                      Style="{StaticResource DangerButton}"
                      IsEnabled="False"
                      Click="BtnDeleteEntry_Click"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- ── 상태바 ────────────────────────────────────────── -->
    <Border Grid.Row="4"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,4">
      <Grid>
        <TextBlock x:Name="TxtStatus"
                   Foreground="{StaticResource TextDimBrush}"
                   FontSize="11" VerticalAlignment="Center"/>
        <TextBlock x:Name="TxtSavedPath"
                   HorizontalAlignment="Right"
                   Foreground="{StaticResource Accent2Brush}"
                   FontSize="11" VerticalAlignment="Center"
                   Cursor="Hand" TextDecorations="Underline"
                   MouseDown="TxtSavedPath_MouseDown"
                   Visibility="Collapsed"/>
      </Grid>
    </Border>
  </Grid>
</Window>
