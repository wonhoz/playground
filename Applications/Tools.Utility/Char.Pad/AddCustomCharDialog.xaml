<Window x:Class="CharPad.AddCustomCharDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="사용자 정의 문자 추가"
        Width="360" Height="210"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Window.Effect>
        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.6" Color="#000000"/>
    </Window.Effect>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 제목 -->
            <Grid Grid.Row="0">
                <TextBlock x:Name="TitleText"
                           Text="+ 사용자 정의 문자 추가"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Width="24" Height="24"
                        Content="✕" FontSize="10"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        Click="CancelBtn_Click"/>
            </Grid>

            <!-- 문자 입력 -->
            <TextBox x:Name="CharBox" Grid.Row="2"
                     Height="34"
                     MaxLength="4"
                     TextChanged="CharBox_TextChanged"/>
            <TextBlock x:Name="CharPlaceholder" Grid.Row="2"
                       Text="문자 입력 (예: ♾, ⬡, 🌙)"
                       Foreground="{StaticResource TextSecondary}"
                       FontFamily="Segoe UI" FontSize="12"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>

            <!-- 이름 입력 -->
            <TextBox x:Name="NameBox" Grid.Row="4"
                     Height="34"
                     MaxLength="50"
                     TextChanged="NameBox_TextChanged"/>
            <TextBlock x:Name="NamePlaceholder" Grid.Row="4"
                       Text="이름 입력 (예: infinity loop)"
                       Foreground="{StaticResource TextSecondary}"
                       FontFamily="Segoe UI" FontSize="12"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>

            <!-- 버튼 -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소" Width="72" Height="30" Margin="0,0,8,0"
                        Click="CancelBtn_Click"/>
                <Button x:Name="AddBtn" Content="추가" Width="72" Height="30"
                        Background="{StaticResource AccentBrush}"
                        IsEnabled="False"
                        Click="AddBtn_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
