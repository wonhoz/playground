<Window x:Class="SkillCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skill.Cast — Claude Code 개발 환경 관리자"
        Width="1280" Height="820"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="Auto"/>
            <!-- 경로 바 -->
            <RowDefinition Height="Auto"/>
            <!-- 탭 헤더 -->
            <RowDefinition Height="*"/>
            <!-- 콘텐츠 -->
            <RowDefinition Height="Auto"/>
            <!-- 하단 바 -->
        </Grid.RowDefinitions>

        <!-- ══ 헤더 ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#141414" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚗️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Skill.Cast" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Claude Code 개발 환경 관리자"
                               FontSize="13" Foreground="{StaticResource Fg2Brush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 새로고침" Click="Refresh_Click" Padding="10,5" Margin="0,0,8,0"/>
                    <Button Content="📁 프로젝트 선택" Click="SelectProject_Click" Padding="10,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ 경로 바 ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🌍 전역:" Foreground="{StaticResource Fg2Brush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" x:Name="GlobalPathText" Foreground="{StaticResource Fg3Brush}"
                           VerticalAlignment="Center" FontSize="11"
                           FontFamily="Cascadia Code, Consolas"/>
                <TextBlock Grid.Column="3" Text="📂 프로젝트:" Foreground="{StaticResource Fg2Brush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="4" x:Name="ProjectPathText" Foreground="{StaticResource Fg3Brush}"
                           VerticalAlignment="Center" FontSize="11"
                           FontFamily="Cascadia Code, Consolas"/>
            </Grid>
        </Border>

        <!-- ══ 탭 바 ═════════════════════════════════════════════════════ -->
        <TabControl x:Name="MainTab" Grid.Row="2" Grid.RowSpan="2"
                    TabStripPlacement="Top" SelectionChanged="MainTab_SelectionChanged">

            <!-- ─ 개요 탭 ─────────────────────────────────────────────── -->
            <TabItem Header="📊 개요" x:Name="OverviewTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24" MaxWidth="900">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 통계 카드 -->
                        <TextBlock Grid.Row="0" Text="현황 요약" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg2Brush}" Margin="0,0,0,12"/>
                        <WrapPanel Grid.Row="2" x:Name="StatCards"/>

                        <!-- 빠른 시작 -->
                        <TextBlock Grid.Row="4" Text="빠른 시작" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg2Brush}" Margin="0,0,0,12"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ─ Commands 탭 ─────────────────────────────────────────── -->
            <TabItem Header="⚡ Commands" x:Name="CommandsTab">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 좌: 목록 -->
                    <Grid Grid.Column="0" Background="{StaticResource Bg2Brush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource Bg3Brush}" Padding="8,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CmdSearchBox" Padding="6,4"
                                         FontFamily="Segoe UI" FontSize="12"
                                         TextChanged="CmdSearch_Changed"
                                         Tag="검색...">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="🔍 검색..." Foreground="#555" Margin="8,4"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Grid.Column="1" Content="+" Margin="4,0,0,0" Padding="8,4"
                                        Click="NewCommand_Click" ToolTip="새 Command 만들기"/>
                            </Grid>
                        </Border>
                        <ListBox Grid.Row="1" x:Name="CommandList"
                                 SelectionChanged="CommandList_SelectionChanged"
                                 Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource Fg2Brush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" VerticalAlignment="Top" Margin="4,0,0,0"
                                                Padding="4,2" CornerRadius="3"
                                                Background="{StaticResource GlobalBadge}">
                                            <TextBlock Text="{Binding SourceLabel}" FontSize="10"
                                                       Foreground="{StaticResource Fg2Brush}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

                    <!-- 우: 상세 -->
                    <Grid Grid.Column="2" x:Name="CmdDetail">
                        <TextBlock Text="← Command를 선택하세요" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="{StaticResource Fg3Brush}"
                                   x:Name="CmdEmptyLabel"/>
                        <Grid x:Name="CmdDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 파일 헤더 -->
                            <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="CmdNameLabel" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="CmdPathLabel" FontSize="11"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   FontFamily="Cascadia Code, Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="📋 경로 복사" Click="CopyPath_Click" Padding="8,5" Margin="0,0,6,0"/>
                                        <Button Content="🗂️ 탐색기" Click="OpenExplorer_Click" Padding="8,5" Margin="0,0,6,0"/>
                                        <Button Content="💾 저장" Click="SaveItem_Click"
                                                Style="{StaticResource AccentButton}" Padding="10,5"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Frontmatter 정보 -->
                            <Border Grid.Row="1" x:Name="CmdFmPanel"
                                    Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="16,8" Visibility="Collapsed">
                                <WrapPanel x:Name="CmdFmWrap" Orientation="Horizontal"/>
                            </Border>

                            <!-- 내용 에디터 -->
                            <TextBox Grid.Row="2" x:Name="CmdContentEditor"
                                     AcceptsReturn="True" AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Margin="0" Padding="16"
                                     BorderThickness="0"
                                     Background="{StaticResource BgBrush}"/>

                            <!-- 하단 힌트 -->
                            <Border Grid.Row="3" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                    Padding="16,6">
                                <TextBlock x:Name="CmdHintLabel" Foreground="{StaticResource Fg3Brush}"
                                           FontSize="11"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─ Skills 탭 ───────────────────────────────────────────── -->
            <TabItem Header="🧠 Skills" x:Name="SkillsTab">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Background="{StaticResource Bg2Brush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource Bg3Brush}" Padding="8,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SkillSearchBox" Padding="6,4"
                                         FontFamily="Segoe UI" FontSize="12"
                                         TextChanged="SkillSearch_Changed"/>
                                <Button Grid.Column="1" Content="+" Margin="4,0,0,0" Padding="8,4"
                                        Click="NewSkill_Click" ToolTip="새 Skill 만들기"/>
                            </Grid>
                        </Border>
                        <ListBox Grid.Row="1" x:Name="SkillList"
                                 SelectionChanged="SkillList_SelectionChanged" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource Fg2Brush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" VerticalAlignment="Top" Margin="4,0,0,0"
                                                Padding="4,2" CornerRadius="3"
                                                Background="{StaticResource GlobalBadge}">
                                            <TextBlock Text="{Binding SourceLabel}" FontSize="10"
                                                       Foreground="{StaticResource Fg2Brush}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

                    <Grid Grid.Column="2" x:Name="SkillDetail">
                        <TextBlock Text="← Skill을 선택하세요" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="{StaticResource Fg3Brush}"
                                   x:Name="SkillEmptyLabel"/>
                        <Grid x:Name="SkillDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="SkillNameLabel" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="SkillPathLabel" FontSize="11"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   FontFamily="Cascadia Code, Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="📋 경로 복사" Click="CopySkillPath_Click" Padding="8,5" Margin="0,0,6,0"/>
                                        <Button Content="🗂️ 탐색기" Click="OpenSkillExplorer_Click" Padding="8,5" Margin="0,0,6,0"/>
                                        <Button Content="💾 저장" Click="SaveSkill_Click"
                                                Style="{StaticResource AccentButton}" Padding="10,5"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" x:Name="SkillFmPanel"
                                    Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="16,8" Visibility="Collapsed">
                                <WrapPanel x:Name="SkillFmWrap" Orientation="Horizontal"/>
                            </Border>
                            <TextBox Grid.Row="2" x:Name="SkillContentEditor"
                                     AcceptsReturn="True" AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Margin="0" Padding="16"
                                     BorderThickness="0"
                                     Background="{StaticResource BgBrush}"/>
                            <Border Grid.Row="3" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                    Padding="16,6">
                                <TextBlock x:Name="SkillHintLabel" Foreground="{StaticResource Fg3Brush}"
                                           FontSize="11"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─ Memory 탭 ───────────────────────────────────────────── -->
            <TabItem Header="💾 Memory" x:Name="MemoryTab">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Background="{StaticResource Bg2Brush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource Bg3Brush}" Padding="8,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="💾 메모리 파일 목록" Foreground="{StaticResource Fg2Brush}"
                                       VerticalAlignment="Center" Padding="6,4"/>
                        </Border>
                        <ListBox Grid.Row="1" x:Name="MemoryList"
                                 SelectionChanged="MemoryList_SelectionChanged" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding FilePath}" FontSize="10"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontFamily="Cascadia Code, Consolas"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
                    <Grid Grid.Column="2">
                        <TextBlock Text="← Memory 파일을 선택하세요" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="{StaticResource Fg3Brush}"
                                   x:Name="MemEmptyLabel"/>
                        <Grid x:Name="MemDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="MemNameLabel" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="MemPathLabel" FontSize="11"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   FontFamily="Cascadia Code, Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="📋 경로 복사" Click="CopyMemPath_Click" Padding="8,5" Margin="0,0,6,0"/>
                                        <Button Content="💾 저장" Click="SaveMem_Click"
                                                Style="{StaticResource AccentButton}" Padding="10,5"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBox Grid.Row="1" x:Name="MemContentEditor"
                                     AcceptsReturn="True" AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Margin="0" Padding="16"
                                     BorderThickness="0"
                                     Background="{StaticResource BgBrush}"/>
                            <Border Grid.Row="2" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                    Padding="16,6">
                                <TextBlock Foreground="{StaticResource Fg3Brush}" FontSize="11"
                                           Text="⚠️ 메모리 파일 수정 시 Claude Code 동작에 영향을 줍니다. 신중하게 수정하세요."/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─ Plugins 탭 ──────────────────────────────────────────── -->
            <TabItem Header="🔌 Plugins" x:Name="PluginsTab">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="220"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Background="{StaticResource Bg2Brush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource Bg3Brush}" Padding="8,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock x:Name="PluginCountLabel" Foreground="{StaticResource Fg2Brush}"
                                       VerticalAlignment="Center" Padding="6,4"/>
                        </Border>
                        <ListBox Grid.Row="1" x:Name="PluginList"
                                 SelectionChanged="PluginList_SelectionChanged" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource Fg2Brush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" VerticalAlignment="Top" Margin="4,0,0,0"
                                                Padding="4,2" CornerRadius="3"
                                                Background="{StaticResource Bg4Brush}">
                                            <TextBlock Text="{Binding Version}" FontSize="10"
                                                       Foreground="{StaticResource Fg3Brush}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
                    <Grid Grid.Column="2">
                        <TextBlock Text="← Plugin을 선택하세요" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="{StaticResource Fg3Brush}"
                                   x:Name="PluginEmptyLabel"/>
                        <ScrollViewer x:Name="PluginDetailScroll" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PluginDetailPanel" Margin="20">
                                <!-- Plugin 상세 내용은 코드에서 동적으로 생성 -->
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─ 설정/Hooks/MCP 탭 ───────────────────────────────────── -->
            <TabItem Header="⚙️ 설정 &amp; Hooks" x:Name="ConfigTab">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" MinWidth="180"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Background="{StaticResource Bg2Brush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource Bg3Brush}" Padding="8,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="⚙️ 설정 파일 목록" Foreground="{StaticResource Fg2Brush}"
                                       Padding="6,4"/>
                        </Border>
                        <ListBox Grid.Row="1" x:Name="ConfigList"
                                 SelectionChanged="ConfigList_SelectionChanged" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TypeIcon}" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SourceLabel}" FontSize="11"
                                                   Foreground="{StaticResource Fg2Brush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
                    <Grid Grid.Column="2">
                        <TextBlock Text="← 설정 파일을 선택하세요" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="{StaticResource Fg3Brush}"
                                   x:Name="CfgEmptyLabel"/>
                        <Grid x:Name="CfgDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="CfgNameLabel" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="CfgPathLabel" FontSize="11"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   FontFamily="Cascadia Code, Consolas"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="🗂️ 탐색기" Padding="8,5"
                                            Click="OpenCfgExplorer_Click"/>
                                </Grid>
                            </Border>
                            <TextBox Grid.Row="1" x:Name="CfgContentViewer"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Margin="0" Padding="16"
                                     BorderThickness="0"
                                     Background="{StaticResource BgBrush}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─ 지식 베이스 탭 ─────────────────────────────────────── -->
            <TabItem Header="📚 지식 베이스" x:Name="KnowledgeTab">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Background="{StaticResource Bg2Brush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource Bg3Brush}" Padding="14,10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="📚 Claude Code 완전 가이드" FontWeight="SemiBold"/>
                        </Border>
                        <ListBox Grid.Row="1" x:Name="ArticleList"
                                 SelectionChanged="ArticleList_SelectionChanged" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Category}" FontSize="11"
                                                   Foreground="{StaticResource Fg3Brush}" Margin="24,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
                    <Grid Grid.Column="2">
                        <TextBlock Text="← 문서를 선택하세요" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="{StaticResource Fg3Brush}"
                                   x:Name="ArticleEmptyLabel"/>
                        <Grid x:Name="ArticleDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ArticleIconLabel" FontSize="22"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="ArticleTitleLabel" FontSize="16"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBox Grid.Row="1" x:Name="ArticleContent"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Margin="0" Padding="20"
                                     BorderThickness="0"
                                     FontFamily="Segoe UI"
                                     FontSize="13"
                                     Background="{StaticResource BgBrush}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ══ 하단 상태 바 ═══════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#111111"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBar" Foreground="{StaticResource Fg2Brush}" FontSize="12"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource Fg3Brush}" FontSize="11" VerticalAlignment="Center"
                               Text="Skill.Cast v1.0 | Claude Code 개발 환경 관리자"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
