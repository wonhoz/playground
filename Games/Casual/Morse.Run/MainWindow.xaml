<Window x:Class="MorseRun.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Morse.Run" Height="640" Width="900"
        Background="#0F0F1E" Foreground="#E0E0E0"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- HUD 상단 -->
        <Border Grid.Row="0" Background="#14142A" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡ Morse.Run" FontSize="16" FontWeight="Bold" Foreground="#50C8DC" Margin="0,0,16,0"/>
                    <TextBlock Text="Level " FontSize="11" Foreground="#666688" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblLevel" Text="1" FontSize="14" FontWeight="Bold" Foreground="#FFDD44" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="♥" FontSize="16" Foreground="#FF6666" Margin="0,0,4,0"/>
                    <TextBlock x:Name="LblLives" Text="3" FontSize="14" FontWeight="Bold" Foreground="#FF6666" Margin="0,0,20,0"/>
                    <TextBlock Text="SCORE" FontSize="10" Foreground="#666688" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblScore" Text="0" FontSize="18" FontWeight="Bold" Foreground="#50C8DC"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnStart" Click="BtnStart_Click"
                            Background="#1A3A2A" BorderBrush="#2A6A4A">▶ 시작</Button>
                    <Button x:Name="BtnPause" Click="BtnPause_Click"
                            Margin="6,0,0,0" IsEnabled="False">⏸ 일시정지</Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 게임 캔버스 -->
        <Canvas x:Name="GameCanvas" Grid.Row="1"
                Background="#0A0A18" ClipToBounds="True"
                SizeChanged="GameCanvas_SizeChanged">

            <!-- 지면 -->
            <Rectangle x:Name="Ground" Fill="#1A1A30" Height="20"/>

            <!-- 플레이어 (러너) -->
            <Canvas x:Name="PlayerCanvas" Width="30" Height="40">
                <!-- 몸통 -->
                <Ellipse Width="20" Height="20" Fill="#50C8DC" Canvas.Left="5" Canvas.Top="0"/>
                <!-- 다리1 -->
                <Rectangle x:Name="Leg1" Width="6" Height="18" Fill="#3A98AA"
                           Canvas.Left="7" Canvas.Top="18" RenderTransformOrigin="0.5,0"/>
                <!-- 다리2 -->
                <Rectangle x:Name="Leg2" Width="6" Height="18" Fill="#3A98AA"
                           Canvas.Left="17" Canvas.Top="18" RenderTransformOrigin="0.5,0"/>
            </Canvas>

            <!-- 모스 신호 입력 표시 -->
            <Border x:Name="MorseIndicator" Canvas.Bottom="30" Canvas.Left="10"
                    Background="#1A1A30" BorderBrush="#444466" BorderThickness="1"
                    CornerRadius="4" Padding="10,6">
                <StackPanel>
                    <TextBlock x:Name="LblCurrentMorse" Text="_ _ . _" FontFamily="Consolas"
                               FontSize="18" Foreground="#50C8DC" TextAlignment="Center"/>
                    <TextBlock x:Name="LblTargetChar" Text="?" FontSize="12"
                               Foreground="#888888" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 현재 문자 출제 -->
            <Border x:Name="QuestionBox" Canvas.Top="10" Canvas.Right="10"
                    Background="#1A2A1A" BorderBrush="#2A6A4A" BorderThickness="1"
                    CornerRadius="6" Padding="16,10">
                <StackPanel>
                    <TextBlock Text="해독하세요:" FontSize="10" Foreground="#666688" TextAlignment="Center"/>
                    <TextBlock x:Name="LblQuestion" Text="" FontSize="32" FontWeight="Bold"
                               Foreground="#A0E080" TextAlignment="Center" FontFamily="Consolas"/>
                    <TextBlock x:Name="LblQuestionMorse" Text="" FontSize="14" FontFamily="Consolas"
                               Foreground="#666888" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 오버레이: 시작/게임오버/일시정지 -->
            <Border x:Name="Overlay" Canvas.Top="0" Canvas.Left="0"
                    Background="#AA0A0A18" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="OverlayTitle" Text="⚡ Morse.Run" FontSize="36" FontWeight="Bold"
                               Foreground="#50C8DC" TextAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock x:Name="OverlayMsg"
                               Text="모스 부호를 입력해 캐릭터를 조종하세요&#10;&#10;[Space] 짧게: 점(·)    [Space] 길게: 선(—)&#10;[Enter] 현재 모스 코드 확정 → 점프/슬라이드/더블점프&#10;[Esc] 일시정지"
                               FontSize="13" Foreground="#AAAACC" TextAlignment="Center" Margin="0,0,0,20"/>
                    <Button x:Name="BtnOverlayStart" Click="BtnStart_Click"
                            HorizontalAlignment="Center" Padding="24,10" FontSize="14"
                            Background="#1A3A2A" BorderBrush="#2A6A4A">▶ 게임 시작</Button>
                    <TextBlock x:Name="OverlayScore" Text="" FontSize="20" FontWeight="Bold"
                               Foreground="#FFDD44" TextAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- 모스 입력 패널 -->
        <Border Grid.Row="2" Background="#13132A" BorderBrush="#1E1E35" BorderThickness="0,1,0,0">
            <Grid Margin="14,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 입력 힌트 -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="모스 코드 입력:" FontSize="11" Foreground="#666688" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Border x:Name="DotIndicator" Width="20" Height="20" Background="#333355"
                            CornerRadius="10" Margin="0,0,4,0">
                        <TextBlock Text="·" FontSize="16" Foreground="#50C8DC"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="점(Space 짧게)" FontSize="10" Foreground="#555577" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Border x:Name="DashIndicator" Width="36" Height="20" Background="#333355"
                            CornerRadius="4" Margin="0,0,4,0">
                        <TextBlock Text="—" FontSize="14" Foreground="#50C8DC"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="선(Space 길게)" FontSize="10" Foreground="#555577" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="[Enter] 확정" FontSize="11" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="[Backspace] 지우기" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 모스 코드 표 -->
                <ItemsControl x:Name="MorseTable" Grid.Row="1" Margin="0,6,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2,1" Padding="6,2" Background="#1A1A30"
                                    BorderBrush="#333355" BorderThickness="1" CornerRadius="3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Char}" FontSize="11" FontWeight="Bold"
                                               Foreground="#E0E0E0" Width="14"/>
                                    <TextBlock Text="{Binding Code}" FontSize="10" FontFamily="Consolas"
                                               Foreground="#7777AA"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="#0A0A1A" BorderBrush="#1A1A30" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar" Margin="10,0" VerticalAlignment="Center"
                       FontSize="10" Foreground="#666688"/>
        </Border>
    </Grid>
</Window>
