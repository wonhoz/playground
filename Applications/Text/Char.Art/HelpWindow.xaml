<Window x:Class="CharArt.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키 도움말"
        Width="420" Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1E"
        Foreground="#E8E8E0"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="Foreground" Value="#00B894"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="KeyStyle">
            <Setter Property="Foreground" Value="#00CEC9"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="DescStyle">
            <Setter Property="Foreground" Value="#E8E8E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Char" Foreground="#00B894" FontSize="16" FontWeight="Bold"/>
            <TextBlock Text="." Foreground="#88A8A8" FontSize="16" FontWeight="Bold"/>
            <TextBlock Text="Art  단축키 도움말" Foreground="#E8E8E0" FontSize="16" FontWeight="Bold"/>
        </StackPanel>
        <Border Grid.Row="0" Background="#2A3A3A" Height="1" VerticalAlignment="Bottom" Margin="0,0,0,-2"/>

        <!-- 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="파일" Style="{StaticResource HeaderStyle}"/>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + O" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text="이미지 열기" Style="{StaticResource DescStyle}"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + S" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text=".txt 저장" Style="{StaticResource DescStyle}"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + Shift + S" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text=".png 저장" Style="{StaticResource DescStyle}"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + Shift + H" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text=".html (컬러) 저장" Style="{StaticResource DescStyle}"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + C" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text="텍스트 아트 복사" Style="{StaticResource DescStyle}"/>
                </Grid>

                <TextBlock Text="생성" Style="{StaticResource HeaderStyle}"/>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Enter / F5" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text="텍스트 아트 생성" Style="{StaticResource DescStyle}"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="드래그 앤 드롭" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text="이미지 파일 불러오기" Style="{StaticResource DescStyle}"/>
                </Grid>

                <TextBlock Text="뷰어" Style="{StaticResource HeaderStyle}"/>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + 마우스휠" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text="출력 텍스트 크기 조정" Style="{StaticResource DescStyle}"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + 0" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text="뷰어 폰트 크기 초기화" Style="{StaticResource DescStyle}"/>
                </Grid>

                <TextBlock Text="기타" Style="{StaticResource HeaderStyle}"/>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="F1" Style="{StaticResource KeyStyle}"/>
                    <TextBlock Grid.Column="1" Text="이 도움말 표시" Style="{StaticResource DescStyle}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- 닫기 버튼 -->
        <Button Grid.Row="2" Content="닫기" Width="80" HorizontalAlignment="Right"
                Margin="0,12,0,0" Click="BtnClose_Click"
                Background="#00B894" Foreground="#0A1A18"
                FontWeight="SemiBold" FontSize="12" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="12,7">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#00CEC9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#007B77"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
