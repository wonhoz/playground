<UserControl x:Class="PdfForge.Views.MergeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="PDF 병합" FontSize="20" FontWeight="SemiBold"
                       Foreground="#E8E8F0" Margin="0,0,0,4"/>
            <TextBlock Text="여러 PDF를 하나로 합칩니다. 파일을 드래그하거나 추가 버튼을 사용하세요."
                       FontSize="12" Foreground="#888899"/>
        </StackPanel>

        <!-- 파일 목록 -->
        <Border Grid.Row="1" Background="#16161F" BorderBrush="#2A2A3E" BorderThickness="1"
                CornerRadius="6" AllowDrop="True"
                Drop="FileList_Drop" DragOver="FileList_DragOver">
            <Grid>
                <!-- 빈 상태 안내 -->
                <StackPanel x:Name="EmptyHint" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="📄" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="PDF 파일을 여기로 드래그하거나" FontSize="13"
                               Foreground="#666677" HorizontalAlignment="Center"/>
                    <TextBlock Text="아래 '파일 추가' 버튼을 클릭하세요" FontSize="13"
                               Foreground="#666677" HorizontalAlignment="Center"/>
                </StackPanel>

                <ListBox x:Name="FileListBox" Background="Transparent" BorderThickness="0"
                         SelectionMode="Extended" Margin="8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📄" FontSize="14"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                           Foreground="#E8E8F0" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="11"
                                           Foreground="#888899" VerticalAlignment="Center" Margin="8,0"/>
                                <Button Grid.Column="3" Content="↑" Width="24" Height="24"
                                        Tag="{Binding}" Click="MoveUp_Click"
                                        ToolTip="위로" Margin="2,0"/>
                                <Button Grid.Column="4" Content="↓" Width="24" Height="24"
                                        Tag="{Binding}" Click="MoveDown_Click"
                                        ToolTip="아래로" Margin="2,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 툴바 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,12" HorizontalAlignment="Right">
            <Button Content="파일 추가" Width="90" Click="AddFiles_Click" Margin="0,0,8,0"/>
            <Button Content="선택 삭제" Width="90" Click="RemoveSelected_Click" Margin="0,0,8,0"/>
            <Button Content="전체 삭제" Width="90" Click="ClearAll_Click"/>
        </StackPanel>

        <!-- 병합 실행 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="PbMerge" Height="6" Margin="0,0,12,0"
                         VerticalAlignment="Center" Visibility="Collapsed"/>
            <Button Grid.Column="1" x:Name="BtnMerge" Content="병합 실행" Width="120" Height="36"
                    Click="BtnMerge_Click"
                    Background="#5B8FFF" Foreground="White" FontWeight="SemiBold"
                    BorderBrush="#4070DD"/>
        </Grid>
    </Grid>
</UserControl>
