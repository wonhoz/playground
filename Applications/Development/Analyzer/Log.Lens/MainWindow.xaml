<Window x:Class="LogLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log.Lens" Height="720" Width="1080"
        MinHeight="440" MinWidth="640"
        Background="#0D0D14"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop" DragOver="Window_DragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 상단 툴바 ── -->
        <Border Grid.Row="0" Background="#131320"
                BorderBrush="#2A2A3A" BorderThickness="0,0,0,1"
                Padding="10,7">
            <StackPanel Orientation="Horizontal">
                <!-- 앱 제목 -->
                <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Log.Lens" FontSize="15" FontWeight="Bold"
                           Foreground="#00C8FF" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- 파일/폴더 열기 -->
                <Button Content="📂 파일 열기" Click="BtnOpenFile_Click"
                        Margin="0,0,8,0" Height="30"
                        ToolTip="로그 파일 열기 (여러 파일 선택 가능, Ctrl+O)"/>
                <Button Content="📁 폴더 열기" Click="BtnOpenFolder_Click"
                        Margin="0,0,20,0" Height="30"
                        ToolTip="폴더 내 텍스트 파일을 최대 20개 탭으로 열기"/>

                <!-- 구분선 -->
                <Border Width="1" Margin="0,3,20,3" Background="#2A2A3A" VerticalAlignment="Stretch"/>

                <!-- 최대 줄 수 -->
                <TextBlock Text="최대 줄 수:" Foreground="#888898" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CbMaxLines" Width="120" Height="30" Margin="0,0,20,0"
                          SelectedIndex="1"
                          ToolTip="탭당 메모리에 유지할 최대 줄 수">
                    <ComboBoxItem Tag="10000">10,000 줄</ComboBoxItem>
                    <ComboBoxItem Tag="50000">50,000 줄</ComboBoxItem>
                    <ComboBoxItem Tag="100000">100,000 줄</ComboBoxItem>
                    <ComboBoxItem Tag="0">무제한</ComboBoxItem>
                </ComboBox>

                <!-- 인코딩 -->
                <TextBlock Text="인코딩:" Foreground="#888898" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CbEncoding" Width="110" Height="30" Margin="0,0,20,0"
                          SelectedIndex="0"
                          ToolTip="파일 인코딩 선택 (새로 열리는 파일에 적용)">
                    <ComboBoxItem Tag="">자동 감지</ComboBoxItem>
                    <ComboBoxItem Tag="utf-8">UTF-8</ComboBoxItem>
                    <ComboBoxItem Tag="euc-kr">EUC-KR</ComboBoxItem>
                    <ComboBoxItem Tag="shift-jis">Shift-JIS</ComboBoxItem>
                    <ComboBoxItem Tag="utf-16">UTF-16</ComboBoxItem>
                </ComboBox>

                <!-- 도움말 -->
                <Button Content="?" Click="BtnHelp_Click"
                        Width="30" Height="30"
                        Style="{StaticResource SecondaryBtn}"
                        ToolTip="단축키 도움말"/>
            </StackPanel>
        </Border>

        <!-- ── 탭 컨트롤 + 빈 화면 안내 ── -->
        <Grid Grid.Row="1">
            <TabControl x:Name="TcMain"/>

            <!-- 탭이 없을 때 안내 문구 -->
            <StackPanel x:Name="EmptyHint"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsHitTestVisible="False">
                <TextBlock Text="🔍" FontSize="56"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="로그 파일을 열어 실시간으로 모니터링하세요"
                           Foreground="#555565" FontSize="16"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="[파일 열기] 버튼 또는 파일을 드래그하여 놓으세요"
                           Foreground="#3A3A4A" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="지원 형식: .log .txt .json .xml .yml .csv 등 모든 텍스트 파일"
                           Foreground="#2A2A3A" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
