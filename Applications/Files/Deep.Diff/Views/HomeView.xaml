<UserControl x:Class="DeepDiff.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F0F1E">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32">

            <!-- 환영 헤더 -->
            <TextBlock Text="무엇을 비교하시겠습니까?" FontSize="26" FontWeight="Light"
                       Foreground="#E8E8F0" Margin="0,0,0,8"/>
            <TextBlock Text="비교할 유형을 선택하세요. 폴더, 텍스트, 이미지, HEX, 클립보드를 지원합니다."
                       FontSize="13" Foreground="#8888AA" Margin="0,0,0,36"/>

            <!-- 비교 유형 카드 -->
            <WrapPanel Orientation="Horizontal">

                <!-- 폴더 비교 -->
                <Border x:Name="CardFolder" Style="{StaticResource CompareCard}"
                        MouseLeftButtonDown="CardFolder_Click" ToolTip="두 폴더를 비교하고 파일 작업을 수행합니다">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="폴더 비교" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#E8E8F0" HorizontalAlignment="Center"/>
                        <TextBlock Text="파일 트리 · 크기 · 날짜 · 내용" FontSize="11"
                                   Foreground="#8888AA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="복사 · 이동 · 삭제 · 동기화"
                                   FontSize="11" Foreground="#5B8FFF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 텍스트 비교 -->
                <Border x:Name="CardText" Style="{StaticResource CompareCard}"
                        MouseLeftButtonDown="CardText_Click" ToolTip="두 텍스트 파일을 라인별로 비교합니다">
                    <StackPanel>
                        <TextBlock Text="📄" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="텍스트 비교" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#E8E8F0" HorizontalAlignment="Center"/>
                        <TextBlock Text="Myers diff · 인라인 하이라이트" FontSize="11"
                                   Foreground="#8888AA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="편집 · 저장 · 다음/이전 차이"
                                   FontSize="11" Foreground="#3FC878" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 이미지 비교 -->
                <Border x:Name="CardImage" Style="{StaticResource CompareCard}"
                        MouseLeftButtonDown="CardImage_Click" ToolTip="두 이미지를 픽셀 단위로 비교합니다">
                    <StackPanel>
                        <TextBlock Text="🖼" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="이미지 비교" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#E8E8F0" HorizontalAlignment="Center"/>
                        <TextBlock Text="나란히 · 오버레이 · 픽셀 diff" FontSize="11"
                                   Foreground="#8888AA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="차이 비율 · 줌 · 채널 분석"
                                   FontSize="11" Foreground="#F0B030" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- HEX 비교 -->
                <Border x:Name="CardHex" Style="{StaticResource CompareCard}"
                        MouseLeftButtonDown="CardHex_Click" ToolTip="두 파일을 바이트 단위로 비교합니다">
                    <StackPanel>
                        <TextBlock Text="🔢" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="HEX 비교" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#E8E8F0" HorizontalAlignment="Center"/>
                        <TextBlock Text="바이트 · HEX + ASCII 뷰어" FontSize="11"
                                   Foreground="#8888AA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="바이너리 · 실행파일 · 이진 데이터"
                                   FontSize="11" Foreground="#3DCFDF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 클립보드 비교 -->
                <Border x:Name="CardClipboard" Style="{StaticResource CompareCard}"
                        MouseLeftButtonDown="CardClipboard_Click" ToolTip="클립보드 또는 직접 입력 텍스트를 비교합니다">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="클립보드 비교" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#E8E8F0" HorizontalAlignment="Center"/>
                        <TextBlock Text="붙여넣기 즉시 비교 · 실시간" FontSize="11"
                                   Foreground="#8888AA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="파일 없이 빠른 텍스트 비교"
                                   FontSize="11" Foreground="#E05555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

            <!-- 팁 섹션 -->
            <Border Margin="0,40,0,0" Background="#14142A" CornerRadius="8"
                    BorderBrush="#2E2E55" BorderThickness="1" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="💡 팁 &amp; 단축키" FontSize="13" FontWeight="SemiBold"
                               Foreground="#F0B030" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📁 폴더 비교" Foreground="#5B8FFF" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="• F5 — 새로고침" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• Ctrl+L→R — 왼쪽→오른쪽 복사" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• Del — 선택 항목 삭제" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• Enter — 하위 폴더 진입" Foreground="#8888AA" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="📄 텍스트 비교" Foreground="#3FC878" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="• F3 — 다음 차이" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• Shift+F3 — 이전 차이" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• Ctrl+S — 저장" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• Ctrl+W — 공백 무시 토글" Foreground="#8888AA" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="🖼 이미지 비교" Foreground="#F0B030" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="• +/- — 줌 인/아웃" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• F — 화면 맞춤" Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="• Tab — 뷰 모드 전환" Foreground="#8888AA" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

    <UserControl.Resources>
        <Style x:Key="CompareCard" TargetType="Border">
            <Setter Property="Width"        Value="200"/>
            <Setter Property="Height"       Value="180"/>
            <Setter Property="Background"   Value="#14142A"/>
            <Setter Property="BorderBrush"  Value="#2E2E55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin"       Value="0,0,16,16"/>
            <Setter Property="Padding"      Value="20,24"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"   Value="#1E1E40"/>
                    <Setter Property="BorderBrush"  Value="#5B8FFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
</UserControl>
