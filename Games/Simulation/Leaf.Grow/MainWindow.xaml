<Window x:Class="LeafGrow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Leaf.Grow"
        Width="980" Height="680"
        MinWidth="820" MinHeight="560"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="TitleBar_MouseDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <Border Grid.Row="0" Background="#060F06"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Height="36">
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="🌿" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Leaf.Grow" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtSpeciesInfo" Text=""
                               Foreground="{StaticResource Fg2Brush}" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="─" Width="38" Height="36" BorderThickness="0"
                            Background="Transparent" Click="MinBtn_Click"/>
                    <Button Content="✕" Width="38" Height="36" BorderThickness="0"
                            Background="Transparent" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 레이아웃 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 패널: 식물 목록 -->
            <Border Grid.Column="0" Background="#080F08"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                    Padding="10,12">
                <DockPanel>
                    <!-- 모드 탭 -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="BtnSandbox" Content="샌드박스" Width="100"
                                Background="{StaticResource AccentBrush}"
                                Foreground="#080F08" FontWeight="SemiBold"
                                Click="BtnSandbox_Click"/>
                        <Button x:Name="BtnPuzzle" Content="퍼즐" Width="100" Margin="4,0,0,0"
                                Click="BtnPuzzle_Click"/>
                    </StackPanel>

                    <!-- 샌드박스: 식물 목록 -->
                    <StackPanel x:Name="PanelSandbox" DockPanel.Dock="Top">
                        <TextBlock Text="식물 선택" Foreground="{StaticResource Fg2Brush}"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <ListBox x:Name="PlantList" Height="380"
                                 SelectionChanged="PlantList_SelectionChanged"/>
                    </StackPanel>

                    <!-- 퍼즐: 목표 목록 -->
                    <StackPanel x:Name="PanelPuzzle" Visibility="Collapsed" DockPanel.Dock="Top">
                        <TextBlock Text="퍼즐 목표" Foreground="{StaticResource Fg2Brush}"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <ListBox x:Name="PuzzleList" Height="380"
                                 SelectionChanged="PuzzleList_SelectionChanged"/>
                    </StackPanel>

                    <!-- 설명 -->
                    <Border DockPanel.Dock="Bottom" Background="#0F1A0F"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                        <TextBlock x:Name="TxtDesc" Text="" FontSize="11"
                                   Foreground="{StaticResource Fg2Brush}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </DockPanel>
            </Border>

            <!-- 중앙: 식물 캔버스 -->
            <Border Grid.Column="1" Background="#06100A">
                <Grid>
                    <Canvas x:Name="PlantCanvas" Background="Transparent"
                            SizeChanged="PlantCanvas_SizeChanged"/>

                    <!-- 성장 단계 배지 -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Background="#80060F06" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="0,0,6,0" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="단계 " Foreground="{StaticResource Fg2Brush}" FontSize="12"/>
                            <TextBlock x:Name="TxtIteration" Text="0 / 5"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- 퍼즐 목표 오버레이 -->
                    <Border x:Name="PuzzleGoalBadge" HorizontalAlignment="Center"
                            VerticalAlignment="Top" Margin="0,8,0,0"
                            Background="#CC060F06" BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,6"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtGoalHint" Text="" FontSize="11"
                                   Foreground="{StaticResource Fg2Brush}" TextWrapping="Wrap"
                                   MaxWidth="400" TextAlignment="Center"/>
                    </Border>

                    <!-- 퍼즐 성공 오버레이 -->
                    <Border x:Name="PuzzleSuccessPanel" Visibility="Collapsed"
                            Background="#CC060F06" Panel.ZIndex="10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🌿 성장 완료!" FontSize="40" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtSuccessMsg" Text="" FontSize="16"
                                       Foreground="{StaticResource FgBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,24"/>
                            <Button Content="다음 퍼즐" Width="140" FontSize="14"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="#060F06" FontWeight="SemiBold"
                                    Click="NextPuzzleBtn_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 우측 패널: 환경 + 성장 제어 -->
            <Border Grid.Column="2" Background="#080F08"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="12,14">
                <StackPanel>
                    <!-- 환경 설정 -->
                    <TextBlock Text="환경" Foreground="{StaticResource Fg2Brush}"
                               FontSize="11" Margin="0,0,0,10"/>

                    <!-- 햇빛 -->
                    <StackPanel Margin="0,0,0,12">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="☀ 햇빛" Foreground="{StaticResource SunBrush}"
                                       FontSize="12" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TxtSun" Text="50%"
                                       Foreground="{StaticResource Fg2Brush}" FontSize="11"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Slider x:Name="SliderSun" Minimum="0" Maximum="1" Value="0.5"
                                Tag="{StaticResource SunBrush}"
                                ValueChanged="EnvSlider_Changed"/>
                    </StackPanel>

                    <!-- 물 -->
                    <StackPanel Margin="0,0,0,12">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="💧 수분" Foreground="{StaticResource WaterBrush}"
                                       FontSize="12" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TxtWater" Text="50%"
                                       Foreground="{StaticResource Fg2Brush}" FontSize="11"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Slider x:Name="SliderWater" Minimum="0" Maximum="1" Value="0.5"
                                Tag="{StaticResource WaterBrush}"
                                ValueChanged="EnvSlider_Changed"/>
                    </StackPanel>

                    <!-- 영양분 -->
                    <StackPanel Margin="0,0,0,16">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="🌱 영양분" Foreground="{StaticResource NutBrush}"
                                       FontSize="12" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TxtNutrients" Text="50%"
                                       Foreground="{StaticResource Fg2Brush}" FontSize="11"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Slider x:Name="SliderNutrients" Minimum="0" Maximum="1" Value="0.5"
                                Tag="{StaticResource NutBrush}"
                                ValueChanged="EnvSlider_Changed"/>
                    </StackPanel>

                    <!-- 성장률 표시 -->
                    <Border Background="#0F1A0F" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="성장률" Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                            <Border Height="6" Background="#1A2E1A" CornerRadius="3" Margin="0,4,0,2">
                                <Border x:Name="GrowthRateBar" HorizontalAlignment="Left"
                                        Height="6" CornerRadius="3"
                                        Background="{StaticResource AccentBrush}" Width="0"/>
                            </Border>
                            <TextBlock x:Name="TxtGrowthRate" Text="50%"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- 성장 제어 버튼 -->
                    <TextBlock Text="성장 제어" Foreground="{StaticResource Fg2Brush}"
                               FontSize="11" Margin="0,0,0,8"/>

                    <Button Content="🌱 한 단계 성장" Margin="0,0,0,6"
                            Click="GrowOneBtn_Click"/>
                    <Button Content="🌳 완전 성장" Margin="0,0,0,6"
                            Background="{StaticResource AccentBrush}"
                            Foreground="#060F06" FontWeight="SemiBold"
                            Click="GrowFullBtn_Click"/>
                    <Button Content="↺ 초기화" Margin="0,0,0,16"
                            Click="ResetBtn_Click"/>

                    <!-- 통계 -->
                    <Border Background="#0F1A0F" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="통계" Foreground="{StaticResource Fg2Brush}"
                                       FontSize="11" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="가지 수: " Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                                <TextBlock x:Name="TxtBranches" Text="0"
                                           Foreground="{StaticResource FgBrush}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="잎 수: " Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                                <TextBlock x:Name="TxtLeaves" Text="0"
                                           Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="꽃 수: " Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                                <TextBlock x:Name="TxtFlowers" Text="0"
                                           Foreground="#FFA0D0" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
