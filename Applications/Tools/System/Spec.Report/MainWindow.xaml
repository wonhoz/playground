<Window x:Class="SpecReport.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spec.Report — 시스템 사양 분석기"
        Width="760" Height="820"
        MinWidth="640" MinHeight="600"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 타이틀바 -->
            <RowDefinition Height="*"/>     <!-- 콘텐츠 -->
            <RowDefinition Height="Auto"/>  <!-- 버튼 바 -->
        </Grid.RowDefinitions>

        <!-- ── 타이틀바 ──────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid Height="38">
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Spec.Report" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text=" — 시스템 사양 분석기"
                               Foreground="{StaticResource Fg3Brush}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="─" Width="40" Height="38" BorderThickness="0"
                            Background="Transparent" Click="MinBtn_Click"/>
                    <Button Content="✕" Width="40" Height="38" BorderThickness="0"
                            Background="Transparent" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 스크롤 콘텐츠 ──────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ContentPanel" Margin="14,10,14,10">

                <!-- 수집 시각 / 기기명 표시 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtComputer" Text="─" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource FgBrush}"/>
                            <TextBlock x:Name="TxtUser" Text="─"
                                       Foreground="{StaticResource Fg3Brush}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="마지막 수집" Foreground="{StaticResource Fg3Brush}"
                                       FontSize="10" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="TxtCollectedAt" Text="─"
                                       Foreground="{StaticResource Fg2Brush}" FontSize="11"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ① CPU 카드 -->
                <Border x:Name="CpuCard"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="CPU" Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"
                                  
                                  />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="TxtCpuName" Text="─" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtCpuSub"  Text="─"
                                           Foreground="{StaticResource Fg2Brush}" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock x:Name="TxtCpuClock" Text="─"
                                           FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                                           Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right"/>
                                <TextBlock Text="최대 클럭" Foreground="{StaticResource Fg3Brush}"
                                           FontSize="10" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                        <Separator Margin="0,8"/>
                        <UniformGrid Rows="1" Columns="3" Margin="0,0,0,2">
                            <StackPanel>
                                <TextBlock Text="물리 코어" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtCpuCores" Text="─" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="논리 프로세서" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtCpuThreads" Text="─" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="소켓 / 아키텍처" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtCpuSocket" Text="─" FontSize="13"
                                           Foreground="{StaticResource Fg2Brush}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ② RAM 카드 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RAM" Foreground="{StaticResource AccentBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtRamTotal" Text="─"
                                       Grid.Column="1"
                                       FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource GreenBrush}"/>
                        </Grid>
                        <ItemsControl x:Name="RamSlotList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Slot}"
                                                   Foreground="{StaticResource Fg3Brush}" FontSize="11"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{StaticResource FgBrush}" FontSize="11">
                                            <Run Text="{Binding CapacityGb, Mode=OneWay}"/>
                                            <Run Text=" " /><Run Foreground="#A0A0CC" Text="{Binding MemoryType, Mode=OneWay}"/>
                                            <Run Text="-"/><Run Foreground="#A0A0CC" Text="{Binding SpeedMHz, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Manufacturer}"
                                                   Foreground="{StaticResource Fg3Brush}" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ③ GPU 카드(들) -->
                <ItemsControl x:Name="GpuList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DriverLine}"
                                                       Foreground="{StaticResource Fg2Brush}" FontSize="11" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding VramText}"
                                                       FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                                                       Foreground="{StaticResource OrangeBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="VRAM" Foreground="{StaticResource Fg3Brush}"
                                                       FontSize="10" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="{Binding ResolutionLine}"
                                               Foreground="{StaticResource Fg3Brush}" FontSize="11" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ④ 스토리지 카드 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="스토리지" Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="DriveList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DriveLetter}"
                                                       FontSize="15" FontWeight="Bold" FontFamily="Consolas"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                       Foreground="{StaticResource Fg2Brush}"
                                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Border Grid.Column="2" Background="#252545" CornerRadius="3"
                                                    Padding="5,1" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding MediaType}"
                                                           FontSize="11" Foreground="{StaticResource GreenBrush}"/>
                                            </Border>
                                            <TextBlock Grid.Column="3" Text="{Binding FileSystem}"
                                                       Foreground="{StaticResource Fg3Brush}"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding SizeText}"
                                                       Foreground="{StaticResource Fg3Brush}"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Model}"
                                                   Foreground="{StaticResource Fg3Brush}" FontSize="10" Margin="0,2,0,3"/>
                                        <!-- 사용률 바 -->
                                        <Border Height="6" CornerRadius="3" Background="#252545"
                                                Margin="0,2,0,2">
                                            <Border HorizontalAlignment="Left" CornerRadius="3"
                                                    Width="{Binding BarWidth}"
                                                    Background="{Binding BarColor}"/>
                                        </Border>
                                        <TextBlock Text="{Binding UsageText}"
                                                   Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ⑤ OS 카드 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="운영체제" Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <UniformGrid Rows="2" Columns="3">
                            <StackPanel Margin="0,4">
                                <TextBlock Text="이름" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtOsName" Text="─" FontSize="13" FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="버전 / 빌드" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtOsBuild" Text="─" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="아키텍처" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtOsArch" Text="─" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="마지막 부팅" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtOsBoot" Text="─" FontSize="12"
                                           Foreground="{StaticResource Fg2Brush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text=".NET 버전" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtDotNet" Text="─" FontSize="12" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="마지막 업데이트" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtWinUpdate" Text="─" FontSize="12"
                                           Foreground="{StaticResource Fg2Brush}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ⑥ 네트워크 카드 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="네트워크" Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="NetworkList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4">
                                            <Run Text="{Binding Icon, Mode=OneWay}"/>
                                            <Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="IP"  Grid.Row="0" Grid.Column="0"
                                                       Foreground="{StaticResource Fg3Brush}" FontSize="11"/>
                                            <TextBlock Text="{Binding IpLine}" Grid.Row="0" Grid.Column="1"
                                                       FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="MAC" Grid.Row="1" Grid.Column="0"
                                                       Foreground="{StaticResource Fg3Brush}" FontSize="11"/>
                                            <TextBlock Text="{Binding MacAddress}" Grid.Row="1" Grid.Column="1"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{StaticResource Fg2Brush}"/>
                                            <TextBlock Text="DNS" Grid.Row="2" Grid.Column="0"
                                                       Foreground="{StaticResource Fg3Brush}" FontSize="11"/>
                                            <TextBlock Text="{Binding DnsLine}" Grid.Row="2" Grid.Column="1"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{StaticResource Fg2Brush}"/>
                                            <TextBlock Text="속도" Grid.Row="3" Grid.Column="0"
                                                       Foreground="{StaticResource Fg3Brush}" FontSize="11"/>
                                            <TextBlock Text="{Binding Speed}" Grid.Row="3" Grid.Column="1"
                                                       FontSize="11" Foreground="{StaticResource Fg2Brush}"/>
                                        </Grid>
                                        <Separator/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ⑦ 보안 카드 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="보안" Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <UniformGrid Rows="1" Columns="4">
                            <StackPanel Margin="0,4">
                                <TextBlock Text="Windows Defender" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtDefender" Text="─" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="방화벽" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtFirewall" Text="─" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="BitLocker" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtBitLocker" Text="─" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="자동 업데이트" Foreground="{StaticResource Fg3Brush}" FontSize="10"/>
                                <TextBlock x:Name="TxtAutoUpdate" Text="─" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ⑧ 설치 소프트웨어 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="14,10" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="설치 소프트웨어" Foreground="{StaticResource AccentBrush}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtSwCount" Text=""
                                           Foreground="{StaticResource Fg3Brush}" FontSize="10"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBox x:Name="TxtSwFilter" Grid.Column="1"
                                     Height="26"
                                     Tag="검색..."
                                     TextChanged="TxtSwFilter_TextChanged"/>
                        </Grid>
                        <ListBox x:Name="SwListBox" MaxHeight="200"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Version}"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   FontFamily="Consolas" FontSize="10"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Publisher}"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── 하단 버튼 바 ────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnRefresh" Grid.Column="0"
                        Content="🔄  새로고침" Padding="14,7" Click="BtnRefresh_Click"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🌐  HTML 리포트" Padding="14,7" Margin="0,0,8,0"
                            Click="BtnHtml_Click"/>
                    <Button Content="💾  JSON 저장" Padding="14,7" Margin="0,0,8,0"
                            Click="BtnJson_Click"/>
                    <Button Content="🔍  비교..." Padding="14,7"
                            Click="BtnCompare_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 로딩 오버레이 ──────────────────────────────── -->
        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="3"
                Background="#CC000010" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="시스템 정보 수집 중..." FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource FgBrush}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtLoadingStep" Text=""
                           Foreground="{StaticResource Fg2Brush}" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
