<UserControl x:Class="PdfForge.Views.PageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="페이지 편집" FontSize="20" FontWeight="SemiBold"
                       Foreground="#E8E8F0" Margin="0,0,0,4"/>
            <TextBlock Text="페이지를 회전, 삭제, 순서 변경합니다."
                       FontSize="12" Foreground="#888899"/>
        </StackPanel>

        <!-- 파일 선택 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtInput" IsReadOnly="True" Margin="0,0,8,0"
                     Text="파일을 선택하세요..." Foreground="#888899" Height="32"/>
            <Button Grid.Column="1" Content="파일 선택" Width="90" Height="32"
                    Click="SelectFile_Click"/>
        </Grid>

        <!-- 작업 툴바 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="↺ 90° 회전" Width="90" Click="Rotate90_Click" Margin="0,0,6,0"
                    ToolTip="선택된 페이지를 시계 방향 90° 회전"/>
            <Button Content="↻ -90° 회전" Width="90" Click="RotateMinus90_Click" Margin="0,0,6,0"
                    ToolTip="선택된 페이지를 반시계 방향 90° 회전"/>
            <Button Content="180° 회전" Width="80" Click="Rotate180_Click" Margin="0,0,16,0"/>
            <Button Content="🗑 삭제" Width="70" Click="DeletePages_Click" Margin="0,0,6,0"
                    Background="#3A1C1C" BorderBrush="#6A2020"/>
            <TextBlock Text="|" Foreground="#333344" VerticalAlignment="Center" Margin="4,0"/>
            <Button Content="↑" Width="32" Click="MoveUp_Click" Margin="4,0,2,0"
                    ToolTip="선택 페이지 위로"/>
            <Button Content="↓" Width="32" Click="MoveDown_Click" Margin="0,0,0,0"
                    ToolTip="선택 페이지 아래로"/>
            <TextBlock x:Name="TxtPageInfo" Foreground="#888899" FontSize="11"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- 페이지 목록 -->
        <Border Grid.Row="3" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6">
            <ListBox x:Name="PageListBox" Background="Transparent" BorderThickness="0"
                     SelectionMode="Extended" Margin="8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="PageListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Number}" FontSize="12"
                                       Foreground="#888899" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="13"
                                       Foreground="#E8E8F0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding RotateText}" FontSize="11"
                                       Foreground="#5B8FFF" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 저장 -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="PbPage" Height="6" Margin="0,0,12,0"
                         VerticalAlignment="Center" Visibility="Collapsed"/>
            <Button Grid.Column="1" x:Name="BtnSave" Content="저장" Width="120" Height="36"
                    Click="BtnSave_Click"
                    Background="#5B8FFF" Foreground="White" FontWeight="SemiBold"
                    BorderBrush="#4070DD"/>
        </Grid>
    </Grid>
</UserControl>
