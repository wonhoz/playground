<UserControl x:Class="SysClean.Views.DiskAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 설명 배너 -->
        <Border Grid.Row="0" Background="#1E1E2E" Padding="16,10" Margin="16,16,16,0"
                CornerRadius="6" BorderBrush="#333333" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="대용량 파일 탐색기" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource BrAccent}"/>
                <TextBlock Text="디스크에서 지정 크기 이상의 대용량 파일을 검색합니다. 불필요한 대용량 파일을 찾아 공간을 확보하세요."
                           FontSize="12" Foreground="#888" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 검색 옵션 -->
        <Border Grid.Row="1" Padding="16,10,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="검색 경로" Foreground="#888" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtPath" Grid.Column="1" Padding="8,5"
                         Text="C:\" ToolTip="검색할 폴더 경로"/>

                <TextBlock Grid.Column="3" Text="최소 크기" Foreground="#888" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CbMinSize" Grid.Column="4" SelectedIndex="2">
                    <ComboBoxItem Content="10 MB"/>
                    <ComboBoxItem Content="50 MB"/>
                    <ComboBoxItem Content="100 MB"/>
                    <ComboBoxItem Content="500 MB"/>
                    <ComboBoxItem Content="1 GB"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- 결과 목록 -->
        <ListView x:Name="FileList" Grid.Row="2" Margin="16,8,16,0"
                  Background="#1E1E1E" BorderThickness="1" BorderBrush="#333"
                  SelectionMode="Extended"
                  GridViewColumnHeader.Click="OnColumnHeaderClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="300">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="파일 이름" Tag="FileName"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold" Margin="4,0"
                                           ToolTip="{Binding FullPath}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="100">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="크기" Tag="SizeBytes"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeText}" Foreground="#FF6B35"
                                           FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="확장자" Tag="Extension"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#252525" CornerRadius="3" Padding="5,2" Margin="2">
                                    <TextBlock Text="{Binding Extension}" FontSize="11"
                                               Foreground="{Binding ExtensionColor}" FontFamily="Consolas"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="120">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="수정일" Tag="LastModified"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LastModifiedText}" Foreground="#888"
                                           FontSize="11" Margin="4,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="300">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="폴더" Tag="Directory"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Directory}" Foreground="#666"
                                           FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Directory}" Margin="4,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 진행률 -->
        <ProgressBar x:Name="PbProgress" Grid.Row="3" Height="3"
                     Background="#1A1A1A" Foreground="{StaticResource BrAccent}"
                     Margin="16,8,16,0" Visibility="Collapsed"/>

        <!-- 하단 -->
        <Border Grid.Row="4" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,1,0,0"
                Padding="16,10" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="TbStatus"
                           Text="경로와 최소 크기를 설정하고 스캔을 시작하세요."
                           Foreground="#888" FontSize="12" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="1" Content="📂  폴더 열기" Click="BtnOpenFolder_Click"
                        Padding="10,6" Margin="0,0,6,0" FontSize="12"
                        Background="#252525" Foreground="#888" BorderBrush="#3A3A3A"
                        ToolTip="선택한 파일의 폴더 열기"/>

                <Button Grid.Column="2" x:Name="BtnScan" Content="🔍  스캔"
                        Click="BtnScan_Click" Margin="0,0,6,0"
                        Padding="14,7" FontSize="13"
                        Background="{StaticResource BrAccentDim}" Foreground="{StaticResource BrAccent}" BorderBrush="{StaticResource BrAccent}"/>

                <Button Grid.Column="3" x:Name="BtnDelete" Content="🗑  선택 삭제"
                        Click="BtnDelete_Click" IsEnabled="False"
                        Padding="14,7" FontSize="13"
                        Background="#3A1A1A" Foreground="#EF5350" BorderBrush="#C62828"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
