<UserControl x:Class="HashCheck.Views.BatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 드롭존 ───────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#16161F" BorderBrush="#2A2A3E" BorderThickness="2"
                CornerRadius="8" Margin="0,0,0,16" Cursor="Hand"
                MouseLeftButtonDown="DropZone_Click">
            <Grid>
                <StackPanel x:Name="DropHint" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Margin="0,16">
                    <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="체크섬 파일을 드래그하거나 클릭하여 선택"
                               FontSize="13" Foreground="#666677" HorizontalAlignment="Center"/>
                    <TextBlock Text=".md5 · .sha1 · .sha256 · .sha512 · .checksum · .sfv"
                               FontSize="11" Foreground="#444455"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Grid x:Name="FileInfoBar" Visibility="Collapsed" Margin="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📋" FontSize="24"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtChecksumFile" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#E8E8F0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtEntryCount" FontSize="11"
                                   Foreground="#888899" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="검증 시작" Width="80" Height="30"
                            Margin="8,0" Click="BtnVerify_Click" x:Name="BtnVerify"/>
                    <Button Grid.Column="3" Content="✕" Width="28" Height="28"
                            VerticalAlignment="Top" Click="BtnClear_Click" ToolTip="초기화"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── 결과 ListView ──────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6" Padding="0">
            <ListView x:Name="LvResults" Background="Transparent"
                      BorderThickness="0" Foreground="#D4D4D4"
                      SelectionMode="Extended">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="34">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusIcon}"
                                               Foreground="{Binding StatusColor}"
                                               FontSize="14" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="파일명" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FilePath}" ToolTip="{Binding FilePath}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="알고리즘" Width="72">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AlgoText}" Foreground="#888899"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="예상 해시" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ExpectedHash}"
                                               FontFamily="Consolas" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="실제 해시" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ActualHash}"
                                               Foreground="{Binding StatusColor}"
                                               FontFamily="Consolas" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0,4"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Border>

        <!-- ── 하단 툴바 ──────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TxtSummary" Foreground="#888899" FontSize="12"
                           VerticalAlignment="Center" Text="파일을 불러오면 검증 결과가 표시됩니다."/>
            </StackPanel>
            <Button Grid.Column="1" Content="CSV 내보내기" Width="110" Height="30"
                    Click="BtnExport_Click" x:Name="BtnExport" IsEnabled="False"/>
        </Grid>
    </Grid>
</UserControl>
