<Window x:Class="MockServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mock.Server" Height="760" Width="1160"
        MinHeight="520" MinWidth="860"
        Background="#0D0D16"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 툴바 ── -->
        <Border Grid.Row="0"
                Background="#131321"
                BorderBrush="#2A2A3D" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <!-- 타이틀 -->
                <TextBlock DockPanel.Dock="Left"
                           Text="Mock.Server"
                           Foreground="#818CF8" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- 오른쪽: 포트 + 서버 시작/중지 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="포트:" Foreground="#888898" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtPort" Text="8080" Width="65" Height="34"
                             Padding="6,0" VerticalContentAlignment="Center"
                             ToolTip="서버 리스닝 포트"/>
                    <Button x:Name="BtnToggle" Content="▶ 서버 시작"
                            Width="105" Height="28" Margin="8,0,0,0"
                            Click="BtnToggle_Click"
                            ToolTip="서버를 시작하거나 중지합니다"/>
                </StackPanel>

                <!-- 중앙: 서버 상태 -->
                <TextBlock x:Name="TxtServerStatus"
                           Foreground="#888898" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ── 본문: TabControl ── -->
        <TabControl x:Name="Tabs" Grid.Row="1"
                    Background="#0D0D16"
                    BorderBrush="#2A2A3D" BorderThickness="0,0,0,0"
                    SelectionChanged="Tabs_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background"   Value="Transparent"/>
                    <Setter Property="Foreground"   Value="#888898"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"      Value="16,8"/>
                    <Setter Property="FontSize"     Value="12"/>
                    <Setter Property="Cursor"       Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="Transparent"
                                        BorderBrush="#2A2A3D" BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#818CF8"/>
                                        <Setter Property="Foreground" Value="#E0E0F0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#C8C8E8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#131321"
                                BorderBrush="#2A2A3D" BorderThickness="0,0,0,1">
                            <TabPanel IsItemsHost="True" HorizontalAlignment="Left" Margin="4,0"/>
                        </Border>
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <!-- ════════════════════════════════════════════════════
                 탭 1: GUI 편집
                 ════════════════════════════════════════════════════ -->
            <TabItem Header="GUI 편집">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" MinWidth="180"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── 왼쪽: 엔드포인트 목록 ── -->
                    <Grid Grid.Column="0" Background="#131321">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 목록 헤더 -->
                        <Border Grid.Row="0" Background="#131321"
                                BorderBrush="#2A2A3D" BorderThickness="0,0,0,1"
                                Padding="10,7">
                            <TextBlock Text="엔드포인트 목록"
                                       Foreground="#888898" FontSize="11"/>
                        </Border>

                        <!-- 목록 -->
                        <ListBox x:Name="LbEndpoints" Grid.Row="1"
                                 Background="#0D0D16"
                                 SelectionChanged="LbEndpoints_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" BorderBrush="#2A2A3D" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <!-- Enabled 표시 -->
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6"
                                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#22C55E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                <Setter Property="Fill" Value="#3A3A55"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <!-- Method -->
                                            <Border DockPanel.Dock="Left"
                                                    Background="#1A1A35"
                                                    CornerRadius="2" Padding="4,1"
                                                    Margin="0,0,6,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Method}"
                                                           Foreground="#818CF8" FontSize="10"
                                                           FontWeight="Bold" FontFamily="Consolas"/>
                                            </Border>
                                            <!-- Status -->
                                            <Border DockPanel.Dock="Right"
                                                    Background="#1A1A2E"
                                                    CornerRadius="2" Padding="4,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#A5B4FC" FontSize="10"
                                                           FontFamily="Consolas"/>
                                            </Border>
                                            <!-- Path -->
                                            <TextBlock Text="{Binding Path}"
                                                       Foreground="#C8C8E8" FontSize="11"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 목록 하단 버튼 -->
                        <Border Grid.Row="2" Background="#131321"
                                BorderBrush="#2A2A3D" BorderThickness="0,1,0,0"
                                Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnAdd" Content="+ 추가" Width="70" Height="24"
                                        FontSize="11" Click="BtnAdd_Click"
                                        ToolTip="새 엔드포인트 추가"/>
                                <Button x:Name="BtnDelete" Content="- 삭제" Width="70" Height="24"
                                        FontSize="11" Margin="6,0,0,0"
                                        Style="{StaticResource DangerBtn}"
                                        Click="BtnDelete_Click"
                                        ToolTip="선택된 엔드포인트 삭제"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── GridSplitter (수직) ── -->
                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <!-- ── 오른쪽: 편집 패널 ── -->
                    <Grid Grid.Column="2">
                        <!-- 플레이스홀더 -->
                        <TextBlock x:Name="TxtGuiPlaceholder"
                                   Text="← 엔드포인트를 선택하거나 [+ 추가]를 눌러 새로 만드세요."
                                   Foreground="#555570" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- 편집기 패널 -->
                        <ScrollViewer x:Name="GuiEditor" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20,16" MaxWidth="640">

                                <!-- 활성화 + 설명 -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- CheckBox 커스텀 ControlTemplate -->
                                    <CheckBox x:Name="ChkEnabled" Grid.Column="0"
                                              Content="활성화"
                                              IsChecked="True"
                                              Foreground="#E0E0F0" FontSize="12"
                                              VerticalAlignment="Center"
                                              Margin="0,0,16,0"
                                              Checked="GuiField_Changed"
                                              Unchecked="GuiField_Changed">
                                        <CheckBox.Template>
                                            <ControlTemplate TargetType="CheckBox">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border x:Name="Bd" Width="16" Height="16"
                                                            CornerRadius="3"
                                                            Background="#22223A"
                                                            BorderBrush="#2A2A3D" BorderThickness="1"
                                                            Margin="0,0,6,0">
                                                        <Path x:Name="Chk" Data="M 2 8 L 6 12 L 14 4"
                                                              Stroke="#818CF8" StrokeThickness="2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Visibility="Collapsed"/>
                                                    </Border>
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chk" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#818CF8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#818CF8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </CheckBox.Template>
                                    </CheckBox>
                                    <TextBox x:Name="TxtEdDesc" Grid.Column="1"
                                             Height="28" VerticalContentAlignment="Center"
                                             TextChanged="GuiField_Changed"/>
                                </Grid>

                                <!-- 메서드 + 경로 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CmbMethod" Grid.Column="0" Height="28"
                                              Margin="0,0,8,0"
                                              SelectionChanged="GuiCombo_Changed">
                                        <ComboBoxItem Content="GET"    IsSelected="True"/>
                                        <ComboBoxItem Content="POST"/>
                                        <ComboBoxItem Content="PUT"/>
                                        <ComboBoxItem Content="PATCH"/>
                                        <ComboBoxItem Content="DELETE"/>
                                    </ComboBox>
                                    <TextBox x:Name="TxtEdPath" Grid.Column="1"
                                             Height="28" VerticalContentAlignment="Center"
                                             FontFamily="Consolas" Text="/api/endpoint"
                                             TextChanged="GuiField_Changed"/>
                                </Grid>

                                <!-- 상태 코드 + 지연 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="상태 코드" Foreground="#888898"
                                                   FontSize="11" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CmbStatus" Height="28"
                                                  SelectionChanged="GuiCombo_Changed">
                                            <ComboBoxItem Content="200 OK"           IsSelected="True"/>
                                            <ComboBoxItem Content="201 Created"/>
                                            <ComboBoxItem Content="204 No Content"/>
                                            <ComboBoxItem Content="301 Moved"/>
                                            <ComboBoxItem Content="400 Bad Request"/>
                                            <ComboBoxItem Content="401 Unauthorized"/>
                                            <ComboBoxItem Content="403 Forbidden"/>
                                            <ComboBoxItem Content="404 Not Found"/>
                                            <ComboBoxItem Content="422 Unprocessable"/>
                                            <ComboBoxItem Content="500 Internal Error"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="지연 (ms)" Foreground="#888898"
                                                   FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtEdDelay" Height="28"
                                                 VerticalContentAlignment="Center"
                                                 Text="0" FontFamily="Consolas"
                                                 TextChanged="GuiField_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 응답 본문 레이블 -->
                                <TextBlock Text="응답 본문 (JSON)" Foreground="#888898"
                                           FontSize="11" Margin="0,0,0,4"/>

                                <!-- 응답 TextBox -->
                                <TextBox x:Name="TxtEdBody"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         Height="200"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Margin="0,0,0,16"
                                         TextChanged="GuiField_Changed"/>

                                <!-- 내보내기 / 가져오기 버튼 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="JSON 내보내기" Width="110" Height="28"
                                            FontSize="11" Margin="0,0,8,0"
                                            Style="{StaticResource SecondaryBtn}"
                                            Click="BtnExport_Click"
                                            ToolTip="현재 엔드포인트를 JSON 파일로 내보냅니다"/>
                                    <Button Content="JSON 가져오기" Width="110" Height="28"
                                            FontSize="11"
                                            Style="{StaticResource SecondaryBtn}"
                                            Click="BtnImport_Click"
                                            ToolTip="JSON 파일에서 엔드포인트를 가져옵니다"/>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════
                 탭 2: 코드 편집
                 ════════════════════════════════════════════════════ -->
            <TabItem Header="코드 편집">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" MinWidth="100"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="210" MinWidth="160"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── 열0: 파일 작업 패널 ── -->
                    <Grid Grid.Column="0" Background="#131321">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#131321"
                                BorderBrush="#2A2A3D" BorderThickness="0,0,0,1"
                                Padding="10,7">
                            <TextBlock Text="파일"
                                       Foreground="#888898" FontSize="11"/>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="8,10,8,10">
                            <Button x:Name="BtnOpen" Content="📂 열기"
                                    Height="28" FontSize="11" Margin="0,0,0,6"
                                    Style="{StaticResource SecondaryBtn}"
                                    Click="BtnOpen_Click"
                                    ToolTip="YAML/JSON 파일 열기"/>
                            <Button x:Name="BtnSave" Content="💾 저장"
                                    Height="28" FontSize="11" Margin="0,0,0,6"
                                    Style="{StaticResource SecondaryBtn}"
                                    Click="BtnSave_Click"
                                    ToolTip="현재 편집 내용을 파일로 저장"/>
                            <Button x:Name="BtnNew"  Content="📄 새로"
                                    Height="28" FontSize="11" Margin="0,0,0,16"
                                    Style="{StaticResource SecondaryBtn}"
                                    Click="BtnNew_Click"
                                    ToolTip="기본 YAML 템플릿으로 초기화"/>

                            <TextBlock Text="포맷" Foreground="#888898"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CbFormat" Height="28"
                                      SelectionChanged="CbFormat_SelectionChanged">
                                <ComboBoxItem Content="YAML" IsSelected="True"/>
                                <ComboBoxItem Content="JSON"/>
                            </ComboBox>

                            <TextBlock x:Name="TxtValidation"
                                       Foreground="#22C55E" FontSize="10"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>

                            <Button x:Name="BtnApply" Content="적용"
                                    Height="28" FontSize="11" Margin="0,10,0,0"
                                    Click="BtnApply_Click"
                                    ToolTip="에디터 내용을 파싱하여 라우트에 반영"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── 열1: GridSplitter ── -->
                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <!-- ── 열2: 에디터 TextBox ── -->
                    <TextBox x:Name="TxtEditor"
                             Grid.Column="2"
                             FontFamily="Consolas" FontSize="12"
                             AcceptsReturn="True" AcceptsTab="True"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             Background="#0D0D16" Foreground="#C8C8E8"
                             CaretBrush="#818CF8"
                             BorderThickness="0"
                             Padding="10,8"
                             TextChanged="TxtEditor_TextChanged"/>

                    <!-- ── 열3: GridSplitter ── -->
                    <GridSplitter Grid.Column="3"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <!-- ── 열4: 파싱된 라우트 목록 ── -->
                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#131321"
                                BorderBrush="#2A2A3D" BorderThickness="0,0,0,1"
                                Padding="10,7">
                            <DockPanel>
                                <TextBlock x:Name="TxtRouteCount" DockPanel.Dock="Right"
                                           Foreground="#555570" FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="파싱된 라우트"
                                           Foreground="#888898" FontSize="11"/>
                            </DockPanel>
                        </Border>

                        <ListBox x:Name="LbRoutes" Grid.Row="1"
                                 Background="#0D0D16"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,5" BorderBrush="#2A2A3D" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <Border DockPanel.Dock="Left"
                                                    Background="#1A1A35"
                                                    BorderBrush="#818CF8" BorderThickness="1"
                                                    CornerRadius="3" Padding="4,2"
                                                    Margin="0,0,6,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Method}"
                                                           Foreground="#818CF8" FontSize="10"
                                                           FontWeight="Bold" FontFamily="Consolas"/>
                                            </Border>
                                            <Border DockPanel.Dock="Right"
                                                    Background="#1A1A2E"
                                                    CornerRadius="3" Padding="4,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#A5B4FC" FontSize="10"
                                                           FontFamily="Consolas"/>
                                            </Border>
                                            <TextBlock Text="{Binding Path}"
                                                       Foreground="#C8C8E8" FontSize="11"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ── GridSplitter (수평) ── -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>

        <!-- ── 요청 로그 (항상 표시) ── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#131321"
                    BorderBrush="#2A2A3D" BorderThickness="0,0,0,1"
                    Padding="10,5">
                <DockPanel>
                    <Button x:Name="BtnClearLog" Content="🗑 지우기"
                            DockPanel.Dock="Right"
                            Style="{StaticResource SecondaryBtn}"
                            Width="75" Height="22" FontSize="11"
                            Click="BtnClearLog_Click"/>
                    <TextBlock Text="요청 로그"
                               Foreground="#888898" FontSize="11"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <ListBox x:Name="LbLog"
                     Grid.Row="1"
                     Background="#0D0D16"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#C8C8E8" Padding="8,3"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
