<UserControl x:Class="SysClean.Views.CleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:SysClean.Models"
             Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 메인 콘텐츠 (좌: 체크리스트, 우: 결과) ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 항목 체크리스트 -->
            <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <ItemsControl x:Name="TargetList" Margin="0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CleanTarget}">
                                <Grid>
                                    <!-- 그룹 헤더 -->
                                    <Border x:Name="GroupBorder" Visibility="Collapsed"
                                            Background="#252525" Padding="12,8,12,6"
                                            Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Foreground="#888"/>
                                    </Border>
                                    <!-- 일반 항목 -->
                                    <Border x:Name="ItemBorder" Visibility="Collapsed" Padding="12,5">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  ToolTip="{Binding Description}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13"/>
                                                <TextBlock Text="{Binding SizeText}"
                                                           FontSize="11" Foreground="{StaticResource BrAccent}"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                        <Setter TargetName="GroupBorder" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="ItemBorder" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsGroup}" Value="False">
                                        <Setter TargetName="GroupBorder" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="ItemBorder" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- 구분선 -->
            <GridSplitter Grid.Column="1" Width="3" Background="#2A2A2A" HorizontalAlignment="Stretch"/>

            <!-- 우측: 스캔 결과 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 결과 헤더 -->
                <Border Grid.Row="0" Background="#1E1E1E" Padding="16,10" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <TextBlock x:Name="TbResultHeader" Text="분석 버튼을 클릭하면 정리 가능한 파일을 검색합니다."
                               Foreground="#666" FontSize="12"/>
                </Border>

                <!-- 결과 목록 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ResultPanel" Margin="16,12">
                        <!-- 결과가 없을 때 힌트 -->
                        <TextBlock x:Name="TbHint"
                                   Text="&#x1F9F9;  분석을 실행하면 정리 가능한 파일 목록이 여기에 표시됩니다."
                                   Foreground="#444" FontSize="14" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,60,0,0" TextAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ── 진행률 바 ── -->
        <ProgressBar x:Name="PbProgress" Grid.Row="1" Height="3"
                     Background="#1A1A1A" Foreground="{StaticResource BrAccent}"
                     Visibility="Collapsed"/>

        <!-- ── 하단 액션 바 ── -->
        <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 상태 텍스트 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TbStatus" Text="준비" Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="TbTotalSize" Text="" Foreground="{StaticResource BrAccent}" FontSize="12"
                               FontWeight="SemiBold" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- 전체 선택 -->
                <Button Grid.Column="1" x:Name="BtnSelectAll" Content="전체 선택"
                        Click="BtnSelectAll_Click" Margin="0,0,6,0"
                        Padding="10,6" FontSize="12"/>

                <!-- 폴더 추가 버튼 -->
                <Button Grid.Column="2" x:Name="BtnAddFolder" Content="📁  폴더 추가"
                        Click="BtnAddFolder_Click" Margin="0,0,6,0"
                        Padding="10,6" FontSize="12"
                        Background="#252535" Foreground="#888" BorderBrush="#3A3A5A"
                        ToolTip="청소 대상 커스텀 폴더 추가"/>

                <!-- 복사 버튼 -->
                <Button Grid.Column="3" x:Name="BtnCopy" Content="📋  복사"
                        Click="BtnCopy_Click" Margin="0,0,6,0"
                        Padding="10,6" FontSize="12" IsEnabled="False"
                        ToolTip="분석 결과를 클립보드에 복사"/>

                <!-- 분석 버튼 -->
                <Button Grid.Column="4" x:Name="BtnAnalyze" Content="🔍  분석"
                        Click="BtnAnalyze_Click" Margin="0,0,6,0"
                        Padding="14,7" FontSize="13"
                        Background="{StaticResource BrAccentDim}" Foreground="{StaticResource BrAccent}"
                        BorderBrush="{StaticResource BrAccent}"/>

                <!-- 청소 버튼 -->
                <Button Grid.Column="5" x:Name="BtnClean" Content="🧹  청소 실행"
                        Click="BtnClean_Click" IsEnabled="False"
                        Padding="14,7" FontSize="13"
                        Background="#1B3A1F" Foreground="#66BB6A" BorderBrush="#388E3C"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
