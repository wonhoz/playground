<Application x:Class="ChordStrike.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- 네온 리듬 팔레트 -->
        <SolidColorBrush x:Key="BgBrush"     Color="#080810"/>
        <SolidColorBrush x:Key="LaneBrush"   Color="#0D0D20"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#1A1A40"/>
        <SolidColorBrush x:Key="HitLineBrush" Color="#2A2A60"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4080FF"/>
        <SolidColorBrush x:Key="PerfectBrush" Color="#FFE040"/>
        <SolidColorBrush x:Key="GoodBrush"   Color="#40FF80"/>
        <SolidColorBrush x:Key="MissBrush"   Color="#FF4040"/>
        <SolidColorBrush x:Key="FgBrush"     Color="#E0E0FF"/>
        <SolidColorBrush x:Key="Fg2Brush"    Color="#7070A0"/>

        <!-- 레인 색상 (좌4 파랑, 우4 보라) -->
        <SolidColorBrush x:Key="LaneL0" Color="#3060C0"/>
        <SolidColorBrush x:Key="LaneL1" Color="#2850A0"/>
        <SolidColorBrush x:Key="LaneL2" Color="#3060C0"/>
        <SolidColorBrush x:Key="LaneL3" Color="#2850A0"/>
        <SolidColorBrush x:Key="LaneR0" Color="#8040C0"/>
        <SolidColorBrush x:Key="LaneR1" Color="#6030A0"/>
        <SolidColorBrush x:Key="LaneR2" Color="#8040C0"/>
        <SolidColorBrush x:Key="LaneR3" Color="#6030A0"/>

        <Style TargetType="Button">
            <Setter Property="Background"      Value="#1A1A3A"/>
            <Setter Property="Foreground"      Value="{StaticResource FgBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
