<Window x:Class="SpecView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spec.View" Width="1100" Height="760"
        MinWidth="900" MinHeight="600"
        Background="#0B0F1A" Foreground="#E2E8F0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- 섹션 카드 스타일 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"     Value="#111827"/>
            <Setter Property="BorderBrush"    Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="8"/>
            <Setter Property="Padding"        Value="16"/>
            <Setter Property="Margin"         Value="0,0,0,12"/>
        </Style>
        <!-- 레이블 스타일 -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <!-- 값 스타일 -->
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- 큰 값 스타일 -->
        <Style x:Key="BigValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- 헤더 레이블 -->
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#00C8E0"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>   <!-- 타이틀바 -->
                <RowDefinition Height="52"/>   <!-- 툴바 -->
                <RowDefinition Height="*"/>    <!-- 탭 콘텐츠 -->
                <RowDefinition Height="28"/>   <!-- 상태바 -->
            </Grid.RowDefinitions>

            <!-- ── 타이틀바 ─────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#0D1524"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" Foreground="#00C8E0" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Spec.View" Foreground="#E2E8F0" FontSize="13"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="시스템 하드웨어 스펙 스캐너"
                                   Foreground="#334155" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="MinBtn" Content="─" Width="32" Height="28"
                                Click="MinBtn_Click" FontSize="11" Margin="0,0,4,0"
                                Background="Transparent" BorderThickness="0" Foreground="#64748B"/>
                        <Button x:Name="CloseBtn" Content="✕" Width="32" Height="28"
                                Click="CloseBtn_Click" FontSize="11"
                                Background="Transparent" BorderThickness="0" Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 툴바 ────────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="#0D1524"
                    BorderBrush="#1E293B" BorderThickness="0,0,0,1"
                    Padding="14,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ScanBtn" Content="🔍  스캔" Width="100" Height="32"
                                Style="{StaticResource AccentBtn}" Margin="0,0,8,0"
                                Click="ScanBtn_Click"/>
                        <Separator Width="1" Height="22" Background="#1E293B" Margin="0,0,8,0"/>
                        <Button Content="📋 Markdown" Width="110" Height="32" Margin="0,0,6,0"
                                Click="ExportMarkdown_Click"/>
                        <Button Content="🌐 HTML" Width="90" Height="32" Margin="0,0,6,0"
                                Click="ExportHtml_Click"/>
                        <Button Content="📄 텍스트 복사" Width="105" Height="32" Margin="0,0,6,0"
                                Click="CopyText_Click"/>
                        <Button Content="🖨 인쇄/PDF" Width="100" Height="32"
                                Click="Print_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtLastScan" Foreground="#334155" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtChanges" Foreground="#F59E0B" FontSize="11"
                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 탭 콘텐츠 ────────────────────────────────────────── -->
            <TabControl x:Name="Tabs" Grid.Row="2" Background="#0D1524">

                <!-- 개요 -->
                <TabItem Header="📊 개요">
                    <ScrollViewer Padding="20">
                        <StackPanel x:Name="PanelOverview">
                            <!-- 컴퓨터 정보 헤더 -->
                            <Border Style="{StaticResource Card}" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="TxtPcName"
                                                   Foreground="#00C8E0" FontSize="20"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtOsName"
                                                   Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock x:Name="TxtScanTime"
                                                   Foreground="#334155" FontSize="11"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock x:Name="TxtChangesSummary"
                                                   Foreground="#F59E0B" FontSize="11"
                                                   HorizontalAlignment="Right" Margin="0,4,0,0"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 스펙 카드 2열 그리드 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- CPU 카드 -->
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="🔲  CPU" Style="{StaticResource CardHeader}"/>
                                        <TextBlock x:Name="OvCpuName"  Style="{StaticResource BigValue}"/>
                                        <TextBlock x:Name="OvCpuSpec"  Style="{StaticResource Value}"
                                                   Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="OvCpuClock" Style="{StaticResource Value}"
                                                   Foreground="#64748B" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- 메모리 카드 -->
                                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="🧮  메모리" Style="{StaticResource CardHeader}"/>
                                        <TextBlock x:Name="OvMemTotal"  Style="{StaticResource BigValue}"/>
                                        <TextBlock x:Name="OvMemType"   Style="{StaticResource Value}"
                                                   Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="OvMemSlots"  Style="{StaticResource Value}"
                                                   Foreground="#64748B" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- GPU 카드 -->
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="🖥  GPU" Style="{StaticResource CardHeader}"/>
                                        <TextBlock x:Name="OvGpuName"   Style="{StaticResource BigValue}" FontSize="16"/>
                                        <TextBlock x:Name="OvGpuVram"   Style="{StaticResource Value}"
                                                   Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="OvGpuDriver" Style="{StaticResource Value}"
                                                   Foreground="#64748B" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- 마더보드 카드 -->
                                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="🔧  마더보드" Style="{StaticResource CardHeader}"/>
                                        <TextBlock x:Name="OvBoardName"  Style="{StaticResource BigValue}" FontSize="16"/>
                                        <TextBlock x:Name="OvBoardBios"  Style="{StaticResource Value}"
                                                   Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="OvBoardDate"  Style="{StaticResource Value}"
                                                   Foreground="#64748B" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- 저장장치 카드 -->
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="💾  저장장치" Style="{StaticResource CardHeader}"/>
                                        <TextBlock x:Name="OvDriveCount"  Style="{StaticResource BigValue}"/>
                                        <TextBlock x:Name="OvDriveTotal"  Style="{StaticResource Value}"
                                                   Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="OvDriveSmart"  Style="{StaticResource Value}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- 변경 감지 카드 -->
                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="🔔  변경 감지" Style="{StaticResource CardHeader}"/>
                                        <TextBlock x:Name="OvChangeStatus" Style="{StaticResource BigValue}"
                                                   FontSize="16" Foreground="#10B981"/>
                                        <ItemsControl x:Name="OvChangeList" Margin="0,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#F59E0B"
                                                               FontSize="11" Margin="0,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- CPU -->
                <TabItem Header="🔲 CPU">
                    <ScrollViewer Padding="20">
                        <StackPanel x:Name="PanelCpu">
                            <TextBlock Text="CPU 정보" Foreground="#00C8E0" FontSize="14"
                                       FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <Border Style="{StaticResource Card}">
                                <Grid x:Name="GridCpu"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 메모리 -->
                <TabItem Header="🧮 메모리">
                    <ScrollViewer Padding="20">
                        <StackPanel x:Name="PanelMemory">
                            <TextBlock Text="메모리 정보" Foreground="#00C8E0" FontSize="14"
                                       FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <Border Style="{StaticResource Card}" x:Name="MemSummaryCard">
                                <StackPanel x:Name="MemSummaryPanel"/>
                            </Border>
                            <TextBlock Text="슬롯 상세" Foreground="#00C8E0" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ListView x:Name="ListMemSlots" VirtualizingPanel.IsVirtualizing="True">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="슬롯"        Width="80"  DisplayMemberBinding="{Binding DeviceLocator}"/>
                                        <GridViewColumn Header="뱅크"        Width="80"  DisplayMemberBinding="{Binding BankLabel}"/>
                                        <GridViewColumn Header="용량"        Width="80"  DisplayMemberBinding="{Binding CapacityDisplay}"/>
                                        <GridViewColumn Header="타입"        Width="70"  DisplayMemberBinding="{Binding MemoryType}"/>
                                        <GridViewColumn Header="속도"        Width="80"  DisplayMemberBinding="{Binding SpeedDisplay}"/>
                                        <GridViewColumn Header="제조사"      Width="120" DisplayMemberBinding="{Binding Manufacturer}"/>
                                        <GridViewColumn Header="파트 넘버"   Width="200" DisplayMemberBinding="{Binding PartNumber}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- GPU -->
                <TabItem Header="🖥 GPU">
                    <ScrollViewer Padding="20">
                        <StackPanel x:Name="PanelGpu">
                            <TextBlock Text="GPU 정보" Foreground="#00C8E0" FontSize="14"
                                       FontWeight="SemiBold" Margin="0,0,0,16"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 마더보드 -->
                <TabItem Header="🔧 마더보드">
                    <ScrollViewer Padding="20">
                        <StackPanel x:Name="PanelBoard">
                            <TextBlock Text="마더보드 / BIOS 정보" Foreground="#00C8E0"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <Border Style="{StaticResource Card}">
                                <Grid x:Name="GridBoard"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 저장장치 -->
                <TabItem Header="💾 저장장치">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="저장장치 목록" Foreground="#00C8E0"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ListView x:Name="ListDrives" Grid.Row="1"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="모델"           Width="260" DisplayMemberBinding="{Binding Model}"/>
                                    <GridViewColumn Header="용량"           Width="90"  DisplayMemberBinding="{Binding SizeDisplay}"/>
                                    <GridViewColumn Header="인터페이스"     Width="110" DisplayMemberBinding="{Binding InterfaceType}"/>
                                    <GridViewColumn Header="종류"           Width="90"  DisplayMemberBinding="{Binding MediaType}"/>
                                    <GridViewColumn Header="WMI 상태"       Width="90"  DisplayMemberBinding="{Binding Status}"/>
                                    <GridViewColumn Header="S.M.A.R.T"      Width="180">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SmartStatus}"
                                                           Foreground="{Binding SmartColor}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- 네트워크 -->
                <TabItem Header="🌐 네트워크">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="네트워크 어댑터" Foreground="#00C8E0"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ListView x:Name="ListNetworks" Grid.Row="1"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="이름"       Width="240" DisplayMemberBinding="{Binding Description}"/>
                                    <GridViewColumn Header="MAC 주소"   Width="140" DisplayMemberBinding="{Binding MACAddress}"/>
                                    <GridViewColumn Header="종류"       Width="120" DisplayMemberBinding="{Binding AdapterType}"/>
                                    <GridViewColumn Header="속도"       Width="100" DisplayMemberBinding="{Binding Speed}"/>
                                    <GridViewColumn Header="연결 상태"  Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ConnectionStatus}"
                                                           Foreground="{Binding StatusColor}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- 실시간 모니터 -->
                <TabItem Header="📡 실시간 모니터" x:Name="TabMonitor">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="실시간 센서 데이터" Foreground="#00C8E0"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <Button x:Name="MonitorToggleBtn" Content="▶ 시작" Width="80" Height="28"
                                    Click="MonitorToggle_Click" Margin="0,0,12,0"/>
                            <TextBlock x:Name="TxtMonitorStatus" Foreground="#64748B" FontSize="11"
                                       VerticalAlignment="Center" Text="(탭 진입 시 자동 시작)"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl x:Name="ListSensors">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#111827" BorderBrush="#1E293B"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="12,8" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding HardwareName}"
                                                           Foreground="#94A3B8" FontSize="11"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SensorName}"
                                                           Foreground="#E2E8F0" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding SensorType}"
                                                           Foreground="#64748B" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding ValueDisplay}"
                                                           Foreground="{Binding ValueColor}"
                                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- ── 상태바 ────────────────────────────────────────────── -->
            <Border Grid.Row="3" Background="#0D1524"
                    BorderBrush="#1E293B" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <Grid Margin="14,0">
                    <TextBlock x:Name="TxtStatus" Foreground="#334155" FontSize="11"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtMonitorDot" Foreground="#64748B" FontSize="11" Margin="0,0,16,0"/>
                        <TextBlock Text="Spec.View" Foreground="#1E293B" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 로딩 오버레이 ─────────────────────────────────────── -->
            <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="4"
                    Background="#CC0B0F1A" CornerRadius="10" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="하드웨어 정보 수집 중..." Foreground="#E2E8F0"
                               FontSize="15" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtLoadingDetail" Foreground="#64748B" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
