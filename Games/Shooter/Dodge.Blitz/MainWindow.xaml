<Window x:Class="DodgeBlitz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodge.Blitz" Width="500" Height="608"
        ResizeMode="NoResize"
        Background="#05050F" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        Focusable="True">
    <Grid>
        <!-- Game Canvas -->
        <Canvas x:Name="GameCanvas" Background="#05050F" ClipToBounds="True"
                Margin="0,50,0,0" Width="500" Height="550"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="ShakeTransform"/>
            </Canvas.RenderTransform>
        </Canvas>

        <!-- Close-call flash overlay -->
        <Border x:Name="CloseCallFlash" Width="500" Height="550"
                Margin="0,50,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                Background="#33FFFFFF" IsHitTestVisible="False"
                Opacity="0"/>

        <!-- HUD Top Bar -->
        <Grid x:Name="HudPanel" Height="50" VerticalAlignment="Top" Background="#0D0D1A" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 생존 시간 -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock Text="TIME " FontSize="13" FontWeight="Bold" Foreground="#888888" FontFamily="Consolas"/>
                <TextBlock x:Name="TimeText" Text="0.0" FontSize="20" FontWeight="Bold" Foreground="#00FFCC" FontFamily="Consolas"/>
                <TextBlock Text="s" FontSize="13" Foreground="#888888" FontFamily="Consolas" Margin="1,0,0,0"/>
            </StackPanel>

            <!-- 최고 기록 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock Text="BEST " FontSize="13" FontWeight="Bold" Foreground="#888888" FontFamily="Consolas"/>
                <TextBlock x:Name="BestText" Text="0.0" FontSize="20" FontWeight="Bold" Foreground="#FFD700" FontFamily="Consolas"/>
                <TextBlock Text="s" FontSize="13" Foreground="#888888" FontFamily="Consolas" Margin="1,0,0,0"/>
            </StackPanel>

            <!-- 현재 단계 -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="LevelText" Text="NOVICE" FontSize="13" FontWeight="Bold"
                           Foreground="#00FFCC" FontFamily="Consolas" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect x:Name="LevelGlow" Color="#00FFCC" BlurRadius="6" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Milestone Popup -->
        <TextBlock x:Name="MilestoneText" Text="" FontSize="34" FontWeight="Bold"
                   Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontFamily="Consolas" Margin="0,-60,0,0" Visibility="Collapsed">
            <TextBlock.Effect>
                <DropShadowEffect Color="#FFD700" BlurRadius="18" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Title Screen -->
        <StackPanel x:Name="TitlePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="DODGE.BLITZ" FontSize="44" FontWeight="Bold"
                       Foreground="#FF4444" HorizontalAlignment="Center" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FF0000" BlurRadius="28" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="BULLET HELL SURVIVOR" FontSize="13" Foreground="#888888"
                       HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Consolas"/>

            <TextBlock x:Name="TitleBestText" Text="BEST  0.0s" FontSize="15" Foreground="#FFD700"
                       HorizontalAlignment="Center" Margin="0,16,0,0" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="8" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock FontSize="16" Foreground="#00FFCC"
                       HorizontalAlignment="Center" Margin="0,20,0,0" FontFamily="Consolas"
                       TextAlignment="Center">
                <Run Text="[ ENTER to Start ]"/>
                <LineBreak/>
                <Run Text="[ 🎮 A / Start ]" Foreground="#A0A0CC" FontSize="13"/>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FFCC" BlurRadius="10" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock FontSize="12" Foreground="#555566" HorizontalAlignment="Center"
                       Margin="0,18,0,0" FontFamily="Consolas" TextAlignment="Center">
                <Run Text="WASD / Arrow Keys  ·  Left Stick / D-Pad  move"/>
                <LineBreak/>
                <Run Text="P  pause  ·  M  mute  ·  V  volume  ·  H  how to play"/>
                <LineBreak/>
                <Run Text="Dodge all bullets — survive as long as possible"/>
            </TextBlock>

            <TextBlock x:Name="SessionStatsText" Text="" FontSize="11"
                       Foreground="#A088CC" HorizontalAlignment="Center"
                       Margin="0,10,0,0" FontFamily="Consolas" TextAlignment="Center"
                       Visibility="Collapsed"/>

            <TextBlock x:Name="JoystickStatusText" Text="" FontSize="11"
                       Foreground="#4488AA" HorizontalAlignment="Center"
                       Margin="0,6,0,0" FontFamily="Consolas"/>
        </StackPanel>

        <!-- Countdown Overlay -->
        <TextBlock x:Name="CountdownText" Text="" FontSize="120" FontWeight="Bold"
                   Foreground="#00FFCC" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontFamily="Consolas" Visibility="Collapsed">
            <TextBlock.Effect>
                <DropShadowEffect Color="#00FFCC" BlurRadius="36" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Game Over Screen -->
        <Border x:Name="GameOverPanel" Background="#DD05050F" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="GAME OVER" FontSize="48" FontWeight="Bold"
                           Foreground="#FF4444" HorizontalAlignment="Center" FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF0000" BlurRadius="28" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="FinalTimeText" Text="" FontSize="24" FontWeight="Bold"
                           Foreground="#00FFCC" HorizontalAlignment="Center" Margin="0,16,0,0" FontFamily="Consolas"/>
                <TextBlock x:Name="FinalBestText" Text="" FontSize="16"
                           Foreground="#FFD700" HorizontalAlignment="Center" Margin="0,8,0,0" FontFamily="Consolas"/>
                <TextBlock x:Name="HistoryText" Text="" FontSize="12"
                           Foreground="#556688" HorizontalAlignment="Center" Margin="0,14,0,0"
                           FontFamily="Consolas" TextAlignment="Center"/>
                <TextBlock Text="[ ENTER to Retry ]" FontSize="14" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,20,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>

        <!-- Pause Screen -->
        <Border x:Name="PausePanel" Background="#AA05050F" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="PAUSED" FontSize="52" FontWeight="Bold"
                           Foreground="#00FFCC" HorizontalAlignment="Center" FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFCC" BlurRadius="22" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,24,0,0" FontFamily="Consolas"
                           TextAlignment="Center">
                    <Run Text="[ P / Enter  Resume ]"/>
                    <LineBreak/>
                    <Run Text="[ ESC  Back to Title ]" FontSize="12" Foreground="#555566"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Mute Toast -->
        <TextBlock x:Name="MuteToast" Text="" FontSize="20" FontWeight="Bold"
                   Foreground="#00FFCC" HorizontalAlignment="Center" VerticalAlignment="Top"
                   FontFamily="Consolas" Margin="0,64,0,0" Visibility="Collapsed">
            <TextBlock.Effect>
                <DropShadowEffect Color="#00FFCC" BlurRadius="10" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- How To Play Overlay -->
        <Border x:Name="HelpPanel" Background="#EE05050F" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="340">
                <TextBlock Text="HOW TO PLAY" FontSize="26" FontWeight="Bold"
                           Foreground="#00FFCC" HorizontalAlignment="Center" FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFCC" BlurRadius="14" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock FontSize="11" Foreground="#3A3A4A" HorizontalAlignment="Center"
                           Margin="0,6,0,0" FontFamily="Consolas"
                           Text="────────────────────────────"/>

                <!-- 조작 -->
                <TextBlock Text="MOVEMENT" FontSize="12" FontWeight="Bold"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,10,0,4" FontFamily="Consolas"/>
                <TextBlock FontSize="12" Foreground="#CCCCCC" HorizontalAlignment="Center"
                           FontFamily="Consolas" TextAlignment="Center">
                    <Run Text="WASD  /  Arrow Keys"/>
                    <LineBreak/>
                    <Run Text="Left Stick  /  D-Pad" Foreground="#A0A0CC"/>
                </TextBlock>

                <TextBlock FontSize="11" Foreground="#3A3A4A" HorizontalAlignment="Center"
                           Margin="0,10,0,0" FontFamily="Consolas"
                           Text="────────────────────────────"/>

                <!-- 레벨 -->
                <TextBlock Text="LEVELS" FontSize="12" FontWeight="Bold"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,10,0,6" FontFamily="Consolas"/>
                <TextBlock FontSize="12" FontFamily="Consolas" HorizontalAlignment="Center" TextAlignment="Center">
                    <Run Text="NOVICE " Foreground="#888888"/><Run Text="0 – 10s" Foreground="#555566"/>
                    <LineBreak/>
                    <Run Text="SKILLED" Foreground="#66AAFF"/><Run Text="  10 – 20s" Foreground="#555566"/>
                    <LineBreak/>
                    <Run Text="EXPERT " Foreground="#FF9900"/><Run Text="20 – 35s" Foreground="#555566"/>
                    <LineBreak/>
                    <Run Text="VETERAN" Foreground="#FF66AA"/><Run Text="  35 – 60s" Foreground="#555566"/>
                    <LineBreak/>
                    <Run Text="LEGEND " Foreground="#FF4444"/><Run Text="60s +" Foreground="#555566"/>
                </TextBlock>

                <TextBlock FontSize="11" Foreground="#3A3A4A" HorizontalAlignment="Center"
                           Margin="0,10,0,0" FontFamily="Consolas"
                           Text="────────────────────────────"/>

                <!-- 총알 패턴 -->
                <TextBlock Text="BULLET PATTERNS" FontSize="12" FontWeight="Bold"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,10,0,6" FontFamily="Consolas"/>
                <TextBlock FontSize="12" FontFamily="Consolas" HorizontalAlignment="Center" TextAlignment="Center">
                    <Run Text="NOVICE  " Foreground="#555566"/><Run Text="Homing (single)" Foreground="#AAAAAA"/>
                    <LineBreak/>
                    <Run Text="SKILLED " Foreground="#555566"/><Run Text="+ Spread 3-way" Foreground="#AAAAAA"/>
                    <LineBreak/>
                    <Run Text="EXPERT  " Foreground="#555566"/><Run Text="+ Homing pair  + Spread 5-way" Foreground="#AAAAAA"/>
                    <LineBreak/>
                    <Run Text="VETERAN+" Foreground="#555566"/><Run Text="+ Fast straight" Foreground="#AAAAAA"/>
                </TextBlock>

                <TextBlock FontSize="11" Foreground="#3A3A4A" HorizontalAlignment="Center"
                           Margin="0,10,0,0" FontFamily="Consolas"
                           Text="────────────────────────────"/>

                <!-- 단축키 -->
                <TextBlock Text="SHORTCUTS" FontSize="12" FontWeight="Bold"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,10,0,6" FontFamily="Consolas"/>
                <TextBlock FontSize="12" FontFamily="Consolas" HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <Run Text="Enter" Foreground="#00FFCC"/><Run Text="  Start / Resume  " Foreground="#666666"/>
                    <Run Text="P" Foreground="#00FFCC"/><Run Text="  Pause" Foreground="#666666"/>
                    <LineBreak/>
                    <Run Text="M" Foreground="#00FFCC"/><Run Text="  Mute / Unmute  " Foreground="#666666"/>
                    <Run Text="V" Foreground="#00FFCC"/><Run Text="  BGM Volume (3 levels)" Foreground="#666666"/>
                    <LineBreak/>
                    <Run Text="H" Foreground="#00FFCC"/><Run Text="  Help  " Foreground="#666666"/>
                    <Run Text="ESC" Foreground="#00FFCC"/><Run Text="  Title / Quit" Foreground="#666666"/>
                </TextBlock>

                <TextBlock FontSize="11" Foreground="#3A3A4A" HorizontalAlignment="Center"
                           Margin="0,10,0,0" FontFamily="Consolas"
                           Text="────────────────────────────"/>

                <!-- 시작 시 -->
                <TextBlock Text="START SEQUENCE" FontSize="12" FontWeight="Bold"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,10,0,4" FontFamily="Consolas"/>
                <TextBlock FontSize="11" Foreground="#AAAAAA" HorizontalAlignment="Center"
                           FontFamily="Consolas" TextAlignment="Center"
                           Text="3 — 2 — 1 countdown before bullets start"/>

                <TextBlock Text="[ H / ESC  Close ]" FontSize="12" Foreground="#555566"
                           HorizontalAlignment="Center" Margin="0,18,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
