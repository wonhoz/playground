<Window x:Class="HashCheck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HashCheck.Views"
        Title="Hash.Check" Height="660" Width="900" MinHeight="480" MinWidth="720"
        Background="#111118" Foreground="#E8E8F0"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#0D0D16" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1" Padding="20,12">
            <TextBlock FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                <Run Text="Hash" Foreground="#22C55E"/>
                <Run Text=".Check" Foreground="#E8E8F0"/>
            </TextBlock>
        </Border>

        <!-- 탭 -->
        <TabControl Grid.Row="1" x:Name="Tabs" Background="#111118" BorderThickness="0"
                    Padding="0" SelectionChanged="Tabs_SelectionChanged">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}"/>
            </TabControl.ItemContainerStyle>
            <TabItem Header="단일 파일" Tag="Single">
                <views:SingleView x:Name="SingleView"/>
            </TabItem>
            <TabItem Header="일괄 검증" Tag="Batch">
                <views:BatchView x:Name="BatchView"/>
            </TabItem>
            <TabItem Header="폴더 해시" Tag="Folder">
                <views:FolderView x:Name="FolderView"/>
            </TabItem>
            <TabItem Header="변경 감시" Tag="Watch">
                <views:WatchView x:Name="WatchView"/>
            </TabItem>
        </TabControl>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#0D0D16" BorderBrush="#2A2A3E" BorderThickness="0,1,0,0" Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Text="파일을 드래그하거나 탭을 선택하세요."
                           Foreground="#888899" FontSize="11" VerticalAlignment="Center"/>
                <ProgressBar x:Name="PbMain" Grid.Column="1" Width="140" Height="4"
                             Visibility="Collapsed" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
