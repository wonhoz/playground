<UserControl x:Class="DeepDiff.Views.FolderCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DeepDiff.Views"
             Background="#0F0F1E">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 경로 선택 -->
            <RowDefinition Height="Auto"/>   <!-- 툴바 -->
            <RowDefinition Height="Auto"/>   <!-- 필터/검색 -->
            <RowDefinition Height="*"/>      <!-- 파일 목록 -->
            <RowDefinition Height="Auto"/>   <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- 경로 선택 영역 -->
        <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1"
                        CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtLeftPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12"
                                 VerticalAlignment="Center" Padding="4,3"
                                 KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                ToolTip="폴더 선택" Click="BtnLeftBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                        <Button Grid.Column="2" Content="↑" Width="26" Height="26" Padding="0"
                                ToolTip="상위 폴더" Click="BtnLeftUp_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>

                <Button Grid.Column="1" Content="⇆" Width="36" FontSize="14" Margin="6,0"
                        ToolTip="경로 교환" Click="BtnSwap_Click"/>

                <Border Grid.Column="2" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1"
                        CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtRightPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12"
                                 VerticalAlignment="Center" Padding="4,3"
                                 KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                ToolTip="폴더 선택" Click="BtnRightBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                        <Button Grid.Column="2" Content="↑" Width="26" Height="26" Padding="0"
                                ToolTip="상위 폴더" Click="BtnRightUp_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>

                <Button Grid.Column="3" Content="비교" Padding="14,6" Margin="6,0,0,0"
                        Background="#1E2E50" BorderBrush="#5B8FFF" Foreground="#5B8FFF"
                        Click="BtnCompare_Click" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- 툴바 -->
        <Border Grid.Row="1" Background="#0F0F1E" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="10,6">
            <WrapPanel Orientation="Horizontal">
                <Button x:Name="BtnAll"     Content="모두"  Width="60" Click="BtnFilter_Click" Tag="All"/>
                <Button x:Name="BtnDiffs"   Content="차이"  Width="60" Click="BtnFilter_Click" Tag="Diffs"/>
                <Button x:Name="BtnSame"    Content="동일"  Width="60" Click="BtnFilter_Click" Tag="Same"/>
                <Button x:Name="BtnLeftOnly" Content="← 좌만" Width="70" Click="BtnFilter_Click" Tag="LeftOnly"/>
                <Button x:Name="BtnRightOnly" Content="우만 →" Width="70" Click="BtnFilter_Click" Tag="RightOnly"/>

                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>

                <Button Content="← 복사" Width="70" Click="BtnCopyLR_Click" ToolTip="선택 항목을 오른쪽으로 복사"/>
                <Button Content="복사 →" Width="70" Click="BtnCopyRL_Click" ToolTip="선택 항목을 왼쪽으로 복사"/>
                <Button Content="← 이동" Width="70" Click="BtnMoveLR_Click" ToolTip="선택 항목을 오른쪽으로 이동"/>
                <Button Content="이동 →" Width="70" Click="BtnMoveRL_Click" ToolTip="선택 항목을 왼쪽으로 이동"/>

                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>

                <Button Content="🗑 삭제"  Width="70" Click="BtnDelete_Click"/>
                <Button Content="📂 탐색기" Width="75" Click="BtnOpenExplorer_Click"/>
                <Button Content="📄 텍스트 비교" Width="90" Click="BtnOpenTextDiff_Click"/>

                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>

                <CheckBox x:Name="ChkRecurse" Content="하위폴더" VerticalAlignment="Center"
                          Checked="ChkRecurse_Changed" Unchecked="ChkRecurse_Changed"/>
                <CheckBox x:Name="ChkContent" Content="내용 비교" VerticalAlignment="Center"
                          Checked="ChkContent_Changed" Unchecked="ChkContent_Changed"
                          ToolTip="파일 내용(해시)으로 비교 (느림)"/>

                <Button Content="🔄 새로고침" Width="85" Click="BtnRefresh_Click" Margin="4,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- 필터/검색 -->
        <Border Grid.Row="2" Padding="12,5" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="필터:" Foreground="#8888AA" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" x:Name="TxtFilter" Text="*.*" FontFamily="Consolas" FontSize="12"
                         ToolTip="예: *.cs;*.txt" KeyDown="TxtFilter_KeyDown"/>
                <TextBlock Grid.Column="2" Text="검색:" Foreground="#8888AA" FontSize="12"
                           VerticalAlignment="Center" Margin="12,0,6,0"/>
                <TextBox Grid.Column="3" x:Name="TxtSearch" FontSize="12"
                         TextChanged="TxtSearch_TextChanged"/>
                <!-- 범례 -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="12" Height="12" Background="#182A20" BorderBrush="#3FC878" BorderThickness="1"/>
                        <TextBlock Text="동일" Foreground="#8888AA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="12" Height="12" Background="#2A2310" BorderBrush="#F0B030" BorderThickness="1"/>
                        <TextBlock Text="차이" Foreground="#8888AA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="12" Height="12" Background="#182030" BorderBrush="#5B8FFF" BorderThickness="1"/>
                        <TextBlock Text="좌만" Foreground="#8888AA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="12" Height="12" Background="#2A1818" BorderBrush="#E05555" BorderThickness="1"/>
                        <TextBlock Text="우만" Foreground="#8888AA" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 파일 목록 -->
        <ListView x:Name="FileList" Grid.Row="3" Margin="0"
                  SelectionMode="Extended"
                  Background="#0F0F1E" BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  MouseDoubleClick="FileList_DoubleClick"
                  GridViewColumnHeader.Click="OnColumnHeaderClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="260">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="왼쪽 이름" Tag="LeftName"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding LeftRowColor}" Padding="4,3" Margin="-4,0">
                                    <TextBlock Text="{Binding IndentedName}" Foreground="#E8E8F0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LeftFullPath}"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="크기" Tag="LeftSize"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding LeftRowColor}" Padding="4,3" Margin="-4,0">
                                    <TextBlock Text="{Binding LeftSizeText}" Foreground="#8888AA"
                                               HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="수정일" Tag="LeftModified"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding LeftRowColor}" Padding="4,3" Margin="-4,0">
                                    <TextBlock Text="{Binding LeftModText}" Foreground="#8888AA" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="50">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="상태"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusIcon}" FontSize="14" FontWeight="Bold"
                                           Foreground="{Binding StatusColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="260">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="오른쪽 이름" Tag="RightName"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding RightRowColor}" Padding="4,3" Margin="-4,0">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8E8F0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding RightFullPath}"
                                               Visibility="{Binding RightName, Converter={StaticResource NullToVisibility}}"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="크기" Tag="RightSize"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding RightRowColor}" Padding="4,3" Margin="-4,0">
                                    <TextBlock Text="{Binding RightSizeText}" Foreground="#8888AA"
                                               HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="수정일" Tag="RightModified"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding RightRowColor}" Padding="4,3" Margin="-4,0">
                                    <TextBlock Text="{Binding RightModText}" Foreground="#8888AA" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="← 오른쪽으로 복사" Click="BtnCopyLR_Click"/>
                    <MenuItem Header="오른쪽에서 복사 →" Click="BtnCopyRL_Click"/>
                    <MenuItem Header="← 오른쪽으로 이동" Click="BtnMoveLR_Click"/>
                    <MenuItem Header="오른쪽에서 이동 →" Click="BtnMoveRL_Click"/>
                    <Separator Style="{StaticResource SeparatorMenuItem}"/>
                    <MenuItem Header="🗑 삭제" Click="BtnDelete_Click"/>
                    <Separator Style="{StaticResource SeparatorMenuItem}"/>
                    <MenuItem Header="📄 텍스트로 비교" Click="BtnOpenTextDiff_Click"/>
                    <MenuItem Header="🔢 HEX로 비교"    Click="BtnOpenHexDiff_Click"/>
                    <MenuItem Header="🖼 이미지로 비교"  Click="BtnOpenImageDiff_Click"/>
                    <Separator Style="{StaticResource SeparatorMenuItem}"/>
                    <MenuItem Header="📂 왼쪽 탐색기에서 열기"  Click="BtnOpenLeftExplorer_Click"/>
                    <MenuItem Header="📂 오른쪽 탐색기에서 열기" Click="BtnOpenRightExplorer_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>

        <!-- 상태바 -->
        <Border Grid.Row="4" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TbStatus" Grid.Column="0" Foreground="#8888AA" FontSize="12"
                           VerticalAlignment="Center" Text="폴더를 선택하고 비교를 시작하세요."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TbSame"      Foreground="#3FC878" FontSize="11"/>
                    <TextBlock x:Name="TbDiff"      Foreground="#F0B030" FontSize="11"/>
                    <TextBlock x:Name="TbLeftOnly"  Foreground="#5B8FFF" FontSize="11"/>
                    <TextBlock x:Name="TbRightOnly" Foreground="#E05555" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>


</UserControl>
