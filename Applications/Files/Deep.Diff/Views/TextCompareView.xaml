<UserControl x:Class="DeepDiff.Views.TextCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DeepDiff.Views"
             Background="#0F0F1E"
             KeyDown="UserControl_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 경로 선택 -->
            <RowDefinition Height="Auto"/>  <!-- 툴바 -->
            <RowDefinition Height="*"/>     <!-- diff 뷰어 -->
            <RowDefinition Height="Auto"/>  <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- 경로 선택 -->
        <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1" CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtLeftPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12"
                                 VerticalAlignment="Center" Padding="4,3" KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                Click="BtnLeftBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>

                <Button Grid.Column="1" Content="⇆" Width="36" FontSize="14" Margin="6,0"
                        Click="BtnSwap_Click" ToolTip="파일 교환"/>

                <Border Grid.Column="2" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1" CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtRightPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12"
                                 VerticalAlignment="Center" Padding="4,3" KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                Click="BtnRightBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>

                <Button Grid.Column="3" Content="비교" Padding="14,6" Margin="6,0,0,0"
                        Background="#1E2E50" BorderBrush="#5B8FFF" Foreground="#5B8FFF"
                        Click="BtnCompare_Click" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- 툴바 -->
        <Border Grid.Row="1" Background="#0F0F1E" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="10,6">
            <WrapPanel Orientation="Horizontal">
                <Button Content="◀ 이전 차이" Click="BtnPrevDiff_Click" ToolTip="Shift+F3"/>
                <Button Content="다음 차이 ▶" Click="BtnNextDiff_Click" ToolTip="F3"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <Button Content="← 왼쪽→오른쪽" Click="BtnCopyLR_Click" ToolTip="선택 줄을 오른쪽으로 복사"/>
                <Button Content="오른쪽→왼쪽 →" Click="BtnCopyRL_Click" ToolTip="선택 줄을 왼쪽으로 복사"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <Button Content="💾 왼쪽 저장"  Click="BtnSaveLeft_Click"  ToolTip="왼쪽 파일 저장 (Ctrl+S)"/>
                <Button Content="💾 오른쪽 저장" Click="BtnSaveRight_Click" ToolTip="오른쪽 파일 저장"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <CheckBox x:Name="ChkIgnoreWS" Content="공백 무시" VerticalAlignment="Center"
                          Checked="ChkOption_Changed" Unchecked="ChkOption_Changed"/>
                <CheckBox x:Name="ChkIgnoreCase" Content="대소문자 무시" VerticalAlignment="Center"
                          Checked="ChkOption_Changed" Unchecked="ChkOption_Changed"/>
                <CheckBox x:Name="ChkWrap" Content="줄 바꿈" VerticalAlignment="Center"
                          Checked="ChkWrap_Changed" Unchecked="ChkWrap_Changed"/>
                <Separator Width="1" Height="20" Background="#2E2E55" Margin="4,0"/>
                <TextBlock Text="폰트:" Foreground="#8888AA" FontSize="12" VerticalAlignment="Center"/>
                <ComboBox x:Name="CbFontSize" Width="55" FontSize="12" SelectionChanged="CbFontSize_Changed">
                    <ComboBoxItem Content="10" Tag="10"/>
                    <ComboBoxItem Content="11" Tag="11" IsSelected="True"/>
                    <ComboBoxItem Content="12" Tag="12"/>
                    <ComboBoxItem Content="14" Tag="14"/>
                    <ComboBoxItem Content="16" Tag="16"/>
                </ComboBox>
            </WrapPanel>
        </Border>

        <!-- Diff 뷰어 (두 패널) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 패널 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="8,4">
                    <TextBlock x:Name="TbLeftInfo" Text="왼쪽" Foreground="#8888AA" FontSize="11" FontFamily="Consolas"/>
                </Border>
                <ScrollViewer x:Name="LeftScroll" Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Hidden"
                              ScrollChanged="LeftScroll_ScrollChanged">
                    <ItemsControl x:Name="LeftList"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="LineRow" Background="{Binding LeftBg}" MinHeight="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding LeftLineNumText}"
                                               Foreground="#55556A" FontFamily="Consolas" FontSize="{Binding FontSz}"
                                               HorizontalAlignment="Right" Padding="0,1,6,1"/>
                                    <Border Grid.Column="1" Width="3" Background="{Binding StatusBarColor}"/>
                                    <local:HighlightedTextBlock Grid.Column="2"
                                               Segments="{Binding LeftSegments}"
                                               FontFamily="Consolas" FontSize="{Binding FontSz}"
                                               Foreground="#E8E8F0" Padding="6,1"
                                               TextWrapping="{Binding WrapMode}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

            <!-- 오른쪽 패널 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="8,4">
                    <TextBlock x:Name="TbRightInfo" Text="오른쪽" Foreground="#8888AA" FontSize="11" FontFamily="Consolas"/>
                </Border>
                <ScrollViewer x:Name="RightScroll" Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="RightScroll_ScrollChanged">
                    <ItemsControl x:Name="RightList"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="{Binding RightBg}" MinHeight="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding RightLineNumText}"
                                               Foreground="#55556A" FontFamily="Consolas" FontSize="{Binding FontSz}"
                                               HorizontalAlignment="Right" Padding="0,1,6,1"/>
                                    <Border Grid.Column="1" Width="3" Background="{Binding StatusBarColor}"/>
                                    <local:HighlightedTextBlock Grid.Column="2"
                                               Segments="{Binding RightSegments}"
                                               FontFamily="Consolas" FontSize="{Binding FontSz}"
                                               Foreground="#E8E8F0" Padding="6,1"
                                               TextWrapping="{Binding WrapMode}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TbStatus" Foreground="#8888AA" FontSize="12" VerticalAlignment="Center"
                           Text="파일을 선택하고 비교를 시작하세요."/>
                <TextBlock x:Name="TbDiffNav" Grid.Column="1" Foreground="#F0B030" FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
