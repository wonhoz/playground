<Application x:Class="CharPad.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- 다크 테마 기본 색상 (아이콘 팔레트: #1DE9B6 민트 → #0288D1 파랑 그라디언트 반영) -->
        <SolidColorBrush x:Key="BgBrush"       Color="#1A1A2E"/>
        <SolidColorBrush x:Key="SurfaceBrush"  Color="#1A2535"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="#1A3A55"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#0288D1"/>
        <SolidColorBrush x:Key="AccentHover"   Color="#29B6F6"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="TabActive"     Color="#0288D1"/>
        <SolidColorBrush x:Key="TabInactive"   Color="#1A2535"/>
        <SolidColorBrush x:Key="CharHover"     Color="#1A3550"/>
        <SolidColorBrush x:Key="FavColor"      Color="#FFD700"/>

        <!-- ScrollBar Thumb 공통 ControlTemplate -->
        <ControlTemplate x:Key="DarkThumbTemplate" TargetType="Thumb">
            <Border x:Name="ThumbBorder" Background="#2A4A6A" CornerRadius="3"/>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ThumbBorder" Property="Background" Value="#0288D1"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="ThumbBorder" Property="Background" Value="#29B6F6"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ScrollBar 스타일 — Orientation 별 분기 (세로: Width=6 / 가로: Height=6) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Template="{StaticResource DarkThumbTemplate}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="6"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox 스타일 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="8,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1DE9B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button 스타일 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E2E55"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0277BD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
