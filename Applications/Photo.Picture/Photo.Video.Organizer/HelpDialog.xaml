<Window x:Class="Photo.Video.Organizer.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="도움말"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Border Background="#2D2D2D" CornerRadius="10" BorderBrush="#404040" BorderThickness="1">
        <StackPanel Margin="20">

            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="? 사용 방법 &amp; 단축키"
                           FontSize="15" FontWeight="SemiBold" Foreground="#EEEEEE"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕" Click="Close_Click"
                        Width="28" Height="28" Cursor="Hand"
                        Foreground="#9E9E9E" BorderThickness="0" Background="Transparent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Section: 기본 사용법 -->
            <TextBlock Text="기본 사용법" FontSize="12" FontWeight="SemiBold"
                       Foreground="#4FC3F7" Margin="0,0,0,8"/>

            <StackPanel Margin="0,0,0,14">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="1" Foreground="#4FC3F7" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="드래그 앤 드롭 또는 [파일 선택]으로 사진/동영상을 추가합니다."
                               FontSize="12" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="2" Foreground="#4FC3F7" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="[폴더 선택]으로 정리할 대상 폴더를 지정합니다."
                               FontSize="12" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="3" Foreground="#4FC3F7" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="폴더 구조 및 옵션을 선택한 뒤 [미리 보기]로 확인하거나, 바로 [정리 시작]을 누릅니다."
                               FontSize="12" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="#404040" Margin="0,0,0,14"/>

            <!-- Section: 폴더 구조 -->
            <TextBlock Text="폴더 구조 옵션" FontSize="12" FontWeight="SemiBold"
                       Foreground="#4FC3F7" Margin="0,0,0,8"/>

            <Border Background="#252525" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="yyyy/MM/파일명" FontFamily="Consolas" FontSize="11" Foreground="#66BB6A"/>
                        <TextBlock Grid.Column="1" Text="연/월 폴더 (기본)" FontSize="11" Foreground="#9E9E9E"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="yyyy/MM/yyyy-MM-dd/파일명" FontFamily="Consolas" FontSize="11" Foreground="#66BB6A"/>
                        <TextBlock Grid.Column="1" Text="연/월/일 폴더" FontSize="11" Foreground="#9E9E9E"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="사용자 정의" FontFamily="Consolas" FontSize="11" Foreground="#66BB6A"/>
                        <TextBlock Grid.Column="1" Text="예: yyyy/MM/dd  또는  yyyy" FontSize="11" Foreground="#9E9E9E"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Section: 단축키 -->
            <TextBlock Text="단축키" FontSize="12" FontWeight="SemiBold"
                       Foreground="#4FC3F7" Margin="0,0,0,8"/>

            <Border Background="#252525" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Background="#383838" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                            <TextBlock Text="Delete" FontFamily="Consolas" FontSize="11" Foreground="#EEEEEE"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="파일 목록에서 선택 항목 제거" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Background="#383838" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                            <TextBlock Text="Ctrl+O" FontFamily="Consolas" FontSize="11" Foreground="#EEEEEE"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="파일 선택 다이얼로그 열기" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Background="#383838" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                            <TextBlock Text="Enter" FontFamily="Consolas" FontSize="11" Foreground="#EEEEEE"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="정리 시작 (파일·폴더 선택 완료 시)" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Background="#383838" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                            <TextBlock Text="Escape" FontFamily="Consolas" FontSize="11" Foreground="#EEEEEE"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="정리 취소 (진행 중일 때)" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Section: 옵션 설명 -->
            <TextBlock Text="옵션" FontSize="12" FontWeight="SemiBold"
                       Foreground="#4FC3F7" Margin="0,0,0,8"/>

            <Border Background="#252525" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="EXIF 방향 자동 회전" FontSize="11" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,3"/>
                    <TextBlock Text="카메라가 기록한 회전 정보를 실제 화상에 반영합니다. JPEG 품질 100%로 재저장."
                               FontSize="11" Foreground="#777777" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="파일 이동 (원본 삭제)" FontSize="11" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,3"/>
                    <TextBlock Text="복사 후 원본 파일을 삭제합니다. 복사본 없이 파일을 정리할 때 사용하세요."
                               FontSize="11" Foreground="#777777" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="처리 로그 저장 (CSV)" FontSize="11" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,3"/>
                    <TextBlock Text="완료 후 대상 폴더에 organizer_log_*.csv 파일로 처리 내역을 저장합니다."
                               FontSize="11" Foreground="#777777" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Close Button -->
            <Button Content="닫기" Click="Close_Click" HorizontalAlignment="Right"
                    Cursor="Hand" Padding="24,8">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4FC3F7"/>
                        <Setter Property="Foreground" Value="#1E1E1E"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#29B6F6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</Window>
