<Window x:Class="ChordStrike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chord.Strike"
        Width="780" Height="660"
        MinWidth="680" MinHeight="580"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <Border Grid.Row="0" Background="#050508"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid Height="36">
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="🎵" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Chord.Strike" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtSongInfo" Text=""
                               Foreground="{StaticResource Fg2Brush}" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="─" Width="38" Height="36" BorderThickness="0"
                            Background="Transparent" Click="MinBtn_Click"/>
                    <Button Content="✕" Width="38" Height="36" BorderThickness="0"
                            Background="Transparent" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 영역 -->
        <Grid Grid.Row="1">

            <!-- 메뉴 오버레이 -->
            <Border x:Name="MenuPanel" Background="#E0080810" Panel.ZIndex="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🎵 Chord.Strike" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource PerfectBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="멀티키 코드 리듬 게임" FontSize="14"
                               Foreground="{StaticResource Fg2Brush}"
                               HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <!-- 곡 선택 -->
                    <Border Background="#1A1A3A" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="곡 선택" Foreground="{StaticResource Fg2Brush}"
                                       FontSize="11" Margin="0,0,0,10"/>
                            <ListBox x:Name="ChartList" Background="Transparent"
                                     BorderThickness="0" Foreground="{StaticResource FgBrush}"
                                     SelectionChanged="ChartList_SelectionChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- 키 레이아웃 -->
                    <Border Background="#0D0D20" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="키 레이아웃: A S D F  |  J K L ;" FontSize="12"
                                       Foreground="{StaticResource Fg2Brush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="판정: Perfect ±65ms  /  Good ±120ms" FontSize="11"
                                       Foreground="{StaticResource Fg2Brush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="▶  시작" FontSize="16" Width="200"
                            Background="{StaticResource AccentBrush}"
                            Click="StartBtn_Click"/>
                </StackPanel>
            </Border>

            <!-- 게임 레인 -->
            <Canvas x:Name="LaneCanvas" Background="Transparent" ClipToBounds="True">
                <!-- 레인 구분선 (코드에서 생성) -->
            </Canvas>

            <!-- 결과 오버레이 -->
            <Border x:Name="ResultPanel" Visibility="Collapsed" Background="#CC080810"
                    Panel.ZIndex="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtGrade" Text="S" FontSize="72" FontWeight="Bold"
                               Foreground="{StaticResource PerfectBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtAccuracy" Text="100%" FontSize="24"
                               Foreground="{StaticResource FgBrush}" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <TextBlock Text="Perfect: " Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock x:Name="TxtPerfect" Text="0"
                                   Foreground="{StaticResource PerfectBrush}" FontWeight="SemiBold"
                                   Margin="0,0,20,0"/>
                        <TextBlock Text="Good: " Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock x:Name="TxtGood" Text="0"
                                   Foreground="{StaticResource GoodBrush}" FontWeight="SemiBold"
                                   Margin="0,0,20,0"/>
                        <TextBlock Text="Miss: " Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock x:Name="TxtMiss" Text="0"
                                   Foreground="{StaticResource MissBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtMaxCombo" Text="Max Combo: 0" FontSize="14"
                               Foreground="{StaticResource Fg2Brush}"
                               HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="🔄 다시 시작" Margin="0,0,12,0" Click="RetryBtn_Click"/>
                        <Button Content="🎵 곡 선택" Click="MenuBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 하단 HUD -->
        <Border Grid.Row="2" Background="#050508"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="14,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 콤보 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="COMBO " Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                    <TextBlock x:Name="TxtCombo" Text="0"
                               Foreground="{StaticResource PerfectBrush}"
                               FontSize="14" FontWeight="Bold"/>
                </StackPanel>

                <!-- 진행 바 -->
                <Border Grid.Column="1" Width="200" Height="6" Background="#1A1A30"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="3">
                    <Border x:Name="ProgressBar" HorizontalAlignment="Left" Height="6"
                            CornerRadius="3" Background="{StaticResource AccentBrush}" Width="0"/>
                </Border>

                <!-- 점수 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="SCORE " Foreground="{StaticResource Fg2Brush}" FontSize="11"/>
                    <TextBlock x:Name="TxtScore" Text="0"
                               Foreground="{StaticResource FgBrush}"
                               FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
