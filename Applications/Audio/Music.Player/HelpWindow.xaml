<Window x:Class="Music.Player.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="도움말"
        Height="480" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#9C27B0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9E9E9E"/>
    </Window.Resources>

    <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#404040" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#252525" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="도움말" Foreground="#9E9E9E" FontSize="11"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Grid.Column="1" Click="CloseButton_Click" Width="40" Height="28"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="Transparent">
                                            <Path Stroke="#9E9E9E" StrokeThickness="1"
                                                  Data="M0,0 L10,10 M10,0 L0,10"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0">
                <StackPanel Margin="20,16,20,20">

                    <!-- App Info -->
                    <TextBlock Text="Music Player" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="VersionText" Text="v1.1.0" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                    <!-- Keyboard Shortcuts -->
                    <TextBlock Text="키보드 단축키" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                    <!-- Playback -->
                    <TextBlock Text="재생" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="Space" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="재생 / 일시정지" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>
                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="Left / Right" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="5초 뒤로 / 앞으로" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>
                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="Home / End" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="이전 곡 / 다음 곡" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>

                    <!-- Volume -->
                    <TextBlock Text="볼륨" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" Margin="0,12,0,6"/>

                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="Up / Down" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="볼륨 올리기 / 내리기 (5%)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>
                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="M" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="음소거 토글" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>

                    <!-- Playlist -->
                    <TextBlock Text="플레이리스트" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" Margin="0,12,0,6"/>

                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="Ctrl+Up/Down" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="선택 항목 위/아래로 이동" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>
                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="Delete" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="선택 항목 삭제" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>

                    <!-- UI -->
                    <TextBlock Text="UI" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" Margin="0,12,0,6"/>

                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="F1" Foreground="#BBBBBB" FontSize="12" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="도움말" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>
                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Text="타이틀바 더블클릭" Foreground="#BBBBBB" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="플레이리스트 패널 토글" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Grid>

                    <!-- Playback Speed -->
                    <TextBlock Text="재생 속도" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" Margin="0,12,0,6"/>

                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4">
                        하단 속도 버튼(0.5× ~ 2×)으로 재생 속도를 변경합니다.
                        속도는 트랙 전환 시에도 유지되며, 1×를 클릭하면 원래 속도로 돌아옵니다.
                    </TextBlock>

                    <!-- Separator -->
                    <Border Height="1" Background="#333333" Margin="0,16,0,12"/>

                    <!-- Usage Tips -->
                    <TextBlock Text="사용 팁" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run FontWeight="Medium" Foreground="#BBBBBB">파일 추가</Run>
                        <LineBreak/>
                        음악 파일 또는 폴더를 창에 드래그 앤 드롭하거나,
                        플레이리스트 패널의 + 버튼으로 추가할 수 있습니다.
                        <LineBreak/><LineBreak/>
                        <Run FontWeight="Medium" Foreground="#BBBBBB">플레이리스트 검색</Run>
                        <LineBreak/>
                        플레이리스트 패널 상단 검색창에 곡명 또는 아티스트를
                        입력하면 실시간으로 필터링됩니다.
                        <LineBreak/><LineBreak/>
                        <Run FontWeight="Medium" Foreground="#BBBBBB">현재 재생 표시</Run>
                        <LineBreak/>
                        플레이리스트에서 재생 중인 곡은 ▶ 아이콘과 보라색으로 강조 표시됩니다.
                        <LineBreak/><LineBreak/>
                        <Run FontWeight="Medium" Foreground="#BBBBBB">가사 표시</Run>
                        <LineBreak/>
                        음악 파일과 같은 이름의 .lrc 파일이 있으면
                        가사가 자동으로 동기화됩니다.
                        <LineBreak/><LineBreak/>
                        <Run FontWeight="Medium" Foreground="#BBBBBB">재생목록 영속성</Run>
                        <LineBreak/>
                        앱 종료 시 재생목록·재생 위치·볼륨·셔플/반복·재생속도 상태가
                        자동 저장되어 다음 실행 시 복원됩니다.
                    </TextBlock>

                    <!-- Close hint -->
                    <TextBlock Text="ESC 또는 F1로 닫기" FontSize="10"
                               Foreground="#505050" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
