<Window x:Class="FolderPurge.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder.Purge 도움말"
        Height="560" Width="580"
        MinHeight="400" MinWidth="480"
        Background="#1A1A1A" Foreground="#E0E0E0"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Brush aliases — App.xaml 공통 리소스 참조 -->
        <SolidColorBrush x:Key="AccentBrush"     Color="#C85030"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#888888"/>
        <SolidColorBrush x:Key="GreenBrush"      Color="#4CAF50"/>
        <SolidColorBrush x:Key="PanelBrush"      Color="#242424"/>
        <SolidColorBrush x:Key="BorderBrush"     Color="#333333"/>

        <!-- ScrollBar: App.xaml 글로벌 스타일 상속 -->

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin"       Value="0,14,0,5"/>
        </Style>

        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11.5"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight"   Value="20"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="#333333"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,8">

                <!-- 제목 -->
                <TextBlock Text="Folder.Purge 도움말"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
                <Rectangle Height="1" Fill="#333333" Margin="0,8,0,0"/>

                <!-- 단축키 -->
                <TextBlock Text="단축키" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="F1"     Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="도움말 표시" Style="{StaticResource HelpText}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Enter"  Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="스캔 시작 (폴더 목록에 항목이 있을 때)" Style="{StaticResource HelpText}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Delete" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="선택된 항목 삭제 확인" Style="{StaticResource HelpText}"/>
                </Grid>

                <!-- 사용 방법 -->
                <TextBlock Text="사용 방법" Style="{StaticResource SectionHeader}"/>
                <TextBlock Style="{StaticResource HelpText}">
                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">1. 폴더 추가</Run>
                    <LineBreak/>
                    <Run>   · [+ 폴더 추가] 버튼 클릭, 또는 탐색기에서 폴더를 드래그 앤 드롭</Run>
                    <LineBreak/><LineBreak/>
                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">2. 스캔 옵션 설정</Run>
                    <LineBreak/>
                    <Run>   · 빈 폴더 / VS 빌드 아티팩트 / 0바이트 파일 선택</Run>
                    <LineBreak/>
                    <Run>   · VS 아티팩트: bin, obj 폴더와 .user 파일만 남은 폴더 탐지</Run>
                    <LineBreak/>
                    <Run>   · 나이 필터: 최근 N일 이내 수정된 폴더를 탐지 대상에서 제외</Run>
                    <LineBreak/><LineBreak/>
                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">3. [스캔 시작] 또는 Enter</Run>
                    <LineBreak/>
                    <Run>   · 진행률 바로 실시간 확인 가능</Run>
                    <LineBreak/>
                    <Run>   · 완료 후 종류별 요약: 빈 폴더 N / VS 아티팩트 N / 빈 파일 N</Run>
                    <LineBreak/>
                    <Run>   · 여러 루트 폴더 스캔 시 루트별 탐지 개수 요약 표시</Run>
                    <LineBreak/><LineBreak/>
                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">4. 결과 필터링 (필터 바)</Run>
                    <LineBreak/>
                    <Run>   · 종류별 필터: 전체 / 빈 폴더 / VS 아티팩트 / 빈 파일</Run>
                    <LineBreak/>
                    <Run>   · 최소 크기: 지정 KB 이상 항목만 표시</Run>
                    <LineBreak/>
                    <Run>   · 검색: 경로 키워드로 결과 필터링</Run>
                    <LineBreak/><LineBreak/>
                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">5. 삭제할 항목 선택 (체크박스)</Run>
                    <LineBreak/>
                    <Run>   · 전체 선택 / 선택 해제 / 반전 — 현재 필터된 항목에만 적용</Run>
                    <LineBreak/>
                    <Run>   · 행 클릭 / Shift+클릭 (범위) / Ctrl+클릭 → 체크박스 연동</Run>
                    <LineBreak/><LineBreak/>
                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">6. [삭제] 클릭 또는 Delete 키</Run>
                    <LineBreak/>
                    <Run>   · 휴지통으로 이동 (기본, 복구 가능)</Run>
                    <LineBreak/>
                    <Run>   · 미리보기 모드: 실제 삭제 없이 대상 확인</Run>
                    <LineBreak/>
                    <Run>   · 휴지통 삭제 후 [휴지통 열기] 버튼으로 복원 가능</Run>
                </TextBlock>

                <!-- 팁 -->
                <TextBlock Text="팁" Style="{StaticResource SectionHeader}"/>
                <TextBlock Style="{StaticResource HelpText}">
                    <Run>· 결과 항목 더블클릭 또는 우클릭 → 탐색기에서 열기</Run>
                    <LineBreak/>
                    <Run>· 우클릭 → 경로 복사</Run>
                    <LineBreak/>
                    <Run>· 우클릭 → 결과에서 제거: 오탐 항목을 삭제 없이 목록에서만 제거</Run>
                    <LineBreak/>
                    <Run>· 우클릭 → 제외 폴더에 추가: 다음 스캔부터 해당 폴더명 제외</Run>
                    <LineBreak/>
                    <Run>· 컬럼 헤더 클릭 → 정렬 ▲/▼ (오름/내림차순, 상태 저장됨)</Run>
                    <LineBreak/>
                    <Run>· 아티팩트 폴더명 목록에서 bin, obj 외 폴더명 추가 가능</Run>
                    <LineBreak/>
                    <Run>· 통계 패널에서 전체 용량 / 선택 용량을 분리 확인 가능</Run>
                    <LineBreak/>
                    <Run>· 검색·크기 필터 입력 시 300ms 디바운스 적용 (대량 결과 시 부드러운 입력)</Run>
                </TextBlock>

                <!-- 최근 삭제 이력 -->
                <TextBlock Text="최근 삭제 이력" Style="{StaticResource SectionHeader}"/>
                <TextBlock x:Name="HistoryEmpty"
                           Text="삭제 이력이 없습니다."
                           FontSize="11" Foreground="{StaticResource TextSecondary}"
                           Visibility="Collapsed"/>
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#222228" CornerRadius="4" Padding="10,7" Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextPrimary}">
                                            <Run Text="{Binding Time, StringFormat='yyyy-MM-dd HH:mm'}"
                                                 Foreground="#888888"/>
                                            <Run Text="  "/>
                                            <Run Text="{Binding DeletedCount, StringFormat='{}{0:N0}개 삭제'}"
                                                 Foreground="#E0E0E0" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" FontSize="11"
                                               Foreground="{StaticResource GreenBrush}"
                                               Text="{Binding FreedBytesText}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Rectangle Height="1" Fill="#222222" Margin="0,16,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 하단 버튼 -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button Content="닫기 (Esc)" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" IsCancel="True"
                    Click="Close_Click"/>
        </Border>
    </Grid>
</Window>
