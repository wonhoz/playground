<Window x:Class="Stock.Catch.SignalResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="분봉 시그널 분석" Height="720" Width="1180"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🧪 분봉 시그널 분석" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,10"/>

        <!-- 필터 바 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="등급" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{StaticResource FgMuted}"/>
            <ComboBox Grid.Column="1" x:Name="GradeCombo" Width="190" SelectionChanged="Filter_Changed"/>
            <TextBlock Grid.Column="2" Text="타임프레임" VerticalAlignment="Center" Margin="16,0,8,0"
                       Foreground="{StaticResource FgMuted}"/>
            <ComboBox Grid.Column="3" x:Name="TfCombo" Width="90" SelectionChanged="Filter_Changed"/>
            <TextBlock Grid.Column="4" Text="종목" VerticalAlignment="Center" Margin="16,0,8,0"
                       Foreground="{StaticResource FgMuted}"/>
            <ComboBox Grid.Column="5" x:Name="StockCombo" Width="280" SelectionChanged="Filter_Changed"/>
            <Button Grid.Column="6" Content="↕ 중요도순" Style="{StaticResource ChipButton}" Margin="16,0,0,0"
                    Click="SortImportance_Click" ToolTip="중요도(🔥→✅→📈→…) 우선, 같은 등급 안에서는 날짜·시간순. 다시 누르면 날짜·시간순으로 복귀. 컬럼 헤더 클릭으로도 정렬 가능."/>
            <TextBlock Grid.Column="7" x:Name="StatText" VerticalAlignment="Center" HorizontalAlignment="Right"
                       Foreground="{StaticResource FgMuted}" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 시그널 그리드 -->
        <DataGrid Grid.Row="2" x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  ColumnHeaderStyle="{StaticResource DarkColHeader}" CanUserAddRows="False"
                  SelectionMode="Extended" MouseDoubleClick="Grid_MouseDoubleClick"
                  ToolTip="행 더블 클릭 → 실제 모니터링과 동일한 2줄 포맷으로 Slack 전송(알림 형식 학습용)">
            <DataGrid.Columns>
                <DataGridTextColumn Header="★" Binding="{Binding Icon}" Width="42" SortMemberPath="Rank">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="날짜" Binding="{Binding Time, StringFormat=yyyy-MM-dd}" Width="95" SortMemberPath="Time"/>
                <DataGridTextColumn Header="시간" Binding="{Binding Time, StringFormat=HH:mm}" Width="60" SortMemberPath="Time"/>
                <DataGridTextColumn Header="종목" Binding="{Binding Stock}" Width="200"/>
                <DataGridTextColumn Header="TF" Binding="{Binding TfText}" Width="52" SortMemberPath="Tf">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="시그널" Binding="{Binding Label}" Width="150" SortMemberPath="Rank"/>
                <DataGridTextColumn Header="가격" Binding="{Binding Price, StringFormat=N0}" Width="80" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="근거" Binding="{Binding Detail}" Width="2.2*"/>
                <DataGridTextColumn Header="컨텍스트" Binding="{Binding Context}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="※ 행 더블 클릭 = 실제 알림 포맷으로 Slack 전송. 컬럼 헤더 클릭으로도 정렬됩니다. 용어는 [📖 시그널 도움말] 참고."
                       VerticalAlignment="Center" Margin="0,0,16,0" FontSize="11"
                       Foreground="{StaticResource FgMuted}"/>
            <Button Content="닫기" Width="90" Style="{StaticResource AccentButton}" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
