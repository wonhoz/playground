<Application x:Class="SnapDuel.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="BgColor">#1A1A1A</Color>
            <Color x:Key="Bg2Color">#242424</Color>
            <Color x:Key="Bg3Color">#2E2E2E</Color>
            <Color x:Key="AccentColor">#5B8AF0</Color>
            <Color x:Key="TextColor">#E0E0E0</Color>
            <Color x:Key="MutedColor">#888888</Color>
            <Color x:Key="BorderColor">#333333</Color>
            <Color x:Key="P1Color">#4FC3F7</Color>
            <Color x:Key="P2Color">#FF8A65</Color>
            <Color x:Key="GoColor">#66BB6A</Color>
            <Color x:Key="TrapColor">#EF5350</Color>

            <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
            <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2Color}"/>
            <SolidColorBrush x:Key="Bg3Brush" Color="{StaticResource Bg3Color}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
            <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>
            <SolidColorBrush x:Key="BorderBrush2" Color="{StaticResource BorderColor}"/>
            <SolidColorBrush x:Key="P1Brush" Color="{StaticResource P1Color}"/>
            <SolidColorBrush x:Key="P2Brush" Color="{StaticResource P2Color}"/>
            <SolidColorBrush x:Key="GoBrush" Color="{StaticResource GoColor}"/>
            <SolidColorBrush x:Key="TrapBrush" Color="{StaticResource TrapColor}"/>

            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Bg3Brush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#454545"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
