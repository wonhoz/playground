<Window x:Class="BugHunt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bug.Hunt — 버그 찾기 퀴즈" Height="660" Width="920"
        Background="#0F0F1E" ResizeMode="CanResizeWithGrip"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 헤더 -->
    <Border Grid.Row="0" Background="#090918" Padding="16,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="🐛" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <TextBlock Text="BUG.HUNT" FontSize="18" FontWeight="Bold"
                     Foreground="#EF5350" FontFamily="Consolas" VerticalAlignment="Center"/>
          <TextBlock Text=" — 버그 줄을 찾아라!" FontSize="12" Foreground="#888"
                     VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
          <TextBlock Text="점수: " Foreground="#888" FontFamily="Consolas" VerticalAlignment="Center"/>
          <TextBlock x:Name="ScoreLabel" Text="0" Foreground="#FFD54F"
                     FontFamily="Consolas" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
          <TextBlock Text="⏱ " Foreground="#888" VerticalAlignment="Center"/>
          <TextBlock x:Name="TimerLabel" Text="30" Foreground="#EF5350"
                     FontFamily="Consolas" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
          <TextBlock Text="문제: " Foreground="#888" FontFamily="Consolas" VerticalAlignment="Center"/>
          <TextBlock x:Name="QuestionLabel" Text="1/?" Foreground="#4A6FD6"
                     FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 메인: 코드 영역 -->
    <Border Grid.Row="1" Padding="16,12">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 문제 설명 -->
        <Border Background="#1A1A2E" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="🔍 " FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="QuestionDesc" Text=""
                       Foreground="#CCCCEE" FontFamily="Consolas" FontSize="12"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <!-- 코드 스니펫 -->
        <Border Grid.Row="1" Background="#0A0A18" CornerRadius="6"
                BorderBrush="#2A2A4A" BorderThickness="1">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CodeLines" Padding="0,6,0,6">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border x:Name="LineRow" Background="Transparent"
                          Cursor="Hand" MouseLeftButtonDown="Line_Click"
                          Tag="{Binding LineNumber}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding LineNumber}" Foreground="#444"
                                 FontFamily="Consolas" FontSize="13"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Padding="0,2,12,2" Background="#050510"/>
                      <TextBlock Grid.Column="1" Text="{Binding Code}"
                                 Foreground="{Binding ForeColor}"
                                 Background="{Binding BackColor}"
                                 FontFamily="Consolas" FontSize="13"
                                 Padding="12,2" xml:space="preserve"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Grid>
    </Border>

    <!-- 언어 선택 / 난이도 -->
    <Border Grid.Row="2" Background="#090918" Padding="16,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="언어: " Foreground="#888" FontFamily="Consolas" VerticalAlignment="Center"/>
          <ComboBox x:Name="LangCombo" Width="100" Margin="4,0,16,0"
                    SelectionChanged="LangCombo_Changed">
            <ComboBoxItem Content="C#" IsSelected="True"/>
            <ComboBoxItem Content="Python"/>
            <ComboBoxItem Content="JavaScript"/>
            <ComboBoxItem Content="Java"/>
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="난이도: " Foreground="#888" FontFamily="Consolas" VerticalAlignment="Center"/>
          <ComboBox x:Name="DiffCombo" Width="110" Margin="4,0,0,0">
            <ComboBoxItem Content="주니어" IsSelected="True"/>
            <ComboBoxItem Content="시니어"/>
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Button Content="▶ 시작" Click="BtnStart_Click" Margin="0,0,8,0"/>
          <Button Content="⏭ 다음 문제" Click="BtnNext_Click"
                  Background="#1A1A0A" BorderBrush="#886600"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 결과 / 상태바 -->
    <Border Grid.Row="3" Background="#060610" Padding="12,6">
      <Grid>
        <TextBlock x:Name="StatusBar"
                   Text="언어와 난이도를 선택하고 '시작' 버튼을 누르세요. 버그 있는 줄을 클릭하세요!"
                   Foreground="#666" FontFamily="Consolas" FontSize="11"/>
        <TextBlock x:Name="ResultLabel" Text="" Foreground="#FFD54F"
                   FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                   HorizontalAlignment="Right"/>
      </Grid>
    </Border>
  </Grid>
</Window>
