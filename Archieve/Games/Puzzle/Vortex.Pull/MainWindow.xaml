<Window x:Class="VortexPull.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vortex.Pull" Width="860" Height="560"
        ResizeMode="NoResize"
        Background="#06060F" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseDown"
        Focusable="True">
    <Grid>
        <!-- 게임 Canvas -->
        <Canvas x:Name="GameCanvas" Background="#06060F" ClipToBounds="True"/>

        <!-- ── 상단 HUD ──────────────────────────────── -->
        <Grid x:Name="HudPanel" VerticalAlignment="Top" Margin="14,7" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="LEVEL " FontSize="13" FontWeight="Bold"
                           Foreground="#444466" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock x:Name="LevelNumText" Text="1" FontSize="13" FontWeight="Bold"
                           Foreground="#7AC0FF" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock x:Name="LevelNameText" Text="" FontSize="11"
                           Foreground="#333355" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#0D0D20" CornerRadius="4"
                    Padding="14,4" HorizontalAlignment="Center">
                <TextBlock x:Name="ModeText" Text="[ EDIT ]" FontSize="13" FontWeight="Bold"
                           Foreground="#7AC0FF" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="HintBarTop" Grid.Column="2" FontSize="11"
                       Foreground="#333355" FontFamily="Consolas"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── 하단 힌트 ─────────────────────────────── -->
        <TextBlock x:Name="HintBar" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="0,0,0,8" FontSize="11" FontFamily="Consolas"
                   Foreground="#222244" Visibility="Collapsed"/>

        <!-- ── 범례 (좌하단) ────────────────────────── -->
        <StackPanel x:Name="LegendPanel" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="12,0,0,10" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#334455">
                <Run Foreground="#5DADE2">●</Run><Run> 인력  </Run>
                <Run Foreground="#E74C3C">●</Run><Run> 척력  </Run>
                <Run Foreground="#A569BD">●</Run><Run> 소용돌이</Run>
            </TextBlock>
        </StackPanel>

        <!-- ── 타이틀 ─────────────────────────────────── -->
        <StackPanel x:Name="TitlePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="VORTEX.PULL" FontSize="50" FontWeight="Bold"
                       Foreground="#7AC0FF" HorizontalAlignment="Center" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#7AC0FF" BlurRadius="30" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="소용돌이 중력 유도 퍼즐" FontSize="13" Foreground="#222244"
                       HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Consolas"/>

            <TextBlock Text="[ ENTER TO START ]" FontSize="16" Foreground="#5DA8E2"
                       HorizontalAlignment="Center" Margin="0,36,0,0" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#5DA8E2" BlurRadius="12" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock FontSize="11" Foreground="#222244" HorizontalAlignment="Center"
                       Margin="0,24,0,0" FontFamily="Consolas" TextAlignment="Center">
                <Run Text="클릭 슬롯  —  발생기 종류 순환 (없음→인력→척력→소용돌이)"/>
                <LineBreak/>
                <Run Text="SPACE  —  실행/리셋    ESC  —  타이틀"/>
            </TextBlock>
        </StackPanel>

        <!-- ── 결과 오버레이 ─────────────────────────── -->
        <Border x:Name="ResultOverlay" Background="#CC000008" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ResultTitle" Text="" FontSize="40" FontWeight="Bold"
                           HorizontalAlignment="Center" FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect x:Name="ResultGlow" Color="#7AC0FF" BlurRadius="26" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="ResultSub" Text="" FontSize="14"
                           Foreground="#7AC0FF" HorizontalAlignment="Center"
                           Margin="0,12,0,0" FontFamily="Consolas" TextAlignment="Center"/>
                <TextBlock x:Name="ResultAction" Text="" FontSize="13" Foreground="#333355"
                           HorizontalAlignment="Center" Margin="0,28,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
