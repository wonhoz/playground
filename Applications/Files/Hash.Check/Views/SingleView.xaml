<UserControl x:Class="HashCheck.Views.SingleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <UserControl.Resources>
        <Style x:Key="AlgoLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="Width"      Value="58"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="HashText" TargetType="TextBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsReadOnly"      Value="True"/>
            <Setter Property="FontFamily"      Value="Consolas, 'Courier New'"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#D4D4D4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 드롭존 ────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#16161F" BorderBrush="#2A2A3E" BorderThickness="2"
                CornerRadius="8" Margin="0,0,0,20" Cursor="Hand"
                MouseLeftButtonDown="DropZone_Click">
            <Grid>
                <StackPanel x:Name="DropHint" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Margin="0,20">
                    <TextBlock Text="🔒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="파일을 여기로 드래그하거나 클릭하여 선택" FontSize="13"
                               Foreground="#666677" HorizontalAlignment="Center"/>
                    <TextBlock Text="MD5 · SHA-1 · SHA-256 · SHA-512 동시 계산"
                               FontSize="11" Foreground="#444455"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Grid x:Name="FileInfo" Visibility="Collapsed" Margin="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📄" FontSize="28"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtFileName" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#E8E8F0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtFileMeta" FontSize="11"
                                   Foreground="#888899" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="✕" Width="28" Height="28"
                            VerticalAlignment="Top" Click="ClearFile_Click" ToolTip="초기화"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── 해시 결과 카드 ─────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <!-- MD5 -->
            <Border x:Name="CardMD5" Background="#16161F" BorderBrush="#2A2A3E"
                    BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="MD5" Style="{StaticResource AlgoLabel}"/>
                    <TextBox x:Name="TxtMD5" Grid.Column="1" Style="{StaticResource HashText}"
                             Text="—"/>
                    <Button Grid.Column="2" Content="복사" Width="50" Height="26"
                            Click="CopyMD5_Click" Tag="MD5"/>
                </Grid>
            </Border>
            <!-- SHA-1 -->
            <Border x:Name="CardSHA1" Background="#16161F" BorderBrush="#2A2A3E"
                    BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SHA-1" Style="{StaticResource AlgoLabel}"/>
                    <TextBox x:Name="TxtSHA1" Grid.Column="1" Style="{StaticResource HashText}"
                             Text="—"/>
                    <Button Grid.Column="2" Content="복사" Width="50" Height="26"
                            Click="CopySHA1_Click"/>
                </Grid>
            </Border>
            <!-- SHA-256 -->
            <Border x:Name="CardSHA256" Background="#16161F" BorderBrush="#2A2A3E"
                    BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SHA-256" Style="{StaticResource AlgoLabel}"/>
                    <TextBox x:Name="TxtSHA256" Grid.Column="1" Style="{StaticResource HashText}"
                             Text="—"/>
                    <Button Grid.Column="2" Content="복사" Width="50" Height="26"
                            Click="CopySHA256_Click"/>
                </Grid>
            </Border>
            <!-- SHA-512 -->
            <Border x:Name="CardSHA512" Background="#16161F" BorderBrush="#2A2A3E"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SHA-512" Style="{StaticResource AlgoLabel}"/>
                    <TextBox x:Name="TxtSHA512" Grid.Column="1" Style="{StaticResource HashText}"
                             Text="—"/>
                    <Button Grid.Column="2" Content="복사" Width="50" Height="26"
                            Click="CopySHA512_Click"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ── 예상 해시 비교 ─────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#16161F" BorderBrush="#2A2A3E"
                BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="예상 해시 붙여넣기 (자동 비교)" FontSize="12"
                           Foreground="#888899" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtExpected" Height="34" FontFamily="Consolas"
                             Margin="0,0,8,0" TextChanged="TxtExpected_TextChanged"
                             ToolTip="길이로 MD5/SHA-1/SHA-256/SHA-512 자동 감지"/>
                    <Button Grid.Column="1" Content="붙여넣기" Width="80" Height="34"
                            Click="BtnPaste_Click"/>
                </Grid>
                <Border x:Name="CompareResult" Margin="0,10,0,0" Padding="12,8"
                        CornerRadius="5" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtCompareIcon" FontSize="18" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCompareMsg" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 진행 표시 -->
        <ProgressBar Grid.Row="3" x:Name="PbHash" Height="4" Visibility="Collapsed"/>
    </Grid>
</UserControl>
