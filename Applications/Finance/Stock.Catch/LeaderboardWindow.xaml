<Window x:Class="Stock.Catch.LeaderboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="급등락 전광판" Height="860" Width="1280"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="Sect" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="BoardLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <!-- 순위 한 줄: 순위 · 종목(코드) · 현재가 · 등락률 · 거래량/부가 -->
        <DataTemplate x:Key="MoverRowTpl">
            <Border Background="{Binding RowBg}" CornerRadius="4" Padding="6,2" Margin="0,1"
                    MouseLeftButtonDown="Row_DoubleClick" Tag="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="78"/>
                        <ColumnDefinition Width="62"/>
                        <ColumnDefinition Width="92"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding RankText}" Style="{StaticResource BoardLbl}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding NewBadge}" Foreground="#FFD54F" FontSize="11" FontWeight="Bold" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Display}" Foreground="{StaticResource FgBrush}" FontSize="12"
                                   TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                        <TextBlock Text="{Binding SymbolSuffix}" Style="{StaticResource BoardLbl}" Margin="5,1,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding PriceText}" Foreground="{StaticResource FgBrush}"
                               FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="{Binding ChgText}" Foreground="{Binding ChgBrush}"
                               FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="{Binding VolText}" Style="{StaticResource BoardLbl}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
        <!-- 카테고리 패널(제목 + 리스트) -->
        <Style x:Key="BoardPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 바 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="🏆 급등락 전광판" FontSize="17" FontWeight="Bold" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Style="{StaticResource BoardLbl}" Margin="14,4,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="갱신 주기" Style="{StaticResource BoardLbl}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="IntervalCombo" Width="86" SelectionChanged="Interval_Changed">
                    <ComboBoxItem Content="15초" Tag="15"/>
                    <ComboBoxItem Content="30초" Tag="30"/>
                    <ComboBoxItem Content="60초" Tag="60"/>
                    <ComboBoxItem Content="120초" Tag="120"/>
                </ComboBox>
                <Button x:Name="RefreshBtn" Content="↻ 새로고침" Style="{StaticResource ChipButton}" Margin="10,0,0,0" Click="Refresh_Click"/>
            </StackPanel>
        </Grid>

        <!-- 국내 | 미국 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 국내 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="2,0,2,6">
                    <TextBlock Text="🇰🇷 한국 (KIS 실시간)" FontSize="14" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
                    <TextBlock x:Name="KrStatusText" Style="{StaticResource BoardLbl}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource BoardPanel}" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="🚀 급등 TOP" Style="{StaticResource Sect}" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="KrGainList" ItemTemplate="{StaticResource MoverRowTpl}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource BoardPanel}" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📉 급락 TOP" Style="{StaticResource Sect}" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="KrLoseList" ItemTemplate="{StaticResource MoverRowTpl}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                <Border Grid.Row="3" Style="{StaticResource BoardPanel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="🔊 거래량 급증 TOP (전일比 거래증가율)" Style="{StaticResource Sect}" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="KrVolList" ItemTemplate="{StaticResource MoverRowTpl}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 미국 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="2,0,2,6">
                    <TextBlock x:Name="UsHeaderText" Text="🇺🇸 미국" FontSize="14" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
                    <TextBlock x:Name="UsStatusText" Style="{StaticResource BoardLbl}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource BoardPanel}" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="🚀 급등 TOP" Style="{StaticResource Sect}" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="UsGainList" ItemTemplate="{StaticResource MoverRowTpl}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource BoardPanel}" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📉 급락 TOP" Style="{StaticResource Sect}" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="UsLoseList" ItemTemplate="{StaticResource MoverRowTpl}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                <Border Grid.Row="3" Style="{StaticResource BoardPanel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="🔊 최다 거래 TOP (당일 누적)" Style="{StaticResource Sect}" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="UsVolList" ItemTemplate="{StaticResource MoverRowTpl}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
