<Window x:Class="Prompt.Forge.Views.VersionHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="버전 히스토리" Width="700" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#0E1A28" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0C8E0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1" BorderBrush="#152230"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#152230"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0A2540"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="#152230"/>
            <Setter Property="Foreground" Value="#8AAAC8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2E45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A1A1A"/>
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A2020"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#060F1A" Padding="16,10">
            <StackPanel>
                <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="SemiBold" Foreground="#1976D2"/>
                <TextBlock Text="저장된 이전 버전을 선택하여 내용을 확인하고 복원할 수 있습니다."
                           Foreground="#6A8FAD" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- 본문 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 버전 목록 -->
            <Grid Grid.Column="0" Background="#060F1A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0C1520" Padding="10,6">
                    <TextBlock Text="이전 버전 목록" Foreground="#6A8FAD" FontSize="11"/>
                </Border>
                <ListBox Grid.Row="1" x:Name="LstVersions"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="LstVersions_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding VersionLabel}" FontWeight="SemiBold"
                                           Foreground="#64B5F6"/>
                                <TextBlock Text="{Binding DateLabel}" FontSize="11"
                                           Foreground="#4A6880" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 내용 미리보기 -->
            <Grid Grid.Column="1" Background="#0C1520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0C1520" Padding="12,6">
                    <TextBlock Text="내용 미리보기" Foreground="#6A8FAD" FontSize="11"/>
                </Border>
                <TextBox Grid.Row="1" x:Name="TxtPreview"
                         Margin="12,4,12,12"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="#0E1A28"
                         Foreground="#B0C8E0"
                         BorderBrush="#162840"
                         BorderThickness="1"
                         Padding="8"
                         FontFamily="Consolas" FontSize="12"/>
            </Grid>
        </Grid>

        <!-- 버튼 바 -->
        <Border Grid.Row="2" Background="#060F1A" Padding="16,8">
            <Grid>
                <TextBlock x:Name="TxtEmptyMsg"
                           Text="저장된 히스토리가 없습니다."
                           Foreground="#4A6880" FontSize="12"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="이 버전 삭제" x:Name="BtnDeleteVersion"
                            Style="{StaticResource DangerBtn}"
                            IsEnabled="False"
                            Click="DeleteVersion_Click" Margin="0,0,8,0"/>
                    <Button Content="이 버전으로 복원" x:Name="BtnRestore"
                            Style="{StaticResource AccentBtn}"
                            IsEnabled="False"
                            Click="Restore_Click" Margin="0,0,8,0"/>
                    <Button Content="닫기" Style="{StaticResource GhostBtn}" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
