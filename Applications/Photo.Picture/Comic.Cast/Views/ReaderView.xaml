<UserControl x:Class="ComicCast.Views.ReaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:ComicCast.Views"
             Background="#000000"
             KeyDown="OnKeyDown" Focusable="True">

    <UserControl.Resources>
        <v:BoolToVisConverter x:Key="BoolToVis"/>
        <v:BoolToVisConverter x:Key="BoolToVisInv" Invert="True"/>
        <v:DoubleFormatConverter x:Key="ZoomFmt" Format="{}{0:P0}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Border Grid.Row="0" Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,5">
                <!-- 내비게이션 -->
                <Button Content="◀" Command="{Binding PrevCommand}" Width="36" Margin="0,0,4,0"/>
                <TextBlock VerticalAlignment="Center" Margin="6,0">
                    <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                </TextBlock>
                <Button Content="▶" Command="{Binding NextCommand}" Width="36" Margin="4,0,12,0"/>

                <!-- 줌 -->
                <Button Content="−" Command="{Binding ZoomOutCommand}" Width="30" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Zoom, Converter={StaticResource ZoomFmt}}"
                           VerticalAlignment="Center" MinWidth="40" TextAlignment="Center"/>
                <Button Content="+" Command="{Binding ZoomInCommand}" Width="30" Margin="4,0,4,0"/>
                <Button Content="1:1" Command="{Binding ZoomFitCommand}" Padding="8,4" Margin="4,0,12,0"/>

                <!-- 보기 모드 -->
                <Button Content="단면" Command="{Binding SingleModeCommand}" Padding="8,4" Margin="0,0,4,0"/>
                <Button Content="망가(쌍)" Command="{Binding DoubleMangaCommand}" Padding="8,4" Margin="0,0,4,0"/>
                <Button Content="웹툰(쌍)" Command="{Binding DoubleWebCommand}" Padding="8,4"/>

                <!-- 책 제목 -->
                <TextBlock Text="{Binding BookTitle}" Foreground="{StaticResource FgSub}"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
            </StackPanel>
        </Border>

        <!-- 페이지 영역 -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="Black">
            <Grid>
                <!-- 로딩 스피너 -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="로딩 중..." Foreground="{StaticResource FgSub}" FontSize="14"/>
                </Border>

                <!-- 단면 보기 -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsDouble, Converter={StaticResource BoolToVisInv}}">
                    <Image Source="{Binding LeftPage}"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MaxHeight="900">
                        <Image.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                        </Image.LayoutTransform>
                    </Image>
                </Border>

                <!-- 쌍면 보기 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsDouble, Converter={StaticResource BoolToVis}}">
                    <Image Source="{Binding LeftPage}"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MaxHeight="900" Margin="0,0,2,0">
                        <Image.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                        </Image.LayoutTransform>
                    </Image>
                    <Image Source="{Binding RightPage}"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MaxHeight="900" Margin="2,0,0,0">
                        <Image.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                        </Image.LayoutTransform>
                    </Image>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Background="{StaticResource Bg0}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FgSub}"
                       FontSize="12" Margin="12,4"/>
        </Border>
    </Grid>
</UserControl>
