<Window x:Class="PerspShift.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Persp.Shift" Height="680" Width="1000"
        Background="#1A1A1A" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="◇ Persp.Shift" FontSize="22" FontWeight="Bold"
                           Foreground="#00BCD4"/>
                <TextBlock x:Name="TxtLevelTitle" FontSize="14" Foreground="#E0E0E0"
                           VerticalAlignment="Bottom" Margin="12,0,0,2"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnPrev" Content="◀" Padding="12,6" Click="OnPrev"/>
                <TextBlock x:Name="TxtLevel" Text="1 / 30" FontSize="14" Foreground="#888"
                           VerticalAlignment="Center" Margin="10,0"/>
                <Button x:Name="BtnNext" Content="▶" Padding="12,6" Click="OnNext" Margin="0,0,8,0"/>
                <Button Content="↺" Padding="10,6" Click="OnReset" ToolTip="초기화"/>
            </StackPanel>
        </Grid>

        <!-- 세 뷰 -->
        <Grid Grid.Row="1" x:Name="ViewGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- GridCanvas 인스턴스는 code-behind에서 삽입 -->
        </Grid>

        <!-- 하단 상태 -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock x:Name="TxtStatus" FontSize="12" Foreground="#888"
                       HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Rectangle Width="14" Height="14" Fill="#4CAF50" RadiusX="2" RadiusY="2"/>
                <TextBlock Text=" 일치" FontSize="11" Foreground="#888" Margin="0,0,14,0"/>
                <Rectangle Width="14" Height="14" Fill="#F44336" RadiusX="2" RadiusY="2"/>
                <TextBlock Text=" 초과" FontSize="11" Foreground="#888" Margin="0,0,14,0"/>
                <Rectangle Width="14" Height="14" RadiusX="2" RadiusY="2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="#00BCD4" Opacity="0.2"/>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBlock Text=" 미충족" FontSize="11" Foreground="#888"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
