<Window x:Class="ServeCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Serve.Cast"
        Height="680" Width="960"
        MinHeight="500" MinWidth="780"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        FontFamily="'Segoe UI', 'Noto Sans KR', sans-serif"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290" MinWidth="240" MaxWidth="380"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 좌측: 설정 패널 ───────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="#252535"
                BorderBrush="#313244" BorderThickness="0 0 1 0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16 16 16 20">

                    <!-- 앱 제목 -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <TextBlock Text="⚡" FontSize="18" Foreground="#89B4FA" VerticalAlignment="Center"/>
                        <TextBlock Text=" Serve.Cast" FontSize="17" FontWeight="SemiBold"
                                   Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- ─── 서버 루트 폴더 ──────────────────────────── -->
                    <TextBlock Text="ROOT FOLDER" FontSize="10" FontWeight="SemiBold"
                               Foreground="#7F849C" Margin="0 0 0 6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtFolder" Grid.Column="0"
                                 Text="" IsReadOnly="True"
                                 ToolTip="서버에서 서빙할 폴더 경로"/>
                        <Button Grid.Column="2" Content="…"
                                ToolTip="폴더 선택"
                                Click="BtnBrowse_Click"/>
                    </Grid>

                    <Separator Margin="0 14"/>

                    <!-- ─── 포트 & HTTPS ──────────────────────────────── -->
                    <TextBlock Text="SERVER" FontSize="10" FontWeight="SemiBold"
                               Foreground="#7F849C" Margin="0 0 0 6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="포트  " Foreground="#7F849C"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtPort" Text="8080"/>
                        </Grid>
                        <CheckBox Grid.Column="2" x:Name="ChkHttps"
                                  Content="HTTPS" VerticalAlignment="Center"
                                  Checked="ChkHttps_Changed" Unchecked="ChkHttps_Changed"/>
                    </Grid>

                    <Separator Margin="0 14"/>

                    <!-- ─── CORS ──────────────────────────────────────── -->
                    <CheckBox x:Name="ChkCors" Content="CORS 허용"
                              Checked="ChkCors_Changed" Unchecked="ChkCors_Changed"/>
                    <StackPanel x:Name="PanelCors" Visibility="Collapsed" Margin="0 8 0 0">
                        <TextBlock Text="허용 Origins (쉼표 구분, * = 전체)"
                                   Foreground="#7F849C" FontSize="11" Margin="0 0 0 4"/>
                        <TextBox x:Name="TxtCorsOrigins" Text="*"/>
                    </StackPanel>

                    <Separator Margin="0 14"/>

                    <!-- ─── Basic Auth ────────────────────────────────── -->
                    <CheckBox x:Name="ChkAuth" Content="Basic 인증 (비밀번호 보호)"
                              Checked="ChkAuth_Changed" Unchecked="ChkAuth_Changed"/>
                    <StackPanel x:Name="PanelAuth" Visibility="Collapsed" Margin="0 8 0 0">
                        <TextBlock Text="사용자명" Foreground="#7F849C" FontSize="11" Margin="0 0 0 4"/>
                        <TextBox x:Name="TxtAuthUser" Text="admin" Margin="0 0 0 8"/>
                        <TextBlock Text="비밀번호" Foreground="#7F849C" FontSize="11" Margin="0 0 0 4"/>
                        <PasswordBox x:Name="PbAuthPass"/>
                    </StackPanel>

                    <Separator Margin="0 14"/>

                    <!-- ─── 기타 옵션 ──────────────────────────────────── -->
                    <TextBlock Text="OPTIONS" FontSize="10" FontWeight="SemiBold"
                               Foreground="#7F849C" Margin="0 0 0 8"/>
                    <CheckBox x:Name="ChkSpa" Content="SPA 모드  (404 → index.html)"
                              Margin="0 0 0 8"/>
                    <CheckBox x:Name="ChkDir" Content="디렉터리 목록 보기"
                              IsChecked="True" Margin="0 0 0 0"/>

                    <Separator Margin="0 14"/>

                    <!-- ─── 시작/정지 버튼 ────────────────────────────── -->
                    <Button x:Name="BtnToggle"
                            Content="▶  서버 시작"
                            Style="{StaticResource AccentButton}"
                            Click="BtnToggle_Click"
                            Height="42"/>

                    <!-- ─── 서버 상태 (실행 중일 때만 표시) ──────────── -->
                    <StackPanel x:Name="PanelStatus" Visibility="Collapsed" Margin="0 16 0 0">

                        <TextBlock Text="LOCAL" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#7F849C" Margin="0 0 0 5"/>
                        <TextBlock x:Name="TxtLocalUrl"
                                   Foreground="#89B4FA" FontSize="12.5"
                                   TextDecorations="Underline" Cursor="Hand"
                                   MouseLeftButtonUp="TxtUrl_Click"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="LAN" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#7F849C" Margin="0 10 0 5"/>
                        <TextBlock x:Name="TxtLanUrl"
                                   Foreground="#89B4FA" FontSize="12.5"
                                   TextDecorations="Underline" Cursor="Hand"
                                   MouseLeftButtonUp="TxtLanUrl_Click"
                                   TextWrapping="Wrap"/>

                        <!-- QR 코드 -->
                        <TextBlock Text="QR CODE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#7F849C" Margin="0 12 0 8"/>
                        <Image x:Name="ImgQr"
                               Width="160" Height="160"
                               HorizontalAlignment="Left"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── GridSplitter ─────────────────────────────────────────── -->
        <GridSplitter Grid.Column="1"
                      Width="4" HorizontalAlignment="Stretch"
                      Background="#252535"/>

        <!-- ── 우측: 요청 로그 ──────────────────────────────────────── -->
        <Grid Grid.Column="2" Background="#1E1E2E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Border Grid.Row="0"
                    Background="#252535"
                    BorderBrush="#313244" BorderThickness="0 0 0 1"
                    Padding="14 9">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="요청 로그" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#CDD6F4" VerticalAlignment="Center"/>
                        <Border Background="#1E2A40" CornerRadius="8"
                                Margin="10 0 0 0" Padding="7 2">
                            <TextBlock x:Name="TxtLogCount"
                                       Text="0" FontSize="11"
                                       Foreground="#89B4FA"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <CheckBox x:Name="ChkAutoScroll" Content="자동 스크롤"
                                  IsChecked="True" VerticalAlignment="Center"
                                  Margin="0 0 12 0"/>
                        <Button Content="지우기" Padding="10 4"
                                Click="BtnClear_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1" x:Name="LogGrid"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns>
                    <!-- 시간 -->
                    <DataGridTextColumn Header="시간"
                                        Binding="{Binding TimeStr}"
                                        Width="72"
                                        ElementStyle="{StaticResource {x:Type TextBlock}}"/>

                    <!-- 메서드 -->
                    <DataGridTemplateColumn Header="메서드" Width="68">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="4 1"
                                        HorizontalAlignment="Left"
                                        Margin="2 3"
                                        Background="#1E2A40">
                                    <TextBlock Text="{Binding Method}"
                                               Foreground="#89B4FA"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 경로 -->
                    <DataGridTextColumn Header="경로"
                                        Binding="{Binding Path}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                <Setter Property="FontSize"   Value="12"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 상태 -->
                    <DataGridTemplateColumn Header="상태" Width="56">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusCode}"
                                           Foreground="{Binding StatusColor}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 응답 시간 -->
                    <DataGridTextColumn Header="시간"
                                        Binding="{Binding ElapsedStr}"
                                        Width="62">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"       Value="#7F849C"/>
                                <Setter Property="FontFamily"       Value="Cascadia Code, Consolas"/>
                                <Setter Property="FontSize"         Value="12"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 크기 -->
                    <DataGridTextColumn Header="크기"
                                        Binding="{Binding BytesStr}"
                                        Width="68">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"       Value="#7F849C"/>
                                <Setter Property="FontFamily"       Value="Cascadia Code, Consolas"/>
                                <Setter Property="FontSize"         Value="12"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 상태 바 -->
            <Border Grid.Row="2"
                    Background="#252535"
                    BorderBrush="#313244" BorderThickness="0 1 0 0"
                    Padding="14 5">
                <TextBlock x:Name="TxtStatus"
                           Text="준비" FontSize="11"
                           Foreground="#7F849C"/>
            </Border>
        </Grid>
    </Grid>
</Window>
