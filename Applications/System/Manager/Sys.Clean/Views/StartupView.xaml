<UserControl x:Class="SysClean.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 설명 배너 -->
        <Border Grid.Row="0" Background="#1E2430" Padding="16,10" Margin="16,16,16,0"
                CornerRadius="6" BorderBrush="#2A3A5A" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="시작 프로그램 관리" FontSize="14" FontWeight="SemiBold" Foreground="#4FC3F7"/>
                <TextBlock Text="Windows 시작 시 자동 실행되는 프로그램을 활성화/비활성화하거나 삭제할 수 있습니다. 불필요한 시작 프로그램을 줄이면 부팅 속도가 향상됩니다."
                           FontSize="12" Foreground="#888" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 검색 -->
        <Border Grid.Row="1" Padding="16,10,16,0">
            <TextBox x:Name="TxtSearch" Text="" Padding="8,6"
                     TextChanged="TxtSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍  프로그램 이름으로 검색..."
                                                           Foreground="#555" FontSize="13" Margin="10,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Border>

        <!-- 추가 폼 (기본 숨김) -->
        <Border x:Name="AddPanel" Grid.Row="2" Visibility="Collapsed"
                Background="#1E2430" BorderBrush="#2A3A5A" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="16,6,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- 이름 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="이름" Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="TxtAddName" Grid.Column="1" Padding="8,5"/>
                </Grid>
                <!-- 명령 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="명령" Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="TxtAddCommand" Grid.Column="1" Padding="8,5"
                             ToolTip="실행 파일 전체 경로 또는 명령어"/>
                    <Button Grid.Column="3" Content="찾아보기" Click="BtnBrowse_Click"
                            Padding="10,5" FontSize="12"/>
                </Grid>
                <!-- 위치 + 저장/취소 -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="위치" Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
                    <ComboBox x:Name="CbAddLocation" Grid.Column="1" SelectedIndex="1">
                        <ComboBoxItem Content="HKLM (모든 사용자, 관리자 필요)"/>
                        <ComboBoxItem Content="HKCU (현재 사용자)"/>
                    </ComboBox>
                    <Button Grid.Column="3" Content="✅  저장" Click="BtnAddSave_Click"
                            Padding="12,5" FontSize="12"
                            Background="#1B3A1F" Foreground="#66BB6A" BorderBrush="#388E3C"/>
                    <Button Grid.Column="5" Content="취소" Click="BtnAddCancel_Click"
                            Padding="12,5" FontSize="12"/>
                </Grid>
            </Grid>
        </Border>

        <!-- 목록 -->
        <ListView x:Name="StartupList" Grid.Row="3" Margin="16,8,16,0"
                  Background="#1E1E1E" BorderThickness="1" BorderBrush="#333"
                  MouseDoubleClick="StartupList_MouseDoubleClick"
                  GridViewColumnHeader.Click="OnColumnHeaderClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="220">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="프로그램 이름" Tag="Name"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold" Margin="4,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="90">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="상태" Tag="IsEnabled"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBorder" CornerRadius="3" Padding="6,2" Margin="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1B3A1F"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Background" Value="#3A2A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#66BB6A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Foreground" Value="#FFA726"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="150">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="위치" Tag="LocationText"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LocationText}" Foreground="#888"
                                           FontSize="11" Margin="4,0" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="영향도" Tag="ImpactLevel"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ImpactLevel}"
                                           Foreground="{Binding ImpactColor}"
                                           FontSize="11" FontWeight="SemiBold" Margin="4,0"
                                           ToolTip="실행 파일 크기 기반 부팅 지연 추정"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="340">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="명령" Tag="Command"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Command}" Foreground="#666"
                                           FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Command}" Margin="4,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 하단 -->
        <Border Grid.Row="4" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,1,0,0"
                Padding="16,10" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="TbStatus" Text="더블클릭으로 활성화/비활성화를 전환합니다."
                           Foreground="#888" FontSize="12" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="🔄  새로고침" Click="BtnRefresh_Click"
                        Padding="10,6" Margin="0,0,6,0" FontSize="12"/>

                <Button Grid.Column="2" x:Name="BtnAdd" Content="➕  추가" Click="BtnAdd_Click"
                        Padding="10,6" Margin="0,0,6,0" FontSize="12"
                        Background="#252535" Foreground="#4FC3F7" BorderBrush="#2A3A5A"/>

                <Button Grid.Column="3" x:Name="BtnEnable" Content="✅  활성화"
                        Click="BtnEnable_Click" Padding="10,6" Margin="0,0,6,0"
                        FontSize="12" Background="#1B3A1F" Foreground="#66BB6A" BorderBrush="#388E3C"/>

                <Button Grid.Column="4" x:Name="BtnDisable" Content="⏸  비활성화"
                        Click="BtnDisable_Click" Padding="10,6" Margin="0,0,6,0"
                        FontSize="12" Background="#3A2A1A" Foreground="#FFA726" BorderBrush="#F57C00"/>

                <Button Grid.Column="5" x:Name="BtnDelete" Content="🗑  삭제"
                        Click="BtnDelete_Click" Padding="10,6"
                        FontSize="12" Background="#3A1A1A" Foreground="#EF5350" BorderBrush="#C62828"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
