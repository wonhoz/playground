<Window x:Class="Stock.Catch.FavoriteEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="즐겨찾기 이름 수정" Height="215" Width="380"
        Background="{StaticResource WindowBg}" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✏ 즐겨찾기 이름 수정" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="종목코드" Foreground="{StaticResource FgMuted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock x:Name="CodeText" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="표시 이름" Foreground="{StaticResource FgMuted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBox x:Name="NameBox" Width="255"
                     ToolTip="즐겨찾기 콤보에 표시할 이름. 긴 정식 명칭 대신 짧은 별칭 권장(예: SK하이닉스 레버리지)."/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="저장" Width="80" Style="{StaticResource AccentButton}" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
