<Window x:Class="Sched.Cast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Sched.Cast.ViewModels"
        Title="Sched.Cast — 작업 스케줄러"
        Width="900" Height="560"
        MinWidth="700" MinHeight="420"
        Background="#13131F" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="12"
        WindowStartupLocation="CenterScreen"
>

    <Window.Resources
>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="TbBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderBrush"     Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252535"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Background"  Value="#1E3A5E"/>
            <Setter Property="Foreground"  Value="#60A5FA"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
        </Style>

        <!-- DataGrid 다크 스타일 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="#E0E0E0"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="GridLinesVisibility"    Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E1E2E"/>
            <Setter Property="RowBackground"          Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#0D0D1A"/>
            <Setter Property="SelectionMode"          Value="Single"/>
            <Setter Property="SelectionUnit"          Value="FullRow"/>
            <Setter Property="CanUserAddRows"         Value="False"/>
            <Setter Property="CanUserDeleteRows"      Value="False"/>
            <Setter Property="CanUserResizeRows"      Value="False"/>
            <Setter Property="AutoGenerateColumns"    Value="False"/>
            <Setter Property="HeadersVisibility"      Value="Column"/>
            <Setter Property="ColumnHeaderHeight"     Value="34"/>
            <Setter Property="RowHeight"              Value="34"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A2A4A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C1C2C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="#16162A"/>
            <Setter Property="Foreground"       Value="#888899"/>
            <Setter Property="Padding"          Value="8,0"/>
            <Setter Property="BorderBrush"      Value="#1E1E2E"/>
            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 스크롤바 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="Width"      Value="8"/>
            <Setter Property="MinWidth"   Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/></Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/></Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Bd" Background="#3A3A55" CornerRadius="4" Margin="2,2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#5A5A7A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- 툴바 -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="36"/>   <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ── 툴바 ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#16162A" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource AccentBtn}" Content="+ 새 작업" Click="NewTask_Click"/>
                <Button Style="{StaticResource TbBtn}" Content="▶ 실행" Margin="6,0,0,0"
                        IsEnabled="{Binding HasSelection}" Click="Run_Click"/>
                <Button Style="{StaticResource TbBtn}" Content="■ 중지" Margin="4,0,0,0"
                        IsEnabled="{Binding HasSelection}" Click="Stop_Click"/>
                <Button Style="{StaticResource TbBtn}" Content="⏯ 활성화 토글" Margin="4,0,0,0"
                        IsEnabled="{Binding HasSelection}" Click="Toggle_Click"/>
                <Button Style="{StaticResource DangerBtn}" Content="🗑 삭제" Margin="4,0,0,0"
                        IsEnabled="{Binding HasSelection}" Click="Delete_Click"/>
                <Separator Background="#2A2A3E" Width="1" Height="20" Margin="10,0"/>
                <Button Style="{StaticResource TbBtn}" Content="↻ 새로고침" Click="Refresh_Click"/>
            </StackPanel>
        </Border>

        <!-- ── 작업 목록 ─────────────────────────────────────────────── -->
        <DataGrid Grid.Row="1" x:Name="Grid"
                  ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding Selected, Mode=TwoWay}"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="작업 이름"  Binding="{Binding Name}"         Width="180"/>
                <DataGridTemplateColumn Header="상태" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                            <TextBlock Text="{Binding StateText}"
                                       Foreground="{Binding StateColor}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="마지막 실행" Binding="{Binding LastRunText}"   Width="160"/>
                <DataGridTextColumn Header="다음 실행"   Binding="{Binding NextRunText}"   Width="160"/>
                <DataGridTemplateColumn Header="결과" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                            <TextBlock Text="{Binding LastResultText}"
                                       Foreground="{Binding LastResultColor}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="실행 파일" Binding="{Binding ExeShort}"       Width="*"/>
                <DataGridTextColumn Header="설명"     Binding="{Binding Description}"    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── 상태바 ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#16162A" BorderBrush="#1E1E2E" BorderThickness="0,1,0,0" Padding="14,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#555566"
                       VerticalAlignment="Center" FontSize="11"/>
        </Border>
    </Grid>
</Window>
