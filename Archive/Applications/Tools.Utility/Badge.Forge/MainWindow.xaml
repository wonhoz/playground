<Window x:Class="BadgeForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Badge.Forge — SVG 배지 생성기" Height="640" Width="940"
        Background="#0F0F1E" ResizeMode="CanResizeWithGrip"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 헤더 -->
    <Border Grid.Row="0" Background="#090918" Padding="16,10">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="🏷️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <TextBlock Text="BADGE.FORGE" FontSize="18" FontWeight="Bold"
                   Foreground="#4A6FD6" FontFamily="Consolas" VerticalAlignment="Center"/>
        <TextBlock Text=" — 오프라인 SVG 배지 생성기" FontSize="12" Foreground="#888"
                   VerticalAlignment="Center" Margin="6,0,0,0"/>
      </StackPanel>
    </Border>

    <!-- 메인 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 좌측 설정 패널 -->
      <Border Background="#0A0A1A" BorderBrush="#1A1A3A" BorderThickness="0,0,1,0" Padding="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <!-- 텍스트 -->
            <TextBlock Text="📝 텍스트" FontWeight="Bold" Foreground="#4A6FD6" Margin="0,0,0,4"/>
            <Label Content="레이블 (좌측)"/>
            <TextBox x:Name="LabelBox" Text="build" TextChanged="Preview_Changed"/>
            <Label Content="값 (우측)"/>
            <TextBox x:Name="ValueBox" Text="passing" TextChanged="Preview_Changed"/>

            <!-- 스타일 -->
            <TextBlock Text="🎨 스타일" FontWeight="Bold" Foreground="#4A6FD6" Margin="0,12,0,4"/>
            <Label Content="배지 스타일"/>
            <ComboBox x:Name="StyleCombo" SelectionChanged="Preview_Changed">
              <ComboBoxItem Content="flat" IsSelected="True"/>
              <ComboBoxItem Content="flat-square"/>
              <ComboBoxItem Content="for-the-badge"/>
              <ComboBoxItem Content="plastic"/>
              <ComboBoxItem Content="social"/>
            </ComboBox>

            <!-- 색상 -->
            <TextBlock Text="🎨 색상" FontWeight="Bold" Foreground="#4A6FD6" Margin="0,12,0,4"/>
            <Label Content="레이블 색상 (hex)"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox x:Name="LabelColorBox" Text="555" TextChanged="Preview_Changed"/>
              <Border x:Name="LabelColorSwatch" Grid.Column="1" Width="28" Height="28"
                      CornerRadius="4" Margin="4,0,0,0" Background="#555555"/>
            </Grid>
            <Label Content="값 색상 (hex)"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox x:Name="ValueColorBox" Text="4c1" TextChanged="Preview_Changed"/>
              <Border x:Name="ValueColorSwatch" Grid.Column="1" Width="28" Height="28"
                      CornerRadius="4" Margin="4,0,0,0" Background="#44cc11"/>
            </Grid>

            <!-- 프리셋 팔레트 -->
            <TextBlock Text="빠른 색상 프리셋" Foreground="#888" FontSize="11" Margin="0,6,0,4"/>
            <WrapPanel x:Name="PalettePanel" Margin="0,0,0,4"/>

            <!-- 내보내기 -->
            <TextBlock Text="📤 내보내기" FontWeight="Bold" Foreground="#4A6FD6" Margin="0,14,0,4"/>
            <Button Content="📋 SVG 복사" Click="BtnCopySvg_Click" Margin="0,0,0,4"/>
            <Button Content="🖼️ PNG 저장" Click="BtnSavePng_Click" Margin="0,0,0,4"/>
            <Button Content="📄 Markdown 코드 복사" Click="BtnCopyMd_Click" Margin="0,0,0,4"/>
            <Button Content="⭐ 즐겨찾기 저장" Click="BtnFavorite_Click" Margin="0,0,0,4"
                    Background="#1A1A0A" BorderBrush="#886600"/>

            <!-- shields.io URL 가져오기 -->
            <TextBlock Text="🔗 URL 가져오기" FontWeight="Bold" Foreground="#4A6FD6" Margin="0,12,0,4"/>
            <TextBox x:Name="ImportUrlBox" Text="shields.io URL 붙여넣기"/>
            <Button Content="가져오기" Click="BtnImport_Click" Margin="0,4,0,0"/>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- 우측 미리보기 + 즐겨찾기 -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- 미리보기 -->
        <Border Background="#0D0D1A" Padding="20">
          <StackPanel>
            <TextBlock Text="미리보기" Foreground="#888" FontFamily="Consolas"
                       FontSize="11" Margin="0,0,0,10"/>

            <!-- 배지 미리보기 (Image) -->
            <Border Background="#FFFFFF" CornerRadius="4" Padding="20,16" HorizontalAlignment="Left">
              <Image x:Name="PreviewImage" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>

            <!-- 어두운 배경 미리보기 -->
            <TextBlock Text="어두운 배경" Foreground="#888" FontFamily="Consolas"
                       FontSize="11" Margin="0,12,0,6"/>
            <Border Background="#1A1A2E" CornerRadius="4" Padding="20,16" HorizontalAlignment="Left">
              <Image x:Name="PreviewImageDark" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>

            <!-- SVG 코드 -->
            <TextBlock Text="SVG 코드" Foreground="#888" FontFamily="Consolas"
                       FontSize="11" Margin="0,14,0,4"/>
            <TextBox x:Name="SvgCodeBox" Background="#050510" Foreground="#6A9955"
                     FontFamily="Consolas" FontSize="11" IsReadOnly="True"
                     TextWrapping="Wrap" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                     BorderBrush="#1A1A3A"/>
          </StackPanel>
        </Border>

        <!-- 즐겨찾기 -->
        <Border Grid.Row="1" Background="#080815" BorderBrush="#1A1A3A"
                BorderThickness="0,1,0,0" Padding="16,10">
          <StackPanel>
            <TextBlock Text="⭐ 즐겨찾기" FontWeight="Bold" Foreground="#4A6FD6"
                       Margin="0,0,0,8"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="150">
              <WrapPanel x:Name="FavoritePanel" Orientation="Horizontal"/>
            </ScrollViewer>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- 상태바 -->
    <Border Grid.Row="2" Background="#060610" Padding="12,5">
      <TextBlock x:Name="StatusBar" Text="레이블과 값을 입력해 배지를 생성하세요."
                 Foreground="#666" FontFamily="Consolas" FontSize="11"/>
    </Border>
  </Grid>
</Window>
