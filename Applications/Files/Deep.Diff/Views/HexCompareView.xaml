<UserControl x:Class="DeepDiff.Views.HexCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F0F1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 경로 선택 -->
        <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1" CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtLeftPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Padding="4,3"
                                 KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                Click="BtnLeftBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>
                <Button Grid.Column="1" Content="⇆" Width="36" FontSize="14" Margin="6,0" Click="BtnSwap_Click"/>
                <Border Grid.Column="2" Background="#141428" BorderBrush="#2E2E55" BorderThickness="1" CornerRadius="4" Padding="4,2">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtRightPath" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                 Foreground="#E8E8F0" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Padding="4,3"
                                 KeyDown="TxtPath_KeyDown"/>
                        <Button Grid.Column="1" Content="📂" Width="28" Height="26" Padding="0"
                                Click="BtnRightBrowse_Click" Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </Border>
                <Button Grid.Column="3" Content="비교" Padding="14,6" Margin="6,0,0,0"
                        Background="#1E2E50" BorderBrush="#5B8FFF" Foreground="#5B8FFF"
                        Click="BtnCompare_Click" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- 컬럼 헤더 -->
        <Border Grid.Row="1" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="11" Foreground="#55556A"
                           Text="  주소           00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F   ASCII           "/>
                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="11" Foreground="#55556A"
                           Text="  주소           00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F   ASCII           "/>
            </Grid>
        </Border>

        <!-- HEX 뷰어 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer x:Name="LeftScroll" Grid.Column="0"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden"
                          ScrollChanged="LeftScroll_ScrollChanged">
                <ItemsControl x:Name="LeftHex"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock x:Name="HexLine" Text="{Binding LeftDisplay}"
                                       FontFamily="Consolas" FontSize="11" Padding="6,1"
                                       Background="{Binding RowBg}"
                                       Foreground="{Binding LeftFg}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

            <ScrollViewer x:Name="RightScroll" Grid.Column="2"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          ScrollChanged="RightScroll_ScrollChanged">
                <ItemsControl x:Name="RightHex"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RightDisplay}"
                                       FontFamily="Consolas" FontSize="11" Padding="6,1"
                                       Background="{Binding RowBg}"
                                       Foreground="{Binding RightFg}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TbStatus" Foreground="#8888AA" FontSize="12"
                           Text="파일을 선택하고 비교를 시작하세요."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TbLeftSize"  Foreground="#5B8FFF" FontSize="11"/>
                    <TextBlock x:Name="TbRightSize" Foreground="#3FC878" FontSize="11"/>
                    <TextBlock x:Name="TbDiffRows"  Foreground="#F0B030" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
