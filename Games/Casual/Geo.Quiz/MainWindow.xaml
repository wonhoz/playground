<Window x:Class="Geo.Quiz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geo.Quiz — 세계 지리 퀴즈"
        Width="600" Height="700"
        MinWidth="480" MinHeight="560"
        Background="#0A0A18" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- 기본 버튼 -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#C0C0D0"/>
            <Setter Property="BorderBrush"     Value="#3A3A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A40"/>
                                <Setter Property="Foreground" Value="#E0E0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 강조 버튼 -->
        <Style x:Key="AccBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="#0E3A6E"/>
            <Setter Property="Foreground"  Value="#60A5FA"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
        </Style>

        <!-- 선택지 버튼 -->
        <Style x:Key="ChoiceBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#0C0C20"/>
            <Setter Property="Foreground"      Value="#C0C0D0"/>
            <Setter Property="BorderBrush"     Value="#3A3A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="0,0,24,0"/>
                                    <TextBlock Text="▾" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Foreground="#606080" Margin="0,0,4,0"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom">
                                <Border Background="#12122A" BorderBrush="#3A3A5A" BorderThickness="1" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5A5A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Foreground"  Value="#C0C0D0"/>
                        <Setter Property="Padding"     Value="12,8"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#E0E0FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RadioButton (모드 선택) -->
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#14142A" BorderBrush="#2A2A4A"
                                BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0E2A50"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ══ 시작 화면 ══════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="StartPanel" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsStartScreen, Converter={StaticResource BoolVis}}">
            <StackPanel Margin="50,40" MaxWidth="480">
                <!-- 타이틀 -->
                <TextBlock Text="🌍" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Geo.Quiz" FontSize="32" FontWeight="Bold"
                           Foreground="#60A5FA" HorizontalAlignment="Center"/>
                <TextBlock Text="세계 지리 퀴즈" FontSize="15" Foreground="#6A6A9A"
                           HorizontalAlignment="Center" Margin="0,4,0,40"/>

                <!-- 퀴즈 모드 -->
                <TextBlock Text="퀴즈 모드" Foreground="#8A8AAA" FontSize="11" Margin="0,0,0,8"/>
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <RadioButton x:Name="RbCapital"   Content="🏛️ 수도 맞추기"  Style="{StaticResource ModeRadio}"
                                 IsChecked="True" GroupName="Mode" Margin="0,0,6,0" Checked="Mode_Checked"/>
                    <RadioButton x:Name="RbFlag"      Content="🚩 국기 맞추기"  Style="{StaticResource ModeRadio}"
                                 GroupName="Mode" Margin="3,0,3,0" Checked="Mode_Checked"/>
                    <RadioButton x:Name="RbContinent" Content="🗺️ 대륙 맞추기" Style="{StaticResource ModeRadio}"
                                 GroupName="Mode" Margin="6,0,0,0" Checked="Mode_Checked"/>
                </UniformGrid>

                <!-- 대륙 필터 -->
                <TextBlock Text="대륙 범위" Foreground="#8A8AAA" FontSize="11" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding Continents}"
                          SelectedItem="{Binding Continent, Mode=TwoWay}"
                          Margin="0,0,0,24"/>

                <!-- 문제 수 -->
                <TextBlock Text="문제 수" Foreground="#8A8AAA" FontSize="11" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding CountOptions}"
                          SelectedItem="{Binding QuestionCount, Mode=TwoWay}"
                          Margin="0,0,0,40"/>

                <!-- 시작 버튼 -->
                <Button Content="▶  퀴즈 시작" Style="{StaticResource AccBtn}"
                        Command="{Binding StartCmd}"
                        FontSize="15" Padding="0,14" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ 퀴즈 화면 ══════════════════════════════════════════════════════ -->
        <Grid x:Name="QuizPanel"
              Visibility="{Binding IsQuizScreen, Converter={StaticResource BoolVis}}"
              Margin="40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 진행 표시 + 메뉴 버튼 -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← 메뉴" Style="{StaticResource Btn}"
                        Command="{Binding RestartCmd}"
                        FontSize="11" Padding="10,4" Margin="0,0,12,0"
                        VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Value="{Binding ProgressPct, Mode=OneWay}" Minimum="0" Maximum="100"
                             Height="6" Background="#1A1A30" Foreground="#3B82F6"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding ProgressText}"
                           Foreground="#6A6A9A" FontSize="11" Margin="12,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 질문 영역 -->
            <Border Grid.Row="1" Background="#0C0C22" BorderBrush="#1A1A40"
                    BorderThickness="1" CornerRadius="12" Padding="30,28">
                <StackPanel>
                    <!-- 국기 이모지 (Flag 모드 전용) — Segoe UI Emoji 폰트로 크게 표시 -->
                    <TextBlock x:Name="TbFlagEmoji"
                               Text="{Binding CurrentQuestion.FlagDisplay}"
                               FontFamily="Segoe UI Emoji" FontSize="80"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- 질문 텍스트 -->
                    <TextBlock Text="{Binding CurrentQuestion.QuestionText}"
                               FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap"
                               Foreground="#E0E0F0" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,0,0,32"/>

                    <!-- 선택지 4개 -->
                    <Button x:Name="BtnChoice0" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[0]}"
                            Command="{Binding Choice0Cmd}" Margin="0,0,0,8"
                            Tag="0" Click="Choice_Click"/>
                    <Button x:Name="BtnChoice1" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[1]}"
                            Command="{Binding Choice1Cmd}" Margin="0,0,0,8"
                            Tag="1" Click="Choice_Click"/>
                    <Button x:Name="BtnChoice2" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[2]}"
                            Command="{Binding Choice2Cmd}" Margin="0,0,0,8"
                            Tag="2" Click="Choice_Click"/>
                    <Button x:Name="BtnChoice3" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[3]}"
                            Command="{Binding Choice3Cmd}"
                            Tag="3" Click="Choice_Click"/>
                </StackPanel>
            </Border>

            <!-- 다음 버튼 -->
            <Button Grid.Row="2" Content="다음 ▶" Style="{StaticResource AccBtn}"
                    Command="{Binding NextCmd}"
                    FontSize="14" Padding="0,12" HorizontalAlignment="Stretch"
                    Margin="0,16,0,0"/>
        </Grid>

        <!-- ══ 결과 화면 ══════════════════════════════════════════════════════ -->
        <StackPanel x:Name="ResultPanel" VerticalAlignment="Center"
                    Visibility="{Binding IsResultScreen, Converter={StaticResource BoolVis}}"
                    Margin="60,0">
            <TextBlock x:Name="TbGradeEmoji" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock x:Name="TbGrade" FontSize="48" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock x:Name="TbScore" FontSize="18" Foreground="#9CA3AF"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>

            <!-- 정답/오답 통계 -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#0F2D1F" BorderBrush="#155724"
                        BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TbCorrect" FontSize="28" FontWeight="Bold"
                                   Foreground="#4ADE80" HorizontalAlignment="Center"/>
                        <TextBlock Text="정답" Foreground="#4ADE80" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#2D0F0F" BorderBrush="#7F1D1D"
                        BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="8,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TbWrong" FontSize="28" FontWeight="Bold"
                                   Foreground="#F87171" HorizontalAlignment="Center"/>
                        <TextBlock Text="오답" Foreground="#F87171" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Button Content="🔄  다시 하기" Style="{StaticResource AccBtn}"
                    Command="{Binding RestartCmd}"
                    FontSize="14" Padding="0,14" HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</Window>
