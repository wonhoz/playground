<Window x:Class="Prompt.Forge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Prompt.Forge"
        xmlns:ctrl="clr-namespace:Prompt.Forge.Controls"
        Title="Prompt.Forge" Width="1000" Height="680"
        MinWidth="800" MinHeight="500"
        Background="#0C1520" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen"
>

    <Window.Resources>

        <!-- 액센트 버튼 -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 위험 버튼 -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3A1A1A"/>
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A2020"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 즐겨찾기 버튼 -->
        <Style x:Key="FavBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6A8FAD"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#162840"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 목록 아이템 -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0C8E0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1" BorderBrush="#0F1E2E"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0F1E2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0A2040"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 상단 툴바 ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#060F1A" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Prompt.Forge"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#1976D2" VerticalAlignment="Center"/>
                <Grid Grid.Column="1" Margin="16,0">
                    <TextBox x:Name="TxtSearch"
                             Height="30"
                             Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="프롬프트 검색..."
                                                                   Foreground="#3A5570"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button x:Name="BtnClearSearch" Width="22" Height="22"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,3,0" Visibility="Collapsed"
                            Click="ClearSearch_Click" ToolTip="검색 및 필터 초기화">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="✕" FontSize="10" Foreground="#6A8FAD"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                        <Setter Property="Foreground" Value="#B0C8E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="↑ 내보내기" Click="Export_Click" Margin="0,0,6,0"/>
                    <Button Content="↓ 가져오기" Click="Import_Click" Margin="0,0,6,0"/>
                    <Button Content="☁ 업로드" Click="GistUpload_Click"
                            ToolTip="GitHub Gist에 업로드 (설정에서 PAT 필요)"
                            Margin="0,0,4,0"/>
                    <Button Content="☁ 다운로드" Click="GistDownload_Click"
                            ToolTip="GitHub Gist에서 다운로드"
                            Margin="0,0,6,0"/>
                    <Button Content="⚙" ToolTip="동기화 설정" Click="SyncSettings_Click"
                            Margin="0,0,8,0" Padding="8,6"/>
                    <Button x:Name="BtnHelp" Content="?" ToolTip="단축키 도움말" Click="Help_Click" Margin="0,0,8,0" Padding="8,6"/>
                    <Button Content="+ 새 프롬프트" Style="{StaticResource AccentBtn}"
                            Click="NewPrompt_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 본문 ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="480"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 필터 + 목록 -->
            <Grid Grid.Column="0" Background="#060F1A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 필터 -->
                <StackPanel Grid.Row="0" Margin="10,10,10,6">
                    <ComboBox x:Name="CbTag" Margin="0,0,0,6"
                              SelectionChanged="Filter_Changed"/>
                    <ComboBox x:Name="CbService" Margin="0,0,0,6"
                              SelectionChanged="Filter_Changed"/>
                    <CheckBox x:Name="ChkFav" Content="즐겨찾기만"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"
                              Margin="0,0,0,6"/>
                    <ComboBox x:Name="CbSort" SelectedIndex="0"
                              SelectionChanged="Sort_Changed">
                        <ComboBoxItem Content="최근 수정순"/>
                        <ComboBoxItem Content="자주 사용순"/>
                        <ComboBoxItem Content="사용자 정의"/>
                    </ComboBox>
                </StackPanel>

                <!-- 목록 -->
                <ListBox Grid.Row="1" x:Name="LstItems"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionMode="Extended"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         SelectionChanged="LstItems_SelectionChanged"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="LstItems_PreviewMouseLeftButtonDown"
                         MouseMove="LstItems_MouseMove"
                         DragOver="LstItems_DragOver"
                         Drop="LstItems_Drop">
                    <ListBox.ContextMenu>
                        <ContextMenu Background="#0F1E2E" BorderBrush="#1E3555">
                            <MenuItem x:Name="MenuCopyContent" Header="내용 복사"
                                      Click="CopyFromMenu_Click"
                                      Foreground="#B0C8E0"/>
                            <Separator Background="#1E3555" Margin="4,2"/>
                            <MenuItem x:Name="MenuBulkTagEdit" Header="선택 항목 일괄 태그 편집"
                                      Click="BulkTagEdit_Click"
                                      Foreground="#B0C8E0"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.ToolTip>
                                    <ToolTip MaxWidth="320" Background="#060F1A"
                                             BorderBrush="#1E3555" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       Foreground="#E0E0E0" FontSize="12"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                       Foreground="#8AAAC8" FontFamily="Consolas"
                                                       FontSize="11" MaxHeight="80"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Grid.ToolTip>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ctrl:TextHighlighter.RawText="{Binding Title}"
                                               ctrl:TextHighlighter.Query="{Binding DataContext.Search,
                                                   RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Tags}" FontSize="11"
                                                   Foreground="#64B5F6"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"
                                                   Cursor="Hand"
                                                   ToolTip="클릭하여 태그 필터 적용"
                                                   MouseLeftButtonDown="TagLabel_Click"/>
                                        <TextBlock FontSize="10" Foreground="#3A5570"
                                                   VerticalAlignment="Center" Margin="6,2,0,0"
                                                   Text="{Binding UseCount, StringFormat={}{0}회}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UseCount}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                           VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock Text="📌" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="★" FontSize="14"
                                               Foreground="#FBBF24" Margin="2,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 스플리터 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#0E1A28"/>

            <!-- 오른쪽: 상세 편집 -->
            <Grid Grid.Column="2" Background="#0C1520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>  <!-- 본문 찾기 바 -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 제목 행 -->
                <Grid Grid.Row="0" Margin="16,14,16,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtTitle" FontSize="15" FontWeight="SemiBold"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="BtnPin" Content="📌"
                            Style="{StaticResource FavBtn}" Margin="4,0,0,0"
                            Click="Pin_Click" IsEnabled="{Binding HasSelection}"
                            ToolTip="상단 고정 (Ctrl+P)"/>
                    <Button Grid.Column="2" x:Name="BtnFav" Content="☆"
                            Style="{StaticResource FavBtn}" Margin="4,0,0,0"
                            Click="Fav_Click" IsEnabled="{Binding HasSelection}"/>
                </Grid>

                <!-- 메타 행 (태그 · 서비스) -->
                <Grid Grid.Row="1" Margin="16,0,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtTags" Height="30">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="태그 (쉼표 구분)"
                                                                   Foreground="#3A5570"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBox Grid.Column="2" x:Name="TxtService" Height="30">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="대상 서비스"
                                                                   Foreground="#3A5570"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>

                <!-- 본문 찾기 바 (Ctrl+G) -->
                <Border Grid.Row="2" x:Name="FindBar" Visibility="Collapsed"
                        Background="#0A1825" Margin="16,0,16,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtFind" Height="28"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtFind_TextChanged"
                                 KeyDown="TxtFind_KeyDown"/>
                        <TextBlock Grid.Column="1" x:Name="TxtFindCount"
                                   Foreground="#4A6880" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0"/>
                        <Button Grid.Column="2" Content="▲" Padding="6,4"
                                Click="FindPrev_Click" ToolTip="이전 (Shift+Enter)"/>
                        <Button Grid.Column="3" Content="▼" Padding="6,4" Margin="4,0"
                                Click="FindNext_Click" ToolTip="다음 (Enter)"/>
                        <Button Grid.Column="4" Content="✕" Padding="6,4"
                                Click="FindClose_Click" ToolTip="닫기 (Esc)"/>
                    </Grid>
                </Border>

                <!-- 콘텐츠 에디터 -->
                <TextBox Grid.Row="3" x:Name="TxtContent"
                         Margin="16,0,16,8"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="13">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                <VisualBrush.Visual>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="12"
                                                               Foreground="#3A5570" Margin="10,10">
                                                        <Run Text="프롬프트 내용을 입력하세요."/>
                                                        <LineBreak/>
                                                        <Run Text="{}{{변수명}} 형식으로 변수를 삽입하면"/>
                                                        <LineBreak/>
                                                        <Run Text="▶ 변수 채우기 버튼으로 값을 대입한 뒤 클립보드에 복사됩니다."/>
                                                    </TextBlock>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 메모 -->
                <TextBox Grid.Row="4" x:Name="TxtNotes"
                         Margin="16,0,16,8"
                         MaxHeight="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="12">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="메모 (선택)"
                                                               Foreground="#3A5570"
                                                               Margin="10,8"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 액션 버튼 바 -->
                <Border Grid.Row="5" Background="#060F1A" Padding="16,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾  저장 (Ctrl+S)" Click="Save_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="⧉  복제 (Ctrl+D)" Click="Duplicate_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="🕐  버전 저장" Click="SaveVersion_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="📜  히스토리 (Ctrl+H)" Click="ShowHistory_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="▶  변수 채우기 (Ctrl+Enter)" Style="{StaticResource AccentBtn}"
                                    IsEnabled="{Binding HasSelection}" Click="FillVars_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="복사" Click="Copy_Click"
                                    IsEnabled="{Binding HasSelection}" Margin="0,0,8,0"/>
                            <Button Content="삭제" Style="{StaticResource DangerBtn}"
                                    IsEnabled="{Binding HasSelection}" Click="Delete_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ── 상태 바 ────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#040D18" Padding="12,4">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="#6A8FAD" FontSize="11"/>
                <Button x:Name="BtnStats" Content="📊" ToolTip="사용 통계"
                        HorizontalAlignment="Right" Padding="6,0"
                        Click="Stats_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Cursor="Hand"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── 태그 자동완성 팝업 ──────────────────────────────────── -->
        <Popup x:Name="TagPopup" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=TxtTags}"
               Placement="Bottom" VerticalOffset="2">
            <Border Background="#0F1E2E" BorderBrush="#1E3555" BorderThickness="1" CornerRadius="4"
                    MinWidth="{Binding ElementName=TxtTags, Path=ActualWidth}">
                <ListBox x:Name="LstTagSuggestions" MaxHeight="160"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="TagSuggestion_Selected">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#B0C8E0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#152540"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>

        <!-- ── 서비스 자동완성 팝업 ──────────────────────────────────── -->
        <Popup x:Name="ServicePopup" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=TxtService}"
               Placement="Bottom" VerticalOffset="2">
            <Border Background="#0F1E2E" BorderBrush="#1E3555" BorderThickness="1" CornerRadius="4"
                    MinWidth="{Binding ElementName=TxtService, Path=ActualWidth}">
                <ListBox x:Name="LstServiceSuggestions" MaxHeight="160"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="ServiceSuggestion_Selected">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#B0C8E0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#152540"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>

        <!-- ── 최근 검색어 팝업 ────────────────────────────────────── -->
        <Popup x:Name="RecentSearchPopup" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=TxtSearch}"
               Placement="Bottom" VerticalOffset="2">
            <Border Background="#0F1E2E" BorderBrush="#1E3555" BorderThickness="1" CornerRadius="4"
                    MinWidth="{Binding ElementName=TxtSearch, Path=ActualWidth}">
                <StackPanel>
                    <TextBlock Text="최근 검색어" Foreground="#3A5570" FontSize="10"
                               Margin="10,6,10,4"/>
                    <ListBox x:Name="LstRecentSearches" MaxHeight="140"
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="RecentSearch_Selected">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="#B0C8E0"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#152540"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ── 단축키 도움말 팝업 ──────────────────────────────────── -->
        <Popup x:Name="HelpPopup" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=BtnHelp}"
               Placement="Bottom" VerticalOffset="4">
            <Border Background="#0E1A28" BorderBrush="#1E3555" BorderThickness="1" CornerRadius="8"
                    Padding="20,16">
                <StackPanel>
                    <TextBlock Text="단축키" FontWeight="SemiBold" FontSize="12"
                               Foreground="#1976D2" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+N" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="새 프롬프트" Foreground="#B0C8E0" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+S" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="저장" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+D" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="복제" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+C" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="복사 (에디터 포커스 없을 때)" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+Enter" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="변수 채우기" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ctrl+H" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="버전 히스토리" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Ctrl+F" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="검색창 포커스" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Ctrl+G" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="본문 내 텍스트 찾기" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Ctrl+P" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="상단 고정 토글" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="↑ / ↓" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="목록 위·아래 이동" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Esc" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="검색·필터 초기화 (검색창 포커스 시)" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="11" Grid.Column="0" Text="Win+Shift+P" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="창 표시/숨기기" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="12" Grid.Column="0" Text="드래그 앤 드롭" Foreground="#64B5F6" FontFamily="Consolas" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="항목 순서 변경 (필터 없을 때)" Foreground="#B0C8E0" FontSize="12" Margin="0,5,0,0"/>
                    </Grid>
                    <Separator Background="#162840" Margin="0,14,0,12"/>
                    <TextBlock Text="사용 팁" FontWeight="SemiBold" FontSize="12"
                               Foreground="#1976D2" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6A8FAD" FontSize="11"
                               MaxWidth="300" LineHeight="20">
                        <Run Text="• {{변수명}} 형식 (한글 포함) → 변수 채우기 후 자동 복사"/>
                        <LineBreak/>
                        <Run Text="• 변수 채우기 재실행 시 이전 입력값 자동 복원"/>
                        <LineBreak/>
                        <Run Text="• 태그/서비스 입력 시 자동완성 드롭다운 표시"/>
                        <LineBreak/>
                        <Run Text="• 태그 클릭 → 해당 태그로 필터링"/>
                        <LineBreak/>
                        <Run Text="• ★ 클릭 → 즐겨찾기 토글 / 📌 클릭 → 상단 고정"/>
                        <LineBreak/>
                        <Run Text="• '버전 저장' → 히스토리에 현재 버전 보관"/>
                        <LineBreak/>
                        <Run Text="• 내보내기: JSON/CSV 형식 선택, 필터 결과만 선택 가능"/>
                        <LineBreak/>
                        <Run Text="• Ctrl+클릭으로 복수 선택 → 우클릭 일괄 태그 편집"/>
                        <LineBreak/>
                        <Run Text="• 우클릭 → 내용 복사 (단일 항목)"/>
                        <LineBreak/>
                        <Run Text="• 검색어 입력 시 제목 하이라이팅 / 검색창 클릭 → 최근 검색어"/>
                        <LineBreak/>
                        <Run Text="• 목록 항목 호버 → 내용 미리보기 / 사용 횟수 표시"/>
                        <LineBreak/>
                        <Run Text="• Ctrl+G → 프롬���트 본문 내 텍스트 찾기 (Enter/Shift+Enter)"/>
                        <LineBreak/>
                        <Run Text="• 📊 상태바 통계 버튼 → 사용 통계 요약"/>
                        <LineBreak/>
                        <Run Text="• 정렬 방식·최근 검색어·창 크기 재시작 후 자동 복원"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
