<Window x:Class="Stock.Catch.MinuteCsvWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="분봉 CSV 다운로드" Height="265" Width="440"
        Background="{StaticResource WindowBg}" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🕐 1분봉 CSV 다운로드 (기간)" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBlock Text="기간" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{StaticResource FgMuted}"/>
            <TextBox x:Name="FromBox" Width="105" FontSize="13" FontWeight="SemiBold"/>
            <TextBlock Text="~" VerticalAlignment="Center" Margin="6,0" Foreground="{StaticResource FgMuted}"/>
            <TextBox x:Name="ToBox" Width="105" FontSize="13" FontWeight="SemiBold"/>
            <Button Content="오늘" Style="{StaticResource ChipButton}" Margin="10,0,0,0" Click="Today_Click"/>
            <Button Content="1주" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="7" Click="Preset_Click"/>
            <Button Content="1개월" Style="{StaticResource ChipButton}" Margin="6,0,0,0" Tag="30" Click="Preset_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource FgMuted}"
                   VerticalAlignment="Top" Margin="0,10,0,0"
                   Text="※ 기간 내 영업일마다 1분봉(09:00~15:30)을 각각 CSV로 저장합니다(주말·휴장일 자동 건너뜀 · 저장 폴더는 다음 단계에서 선택). 하루만 받으려면 시작·종료를 같은 날짜로 두세요. KIS 보관 기간(약 1개월+) 초과 일자는 데이터가 없을 수 있습니다."/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource BearBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="취소" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="CSV 저장" Width="100" Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
