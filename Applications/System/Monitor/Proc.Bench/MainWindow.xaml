<Window x:Class="ProcBench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proc.Bench" Height="700" Width="980"
        Background="#0F0F1E" Foreground="#E0E0E0"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- 툴바 -->
        <Border Grid.Row="0" Background="#14142A" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <TextBlock Text="⚡ Proc.Bench" FontSize="16" FontWeight="Bold"
                           Foreground="#50C8DC" Margin="0,0,20,0"/>
                <TextBlock Text="CPU · 메모리 · 스토리지 종합 벤치마크" FontSize="11"
                           Foreground="#666688" VerticalAlignment="Center"/>
                <Button x:Name="BtnRunAll" Click="BtnRunAll_Click"
                        Margin="20,0,0,0" Padding="14,5" FontSize="12"
                        Background="#1A3A2A" BorderBrush="#2A6A4A">▶ 전체 실행</Button>
                <Button x:Name="BtnStop" Click="BtnStop_Click"
                        Margin="6,0,0,0" Padding="10,5" FontSize="12"
                        Background="#3A1A1A" BorderBrush="#6A2A2A" IsEnabled="False">■ 중지</Button>
                <Button x:Name="BtnExport" Click="BtnExport_Click"
                        Margin="6,0,0,0" Padding="10,5" FontSize="11">💾 내보내기</Button>
            </StackPanel>
        </Border>

        <!-- 메인 콘텐츠 -->
        <Grid Grid.Row="1" Margin="10,10,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU 벤치 카드 -->
            <Border Grid.Column="0" Background="#13132A" BorderBrush="#333355"
                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🖥" FontSize="20" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="CPU" FontSize="14" FontWeight="Bold" Foreground="#50C8DC"/>
                            <TextBlock x:Name="LblCpuName" Text="..." FontSize="10" Foreground="#666688"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 정수 연산 -->
                    <StackPanel Margin="0,6,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="정수 연산" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblCpuInt" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbCpuInt" Value="0" Maximum="100"
                                     Foreground="#50C8DC"/>
                    </StackPanel>

                    <!-- 부동소수점 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="부동소수점" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblCpuFloat" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbCpuFloat" Value="0" Maximum="100"
                                     Foreground="#7AADFF"/>
                    </StackPanel>

                    <!-- 멀티스레드 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="멀티스레드" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblCpuMulti" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbCpuMulti" Value="0" Maximum="100"
                                     Foreground="#A080FF"/>
                    </StackPanel>

                    <!-- 암호화 -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="암호화(AES)" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblCpuCrypto" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbCpuCrypto" Value="0" Maximum="100"
                                     Foreground="#80DDAA"/>
                    </StackPanel>

                    <Separator Background="#222244" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="종합 점수" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LblCpuScore" Text="—" FontSize="18" FontWeight="Bold" Foreground="#50C8DC"/>
                    </StackPanel>

                    <Button x:Name="BtnRunCpu" Click="BtnRunCpu_Click"
                            Margin="0,12,0,0" Padding="0,6" FontSize="11">▶ CPU 벤치</Button>
                </StackPanel>
            </Border>

            <!-- 메모리 벤치 카드 -->
            <Border Grid.Column="2" Background="#13132A" BorderBrush="#333355"
                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="💾" FontSize="20" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="메모리" FontSize="14" FontWeight="Bold" Foreground="#7AADFF"/>
                            <TextBlock x:Name="LblRamTotal" Text="..." FontSize="10" Foreground="#666688"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 순차 읽기 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="순차 읽기" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblMemRead" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbMemRead" Value="0" Maximum="100"
                                     Foreground="#50C8DC"/>
                    </StackPanel>

                    <!-- 순차 쓰기 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="순차 쓰기" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblMemWrite" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbMemWrite" Value="0" Maximum="100"
                                     Foreground="#7AADFF"/>
                    </StackPanel>

                    <!-- 랜덤 접근 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="랜덤 접근" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblMemRandom" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbMemRandom" Value="0" Maximum="100"
                                     Foreground="#A080FF"/>
                    </StackPanel>

                    <!-- 메모리 지연 -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="메모리 지연" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblMemLatency" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbMemLatency" Value="0" Maximum="100"
                                     Foreground="#80DDAA"/>
                    </StackPanel>

                    <Separator Background="#222244" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="종합 점수" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LblMemScore" Text="—" FontSize="18" FontWeight="Bold" Foreground="#7AADFF"/>
                    </StackPanel>

                    <Button x:Name="BtnRunMem" Click="BtnRunMem_Click"
                            Margin="0,12,0,0" Padding="0,6" FontSize="11">▶ 메모리 벤치</Button>
                </StackPanel>
            </Border>

            <!-- 스토리지 벤치 카드 -->
            <Border Grid.Column="4" Background="#13132A" BorderBrush="#333355"
                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="💿" FontSize="20" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="스토리지" FontSize="14" FontWeight="Bold" Foreground="#A080FF"/>
                            <TextBlock x:Name="LblDiskName" Text="..." FontSize="10" Foreground="#666688"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 순차 읽기 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="순차 읽기" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblDiskSeqRead" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbDiskSeqRead" Value="0" Maximum="100"
                                     Foreground="#50C8DC"/>
                    </StackPanel>

                    <!-- 순차 쓰기 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="순차 쓰기" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblDiskSeqWrite" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbDiskSeqWrite" Value="0" Maximum="100"
                                     Foreground="#7AADFF"/>
                    </StackPanel>

                    <!-- 랜덤 4K 읽기 -->
                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="랜덤 4K 읽기" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblDiskRandRead" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbDiskRandRead" Value="0" Maximum="100"
                                     Foreground="#A080FF"/>
                    </StackPanel>

                    <!-- 랜덤 4K 쓰기 -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="랜덤 4K 쓰기" FontSize="11" Foreground="#AAAACC" Width="100"/>
                            <TextBlock x:Name="LblDiskRandWrite" Text="—" FontSize="11" Foreground="#E0E0E0"/>
                        </StackPanel>
                        <ProgressBar x:Name="PbDiskRandWrite" Value="0" Maximum="100"
                                     Foreground="#80DDAA"/>
                    </StackPanel>

                    <Separator Background="#222244" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="종합 점수" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LblDiskScore" Text="—" FontSize="18" FontWeight="Bold" Foreground="#A080FF"/>
                    </StackPanel>

                    <Button x:Name="BtnRunDisk" Click="BtnRunDisk_Click"
                            Margin="0,12,0,0" Padding="0,6" FontSize="11">▶ 스토리지 벤치</Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#0A0A1A" BorderBrush="#1A1A30" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBar" Margin="10,0" VerticalAlignment="Center"
                           FontSize="10" Foreground="#666688"/>
                <ProgressBar x:Name="PbGlobal" Grid.Column="1" Width="200" Height="6"
                             Margin="0,0,10,0" Foreground="#50C8DC" Value="0" Maximum="100"/>
            </Grid>
        </Border>
    </Grid>
</Window>
