<Window x:Class="StrForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Str.Forge" Height="720" Width="1200"
        Background="#0F0F1E" Foreground="#E0E0E0"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="14" Height="14"
                                    Background="#252538" BorderBrush="#444466" BorderThickness="1"
                                    CornerRadius="2">
                                <Path x:Name="chk" Data="M2,7 L5,10 L12,3" Stroke="#7EC8E3" StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#7EC8E3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2A45"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E38"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ─── 툴바 ─── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center"
                    Background="#14142A" Margin="-10,-10,-10,0">
            <Button x:Name="BtnOpenFolder" Click="BtnOpenFolder_Click" Margin="10,0,6,0">📂 폴더 열기</Button>
            <Button x:Name="BtnPreview" Click="BtnPreview_Click" Margin="0,0,6,0" IsEnabled="False">🔍 미리보기</Button>
            <Button x:Name="BtnApply" Click="BtnApply_Click" Margin="0,0,6,0" IsEnabled="False">✅ 적용</Button>
            <Rectangle Width="1" Fill="#333355" Margin="4,8"/>
            <Button x:Name="BtnSavePreset" Click="BtnSavePreset_Click" Margin="6,0,6,0">💾 프리셋 저장</Button>
            <Button x:Name="BtnLoadPreset" Click="BtnLoadPreset_Click" Margin="0,0,6,0">📋 프리셋 불러오기</Button>
            <Rectangle Width="1" Fill="#333355" Margin="4,8"/>
            <CheckBox x:Name="ChkBackup" Content=".bak 백업" IsChecked="True" Margin="6,0,0,0"/>
        </StackPanel>

        <!-- ─── 메인 3열 분할 ─── -->
        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 규칙 패널 ── -->
            <Border Grid.Column="0" BorderBrush="#333355" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A1A30" CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="8,6">
                            <TextBlock Text="치환 규칙" FontSize="11" Foreground="#7777AA" VerticalAlignment="Center"/>
                            <Button x:Name="BtnAddRule" Click="BtnAddRule_Click"
                                    Margin="8,0,0,0" Padding="6,2" FontSize="11">＋ 추가</Button>
                            <Button x:Name="BtnRemoveRule" Click="BtnRemoveRule_Click"
                                    Margin="4,0,0,0" Padding="6,2" FontSize="11" IsEnabled="False">✕ 삭제</Button>
                        </StackPanel>
                    </Border>

                    <!-- 선택된 규칙 편집 영역 -->
                    <Border Grid.Row="1" Background="#16162C" Padding="8,6" Margin="0,0,0,2">
                        <Grid x:Name="RuleEditor">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="찾기" Grid.Row="0" Grid.Column="0" FontSize="11" Foreground="#7777AA" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtPattern" Grid.Row="0" Grid.Column="1" Margin="0,2"
                                     TextChanged="TxtPattern_TextChanged" FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Text="바꾸기" Grid.Row="1" Grid.Column="0" FontSize="11" Foreground="#7777AA" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacement" Grid.Row="1" Grid.Column="1" Margin="0,2"
                                     TextChanged="TxtReplacement_TextChanged" FontFamily="Consolas" FontSize="12"/>
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,2">
                                <CheckBox x:Name="ChkRegex" Content="정규식" Margin="0,0,8,0" Click="ChkOption_Click"/>
                                <CheckBox x:Name="ChkIgnoreCase" Content="대소문자 무시" Margin="0,0,8,0" Click="ChkOption_Click"/>
                                <CheckBox x:Name="ChkWholeWord" Content="전체 단어" Click="ChkOption_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtPatternError" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                       Foreground="#FF6666" FontSize="10" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <ListBox x:Name="RuleList" Grid.Row="2"
                             SelectionChanged="RuleList_SelectionChanged"
                             BorderThickness="0" Background="#13132A"/>

                    <!-- 파일 패턴 -->
                    <Border Grid.Row="3" Background="#16162C" Padding="8,4">
                        <StackPanel>
                            <TextBlock Text="파일 패턴 (glob)" FontSize="10" Foreground="#7777AA" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtGlob" Text="**/*.cs" FontFamily="Consolas" FontSize="12"
                                     TextChanged="TxtGlob_TextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="#333355" HorizontalAlignment="Stretch"/>

            <!-- ── 파일 목록 ── -->
            <Border Grid.Column="2" BorderBrush="#333355" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1A1A30" CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <TextBlock x:Name="LblFileCount" Text="파일 없음" FontSize="11" Foreground="#7777AA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="ResultList" Grid.Row="1" BorderThickness="0"
                             SelectionChanged="ResultList_SelectionChanged"
                             FontFamily="Consolas" FontSize="11"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="6" Background="#333355" HorizontalAlignment="Stretch"/>

            <!-- ── Diff 미리보기 ── -->
            <Border Grid.Column="4" BorderBrush="#333355" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1A1A30" CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <TextBlock x:Name="LblDiffFile" Text="파일 선택 시 Diff 표시" FontSize="11"
                                       Foreground="#7777AA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <RichTextBox x:Name="DiffView" Grid.Row="1"
                                 BorderThickness="0" Background="#13132A"
                                 FontFamily="Consolas" FontSize="12" Padding="8"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto">
                        <RichTextBox.Document>
                            <FlowDocument x:Name="DiffDoc" PageWidth="10000"/>
                        </RichTextBox.Document>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ─── 상태바 ─── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusBar" VerticalAlignment="Center" FontSize="11" Foreground="#666688"/>
            <TextBlock x:Name="ProgressBar" Grid.Column="1" VerticalAlignment="Center"
                       FontSize="11" Foreground="#555577"/>
        </Grid>
    </Grid>
</Window>
