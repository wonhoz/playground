<Window x:Class="RegVault.ValueEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="값 편집" Height="280" Width="480"
        Background="#1C1C2A" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="값 이름:" Foreground="#888899" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtName" Foreground="#E0E0EE" FontFamily="Consolas" FontSize="12"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="종류:" Foreground="#888899" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtKind" Foreground="#AAAACC" FontSize="12"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="데이터:" Foreground="#888899" FontSize="11" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtValue" AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="80" FontFamily="Consolas" FontSize="12"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk"     Content="✅ 확인" Width="80" Margin="0,0,8,0" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Content="취소"    Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
