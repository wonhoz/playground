<Window x:Class="RegVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reg.Vault — 레지스트리 브라우저"
        Height="720" Width="1200" MinHeight="500" MinWidth="800"
        Background="#1C1C2A" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 툴바 -->
            <RowDefinition Height="Auto"/>   <!-- 주소 표시줄 -->
            <RowDefinition Height="*"/>      <!-- 메인 콘텐츠 -->
            <RowDefinition Height="Auto"/>   <!-- 상태 표시줄 -->
        </Grid.RowDefinitions>

        <!-- ── 툴바 ── -->
        <Border Grid.Row="0" Background="#18182A" BorderBrush="#333355" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="🔑 Reg.Vault" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E0E0EE" VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>

                <!-- 내보내기 버튼들 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnSnapshot" Content="📸 스냅샷 찍기" Margin="4,0" Click="BtnSnapshot_Click" ToolTip="현재 선택된 키의 스냅샷 저장"/>
                    <Button x:Name="BtnCompareDiff" Content="🔍 스냅샷 비교" Margin="4,0" Click="BtnCompareDiff_Click"/>
                    <Button x:Name="BtnExportReg" Content="💾 .reg 내보내기" Margin="4,0" Click="BtnExportReg_Click"/>
                    <Button x:Name="BtnExportJson" Content="📄 JSON 내보내기" Margin="4,0" Click="BtnExportJson_Click"/>
                    <Button x:Name="BtnBookmark" Content="⭐ 북마크 추가" Margin="4,0" Click="BtnBookmark_Click"/>
                </StackPanel>

                <!-- 검색 패널 -->
                <Border Background="#1E1E30" BorderBrush="#444466" BorderThickness="1" CornerRadius="4" Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtSearch" Width="240" Background="Transparent" BorderThickness="0"
                                 Foreground="#E0E0EE" VerticalAlignment="Center"
                                 KeyDown="TxtSearch_KeyDown"
                                 ToolTip="정규식 검색 (Enter)"/>
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="4,0" Foreground="#888899"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ── 주소 표시줄 ── -->
        <Border Grid.Row="1" Background="#1A1A28" BorderBrush="#333355" BorderThickness="0,0,0,1" Padding="8,4">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="⬅" Width="28" Margin="0,0,4,0"
                        x:Name="BtnBack" Click="BtnBack_Click" ToolTip="뒤로"/>
                <TextBlock DockPanel.Dock="Left" Text="경로:" VerticalAlignment="Center"
                           Foreground="#888899" Margin="4,0,6,0" FontSize="11"/>
                <TextBox x:Name="TxtPath" Background="Transparent" BorderThickness="0"
                         Foreground="#C0C0D8" FontFamily="Consolas" FontSize="11"
                         VerticalAlignment="Center"
                         KeyDown="TxtPath_KeyDown"
                         ToolTip="경로 직접 입력 후 Enter"/>
            </DockPanel>
        </Border>

        <!-- ── 메인 콘텐츠 ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="140"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="200" MinWidth="120"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 레지스트리 트리 + 북마크 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <!-- 트리 뷰 -->
                <Border Grid.Row="0" BorderBrush="#333355" BorderThickness="0,0,1,0">
                    <TreeView x:Name="RegTree"
                              Background="#1C1C2A"
                              BorderThickness="0"
                              SelectedItemChanged="RegTree_SelectedItemChanged"
                              TreeViewItem.Expanded="TreeItem_Expanded">
                    </TreeView>
                </Border>

                <!-- 구분선 -->
                <Border Grid.Row="1" Background="#333355" Height="1"/>

                <!-- 북마크 패널 -->
                <Grid Grid.Row="2" Background="#1A1A28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#18182A" BorderBrush="#333355" BorderThickness="0,0,0,1" Padding="8,4">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="⭐ 북마크" Foreground="#AAAACC" FontSize="11" FontWeight="SemiBold"/>
                            <Button DockPanel.Dock="Right" Content="✕" Width="20" Height="20" FontSize="10"
                                    x:Name="BtnDeleteBookmark" Click="BtnDeleteBookmark_Click" ToolTip="선택한 북마크 삭제"/>
                        </DockPanel>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="LstBookmarks" Background="#1A1A28" BorderThickness="0"
                             FontSize="11" SelectionChanged="LstBookmarks_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Foreground="#BBBBDD"
                                           ToolTip="{Binding FullPath}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <!-- 스플리터 -->
            <GridSplitter Grid.Column="1" Width="4" Background="#2A2A40"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- 가운데: 탭 (값 목록 / 검색 결과 / 스냅샷 비교) -->
            <TabControl Grid.Column="2" x:Name="MainTab" SelectionChanged="MainTab_SelectionChanged">
                <!-- 값 목록 탭 -->
                <TabItem Header="📋 값 목록" x:Name="TabValues">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="DgValues" Margin="0"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  SelectionChanged="DgValues_SelectionChanged"
                                  MouseDoubleClick="DgValues_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="이름"    Binding="{Binding DisplayName}" Width="200"/>
                                <DataGridTextColumn Header="종류"    Binding="{Binding KindDisplay}"  Width="120"/>
                                <DataGridTextColumn Header="데이터"  Binding="{Binding DataDisplay}"  Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- 검색 결과 탭 -->
                <TabItem Header="🔍 검색 결과" x:Name="TabSearch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 검색 옵션 -->
                        <Border Grid.Row="0" Background="#1E1E30" BorderBrush="#333355" BorderThickness="0,0,0,1" Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="ChkSearchKeys"      Content="키 이름" IsChecked="True"  Margin="0,0,12,0"/>
                                <CheckBox x:Name="ChkSearchValues"    Content="값 이름" IsChecked="True"  Margin="0,0,12,0"/>
                                <CheckBox x:Name="ChkSearchData"      Content="데이터"  IsChecked="False" Margin="0,0,20,0"/>
                                <TextBlock Text="범위:" VerticalAlignment="Center" Foreground="#888899" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbSearchScope" Width="160" SelectedIndex="0">
                                    <ComboBoxItem>현재 선택된 키</ComboBoxItem>
                                    <ComboBoxItem>HKEY_LOCAL_MACHINE</ComboBoxItem>
                                    <ComboBoxItem>HKEY_CURRENT_USER</ComboBoxItem>
                                    <ComboBoxItem>전체 하이브</ComboBoxItem>
                                </ComboBox>
                                <Button x:Name="BtnSearch" Content="검색" Margin="8,0,4,0" Click="BtnSearch_Click"/>
                                <Button x:Name="BtnSearchCancel" Content="중지" Margin="4,0" Click="BtnSearchCancel_Click" IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1" x:Name="DgSearchResults"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  MouseDoubleClick="DgSearchResult_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="키 경로"   Binding="{Binding KeyPath}"    Width="*"/>
                                <DataGridTextColumn Header="값 이름"   Binding="{Binding ValueName}"  Width="160"/>
                                <DataGridTextColumn Header="데이터"    Binding="{Binding DataDisplay}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- 스냅샷 비교 탭 -->
                <TabItem Header="📊 스냅샷 비교" x:Name="TabDiff">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 스냅샷 선택 -->
                        <Border Grid.Row="0" Background="#1E1E30" BorderBrush="#333355" BorderThickness="0,0,0,1" Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="이전:" VerticalAlignment="Center" Foreground="#888899" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbSnapOld" Width="200" Margin="0,0,12,0" DisplayMemberPath="Label"/>
                                <TextBlock Text="이후:" VerticalAlignment="Center" Foreground="#888899" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbSnapNew" Width="200" Margin="0,0,12,0" DisplayMemberPath="Label"/>
                                <Button x:Name="BtnDiff" Content="🔍 비교" Click="BtnDiff_Click"/>
                                <Button x:Name="BtnDeleteSnapshot" Content="🗑 스냅샷 삭제" Margin="8,0,0,0" Click="BtnDeleteSnapshot_Click"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1" x:Name="DgDiff"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  MouseDoubleClick="DgDiff_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="변경" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DiffLabel}"
                                                       Foreground="{Binding DiffColor}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="키 경로"   Binding="{Binding KeyPath}"   Width="*"/>
                                <DataGridTextColumn Header="값 이름"   Binding="{Binding ValueName}" Width="160"/>
                                <DataGridTextColumn Header="이전 데이터" Binding="{Binding OldData}"  Width="180"/>
                                <DataGridTextColumn Header="이후 데이터" Binding="{Binding NewData}"  Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- 스플리터 -->
            <GridSplitter Grid.Column="3" Width="4" Background="#2A2A40"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- 오른쪽: 선택된 값 상세 / 편집 -->
            <Grid Grid.Column="4" Background="#1A1A28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#18182A" BorderBrush="#333355" BorderThickness="0,0,0,1" Padding="8,4">
                    <TextBlock Text="📌 상세 정보" Foreground="#AAAACC" FontSize="11" FontWeight="SemiBold"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock x:Name="TxtDetailName"  FontSize="11" Foreground="#888899" Margin="0,4,0,0" Text="이름:"/>
                        <TextBlock x:Name="TxtDetailNameV" FontSize="12" Foreground="#E0E0EE" TextWrapping="Wrap" Margin="0,2,0,8"/>

                        <TextBlock x:Name="TxtDetailKind"  FontSize="11" Foreground="#888899" Text="종류:"/>
                        <TextBlock x:Name="TxtDetailKindV" FontSize="12" Foreground="#E0E0EE" Margin="0,2,0,8"/>

                        <TextBlock x:Name="TxtDetailData"  FontSize="11" Foreground="#888899" Text="데이터:"/>
                        <TextBox   x:Name="TxtDetailDataV" FontSize="11" FontFamily="Consolas"
                                   Background="#1E1E30" Foreground="#B0D0FF"
                                   AcceptsReturn="True" TextWrapping="Wrap"
                                   IsReadOnly="True" MaxHeight="300"
                                   Margin="0,2,0,8" BorderBrush="#333355"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 편집 버튼 -->
                <StackPanel Grid.Row="2" Margin="8" Orientation="Vertical">
                    <Button x:Name="BtnEditValue" Content="✏ 값 편집"  Margin="0,2" Click="BtnEditValue_Click"/>
                    <Button x:Name="BtnDeleteValue" Content="🗑 값 삭제" Margin="0,2" Click="BtnDeleteValue_Click"
                            Foreground="#FF7070"/>
                    <Button x:Name="BtnDeleteKey" Content="🗑 키 삭제" Margin="0,2" Click="BtnDeleteKey_Click"
                            Foreground="#FF7070" ToolTip="현재 선택된 키 전체 삭제"/>
                    <Button x:Name="BtnCopyPath" Content="📋 경로 복사" Margin="0,2" Click="BtnCopyPath_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ── 상태 표시줄 ── -->
        <Border Grid.Row="3" Background="#18182A" BorderBrush="#333355" BorderThickness="0,1,0,0" Padding="8,3">
            <DockPanel>
                <ProgressBar x:Name="PbSearch" DockPanel.Dock="Right" Width="120" Margin="8,0"
                             IsIndeterminate="True" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtStatus" Foreground="#888899" FontSize="11"
                           Text="준비" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
