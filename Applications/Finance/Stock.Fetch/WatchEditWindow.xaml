<Window x:Class="Stock.Fetch.WatchEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="관심 종목" Height="565" Width="430"
        Background="{StaticResource WindowBg}" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Name="HeaderText" Text="관심 종목 추가" FontSize="17" FontWeight="Bold"
                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="시장" Style="{StaticResource FieldLbl}"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="MarketCombo" Width="150" SelectionChanged="Market_SelectionChanged">
                <ComboBoxItem Content="국내 (KR)"/>
                <ComboBoxItem Content="미국 (US)"/>
            </ComboBox>
            <CheckBox x:Name="IndexCheck" Content="지수(업종)" VerticalAlignment="Center" Margin="12,0,0,0"
                      Click="Index_Click" ToolTip="국내 업종/지수(코스피 0001·코스닥 1001·코스피200 2001). KIS로 조회."/>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="SymbolLbl" Text="종목코드" Style="{StaticResource FieldLbl}"/>
        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox x:Name="SymbolBox"/>
            <Button Grid.Column="1" x:Name="LookupBtn" Content="🔍 이름" Width="70" Margin="8,0,0,0" Click="Lookup_Click"/>
        </Grid>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="종목명" Style="{StaticResource FieldLbl}"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="시세 소스" Style="{StaticResource FieldLbl}"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="SourceCombo" Margin="0,0,0,10"
                  SelectionChanged="Source_SelectionChanged"/>

        <TextBlock Grid.Row="5" Grid.Column="0" x:Name="ExchangeLbl" Text="거래소" Style="{StaticResource FieldLbl}"/>
        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="ExchangeCombo" Margin="0,0,0,10">
            <ComboBoxItem Content="NAS (나스닥)" Tag="NAS"/>
            <ComboBoxItem Content="NYS (뉴욕)" Tag="NYS"/>
            <ComboBoxItem Content="AMS (아멕스·Arca)" Tag="AMS"/>
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="추세 조건" Style="{StaticResource FieldLbl}"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="RulesBox" Margin="0,0,0,10"
                 ToolTip="이 종목 전용 추세 조건. 기간:상승[:하락] 쉼표 구분(예: 3:1:2 → 3분당 상승1%/하락2%, 5:2 → 5분당 ±2%). 소수점 가능. 비우면 전역 조건 사용."/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="알림" Style="{StaticResource FieldLbl}"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="AlertUpCheck" Content="상승" IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0"
                          ToolTip="상승 추세 알림 받기"/>
                <CheckBox x:Name="AlertDownCheck" Content="하락" IsChecked="True" VerticalAlignment="Center" Margin="0,0,18,0"
                          ToolTip="하락 추세 알림 받기"/>
                <CheckBox x:Name="LadderCheck" Content="매수 래더·갭다운" VerticalAlignment="Center"
                          ToolTip="국내 종목만. 매수 1~4호가 도달·시초가 갭다운 취소선 알림."/>
            </StackPanel>
            <CheckBox x:Name="BottomCheck" Content="바닥 반등 시그널 (볼린저 하단 반등 · 1분봉)" Margin="0,8,0,0"
                      ToolTip="국내 종목만 · KIS 키 필요. 급락 후 볼린저(20,2σ) 하단 터치 → 밴드 복귀 + RSI 과매도 상승 전환 + 거래량 급증이면 알림. 이후 MA5/MA20 골든크로스 확인 알림."/>
        </StackPanel>

        <TextBlock Grid.Row="8" Grid.ColumnSpan="2" x:Name="HintText" Style="{x:Null}" TextWrapping="Wrap"
                   FontSize="11" Foreground="{StaticResource FgMuted}" VerticalAlignment="Top" Margin="0,4,0,0"
                   Text="미국 종목은 티커(예: TSLA, SOXL, SPCX). 프리·정규·애프터를 모두 받으려면 Yahoo 권장. 지수(업종) 체크 시 코스피 0001·코스닥 1001·코스피200 2001 코드를 입력하면 KIS로 조회합니다(KIS 키 필요). 추세 조건을 비우면 전역 조건을 사용합니다. '매수 래더·갭다운'과 '바닥 반등 시그널'은 국내 종목만 지원합니다(반등 시그널은 KIS 1분봉 필요)."/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource BearBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="취소" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="저장" Width="80" Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
