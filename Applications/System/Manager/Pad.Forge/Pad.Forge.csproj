<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Pad.Forge</AssemblyName>
    <RootNamespace>PadForge</RootNamespace>
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>
    <PlatformTarget>x64</PlatformTarget>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Resources\app.ico" Condition="Exists('Resources\app.ico')" />
  </ItemGroup>

  <ItemGroup>
    <!-- HID 컨트롤러 (DirectInput / DS4 / Switch Pro) -->
    <PackageReference Include="HidSharp" Version="2.1.0" />
    <!-- ViGEm 가상 컨트롤러 (드라이버 선택 설치) -->
    <PackageReference Include="Nefarius.ViGEm.Client" Version="1.21.256" />
  </ItemGroup>
</Project>
