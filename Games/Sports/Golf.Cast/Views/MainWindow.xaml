<Window x:Class="GolfCast.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:GolfCast.Views"
        Title="Golf.Cast" Width="760" Height="640"
        Background="#0D1B0D" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HUD 상단 -->
        <Border Grid.Row="0" Background="#1A2E1A"
                BorderBrush="#2E4A2E" BorderThickness="0,0,0,1">
            <Grid Margin="12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtHole" Grid.Column="0" FontSize="15" FontWeight="Bold"
                           Foreground="#4CAF50" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtHoleName" Grid.Column="1" FontSize="12"
                           Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBlock x:Name="TxtPar" Grid.Column="2" FontSize="12" Foreground="#888"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="TxtStrokes" Grid.Column="3" FontSize="15" FontWeight="Bold"
                           Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Grid.Column="4" x:Name="BtnMenu" Content="메뉴" Padding="10,4"
                        Click="OnMenu"/>
            </Grid>
        </Border>

        <!-- 게임 캔버스 -->
        <v:GameCanvas x:Name="Canvas" Grid.Row="1"
                      MouseMove="OnMouseMove"
                      MouseLeftButtonDown="OnMouseDown"
                      MouseLeftButtonUp="OnMouseUp"
                      MouseRightButtonDown="OnRightClick"
                      Cursor="Cross"
                      ClipToBounds="True"/>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Background="#1A2E1A"
                BorderBrush="#2E4A2E" BorderThickness="0,1,0,0">
            <Grid Margin="12,5">
                <TextBlock x:Name="TxtStatus" FontSize="12" Foreground="#888"/>
                <TextBlock x:Name="TxtTotalScore" HorizontalAlignment="Right"
                           FontSize="12" Foreground="#4CAF50"/>
            </Grid>
        </Border>
    </Grid>
</Window>
