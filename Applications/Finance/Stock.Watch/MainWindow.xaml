<Window x:Class="Stock.Watch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:Stock.Watch.Views.Controls"
        Title="Stock.Watch — 종목 조건 감시" Height="760" Width="1240"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ───── 상단 툴바 ───── -->
        <Border Grid.Row="0" Background="#FF21212E" BorderBrush="#FF3A3A3A" BorderThickness="0,0,0,1" Padding="14,10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="📈 Stock.Watch" FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="대기 중" Foreground="#FF888888" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button x:Name="SettingsBtn" Content="⚙ 설정" DockPanel.Dock="Right" Margin="6,0,0,0"/>
                <Button x:Name="RefreshBtn" Content="↻ 새로고침" DockPanel.Dock="Right" Margin="6,0,0,0"/>
                <Button x:Name="ToggleBtn" Content="▶ 감시 시작" DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Width="120"/>
            </DockPanel>
        </Border>

        <!-- ───── 본문 ───── -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <!-- 좌: 관심종목 -->
            <Border Grid.Column="0" Background="#FF1E1E2E" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="관심종목" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="StockList">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="#FF252535" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="6" Padding="9,7">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#FF4A9EFF"/>
                                                    <Setter TargetName="bd" Property="Background" Value="#FF2C2C40"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FF2C2C40"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Display}" FontWeight="SemiBold" FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ChangeText}" Foreground="{Binding ChangeBrush}" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding PriceText}" Foreground="{Binding ChangeBrush}"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBox x:Name="NewCodeBox" Tag="종목코드 6자리"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="AddStockBtn" Content="+ 추가" Margin="0,0,3,0"/>
                            <Button Grid.Column="1" x:Name="RemoveStockBtn" Content="− 삭제" Margin="3,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 중: 차트 -->
            <Border Grid.Column="1" Background="#FF161620" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="14,10,14,6" LastChildFill="False">
                        <TextBlock x:Name="ChartTitle" Text="종목 미선택" FontSize="15" FontWeight="Bold"/>
                        <TextBlock x:Name="ChartPrice" Text="" FontSize="15" FontWeight="Bold" Margin="14,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="🔴상승 🔵하락 · 노랑=볼린저중심 · 보라=RSI" DockPanel.Dock="Right"
                                   Foreground="#FF888888" FontSize="10.5" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ctl:CandleChart Grid.Row="1" x:Name="Chart" Margin="6,0,6,6"/>
                </Grid>
            </Border>

            <!-- 우: 조건 + 알림 -->
            <Border Grid.Column="2" Background="#FF1E1E2E" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="8">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="CondTitle" Text="조건 설정" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="EditorHost">
                            <ctl:RuleSetEditor x:Name="BuyEditor"/>
                            <ctl:RuleSetEditor x:Name="SellEditor"/>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Text="알림 로그" FontWeight="Bold" FontSize="13" Margin="0,10,0,6"/>
                    <Border Grid.Row="3" Background="#FF161620" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="6">
                        <ListBox x:Name="AlertList" Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF21212E" CornerRadius="5" Padding="8,6" Margin="0,2">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="{Binding KindText}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Name}" Margin="6,0,0,0"/>
                                                <TextBlock Text="{Binding TimeText}" DockPanel.Dock="Right" Foreground="#FF888888" FontSize="10.5"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding RuleSummary}" Foreground="#FFBBBBBB" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Background="#FF161620" BorderBrush="#FF3A3A3A" BorderThickness="0,1,0,0" Padding="14,5">
            <TextBlock x:Name="FooterText" Foreground="#FF888888" FontSize="11"
                       Text="설정에서 KIS API 키와 Slack Webhook을 입력한 뒤 감시를 시작하세요."/>
        </Border>
    </Grid>
</Window>
