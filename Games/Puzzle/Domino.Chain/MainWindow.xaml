<Window x:Class="DominoChain.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Domino.Chain" Width="860" Height="560"
        ResizeMode="NoResize"
        Background="#1A1A2E" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Focusable="True">
    <Grid>
        <!-- 배경 Canvas (게임 영역) -->
        <Canvas x:Name="GameCanvas" Background="#1A1A2E" ClipToBounds="True"/>

        <!-- ── 상단 HUD ─────────────────────────────── -->
        <Grid x:Name="HudPanel" VerticalAlignment="Top" Margin="14,8" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 레벨 제목 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="LEVEL " FontSize="13" FontWeight="Bold"
                           Foreground="#888888" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock x:Name="LevelNumText" Text="1" FontSize="13" FontWeight="Bold"
                           Foreground="#00D2A0" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock x:Name="LevelTitleText" Text="" FontSize="11"
                           Foreground="#666666" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- 모드 표시 (중앙) -->
            <Border Grid.Column="1" Background="#2A2A3E" CornerRadius="4"
                    Padding="14,4" HorizontalAlignment="Center">
                <TextBlock x:Name="ModeText" Text="[ EDIT ]" FontSize="13" FontWeight="Bold"
                           Foreground="#FFD700" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </Border>

            <!-- 남은 도미노 / 슬롯 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="남은 도미노: " FontSize="12"
                           Foreground="#888888" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock x:Name="RemainingText" Text="1" FontSize="13" FontWeight="Bold"
                           Foreground="#00D2A0" FontFamily="Consolas" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ── 하단 조작 안내 ──────────────────────── -->
        <TextBlock x:Name="HintBar" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="0,0,0,10" FontSize="11" FontFamily="Consolas"
                   Foreground="#555577" Visibility="Collapsed"/>

        <!-- ── 타이틀 화면 ─────────────────────────── -->
        <StackPanel x:Name="TitlePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="DOMINO.CHAIN" FontSize="48" FontWeight="Bold"
                       Foreground="#00D2A0" HorizontalAlignment="Center" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00D2A0" BlurRadius="30" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="도미노 연쇄 물리 퍼즐" FontSize="13" Foreground="#555577"
                       HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Consolas"/>

            <TextBlock Text="[ ENTER TO START ]" FontSize="16" Foreground="#FFD700"
                       HorizontalAlignment="Center" Margin="0,36,0,0" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock FontSize="11" Foreground="#3A3A5A" HorizontalAlignment="Center"
                       Margin="0,24,0,0" FontFamily="Consolas" TextAlignment="Center">
                <Run Text="클릭  —  빈 슬롯에 도미노 배치"/>
                <LineBreak/>
                <Run Text="SPACE  —  실행 / 편집 전환"/>
                <LineBreak/>
                <Run Text="R  —  리셋    ESC  —  타이틀"/>
            </TextBlock>
        </StackPanel>

        <!-- ── 레벨 클리어 ─────────────────────────── -->
        <Border x:Name="ClearOverlay" Background="#CC000010" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ClearTitle" Text="CHAIN COMPLETE!" FontSize="38" FontWeight="Bold"
                           Foreground="#FFD700" HorizontalAlignment="Center" FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FFD700" BlurRadius="28" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="ClearSub" Text="" FontSize="15"
                           Foreground="#00D2A0" HorizontalAlignment="Center"
                           Margin="0,14,0,0" FontFamily="Consolas"/>
                <TextBlock Text="[ ENTER → 다음 레벨 ]" FontSize="14" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,28,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>

        <!-- ── 게임 완료 ─────────────────────────────── -->
        <Border x:Name="GameCompleteOverlay" Background="#CC000010" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="ALL CHAINS COMPLETE!" FontSize="36" FontWeight="Bold"
                           Foreground="#00D2A0" HorizontalAlignment="Center" FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00D2A0" BlurRadius="28" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="모든 도미노 연쇄를 완성했습니다!" FontSize="15"
                           Foreground="#FFD700" HorizontalAlignment="Center"
                           Margin="0,14,0,0" FontFamily="Consolas"/>
                <TextBlock Text="[ ENTER → 처음부터 ]" FontSize="14" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,28,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>

        <!-- 실패 플래시 -->
        <Border x:Name="FailFlash" Background="#44E74C3C" Visibility="Collapsed"
                IsHitTestVisible="False"/>
    </Grid>
</Window>
