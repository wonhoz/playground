<Window x:Class="LocaleView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Locale.View" Height="720" Width="1200"
        Background="#1A1A1A" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="24"/>
    </Grid.RowDefinitions>

    <!-- 툴바 -->
    <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#333" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
        <TextBlock Text="🌐 Locale.View" FontSize="16" FontWeight="Bold"
                   Foreground="#5B8AF0" VerticalAlignment="Center" Margin="0,0,20,0"/>
        <TextBox x:Name="SearchBox" Width="220" Background="#2A2A2A" Foreground="#E0E0E0"
                 BorderBrush="#444" BorderThickness="1" Padding="8,5"
                 VerticalAlignment="Center" FontSize="12"
                 TextChanged="SearchBox_TextChanged">
          <TextBox.Style>
            <Style TargetType="TextBox">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                      <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </TextBox.Style>
        </TextBox>
        <Button Content="📋 코드 복사" Margin="10,0,0,0" Click="BtnCopyCode_Click"/>
        <Button Content="⚖️ 비교 모드" Margin="6,0,0,0" Click="BtnCompare_Click"/>
        <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="16,0,0,0"
                   Foreground="#888" FontSize="12"/>
      </StackPanel>
    </Border>

    <!-- 메인 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 로케일 목록 -->
      <Border Grid.Column="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,1,0">
        <DataGrid x:Name="LocaleGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="LocaleGrid_SelectionChanged"
                  CanUserSortColumns="True" CanUserResizeRows="False"
                  HeadersVisibility="Column">
          <DataGrid.Columns>
            <DataGridTextColumn Header="로케일" Binding="{Binding Name}" Width="*"/>
            <DataGridTextColumn Header="지역" Binding="{Binding Region}" Width="80"/>
          </DataGrid.Columns>
        </DataGrid>
      </Border>

      <!-- 상세 탭 -->
      <Border Grid.Column="1" Background="#111">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- 로케일 헤더 -->
          <Border Grid.Row="0" Padding="16,12" Background="#151530" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LocaleName" FontSize="20" FontWeight="Bold" Foreground="#E0E0E0"/>
                <TextBlock x:Name="LocaleCode" FontSize="12" Foreground="#5B8AF0"
                           VerticalAlignment="Bottom" Margin="10,0,0,4"/>
              </StackPanel>
              <TextBlock x:Name="LocaleNative" FontSize="13" Foreground="#888" Margin="0,2,0,0"/>
            </StackPanel>
          </Border>

          <!-- 탭 -->
          <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="날짜 / 시간">
              <ScrollViewer Background="Transparent" Padding="16">
                <StackPanel x:Name="DateTimePanel"/>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="숫자 / 통화">
              <ScrollViewer Background="Transparent" Padding="16">
                <StackPanel x:Name="NumberPanel"/>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="달력 / 시간대">
              <ScrollViewer Background="Transparent" Padding="16">
                <StackPanel x:Name="CalendarPanel"/>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="C# 코드">
              <ScrollViewer Background="Transparent" Padding="16">
                <StackPanel x:Name="CodePanel"/>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Grid>
      </Border>
    </Grid>

    <!-- 상태바 -->
    <Border Grid.Row="2" Background="#111" Padding="12,0">
      <TextBlock x:Name="StatusBar" Foreground="#555" FontSize="11" VerticalAlignment="Center"/>
    </Border>
  </Grid>
</Window>
