<Window x:Class="SkyDrift.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sky.Drift"
        Width="580" Height="760"
        ResizeMode="NoResize"
        Background="#050F23"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Grid>
        <!-- ══ 게임 캔버스 ══ -->
        <Canvas x:Name="GameCanvas" Background="#050F23" ClipToBounds="True"/>

        <!-- ══ HUD ══ -->
        <Grid x:Name="HudPanel" Margin="12,10" VerticalAlignment="Top" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TxtAltitude" Text="0 m"
                           Foreground="#64C8FF" FontSize="26" FontWeight="Bold"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="TxtSpeed"
                           Foreground="#888888" FontSize="11" FontFamily="Consolas"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtLiftStatus" Text=""
                           Foreground="#6EFF6E" FontSize="13" FontWeight="Bold"
                           HorizontalAlignment="Right"/>
                <TextBlock Text="[←→] 조종  [ESC] 종료"
                           Foreground="#333344" FontSize="10"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- ══ 타이틀 패널 ══ -->
        <Border x:Name="TitlePanel"
                Background="#08101E" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="40,30" CornerRadius="12"
                BorderBrush="#1A3A5A" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="SKY" Foreground="#64C8FF" FontSize="64" FontWeight="Black"
                           FontFamily="Consolas" HorizontalAlignment="Center" LineHeight="60"/>
                <TextBlock Text="DRIFT" Foreground="#3A8AFF" FontSize="64" FontWeight="Black"
                           FontFamily="Consolas" HorizontalAlignment="Center"/>
                <TextBlock Text="상승기류를 타고 최고 고도를 달성하라!"
                           Foreground="#666688" FontSize="13" HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>

                <Border Margin="0,20,0,0" Background="#0A1828" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="조작법" Foreground="#3A8AFF" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="← →  날개 기울이기" Foreground="#888888" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Text="🌡  열기류 진입 시 자동 상승" Foreground="#888888" FontSize="12"/>
                        <TextBlock Text="⛈  폭풍·새떼 충돌 시 게임 오버" Foreground="#888888" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border x:Name="BdrBestScore" Margin="0,12,0,0" Background="#081018"
                        CornerRadius="6" Padding="8" Visibility="Collapsed">
                    <TextBlock x:Name="TxtBestScore" Text="" Foreground="#FFD93D"
                               FontSize="12" HorizontalAlignment="Center" FontFamily="Consolas"/>
                </Border>

                <TextBlock Text="[ Enter ] 시작" Foreground="#64C8FF" FontSize="18"
                           HorizontalAlignment="Center" Margin="0,20,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>

        <!-- ══ 게임 오버 패널 ══ -->
        <Border x:Name="GameOverPanel" Visibility="Collapsed"
                Background="#08101E" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="40,30" CornerRadius="12"
                BorderBrush="#3A1A1A" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="GAME OVER" Foreground="#FF4747" FontSize="36" FontWeight="Black"
                           FontFamily="Consolas" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtFinalAlt" Text="" Foreground="#64C8FF"
                           FontSize="22" HorizontalAlignment="Center" Margin="0,16,0,4"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="TxtFinalTime" Text="" Foreground="#888888"
                           FontSize="14" HorizontalAlignment="Center"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="TxtNewBest" Text="" Foreground="#FFD93D"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,0"
                           FontFamily="Consolas"/>
                <TextBlock Text="[ Enter ] 다시 시작  [ Esc ] 타이틀" Foreground="#3A8AFF"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,20,0,0"
                           FontFamily="Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
