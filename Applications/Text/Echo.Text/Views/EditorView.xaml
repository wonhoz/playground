<UserControl x:Class="EchoText.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111118">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 좌측 사이드바 ──────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#0D0D16" BorderBrush="#2A2A3E"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,16,12,16">

                    <!-- 음성 선택 -->
                    <TextBlock Text="음성" FontSize="11" Foreground="#888899"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CbVoice" SelectionChanged="CbVoice_SelectionChanged"
                              Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtVoiceInfo" FontSize="10" Foreground="#555566"
                               TextTrimming="CharacterEllipsis" Margin="0,0,0,16"/>

                    <!-- 속도 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="속도" FontSize="11"
                                   Foreground="#888899" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" x:Name="TxtRate" Text="0"
                                   FontSize="11" Foreground="#A855F7" FontWeight="Bold"/>
                    </Grid>
                    <Slider x:Name="SlRate" Minimum="-10" Maximum="10" Value="0"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="SlRate_ValueChanged" Margin="0,0,0,16"/>

                    <!-- 볼륨 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="볼륨" FontSize="11"
                                   Foreground="#888899" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" x:Name="TxtVolume" Text="100"
                                   FontSize="11" Foreground="#A855F7" FontWeight="Bold"/>
                    </Grid>
                    <Slider x:Name="SlVolume" Minimum="0" Maximum="100" Value="100"
                            TickFrequency="5" IsSnapToTickEnabled="True"
                            ValueChanged="SlVolume_ValueChanged" Margin="0,0,0,16"/>

                    <!-- 음높이 (SSML) -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="음높이" FontSize="11"
                                       Foreground="#888899" FontWeight="SemiBold"/>
                            <TextBlock Text=" (SSML)" FontSize="10" Foreground="#444455"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="TxtPitch" Text="0"
                                   FontSize="11" Foreground="#A855F7" FontWeight="Bold"/>
                    </Grid>
                    <Slider x:Name="SlPitch" Minimum="-10" Maximum="10" Value="0"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="SlPitch_ValueChanged" Margin="0,0,0,20"/>

                    <!-- 재생 제어 -->
                    <Button x:Name="BtnPlay" Content="▶  재생"
                            Style="{StaticResource AccentButton}"
                            Height="36" Margin="0,0,0,8"
                            Click="BtnPlay_Click"/>
                    <Button x:Name="BtnStop" Content="⏹  중단"
                            Height="34" Margin="0,0,0,8" IsEnabled="False"
                            Click="BtnStop_Click"/>
                    <Button Content="📋  클립보드 읽기"
                            Height="34" Margin="0,0,0,20"
                            Click="BtnClipboard_Click"/>

                    <Separator Background="#2A2A3E" Margin="0,0,0,16"/>

                    <!-- 내보내기 -->
                    <TextBlock Text="내보내기" FontSize="11" Foreground="#888899"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Button Content="💾  WAV 저장"
                            Height="34" Margin="0,0,0,8"
                            Click="BtnSaveWav_Click"/>
                    <Button Content="🎵  MP3 저장"
                            Height="34" Margin="0,0,0,20"
                            Click="BtnSaveMp3_Click"/>

                    <Separator Background="#2A2A3E" Margin="0,0,0,16"/>

                    <!-- 옵션 -->
                    <TextBlock Text="옵션" FontSize="11" Foreground="#888899"
                               FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <CheckBox x:Name="ChkSsml" Content="SSML 모드"
                              Checked="ChkSsml_Changed" Unchecked="ChkSsml_Changed"
                              Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkWordWrap" Content="자동 줄 바꿈"
                              IsChecked="True"
                              Checked="ChkWordWrap_Changed" Unchecked="ChkWordWrap_Changed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── 우측 편집 영역 ─────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 텍스트 에디터 -->
            <TextBox Grid.Row="0" x:Name="TxtEditor"
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     FontFamily="'Malgun Gothic', 'Segoe UI', sans-serif"
                     FontSize="14"
                     Padding="20,16" Margin="0"
                     VerticalContentAlignment="Top"
                     TextChanged="TxtEditor_TextChanged"
                     Background="#111118" BorderThickness="0"/>

            <!-- 진행 바 -->
            <ProgressBar Grid.Row="1" x:Name="PbExport" Height="3"
                         Visibility="Collapsed" Margin="0"/>

            <!-- 하단 상태 표시 -->
            <Border Grid.Row="2" Background="#0D0D16" BorderBrush="#2A2A3E"
                    BorderThickness="0,1,0,0" Padding="16,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TxtCharCount" Foreground="#555566" FontSize="11"/>
                    <TextBlock Text=" | " Foreground="#333344" FontSize="11"/>
                    <TextBlock x:Name="TxtWordCount" Foreground="#555566" FontSize="11"/>
                    <TextBlock Text=" | " Foreground="#333344" FontSize="11"/>
                    <TextBlock x:Name="TxtEstTime"   Foreground="#555566" FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
