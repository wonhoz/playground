<Window x:Class="WinEvent.Windows.EventDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이벤트 상세 — Win.Event"
        Width="680" Height="500"
        MinWidth="480" MinHeight="350"
        Background="#0D0D16"
        Foreground="#D0D0E0"
        FontFamily="Segoe UI"
        FontSize="12"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 메타 정보 -->
        <Border Grid.Row="0"
                Background="#131320" BorderBrush="#2A2A3A" BorderThickness="1"
                CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="시간:"   Foreground="#888898" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="LblTime" Foreground="#E0E0E0" Margin="0,0,20,0"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="레벨:"   Foreground="#888898" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="LblLevel" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="EventID:" Foreground="#888898" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LblEventId" Foreground="#E0E0E0" Margin="0,0,20,0"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="소스:"    Foreground="#888898" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="LblSource" Foreground="#E0E0E0" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- 전체 메시지 -->
        <TextBox Grid.Row="2"
                 x:Name="TxtMessage"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 Background="#0B0B14"
                 Foreground="#C8C8DC"
                 FontFamily="Consolas"
                 FontSize="12"
                 BorderBrush="#2A2A3A" BorderThickness="1"
                 Padding="12,10"
                 VerticalScrollBarVisibility="Auto"/>

        <!-- 버튼 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="📋 메시지 복사" Click="BtnCopy_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="닫기" Style="{StaticResource SecondaryBtn}"
                    Click="BtnClose_Click" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
