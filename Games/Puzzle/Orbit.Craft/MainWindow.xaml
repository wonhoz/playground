<Window x:Class="OrbitCraft.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbit.Craft" Width="860" Height="560"
        ResizeMode="NoResize"
        Background="#04040E" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        Focusable="True">
    <Grid>
        <!-- 게임 Canvas -->
        <Canvas x:Name="GameCanvas" Background="#04040E" ClipToBounds="True"/>

        <!-- ── 상단 HUD ──────────────────────────────── -->
        <Grid x:Name="HudPanel" VerticalAlignment="Top" Margin="14,7" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="LEVEL " FontSize="13" FontWeight="Bold"
                           Foreground="#333355" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock x:Name="LevelNumText" Text="1" FontSize="13" FontWeight="Bold"
                           Foreground="#FFD060" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock x:Name="LevelNameText" Text="" FontSize="11"
                           Foreground="#333355" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#0A0A1A" CornerRadius="4"
                    Padding="14,4" HorizontalAlignment="Center">
                <TextBlock x:Name="ModeText" Text="[ AIM ]" FontSize="13" FontWeight="Bold"
                           Foreground="#FFD060" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock x:Name="SpeedText" FontSize="11"
                           Foreground="#555577" FontFamily="Consolas" TextAlignment="Right"/>
                <TextBlock x:Name="OrbitText" FontSize="11"
                           Foreground="#555577" FontFamily="Consolas" TextAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- ── 하단 힌트 ─────────────────────────────── -->
        <TextBlock x:Name="HintBar" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="0,0,0,8" FontSize="11" FontFamily="Consolas"
                   Foreground="#1A1A33" Visibility="Collapsed"/>

        <!-- ── 타이틀 ─────────────────────────────────── -->
        <StackPanel x:Name="TitlePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="ORBIT.CRAFT" FontSize="50" FontWeight="Bold"
                       Foreground="#FFD060" HorizontalAlignment="Center" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD060" BlurRadius="30" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="N체 중력 궤도 시뮬레이션 퍼즐" FontSize="13" Foreground="#222244"
                       HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Consolas"/>

            <TextBlock Text="[ ENTER TO START ]" FontSize="16" Foreground="#C0A040"
                       HorizontalAlignment="Center" Margin="0,36,0,0" FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#C0A040" BlurRadius="12" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock FontSize="11" Foreground="#222244" HorizontalAlignment="Center"
                       Margin="0,24,0,0" FontFamily="Consolas" TextAlignment="Center">
                <Run Text="마우스 이동  —  발사 방향·속도 조준"/>
                <LineBreak/>
                <Run Text="SPACE  —  발사/리셋    R  —  조준 초기화    ESC  —  타이틀"/>
            </TextBlock>
        </StackPanel>

        <!-- ── 결과 오버레이 ─────────────────────────── -->
        <Border x:Name="ResultOverlay" Background="#CC000008" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ResultTitle" Text="" FontSize="40" FontWeight="Bold"
                           HorizontalAlignment="Center" FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect x:Name="ResultGlow" Color="#FFD060" BlurRadius="26" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="ResultSub" Text="" FontSize="14"
                           Foreground="#FFD060" HorizontalAlignment="Center"
                           Margin="0,12,0,0" FontFamily="Consolas" TextAlignment="Center"/>
                <TextBlock x:Name="ResultAction" Text="" FontSize="13" Foreground="#333355"
                           HorizontalAlignment="Center" Margin="0,28,0,0" FontFamily="Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
