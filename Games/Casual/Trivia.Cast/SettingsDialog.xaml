<Window x:Class="TriviaCast.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="380" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">
    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="피드백 딜레이 설정"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}"/>

        <!-- 정답 딜레이 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="정답 피드백 시간" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="CorrectHint" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
            </StackPanel>
            <Slider Grid.Column="1" x:Name="CorrectSlider"
                    Minimum="500" Maximum="2000" TickFrequency="500"
                    IsSnapToTickEnabled="False"
                    VerticalAlignment="Center"
                    ValueChanged="CorrectSlider_ValueChanged"/>
        </Grid>

        <!-- 오답 딜레이 -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="오답 피드백 시간" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="WrongHint" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
            </StackPanel>
            <Slider Grid.Column="1" x:Name="WrongSlider"
                    Minimum="1000" Maximum="3000" TickFrequency="500"
                    IsSnapToTickEnabled="False"
                    VerticalAlignment="Center"
                    ValueChanged="WrongSlider_ValueChanged"/>
        </Grid>

        <!-- 버튼 -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="취소" Click="CancelBtn_Click"/>
            <Button Grid.Column="2" Content="저장" Click="SaveBtn_Click"/>
        </Grid>
    </Grid>
</Window>
