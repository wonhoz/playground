<Window x:Class="SysClean.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SysClean.Views"
        Title="Sys.Clean"
        Width="1100" Height="720" MinWidth="860" MinHeight="560"
        Background="#1A1A1A"
        FontFamily="Segoe UI" FontSize="13"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterScreen"
>

    <Window.Resources>
        <!-- 사이드바 내비게이션 버튼 스타일 -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="3,0,0,0"
                                Padding="16,14">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C0C0C0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#252535"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#FF6B35" BorderThickness="3,0,0,0"
                                Padding="16,14">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A1810"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             좌측 사이드바
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#16161E" BorderBrush="#252535" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 로고 -->
                <Border DockPanel.Dock="Top" Padding="16,22,16,16"
                        BorderBrush="#252535" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="🧹" FontSize="28" HorizontalAlignment="Left"/>
                        <TextBlock Text="Sys.Clean" FontSize="18" FontWeight="Bold"
                                   Foreground="#E0E0E0" Margin="0,6,0,0"/>
                        <TextBlock Text="시스템 최적화 도구" FontSize="11"
                                   Foreground="#555" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 하단 정보 영역 (DockPanel.Dock="Bottom" 순서 주의) -->
                <Border DockPanel.Dock="Bottom" Padding="14,12" BorderBrush="#252535" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <!-- 디스크 상태 -->
                        <StackPanel Margin="0,0,0,10">
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="C: 드라이브" FontSize="10" Foreground="#555"/>
                                <TextBlock x:Name="TbDiskUsage" Grid.Column="1" FontSize="10" Foreground="#555"/>
                            </Grid>
                            <ProgressBar x:Name="PbDisk" Height="3" Value="0" Maximum="100"
                                         Background="#2A2A2A" Foreground="#FF6B35" BorderThickness="0"/>
                            <TextBlock x:Name="TbDiskFree" FontSize="10" Foreground="#444" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- 구분선 -->
                        <Separator Margin="0,0,0,8"/>

                        <!-- 버전 + 도움말 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TbVersion" FontSize="10" Foreground="#444" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="?" Click="BtnHelp_Click"
                                    Width="22" Height="22" FontSize="11" FontWeight="Bold"
                                    Background="#252535" Foreground="#666" BorderBrush="#333"
                                    ToolTip="도움말 (F1)" Cursor="Hand"
                                    Padding="0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 내비게이션 메뉴 -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <TextBlock Text="청소" Foreground="#444" FontSize="10" FontWeight="SemiBold"
                               Margin="16,0,0,4"/>

                    <Button x:Name="BtnNavCleaner"
                            Style="{StaticResource NavButtonActive}"
                            Click="Nav_Click" Tag="Cleaner">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧹" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="시스템 청소" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="임시 파일 · 브라우저 캐시" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNavRegistry"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click" Tag="Registry">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔧" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="레지스트리" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="잘못된 항목 정리" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Separator Margin="16,12"/>

                    <TextBlock Text="도구" Foreground="#444" FontSize="10" FontWeight="SemiBold"
                               Margin="16,0,0,4"/>

                    <Button x:Name="BtnNavStartup"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click" Tag="Startup">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="시작 프로그램" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="자동 실행 관리" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNavPrograms"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click" Tag="Programs">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="설치된 프로그램" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="소프트웨어 제거" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Separator Margin="16,12"/>

                    <TextBlock Text="기록" Foreground="#444" FontSize="10" FontWeight="SemiBold"
                               Margin="16,0,0,4"/>

                    <Button x:Name="BtnNavHistory"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click" Tag="History">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="청소 기록" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="이력 · 해제 공간 확인" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             우측 콘텐츠 영역
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <views:CleanerView  x:Name="ViewCleaner"  Visibility="Visible"/>
            <views:RegistryView x:Name="ViewRegistry" Visibility="Collapsed"/>
            <views:StartupView  x:Name="ViewStartup"  Visibility="Collapsed"/>
            <views:ProgramsView x:Name="ViewPrograms" Visibility="Collapsed"/>
            <views:HistoryView  x:Name="ViewHistory"  Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
