<Window x:Class="IconHunt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IconHunt"
        xmlns:conv="clr-namespace:IconHunt"
        Title="Icon Hunt"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/app.ico">
    <Window.Resources>
        <!-- 컨버터 인스턴스 -->
        <local:BoolToColorConverter      x:Key="BoolToColor"/>
        <local:BoolToStarConverter       x:Key="BoolToStar"/>
        <local:BoolToVisConverter        x:Key="BoolToVis"/>
        <local:InverseBoolToVisConverter x:Key="InvBoolToVis"/>
        <local:NullToVisConverter        x:Key="NullToVis"/>
        <local:StringToBrushConverter    x:Key="StringToBrush"/>
        <local:PrefixBadgeColorConverter x:Key="PrefixColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- 툴바 -->
            <RowDefinition Height="*"/>    <!-- 본문 -->
            <RowDefinition Height="28"/>   <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ══ 툴바 ═════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 앱 이름 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Icon Hunt" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — 오픈소스 아이콘 탐색기"
                               Foreground="{StaticResource Fg3Brush}"
                               FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 검색창 -->
                <Grid Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
                    <TextBox x:Name="TxtSearch"
                             Height="34"
                             Padding="36,4,10,4"
                             FontSize="14"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="아이콘 이름 또는 태그로 검색"/>
                    <TextBlock Text="🔍" FontSize="14"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource Fg3Brush}"/>
                    <TextBlock Text="검색어를 입력하세요..."
                               FontSize="13"
                               Margin="36,0,10,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource Fg3Brush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- 우측 버튼들 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="즐겨찾기만"
                              IsChecked="{Binding ShowFavoritesOnly}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    <Button Content="캐시 정리" Click="BtnClearCache_Click"
                            Padding="8,5" Margin="0,0,6,0" FontSize="12"
                            ToolTip="다운로드된 SVG 파일 삭제"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ 본문 ═════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="180" MaxWidth="350"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="240" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽: 라이브러리 목록 ──────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <Border Grid.Row="0" Padding="12,10"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="라이브러리" FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg2Brush}"
                                   FontSize="12"/>
                    </Border>

                    <!-- 컬렉션 목록 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Collections}" Margin="6,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="colBd"
                                            Background="Transparent"
                                            CornerRadius="5"
                                            Margin="0,1"
                                            Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsEnabled}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource Fg3Brush}"/>
                                            </StackPanel>

                                            <!-- 인덱스 버튼 -->
                                            <Button Grid.Column="2"
                                                    Content="↓"
                                                    Padding="5,3"
                                                    FontSize="11"
                                                    Margin="4,0,0,0"
                                                    Tag="{Binding}"
                                                    Click="BtnIndex_Click"
                                                    ToolTip="이 라이브러리 인덱싱">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIndexed}" Value="True">
                                                                <Setter Property="Content" Value="✓"/>
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                                <Setter Property="ToolTip" Value="재인덱싱"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 전체 인덱싱 버튼 -->
                    <Border Grid.Row="2" Padding="8,8"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Button Content="📦 전체 인덱싱" Click="BtnIndexAll_Click"
                                Height="30" FontSize="12" Style="{StaticResource AccentButton}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── 스플리터 ──────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          Cursor="SizeWE"/>

            <!-- ── 중앙: 아이콘 그리드 ─────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 최근/즐겨찾기 탭 (아이콘 없을 때) -->
                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="8,6"
                        Visibility="{Binding HasSelection, Converter={StaticResource InvBoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <!-- 최근 아이콘 -->
                        <TextBlock Text="최근:" FontSize="11"
                                   Foreground="{StaticResource Fg3Brush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ItemsControl ItemsSource="{Binding Recents}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="recentBd"
                                            Background="{StaticResource CardBrush}"
                                            CornerRadius="4"
                                            Padding="6,3"
                                            Margin="0,0,4,0"
                                            Cursor="Hand"
                                            ToolTip="{Binding Id}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Fg2Brush}"/>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{x:Null}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 로딩 오버레이 -->
                <Border Grid.Row="1"
                        Background="#80000010"
                        Panel.ZIndex="10"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="인덱싱 중..." FontSize="16"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="PbIndex" Width="200" Height="6" Margin="0,8,0,0"
                                     IsIndeterminate="True"/>
                    </StackPanel>
                </Border>

                <!-- 아이콘 그리드 -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="6">
                    <ItemsControl x:Name="IconGrid" ItemsSource="{Binding Icons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="iconCard"
                                        Width="100" Height="100"
                                        Margin="4"
                                        CornerRadius="8"
                                        Background="{StaticResource CardBrush}"
                                        BorderThickness="1.5"
                                        BorderBrush="Transparent"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{x:Null}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <!-- 즐겨찾기 별표 -->
                                        <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStar}}"
                                                   FontSize="12"
                                                   Foreground="{Binding IsFavorite, Converter={StaticResource BoolToColor}}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"
                                                   Margin="0,4,6,0"
                                                   Panel.ZIndex="1"/>

                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <!-- 프리픽스 뱃지 -->
                                            <Border Background="{Binding Prefix, Converter={StaticResource PrefixColor}}"
                                                    CornerRadius="3"
                                                    Padding="4,1"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Prefix}"
                                                           FontSize="9"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- SVG 렌더 (Image) -->
                                            <Image x:Name="SvgImage"
                                                   Width="40" Height="40"
                                                   Margin="0,0,0,6"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <!-- 이름 -->
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource Fg2Brush}"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="90"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 검색 결과 없음 -->
                <Border Grid.Row="1"
                        Visibility="{Binding ResultCount, Converter={StaticResource NullToVis}}">
                    <!-- 결과 없음은 코드비하인드에서 처리 -->
                </Border>
            </Grid>

            <!-- ── 스플리터 ──────────────────────────────── -->
            <GridSplitter Grid.Column="3" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          Cursor="SizeWE"/>

            <!-- ── 오른쪽: 상세 패널 ───────────────────── -->
            <Border Grid.Column="4"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">

                <Grid>
                <!-- 선택 없음 -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasSelection, Converter={StaticResource InvBoolToVis}}">
                    <TextBlock Text="🔍" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="아이콘을 선택하면" FontSize="13"
                               Foreground="{StaticResource Fg3Brush}"
                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                    <TextBlock Text="미리보기가 표시됩니다" FontSize="13"
                               Foreground="{StaticResource Fg3Brush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 상세 정보 -->
                <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 미리보기 -->
                        <RowDefinition Height="Auto"/>  <!-- 정보 -->
                        <RowDefinition Height="Auto"/>  <!-- 버튼 -->
                        <RowDefinition Height="*"/>     <!-- 여백 -->
                    </Grid.RowDefinitions>

                    <!-- SVG 미리보기 -->
                    <Border Grid.Row="0" Margin="16,16,16,8"
                            CornerRadius="10"
                            Background="{Binding PreviewBg, Converter={StaticResource StringToBrush}}"
                            Height="180">
                        <Grid>
                            <!-- 다크/라이트 토글 -->
                            <Button Content="{Binding IsDarkPreview, Converter={StaticResource BoolToStar}}"
                                    Width="28" Height="28"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    FontSize="14"
                                    Click="BtnTogglePreview_Click"
                                    ToolTip="다크/라이트 배경 전환"/>

                            <!-- 실제 SVG 이미지 -->
                            <Image x:Name="DetailSvgImage"
                                   Width="100" Height="100"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                            <!-- 로딩 중 -->
                            <TextBlock Text="로딩 중..."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Fg3Brush}"
                                       FontSize="12"
                                       x:Name="TblDetailLoading"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- 아이콘 정보 -->
                    <StackPanel Grid.Row="1" Margin="16,0,16,8">
                        <!-- 이름 -->
                        <TextBlock Text="{Binding SelectedIcon.Name}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>

                        <!-- 컬렉션 정보 -->
                        <TextBlock Text="{Binding SelectedCollectionInfo}"
                                   FontSize="11"
                                   Foreground="{StaticResource Fg3Brush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <!-- 태그 -->
                        <TextBlock Text="{Binding SelectedIcon.Tags}"
                                   FontSize="10"
                                   Foreground="{StaticResource Fg3Brush}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="36"/>

                        <Separator Margin="0,8"/>

                        <!-- ID -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ID:" FontSize="11"
                                       Foreground="{StaticResource Fg3Brush}"
                                       Width="40"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedIcon.Id}"
                                       FontSize="11"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource Accent2Brush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </StackPanel>

                    <!-- 즐겨찾기 + 복사 버튼 -->
                    <Grid Grid.Row="2" Margin="16,0,16,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 즐겨찾기 -->
                        <Button Grid.Row="0"
                                Height="32"
                                Margin="0,0,0,6"
                                Click="BtnFavorite_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Content" Value="☆  즐겨찾기 추가"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedIcon.IsFavorite}" Value="True">
                                            <Setter Property="Content" Value="★  즐겨찾기 해제"/>
                                            <Setter Property="Foreground" Value="{StaticResource StarBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- 복사 버튼들 -->
                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,6">
                            <Button Content="SVG 복사" Click="BtnCopySvg_Click"
                                    Height="30" Margin="0,0,3,0" FontSize="11"/>
                            <Button Content="이름 복사" Click="BtnCopyName_Click"
                                    Height="30" Margin="3,0,3,0" FontSize="11"/>
                            <Button Content="ID 복사" Click="BtnCopyId_Click"
                                    Height="30" Margin="3,0,0,0" FontSize="11"/>
                        </UniformGrid>

                        <!-- PNG 저장 -->
                        <Button Grid.Row="2"
                                Content="📥 PNG로 저장..."
                                Height="32"
                                Click="BtnSavePng_Click"
                                Style="{StaticResource AccentButton}"/>
                    </Grid>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ 상태바 ════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource Fg2Brush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatsText}"
                           Foreground="{StaticResource Fg3Brush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 인덱싱 진행 오버레이 -->
        <Border x:Name="IndexProgressPanel"
                Grid.Row="0" Grid.RowSpan="3"
                Background="#CC000010"
                Panel.ZIndex="100"
                Visibility="Collapsed">
            <Border Background="{StaticResource CardBrush}"
                    CornerRadius="12"
                    Padding="32,24"
                    Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="TblIndexStatus"
                               Text="인덱싱 중..."
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ProgressBar x:Name="PbIndexProgress"
                                 Height="8"
                                 Minimum="0" Maximum="100"
                                 Value="0"
                                 Margin="0,0,0,8"/>
                    <TextBlock x:Name="TblIndexDetail"
                               Text=""
                               FontSize="12"
                               Foreground="{StaticResource Fg3Brush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>
                    <Button x:Name="BtnCancelIndex"
                            Content="취소"
                            Height="32"
                            Click="BtnCancelIndex_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
