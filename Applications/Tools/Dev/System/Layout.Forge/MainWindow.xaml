<Window x:Class="Layout.Forge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layout.Forge — 키보드 리매핑"
        Width="1000" Height="540"
        MinWidth="860" MinHeight="480"
        Background="#13131F" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="TbBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderBrush"     Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252535"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Background"  Value="#1E3A5E"/>
            <Setter Property="Foreground"  Value="#60A5FA"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
        </Style>

        <!-- ComboBox 다크 스타일 -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="#1E1E2E"/>
            <Setter Property="Foreground"       Value="#E0E0E0"/>
            <Setter Property="BorderBrush"      Value="#2A2A3E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▾" Foreground="#555566"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom">
                                    <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1"
                                            MaxHeight="300" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                                <ToggleButton Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent" BorderThickness="0" Opacity="0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"  Value="True"> <Setter Property="Background" Value="#252535"/> </Trigger>
                            <Trigger Property="IsSelected"   Value="True"> <Setter Property="Background" Value="#1E3A5E"/> <Setter Property="Foreground" Value="#60A5FA"/> </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 스크롤바 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="Width"      Value="8"/>
            <Setter Property="MinWidth"   Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/></Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/></Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Bd" Background="#3A3A55" CornerRadius="4" Margin="2,2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#5A5A7A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>  <!-- 툴바 -->
            <RowDefinition Height="*"/>   <!-- 키보드 -->
            <RowDefinition Height="Auto"/><!-- 선택 정보 바 -->
            <RowDefinition Height="52"/>  <!-- Apply/Restore -->
        </Grid.RowDefinitions>

        <!-- ── 툴바 ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#16162A" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="프로파일:" Foreground="#888899" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbProfiles" Width="160" VerticalAlignment="Center"
                          DisplayMemberPath="Name"/>
                <Button Style="{StaticResource TbBtn}" Content="+ 새 프로파일" Margin="6,0,0,0" Click="NewProfile_Click"/>
                <Button Style="{StaticResource TbBtn}" Content="이름 변경" Margin="4,0,0,0" Click="RenameProfile_Click"/>
                <Button Style="{StaticResource DangerBtn}" Content="삭제" Margin="4,0,0,0" Click="DeleteProfile_Click"/>
                <Separator Background="#2A2A3E" Width="1" Height="20" Margin="12,0"/>
                <TextBlock VerticalAlignment="Center" FontSize="11">
                    <Run Text="■ 리매핑" Foreground="#60A5FA"/>
                    <Run Text="  ■ 비활성화" Foreground="#EF4444"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 키보드 캔버스 (코드에서 빌드) ──────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto" Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                <StackPanel x:Name="PnlMain" Orientation="Vertical"/>
                <Border Width="20"/>
                <StackPanel x:Name="PnlNav"  Orientation="Vertical"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ── 선택 키 정보 바 ───────────────────────────────────────── -->
        <Border x:Name="SelectionBar" Grid.Row="2"
                Background="#16162A" BorderBrush="#1E1E2E" BorderThickness="0,1,0,0"
                Padding="14,8" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="선택:" Foreground="#555566" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Border Background="#1A2A4A" BorderBrush="#2563EB" BorderThickness="1"
                        CornerRadius="4" Padding="8,4" Margin="0,0,12,0">
                    <TextBlock x:Name="TxtSelectedKey" Foreground="#60A5FA" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="→  대상:" Foreground="#888899" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbTarget" Width="200" VerticalAlignment="Center"
                          DisplayMemberPath="Name"/>
                <Button Style="{StaticResource AccentBtn}" Content="설정" Margin="8,0,4,0" Click="SetRemap_Click"/>
                <Button Style="{StaticResource TbBtn}"     Content="지우기" Margin="0,0,0,0" Click="ClearRemap_Click"/>
            </StackPanel>
        </Border>

        <!-- ── 하단 Apply / Restore + 상태 ────────────────────────── -->
        <Border Grid.Row="3" Background="#16162A" BorderBrush="#1E1E2E" BorderThickness="0,1,0,0" Padding="14,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource AccentBtn}" Content="🔧  시스템에 적용 (재부팅 필요)"
                        FontSize="13" Padding="16,6" Click="Apply_Click"/>
                <Button Style="{StaticResource DangerBtn}" Content="↩  기본값 복원 (Scancode Map 삭제)"
                        FontSize="13" Padding="16,6" Margin="8,0,0,0" Click="Restore_Click"/>
                <TextBlock x:Name="TxtStatus" Foreground="#4ADE80"
                           VerticalAlignment="Center" Margin="16,0,0,0" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
