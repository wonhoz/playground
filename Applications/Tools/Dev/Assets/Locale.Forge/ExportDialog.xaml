<Window x:Class="LocaleForge.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="형식 변환 내보내기" Width="500" Height="320"
        Background="#1A1A2E" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="변환할 언어 파일을 선택하고 내보낼 형식을 지정하세요."
                   Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="언어:" Foreground="#E0E0E0" VerticalAlignment="Center" Width="60" Margin="0,0,10,0"/>
            <ComboBox x:Name="CbLang" Width="180"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <TextBlock Text="대상 형식:" Foreground="#E0E0E0" VerticalAlignment="Center" Width="60" Margin="0,0,10,0"/>
            <ComboBox x:Name="CbFormat" Width="180">
                <ComboBoxItem Content="JSON" Tag="Json"/>
                <ComboBoxItem Content="YAML" Tag="Yaml"/>
                <ComboBoxItem Content="RESX (Windows 리소스)" Tag="Resx"/>
                <ComboBoxItem Content="PO (GNU Gettext)" Tag="Po"/>
                <ComboBoxItem Content="Properties (Java)" Tag="Properties"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal">
            <TextBlock Text="저장 경로:" Foreground="#E0E0E0" VerticalAlignment="Center" Width="60" Margin="0,0,10,0"/>
            <TextBox x:Name="TxtSavePath" Width="280" Height="28" IsReadOnly="True" Margin="0,0,8,0"/>
            <Button Content="찾기..." Width="60" Click="BtnBrowse_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Width="80" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="내보내기" Width="90" Click="BtnExport_Click"
                    Background="#E94560" BorderBrush="#E94560"/>
        </StackPanel>
    </Grid>
</Window>
