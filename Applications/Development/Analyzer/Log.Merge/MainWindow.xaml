<Window x:Class="LogMerge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log.Merge — 다중 소스 통합 뷰어"
        Width="1300" Height="780" MinWidth="900" MinHeight="500"
        Background="#1A1A1A"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 툴바 -->
            <RowDefinition Height="Auto"/>  <!-- 필터 바 -->
            <RowDefinition Height="*"/>     <!-- 본문 -->
            <RowDefinition Height="Auto"/>  <!-- 상태 바 -->
        </Grid.RowDefinitions>

        <!-- ══ 툴바 ══ -->
        <Border Grid.Row="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button x:Name="BtnAddFile" Content="＋ 파일 추가" Padding="10,5" Click="BtnAddFile_Click" ToolTip="로그 파일 추가 (Ctrl+O)"/>
                <Button x:Name="BtnAddFolder" Content="📁 폴더" Padding="10,5" Margin="6,0,0,0"
                        Style="{StaticResource SecondaryBtn}" Click="BtnAddFolder_Click"/>
                <Separator Width="1" Background="#333333" Margin="8,2"/>
                <Button x:Name="BtnClearAll" Content="🗑 전체 제거" Padding="10,5"
                        Style="{StaticResource SecondaryBtn}" Click="BtnClearAll_Click"/>
                <Separator Width="1" Background="#333333" Margin="8,2"/>
                <CheckBox x:Name="ChkAutoScroll" Content="자동 스크롤" IsChecked="True"
                          VerticalAlignment="Center" Margin="4,0"/>
            </StackPanel>
        </Border>

        <!-- ══ 필터 바 ══ -->
        <Border Grid.Row="1" Background="#161616" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <Grid Margin="8,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 레벨 필터 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="레벨:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                    <CheckBox x:Name="ChkFatal" Content="FATAL" Foreground="#FF4747" IsChecked="True"
                              Checked="LevelFilter_Changed" Unchecked="LevelFilter_Changed" Margin="0,0,6,0"/>
                    <CheckBox x:Name="ChkError" Content="ERROR" Foreground="#FF6B6B" IsChecked="True"
                              Checked="LevelFilter_Changed" Unchecked="LevelFilter_Changed" Margin="0,0,6,0"/>
                    <CheckBox x:Name="ChkWarn"  Content="WARN"  Foreground="#FFD93D" IsChecked="True"
                              Checked="LevelFilter_Changed" Unchecked="LevelFilter_Changed" Margin="0,0,6,0"/>
                    <CheckBox x:Name="ChkInfo"  Content="INFO"  Foreground="#00C8FF" IsChecked="True"
                              Checked="LevelFilter_Changed" Unchecked="LevelFilter_Changed" Margin="0,0,6,0"/>
                    <CheckBox x:Name="ChkDebug" Content="DEBUG" Foreground="#6EA8FE" IsChecked="True"
                              Checked="LevelFilter_Changed" Unchecked="LevelFilter_Changed" Margin="0,0,6,0"/>
                    <CheckBox x:Name="ChkNone"  Content="기타"  Foreground="#888888" IsChecked="True"
                              Checked="LevelFilter_Changed" Unchecked="LevelFilter_Changed"/>
                    <Separator Width="1" Background="#333333" Margin="8,2"/>
                </StackPanel>

                <!-- 코릴레이션 ID 표시 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="추적 ID:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                    <Border x:Name="BdrCorrelation" Background="#2A1A00" BorderBrush="#FF9A3C"
                            BorderThickness="1" CornerRadius="3" Padding="6,2" Cursor="Hand"
                            MouseLeftButtonDown="BdrCorrelation_Click" ToolTip="클릭하여 추적 해제">
                        <TextBlock x:Name="TxtCorrelation" Text="(없음)" Foreground="#FF9A3C" FontSize="11"
                                   FontFamily="Consolas"/>
                    </Border>
                </StackPanel>

                <Separator Grid.Column="2" Width="1" Background="#333333" Margin="4,2"/>

                <!-- 정규식 필터 -->
                <Grid Grid.Column="3" Margin="4,0">
                    <TextBox x:Name="TxtFilter" Padding="6,4"
                             TextChanged="TxtFilter_TextChanged"
                             FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Text="🔍 정규식 필터 (실시간)..." Foreground="#555555"
                               IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtFilter}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Grid.Column="4" x:Name="TxtCount" Foreground="#555555"
                           VerticalAlignment="Center" Margin="8,0,4,0" FontSize="11"/>
            </Grid>
        </Border>

        <!-- ══ 본문: 소스 패널 + 통합 뷰 ══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="350"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 소스 목록 패널 -->
            <Border Grid.Column="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#161616" Padding="8,6">
                        <TextBlock Text="소스 목록" Foreground="#888888" FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <ListBox x:Name="LstSources" Grid.Row="1"
                             Background="#141414" BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,5" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 색상 인디케이터 -->
                                        <Border Grid.Column="0" Width="4" CornerRadius="2"
                                                Background="{Binding Brush}" Margin="0,0,6,0"/>

                                        <!-- 파일명 -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Label}" Foreground="#E0E0E0"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FilePath}"/>
                                            <TextBlock Text="{Binding FilePath}" Foreground="#555555"
                                                       FontSize="9" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- 제거 버튼 -->
                                        <Button Grid.Column="2" Content="×" Width="18" Height="18"
                                                Background="Transparent" Foreground="#555555"
                                                BorderThickness="0" Cursor="Hand" FontSize="13"
                                                Tag="{Binding}" Click="BtnRemoveSource_Click"
                                                Padding="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 드래그 힌트 -->
                    <Border x:Name="BdrSourceHint" Grid.Row="1" Background="#141414"
                            Visibility="Visible">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                            <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="파일을 드래그하거나&#10;위 버튼으로 추가" Foreground="#444444"
                                       TextAlignment="Center" FontSize="11" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 그리퍼 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#2A2A2A" ResizeDirection="Columns"/>

            <!-- 통합 로그 뷰 -->
            <Grid Grid.Column="2">
                <!-- 헤더 -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <Grid Margin="4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="시각"     Foreground="#555555" FontSize="10" Padding="4,4" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="소스"     Foreground="#555555" FontSize="10" Padding="4,4"/>
                        <TextBlock Grid.Column="2" Text="레벨"     Foreground="#555555" FontSize="10" Padding="4,4"/>
                        <TextBlock Grid.Column="3" Text="메시지"   Foreground="#555555" FontSize="10" Padding="4,4"/>
                    </Grid>
                </Border>

                <ListBox x:Name="LstEntries" Grid.Row="1"
                         Background="#1A1A1A" BorderThickness="0"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         SelectionChanged="LstEntries_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Background" Value="{Binding RowBackground}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding TimestampDisplay}"
                                           Foreground="#555555" FontSize="11" FontFamily="Consolas"
                                           Padding="4,2" VerticalAlignment="Center"/>

                                <Border Grid.Column="1" Background="{Binding Source.BadgeBrush}"
                                        CornerRadius="3" Margin="2,2" Padding="4,1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Source.Label}"
                                               Foreground="{Binding Source.Brush}"
                                               FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </Border>

                                <TextBlock Grid.Column="2" Text="{Binding Level}"
                                           Foreground="{Binding LevelBrush}"
                                           FontSize="10" FontFamily="Consolas"
                                           Padding="2,2" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="3" Text="{Binding Raw}"
                                           Foreground="#C0C0C0" FontSize="11" FontFamily="Consolas"
                                           Padding="4,2" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Raw}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 빈 힌트 -->
                <Border x:Name="BdrEmptyHint" Grid.Row="1" Background="#1A1A1A" IsHitTestVisible="False">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center" Opacity="0.2"/>
                        <TextBlock Text="로그 파일을 추가하면 타임라인이 통합됩니다"
                                   Foreground="#333333" FontSize="13" Margin="0,10,0,0"/>
                        <TextBlock Text="여러 파일을 동시에 드래그 &amp; 드롭" Foreground="#2A2A2A"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ 상태 바 ══ -->
        <Border Grid.Row="3" Background="#111111" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
            <Grid Margin="8,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0" Foreground="#555555" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTotal" Grid.Column="1" Foreground="#444444" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
