<Window x:Class="CaseForge.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Case.Forge"
        Width="520" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated"
        Loaded="Window_Loaded">

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#000000"/>
    </Window.Effect>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Margin="16,12,12,0"
                  MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cc  Case.Forge"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <!-- 즐겨찾기 전용 보기 토글 -->
                <Button Grid.Column="1" x:Name="PinFilterBtn"
                        Width="28" Height="28" Content="☆" FontSize="14"
                        Foreground="{StaticResource TextSecondary}" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Click="PinFilterBtn_Click"
                        ToolTip="즐겨찾기만 보기">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252540"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- 설정 -->
                <Button Grid.Column="2" Width="28" Height="28" Content="⚙" FontSize="13"
                        Foreground="{StaticResource TextSecondary}" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Click="SettingsBtn_Click"
                        ToolTip="설정">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252540"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="3" Width="28" Height="28" Content="✕" FontSize="11"
                        Foreground="{StaticResource TextSecondary}" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252540"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 입력 -->
            <Grid Grid.Row="1" Margin="12,10,12,0">
                <TextBox x:Name="InputBox" MinHeight="45" MaxHeight="90"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="InputBox_TextChanged"
                         PreviewKeyDown="InputBox_PreviewKeyDown"/>
                <TextBlock x:Name="Placeholder"
                           Text="변환할 텍스트 입력 (줄바꿈으로 여러 단어 일괄 변환)"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="Segoe UI" FontSize="12"
                           IsHitTestVisible="False"
                           VerticalAlignment="Top"
                           Margin="12,14,0,0"/>
            </Grid>

            <!-- 케이스 목록 -->
            <ScrollViewer Grid.Row="2" Margin="12,8,12,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultPanel"/>
            </ScrollViewer>

            <!-- 상태바 -->
            <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12" Padding="14,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="CopyAllBtn"
                            Content="전체 복사" FontSize="10" Height="22" Padding="6,0"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="CopyAllBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#252540"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Grid.Column="2" x:Name="HotkeyHint" Text="Win+Shift+C"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
