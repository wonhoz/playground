<Window x:Class="Prompt.Forge.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="동기화 설정" Width="580"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#0E1A28" Foreground="#E0E0E0"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="#152230"/>
            <Setter Property="Foreground"       Value="#E0E0E0"/>
            <Setter Property="BorderBrush"      Value="#1E3555"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="CaretBrush"       Value="#1976D2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"    Value="#162840"/>
            <Setter Property="Foreground"    Value="#B0C8E0"/>
            <Setter Property="BorderBrush"   Value="#1E3555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="12,6"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E3348"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#8AAAC8"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 방법 1: DB 경로 -->
        <StackPanel Grid.Row="0">
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1976D2" Margin="0,0,0,10">
                방법 1 — 클라우드 드라이브 (OneDrive / Google Drive / Dropbox)
            </TextBlock>
            <TextBlock Foreground="#6A8FAD" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10">
                DB 파일 경로를 클라우드 드라이브 폴더 안으로 지정하면 자동으로 동기화됩니다.
                변경 후 앱을 재시작하면 적용됩니다. (동시에 두 PC에서 열지 마세요)
            </TextBlock>
            <Label Content="프롬프트 DB 파일 경로 (비워두면 기본값 사용)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtDbPath" Height="48"/>
                <Button  Grid.Column="2" Content="찾아보기" Height="32" Click="Browse_Click"/>
                <Button  Grid.Column="4" Content="기본값" Height="32" Click="ResetDbPath_Click"/>
            </Grid>
            <TextBlock x:Name="TxtCurrentPath" Foreground="#3A5570" FontSize="10"
                       TextWrapping="Wrap" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- 구분선 -->
        <Separator Grid.Row="1" Background="#162840" VerticalAlignment="Center"/>

        <!-- 방법 2: GitHub Gist -->
        <StackPanel Grid.Row="2">
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1976D2" Margin="0,0,0,10">
                방법 2 — GitHub Gist (JSON 수동 동기화)
            </TextBlock>
            <TextBlock Foreground="#6A8FAD" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10">
                GitHub Personal Access Token(PAT)을 입력하면 툴바의 ☁ 버튼으로 Gist에 업로드/다운로드할 수 있습니다.
                PAT 권한: gist (read/write)
            </TextBlock>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="GitHub Personal Access Token"/>
                    <TextBox x:Name="TxtPat" Height="48"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Label Content="Gist ID (처음 업로드 후 자동 저장)"/>
                    <TextBox x:Name="TxtGistId" Height="48"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="저장" Style="{StaticResource AccentBtn}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
