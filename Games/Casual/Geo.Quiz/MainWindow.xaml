<Window x:Class="Geo.Quiz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geo.Quiz — 세계 지리 퀴즈"
        Width="600" Height="700"
        MinWidth="480" MinHeight="560"
        Background="#1A1A2E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- 기본 버튼 -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#C0C0D0"/>
            <Setter Property="BorderBrush"     Value="#3A3A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A40"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6D28D9"/>
                                <Setter Property="Foreground" Value="#E0E0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 강조 버튼 (아이콘 핑크 #DB2777 포인트 컬러 반영) -->
        <Style x:Key="AccBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="#2D1040"/>
            <Setter Property="Foreground"  Value="#F9A8D4"/>
            <Setter Property="BorderBrush" Value="#BE185D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D1450"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#DB2777"/>
                                <Setter Property="Foreground" Value="#FBCFE8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 선택지 버튼 -->
        <Style x:Key="ChoiceBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A40"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6D28D9"/>
                                <Setter Property="Foreground" Value="#E0E0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#0C0C20"/>
            <Setter Property="Foreground"      Value="#C0C0D0"/>
            <Setter Property="BorderBrush"     Value="#3A3A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="0,0,24,0"/>
                                    <TextBlock Text="▾" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Foreground="#606080" Margin="0,0,4,0"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom">
                                <Border Background="#12122A" BorderBrush="#3A3A5A" BorderThickness="1" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5A5A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Foreground"  Value="#C0C0D0"/>
                        <Setter Property="Padding"     Value="12,8"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#E0E0FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar (다크 테마) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#1A1A30" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBd" Background="#3A3A5A"
                                                        CornerRadius="4" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Background" Value="#6D28D9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RadioButton (모드 선택) -->
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#14142A" BorderBrush="#2A2A4A"
                                BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1B4B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6D28D9"/>
                                <Setter Property="Foreground" Value="#A78BFA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ══ 우상단 고정 버튼 (뮤트 + 도움말) ════════════════════════════════ -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,14,14,0" Panel.ZIndex="10">
            <Button x:Name="BtnHelp" Content="?" FontFamily="Segoe UI"
                    Style="{StaticResource Btn}" FontSize="15" FontWeight="Bold"
                    Width="38" Height="38" Padding="0" Margin="0,0,6,0"
                    Click="BtnHelp_Click" ToolTip="단축키 도움말 (F1)"/>
            <Button x:Name="BtnMute" Content="🔊" FontFamily="Segoe UI Emoji"
                    Style="{StaticResource Btn}" FontSize="16"
                    Width="38" Height="38" Padding="0"
                    Click="BtnMute_Click" ToolTip="배경음악 음소거"/>
        </StackPanel>

        <!-- ══ 도움말 팝업 ════════════════════════════════════════════════════ -->
        <Popup x:Name="HelpPopup" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=BtnHelp}"
               Placement="Bottom" StaysOpen="False"
               HorizontalOffset="-160" VerticalOffset="4">
            <Border Background="#12122A" BorderBrush="#3A3A5A" BorderThickness="1"
                    CornerRadius="10" Padding="20,16" MinWidth="240">
                <StackPanel>
                    <TextBlock Text="⌨  단축키 안내" Foreground="#A78BFA"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- 행 0 -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#1E1B4B" CornerRadius="4"
                                Padding="6,3" Margin="0,0,10,6">
                            <TextBlock Text="1 / 2 / 3 / 4" Foreground="#A78BFA" FontSize="11" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="선택지 선택"
                                   Foreground="#C0C0D0" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <!-- 행 1 -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#1E1B4B" CornerRadius="4"
                                Padding="6,3" Margin="0,0,10,6">
                            <TextBlock Text="Enter / Space" Foreground="#A78BFA" FontSize="11" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="다음 문제"
                                   Foreground="#C0C0D0" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <!-- 행 2 -->
                        <Border Grid.Row="2" Grid.Column="0" Background="#1E1B4B" CornerRadius="4"
                                Padding="6,3" Margin="0,0,10,6">
                            <TextBlock Text="H" Foreground="#A78BFA" FontSize="11" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="힌트 사용 (-5점)"
                                   Foreground="#C0C0D0" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <!-- 행 3 -->
                        <Border Grid.Row="3" Grid.Column="0" Background="#1E1B4B" CornerRadius="4"
                                Padding="6,3" Margin="0,0,10,6">
                            <TextBlock Text="P / Esc" Foreground="#A78BFA" FontSize="11" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="일시정지 / 재개 (타이머 모드)"
                                   Foreground="#C0C0D0" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <!-- 행 4 -->
                        <Border Grid.Row="4" Grid.Column="0" Background="#1E1B4B" CornerRadius="4"
                                Padding="6,3" Margin="0,0,10,6">
                            <TextBlock Text="F1" Foreground="#A78BFA" FontSize="11" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="이 도움말 열기/닫기"
                                   Foreground="#C0C0D0" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ══ 시작 화면 ══════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="StartPanel" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsStartScreen, Converter={StaticResource BoolVis}}">
            <StackPanel Margin="50,40" MaxWidth="480">
                <!-- 타이틀 -->
                <TextBlock Text="🌍" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Geo.Quiz" FontSize="32" FontWeight="Bold"
                           Foreground="#A78BFA" HorizontalAlignment="Center"/>
                <TextBlock Text="세계 지리 퀴즈" FontSize="15" Foreground="#6A6A9A"
                           HorizontalAlignment="Center" Margin="0,4,0,40"/>

                <!-- 퀴즈 모드 -->
                <TextBlock Text="퀴즈 모드" Foreground="#8A8AAA" FontSize="11" Margin="0,0,0,8"/>
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <RadioButton x:Name="RbCapital"   Content="🏛️ 수도 맞추기"  Style="{StaticResource ModeRadio}"
                                 IsChecked="True" GroupName="Mode" Margin="0,0,6,0" Checked="Mode_Checked"/>
                    <RadioButton x:Name="RbFlag"      Content="🚩 국기 맞추기"  Style="{StaticResource ModeRadio}"
                                 GroupName="Mode" Margin="3,0,3,0" Checked="Mode_Checked"/>
                    <RadioButton x:Name="RbContinent" Content="🗺️ 대륙 맞추기" Style="{StaticResource ModeRadio}"
                                 GroupName="Mode" Margin="6,0,0,0" Checked="Mode_Checked"/>
                </UniformGrid>

                <!-- 대륙 필터 -->
                <TextBlock Text="대륙 범위" Foreground="#8A8AAA" FontSize="11" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding Continents}"
                          SelectedItem="{Binding Continent, Mode=TwoWay}"
                          Margin="0,0,0,24"/>

                <!-- 문제 수 -->
                <TextBlock Text="문제 수" Foreground="#8A8AAA" FontSize="11" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding CountOptions}"
                          SelectedItem="{Binding QuestionCount, Mode=TwoWay}"
                          Margin="0,0,0,24"/>

                <!-- 타이머 모드 -->
                <CheckBox x:Name="CbTimer" Content="⏱  타이머 모드 (문제당 15초)"
                          IsChecked="{Binding TimerMode, Mode=TwoWay}"
                          Foreground="#9CA3AF" FontSize="13"
                          Cursor="Hand" Margin="0,0,0,40"
                          Checked="CbTimer_Changed" Unchecked="CbTimer_Changed">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <Border x:Name="Bd" Background="#14142A" BorderBrush="#2A2A4A"
                                                BorderThickness="1" CornerRadius="6" Padding="10,8">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="Box" Width="16" Height="16"
                                                        BorderBrush="#5A5A7A" BorderThickness="1"
                                                        CornerRadius="3" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock x:Name="Check" Text="✓" FontSize="11"
                                                               Foreground="#A78BFA" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" Visibility="Collapsed"/>
                                                </Border>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1E1B4B"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6D28D9"/>
                                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                                <Setter Property="Foreground" Value="#A78BFA"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A1A38"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <!-- 시작 버튼 -->
                <Button Content="▶  퀴즈 시작" Style="{StaticResource AccBtn}"
                        Command="{Binding StartCmd}"
                        FontSize="15" Padding="0,14" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ 퀴즈 화면 ══════════════════════════════════════════════════════ -->
        <Grid x:Name="QuizPanel"
              Visibility="{Binding IsQuizScreen, Converter={StaticResource BoolVis}}"
              Margin="40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 진행 표시 + 메뉴 버튼 -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="← 메뉴" Style="{StaticResource Btn}"
                            Command="{Binding RestartCmd}"
                            FontSize="11" Padding="10,4" Margin="0,0,12,0"
                            VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1" Value="{Binding ProgressPct, Mode=OneWay}" Minimum="0" Maximum="100"
                                 Height="6" Background="#1A1A30" Foreground="#7C3AED"
                                 VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding ProgressText}"
                               Foreground="#6A6A9A" FontSize="11" Margin="12,0,6,0"
                               VerticalAlignment="Center"/>
                    <!-- 일시정지 버튼 (타이머 모드에서만 표시) -->
                    <Button Grid.Column="3"
                            Content="{Binding PauseLabel}"
                            Style="{StaticResource Btn}"
                            Command="{Binding PauseCmd}"
                            FontSize="11" Padding="10,4"
                            Visibility="{Binding TimerMode, Converter={StaticResource BoolVis}}"
                            VerticalAlignment="Center"/>
                </Grid>
                <!-- 타이머 바 (타이머 모드 시에만 표시) -->
                <Grid Grid.Row="1" Margin="0,8,0,0"
                      Visibility="{Binding TimerMode, Converter={StaticResource BoolVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0"
                                 Value="{Binding TimerPct, Mode=OneWay}" Minimum="0" Maximum="100"
                                 Height="4" Background="#2D1B69" Foreground="#DB2777"
                                 VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding TimeLeft, StringFormat='{}{0}초'}"
                               Foreground="#DB2777" FontSize="11" Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- 질문 영역 -->
            <Border Grid.Row="1" Background="#0C0C22" BorderBrush="#1A1A40"
                    BorderThickness="1" CornerRadius="12" Padding="30,20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- 국기 이미지 (Flag 모드 전용) — flagcdn.com PNG 로드 -->
                    <Image x:Name="FlagImage"
                           MaxWidth="220" MaxHeight="130"
                           HorizontalAlignment="Center"
                           Stretch="Uniform"
                           Visibility="Collapsed"
                           Margin="0,0,0,12"/>
                    <TextBlock x:Name="TbFlagError"
                               Text="⚠️ 국기 이미지를 불러올 수 없습니다 (인터넷 연결 확인)"
                               Foreground="#FBBF24" FontSize="12"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,0,0,12"
                               Visibility="Collapsed"/>

                    <!-- 질문 텍스트 -->
                    <TextBlock Text="{Binding CurrentQuestion.QuestionText}"
                               FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap"
                               Foreground="#E0E0F0" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,0,0,20"/>

                    <!-- 선택지 4개 -->
                    <Button x:Name="BtnChoice0" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[0]}"
                            Command="{Binding Choice0Cmd}" Margin="0,0,0,8"
                            Tag="0" Click="Choice_Click"/>
                    <Button x:Name="BtnChoice1" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[1]}"
                            Command="{Binding Choice1Cmd}" Margin="0,0,0,8"
                            Tag="1" Click="Choice_Click"/>
                    <Button x:Name="BtnChoice2" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[2]}"
                            Command="{Binding Choice2Cmd}" Margin="0,0,0,8"
                            Tag="2" Click="Choice_Click"/>
                    <Button x:Name="BtnChoice3" Style="{StaticResource ChoiceBtn}"
                            Content="{Binding CurrentQuestion.Choices[3]}"
                            Command="{Binding Choice3Cmd}"
                            Tag="3" Click="Choice_Click"/>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 힌트 + 다음 버튼 -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="💡 힌트 (-5점)" Style="{StaticResource Btn}"
                        Command="{Binding HintCmd}"
                        FontSize="12" Padding="14,12" Margin="0,0,10,0"/>
                <Button Grid.Column="1" Content="다음 ▶" Style="{StaticResource AccBtn}"
                        Command="{Binding NextCmd}"
                        FontSize="14" Padding="0,12"/>
            </Grid>
        </Grid>

        <!-- ══ 결과 화면 ══════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="ResultPanel"
                      Visibility="{Binding IsResultScreen, Converter={StaticResource BoolVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="60,40,60,40">
                <TextBlock x:Name="TbGradeEmoji" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="TbGrade" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="TbScore" FontSize="18" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <!-- 정답/오답 통계 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0F2D1F" BorderBrush="#155724"
                            BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TbCorrect" FontSize="28" FontWeight="Bold"
                                       Foreground="#4ADE80" HorizontalAlignment="Center"/>
                            <TextBlock Text="정답" Foreground="#4ADE80" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#2D0F0F" BorderBrush="#7F1D1D"
                            BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="8,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TbWrong" FontSize="28" FontWeight="Bold"
                                       Foreground="#F87171" HorizontalAlignment="Center"/>
                            <TextBlock Text="오답" Foreground="#F87171" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 오답 노트 -->
                <StackPanel x:Name="WrongPanel" Margin="0,0,0,24">
                    <TextBlock Text="📝 오답 노트" Foreground="#8A8AAA" FontSize="11"
                               Margin="0,0,0,8"/>
                    <ItemsControl x:Name="WrongList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A2E" BorderBrush="#2D2D4A"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="14,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding QuestionText}"
                                                       Foreground="#C0C0D0" FontSize="12"
                                                       TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="내 답: " Foreground="#F87171" FontSize="11"/>
                                                <TextBlock Text="{Binding UserAnswer}"
                                                           Foreground="#F87171" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="정답" Foreground="#4ADE80" FontSize="10"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding CorrectAnswer}"
                                                       Foreground="#4ADE80" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Button Content="📝  오답만 다시 풀기" Style="{StaticResource Btn}"
                        Command="{Binding RetryWrongCmd}"
                        FontSize="14" Padding="0,14" HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"/>
                <Button Content="🔄  다시 하기" Style="{StaticResource AccBtn}"
                        Command="{Binding RestartCmd}"
                        FontSize="14" Padding="0,14" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
