<Window x:Class="NeonSlice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:engine="clr-namespace:NeonSlice.Engine"
        Title="Neon.Slice"
        Width="900" Height="680"
        MinWidth="700" MinHeight="520"
        Background="#0A0A0F"
        WindowStartupLocation="CenterScreen">

  <Grid x:Name="RootGrid">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 게임 캔버스 레이어 (항상 바닥)                                  -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <Grid x:Name="GameLayer" Visibility="Collapsed" Cursor="None">
      <!-- 게임 렌더링 캔버스 (XAML 직접 선언 — 비주얼 트리 보장) -->
      <engine:DrawingVisualHost x:Name="GameCanvas"/>

      <!-- ── HUD ──────────────────────────────────────────────────── -->
      <Grid VerticalAlignment="Top" Margin="0,0,0,0">
        <Grid.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#BB0A0A0F" Offset="0"/>
            <GradientStop Color="#000A0A0F" Offset="1"/>
          </LinearGradientBrush>
        </Grid.Background>
        <StackPanel Orientation="Horizontal" Margin="16,8">

          <!-- 점수 -->
          <StackPanel Margin="0,0,32,0">
            <TextBlock Text="SCORE" Foreground="#6A7080" FontSize="10"
                       FontFamily="Segoe UI"/>
            <TextBlock x:Name="TxtScore" Text="0" Foreground="#00FFFF"
                       FontSize="26" FontFamily="Consolas" FontWeight="Bold"/>
          </StackPanel>

          <!-- 콤보 -->
          <StackPanel Margin="0,0,32,0">
            <TextBlock Text="COMBO" Foreground="#6A7080" FontSize="10"
                       FontFamily="Segoe UI"/>
            <TextBlock x:Name="TxtCombo" Text="×0" Foreground="#FF2D78"
                       FontSize="26" FontFamily="Consolas" FontWeight="Bold"/>
          </StackPanel>

          <!-- 슬라이스 수 -->
          <StackPanel Margin="0,0,32,0">
            <TextBlock Text="SLICED" Foreground="#6A7080" FontSize="10"
                       FontFamily="Segoe UI"/>
            <TextBlock x:Name="TxtSliced" Text="0" Foreground="#4ADE80"
                       FontSize="26" FontFamily="Consolas" FontWeight="Bold"/>
          </StackPanel>

          <!-- 목숨 (Classic) / 타이머 (TimeAttack) / 남은슬라이스 (Zen) -->
          <StackPanel x:Name="PanelLives" Margin="0,0,32,0">
            <TextBlock x:Name="TxtLivesLabel" Text="LIVES" Foreground="#6A7080" FontSize="10"
                       FontFamily="Segoe UI"/>
            <TextBlock x:Name="TxtLives" Text="♥♥♥" Foreground="#FF2D78"
                       FontSize="22" FontFamily="Segoe UI"/>
          </StackPanel>

          <!-- 최고 점수 -->
          <StackPanel Margin="0,0,0,0" HorizontalAlignment="Right">
            <TextBlock Text="BEST" Foreground="#6A7080" FontSize="10"
                       FontFamily="Segoe UI"/>
            <TextBlock x:Name="TxtBest" Text="0" Foreground="#BF5FFF"
                       FontSize="26" FontFamily="Consolas" FontWeight="Bold"/>
          </StackPanel>

          <!-- 피버 표시 -->
          <TextBlock x:Name="TxtFever" Text="🔥 FEVER" Visibility="Collapsed"
                     Foreground="#FF6B00" FontSize="20" FontFamily="Segoe UI"
                     FontWeight="Bold" VerticalAlignment="Center" Margin="24,0,0,0">
            <TextBlock.Effect>
              <DropShadowEffect Color="#FF6B00" ShadowDepth="0" BlurRadius="14" Opacity="0.9"/>
            </TextBlock.Effect>
          </TextBlock>
        </StackPanel>
      </Grid>

      <!-- ESC / F1 힌트 -->
      <TextBlock Text="ESC 일시정지  ·  F1 도움말" Foreground="#2A3A4A" FontSize="11"
                 FontFamily="Segoe UI" VerticalAlignment="Bottom"
                 HorizontalAlignment="Right" Margin="0,0,12,8"/>
    </Grid>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 메뉴 화면                                                       -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <Grid x:Name="MenuLayer">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#0A0A0F" Offset="0"/>
          <GradientStop Color="#0D0A1A" Offset="1"/>
        </LinearGradientBrush>
      </Grid.Background>

      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

        <!-- 타이틀 -->
        <TextBlock Text="NEON" Foreground="#00FFFF" FontSize="64"
                   FontFamily="Consolas" FontWeight="Bold"
                   HorizontalAlignment="Center">
          <TextBlock.Effect>
            <DropShadowEffect Color="#00FFFF" ShadowDepth="0" BlurRadius="24" Opacity="0.9"/>
          </TextBlock.Effect>
        </TextBlock>
        <TextBlock Text="SLICE" Foreground="#FF2D78" FontSize="64"
                   FontFamily="Consolas" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,-18,0,0">
          <TextBlock.Effect>
            <DropShadowEffect Color="#FF2D78" ShadowDepth="0" BlurRadius="24" Opacity="0.9"/>
          </TextBlock.Effect>
        </TextBlock>
        <TextBlock Text="마우스로 도형을 잘라라" Foreground="#6A7080"
                   FontSize="14" FontFamily="Segoe UI"
                   HorizontalAlignment="Center" Margin="0,4,0,32"/>

        <!-- 난이도 선택 -->
        <TextBlock Text="DIFFICULTY" Foreground="#4A5A6A" FontSize="11"
                   FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
          <Button x:Name="BtnEasy" Content="EASY" Width="90" Height="36"
                  Style="{StaticResource ModeBtn}" Margin="0,0,6,0"
                  Click="BtnDifficulty_Click" Tag="Easy"/>
          <Button x:Name="BtnNormal" Content="NORMAL" Width="90" Height="36"
                  Style="{StaticResource ModeBtn}" Margin="0,0,6,0"
                  Click="BtnDifficulty_Click" Tag="Normal"/>
          <Button x:Name="BtnHard" Content="HARD" Width="90" Height="36"
                  Style="{StaticResource ModeBtn}"
                  Click="BtnDifficulty_Click" Tag="Hard"/>
        </StackPanel>

        <!-- 모드 선택 -->
        <TextBlock Text="GAME MODE" Foreground="#4A5A6A" FontSize="11"
                   FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
          <Button x:Name="BtnClassic" Content="CLASSIC" Width="140" Height="46"
                  Style="{StaticResource ModeBtn}" Margin="0,0,8,0"
                  Click="BtnMode_Click" Tag="Classic"/>
          <Button x:Name="BtnTimeAttack" Content="TIME ATTACK" Width="140" Height="46"
                  Style="{StaticResource ModeBtn}" Margin="0,0,8,0"
                  Click="BtnMode_Click" Tag="TimeAttack"/>
          <Button x:Name="BtnZen" Content="ZEN" Width="140" Height="46"
                  Style="{StaticResource ModeBtn}"
                  Click="BtnMode_Click" Tag="Zen"/>
        </StackPanel>

        <!-- 모드 설명 -->
        <TextBlock x:Name="TxtModeDesc"
                   Text="목숨 3개 — 도형을 놓칠 때마다 감소"
                   Foreground="#4A5A6A" FontSize="12" FontFamily="Segoe UI"
                   HorizontalAlignment="Center" Margin="0,4,0,24"/>

        <!-- 시작 버튼 -->
        <Button x:Name="BtnStart" Content="▶  START" Width="200" Height="52"
                Style="{StaticResource MenuBtn}" Padding="0,0,0,0"
                Click="BtnStart_Click" Margin="0,0,0,24"/>

        <!-- 최고 점수 / Top 3 -->
        <Border Background="#0D0D1A" CornerRadius="8" Padding="20,12" Margin="0,0,0,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CLASSIC -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
              <TextBlock Text="CLASSIC" Foreground="#4A5A6A" FontSize="10" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtBestClassic" Text="0" Foreground="#BF5FFF"
                         FontSize="22" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtTop2Classic" Text="" Foreground="#5A3A7A"
                         FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtTop3Classic" Text="" Foreground="#3A2550"
                         FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- TIME ATTACK -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
              <TextBlock Text="TIME ATTACK" Foreground="#4A5A6A" FontSize="10" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtBestTime" Text="0" Foreground="#BF5FFF"
                         FontSize="22" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtTop2Time" Text="" Foreground="#5A3A7A"
                         FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtTop3Time" Text="" Foreground="#3A2550"
                         FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ZEN -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
              <TextBlock Text="ZEN" Foreground="#4A5A6A" FontSize="10" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtBestZen" Text="0" Foreground="#BF5FFF"
                         FontSize="22" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtTop2Zen" Text="" Foreground="#5A3A7A"
                         FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtTop3Zen" Text="" Foreground="#3A2550"
                         FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- 특수 도형 범례 -->
        <Border Background="#0D0D1A" CornerRadius="8" Padding="16,10">
          <StackPanel>
            <TextBlock Text="SPECIAL SHAPES" Foreground="#4A5A6A" FontSize="10"
                       FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Border Background="#110008" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="💣" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                  <StackPanel>
                    <TextBlock Text="BOMB" Foreground="#FF4040" FontSize="9" FontFamily="Segoe UI" FontWeight="Bold"/>
                    <TextBlock Text="-15점, 목숨↓" Foreground="#6A7080" FontSize="9" FontFamily="Segoe UI"/>
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Background="#0A0A00" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="⚡" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                  <StackPanel>
                    <TextBlock Text="LIGHTNING" Foreground="#FFE600" FontSize="9" FontFamily="Segoe UI" FontWeight="Bold"/>
                    <TextBlock Text="전체 클리어" Foreground="#6A7080" FontSize="9" FontFamily="Segoe UI"/>
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Background="#000A10" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="❄" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                  <StackPanel>
                    <TextBlock Text="ICE" Foreground="#78DCFF" FontSize="9" FontFamily="Segoe UI" FontWeight="Bold"/>
                    <TextBlock Text="슬로모션 3초" Foreground="#6A7080" FontSize="9" FontFamily="Segoe UI"/>
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Background="#0A0A00" CornerRadius="4" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="★" FontSize="14" Foreground="#FFE600" Margin="0,0,5,0" VerticalAlignment="Center"/>
                  <StackPanel>
                    <TextBlock Text="STAR" Foreground="#FFE600" FontSize="9" FontFamily="Segoe UI" FontWeight="Bold"/>
                    <TextBlock Text="+10점 보너스" Foreground="#6A7080" FontSize="9" FontFamily="Segoe UI"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- HOW TO PLAY 버튼 -->
        <Button Content="❓  HOW TO PLAY" Width="200" Height="36"
                Style="{StaticResource ModeBtn}" Margin="0,10,0,0"
                Click="BtnHowToPlay_Click"/>

      </StackPanel>
    </Grid>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 도움말 오버레이                                                 -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <Grid x:Name="HelpLayer" Visibility="Collapsed">
      <Grid.Background>
        <SolidColorBrush Color="#EE000000"/>
      </Grid.Background>
      <Border Background="#0D0D1A" BorderBrush="#1E2A3A" BorderThickness="1"
              CornerRadius="12" Padding="36,28"
              VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="380">
        <StackPanel>
          <TextBlock Text="HOW TO PLAY" Foreground="#00FFFF" FontSize="24"
                     FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center"
                     Margin="0,0,0,20">
            <TextBlock.Effect>
              <DropShadowEffect Color="#00FFFF" ShadowDepth="0" BlurRadius="16" Opacity="0.8"/>
            </TextBlock.Effect>
          </TextBlock>

          <!-- 조작법 -->
          <TextBlock Text="🎮  조작" Foreground="#4A5A6A" FontSize="11"
                     FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,6"/>
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="마우스 드래그" Foreground="#E8EAF0" FontSize="13" FontFamily="Segoe UI" Margin="0,3"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="도형 슬라이스" Foreground="#6A7080" FontSize="13" FontFamily="Segoe UI" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="ESC" Foreground="#E8EAF0" FontSize="13" FontFamily="Consolas" FontWeight="Bold" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="일시정지 / 재개" Foreground="#6A7080" FontSize="13" FontFamily="Segoe UI" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="F1" Foreground="#E8EAF0" FontSize="13" FontFamily="Consolas" FontWeight="Bold" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="도움말 열기 / 닫기" Foreground="#6A7080" FontSize="13" FontFamily="Segoe UI" Margin="0,3"/>
          </Grid>

          <!-- 특수 도형 -->
          <TextBlock Text="✨  특수 도형" Foreground="#4A5A6A" FontSize="11"
                     FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,6"/>
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="💣" FontSize="15" Margin="0,3"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="BOMB — 슬라이스 시 -15점·목숨↓, 무시하면 안전" Foreground="#6A7080" FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="⚡" FontSize="15" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="LIGHTNING — 화면 내 모든 도형 클리어" Foreground="#6A7080" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="❄" FontSize="15" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="ICE — 슬로모션 3초 (슬라이스 찬스!)" Foreground="#6A7080" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="★" FontSize="15" Foreground="#FFE600" Margin="0,3"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="STAR — 슬라이스 시 +10점 보너스" Foreground="#6A7080" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>
          </Grid>

          <!-- 피버 -->
          <TextBlock Text="🔥  콤보 &amp; 피버" Foreground="#4A5A6A" FontSize="11"
                     FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,6"/>
          <TextBlock Foreground="#6A7080" FontSize="12" FontFamily="Segoe UI"
                     TextWrapping="Wrap" Margin="0,0,0,20"
                     Text="연속 슬라이스로 콤보가 쌓이면 피버 모드 발동! 피버 중 슬라이스는 슬로모션 + 점수 보너스."/>

          <Button Content="닫기" Width="160" Height="40"
                  Style="{StaticResource MenuBtn}" HorizontalAlignment="Center"
                  Click="BtnHelpClose_Click"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 일시정지 오버레이                                               -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <Grid x:Name="PauseLayer" Visibility="Collapsed">
      <Grid.Background>
        <SolidColorBrush Color="#BB000000"/>
      </Grid.Background>
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="PAUSED" Foreground="#00FFFF" FontSize="52"
                   FontFamily="Consolas" FontWeight="Bold"
                   HorizontalAlignment="Center">
          <TextBlock.Effect>
            <DropShadowEffect Color="#00FFFF" ShadowDepth="0" BlurRadius="20" Opacity="0.8"/>
          </TextBlock.Effect>
        </TextBlock>
        <Button Content="▶  RESUME" Width="200" Height="48"
                Style="{StaticResource MenuBtn}" Margin="0,24,0,12"
                Click="BtnResume_Click"/>
        <Button Content="MENU" Width="200" Height="48"
                Style="{StaticResource ModeBtn}"
                Click="BtnMenu_Click"/>
      </StackPanel>
    </Grid>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 게임오버 화면                                                   -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <Grid x:Name="GameOverLayer" Visibility="Collapsed">
      <Grid.Background>
        <SolidColorBrush Color="#DD000000"/>
      </Grid.Background>
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="320">
        <TextBlock x:Name="TxtGameOverTitle" Text="GAME OVER" Foreground="#FF2D78"
                   FontSize="52" FontFamily="Consolas" FontWeight="Bold"
                   HorizontalAlignment="Center">
          <TextBlock.Effect>
            <DropShadowEffect Color="#FF2D78" ShadowDepth="0" BlurRadius="22" Opacity="0.9"/>
          </TextBlock.Effect>
        </TextBlock>

        <Border Background="#111122" CornerRadius="10" Padding="28,18" Margin="0,20,0,0">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,12">
              <TextBlock Text="SCORE" Foreground="#4A5A6A" FontSize="11" FontFamily="Segoe UI"/>
              <TextBlock x:Name="TxtGoScore" Text="0" Foreground="#00FFFF"
                         FontSize="32" FontFamily="Consolas" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
              <TextBlock Text="MAX COMBO" Foreground="#4A5A6A" FontSize="11" FontFamily="Segoe UI"/>
              <TextBlock x:Name="TxtGoCombo" Text="×0" Foreground="#FF2D78"
                         FontSize="32" FontFamily="Consolas" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,20,12">
              <TextBlock Text="SLICED" Foreground="#4A5A6A" FontSize="11" FontFamily="Segoe UI"/>
              <TextBlock x:Name="TxtGoSliced" Text="0" Foreground="#4ADE80"
                         FontSize="32" FontFamily="Consolas" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
              <TextBlock Text="MISSED" Foreground="#4A5A6A" FontSize="11" FontFamily="Segoe UI"/>
              <TextBlock x:Name="TxtGoMissed" Text="0" Foreground="#BF5FFF"
                         FontSize="32" FontFamily="Consolas" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,10">
              <TextBlock Text="ACCURACY" Foreground="#4A5A6A" FontSize="11" FontFamily="Segoe UI"
                         HorizontalAlignment="Center"/>
              <TextBlock x:Name="TxtGoAccuracy" Text="—" Foreground="#FFE600"
                         FontSize="28" FontFamily="Consolas" FontWeight="Bold"
                         HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.ColumnSpan="2">
              <TextBlock x:Name="TxtGoNewBest" Text="🏆 NEW BEST!" Foreground="#FFE600"
                         FontSize="16" FontFamily="Segoe UI" FontWeight="Bold"
                         HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock.Effect>
                  <DropShadowEffect Color="#FFE600" ShadowDepth="0" BlurRadius="12" Opacity="0.8"/>
                </TextBlock.Effect>
              </TextBlock>
            </StackPanel>
          </Grid>
        </Border>

        <Button Content="▶  PLAY AGAIN" Width="220" Height="50"
                Style="{StaticResource MenuBtn}" Margin="0,20,0,10"
                Click="BtnPlayAgain_Click"/>
        <Button Content="MENU" Width="220" Height="46"
                Style="{StaticResource ModeBtn}"
                Click="BtnMenu_Click"/>
      </StackPanel>
    </Grid>

  </Grid>
</Window>
