<Window x:Class="HookCast.CatchLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hook.Cast — 낚시 도감"
        Width="420" Height="380"
        Background="#0E1620"
        Foreground="#D0E8FF"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="🐠 낚시 도감" FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,10" Foreground="#FFD060"/>
        <ListView x:Name="LogList" Grid.Row="1"
                  Background="Transparent" BorderThickness="0"
                  Foreground="#D0E8FF">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="시간"   Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Time, StringFormat='HH:mm'}" FontSize="11"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="어종"   Width="70"  DisplayMemberBinding="{Binding KorName}"/>
                    <GridViewColumn Header="크기(cm)" Width="80" DisplayMemberBinding="{Binding Size}"/>
                    <GridViewColumn Header="무게(kg)" Width="80" DisplayMemberBinding="{Binding Weight}"/>
                    <GridViewColumn Header="날씨"   Width="60"  DisplayMemberBinding="{Binding Weather}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
