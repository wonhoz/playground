<Window x:Class="GitStats.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Git.Stats — Git 저장소 통계 분석기"
        Width="1100" Height="720" MinWidth="800" MinHeight="520"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Git.Stats" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Git 저장소 통계 분석기" FontSize="13"
                               Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RepoName}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource GreenBrush}" VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📁 저장소 열기" Click="BtnOpen_Click" Margin="0,0,8,0"/>
                    <Button Content="📄 리포트 내보내기" Click="BtnExport_Click"
                            IsEnabled="{Binding IsLoaded}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 요약 카드 -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Border Background="#1C2128" CornerRadius="8" Padding="16,10" MinWidth="120" Margin="0,0,24,0">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalCommits, StringFormat=N0}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="총 커밋" FontSize="11"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#1C2128" CornerRadius="8" Padding="16,10" MinWidth="120" Margin="0,0,24,0">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalAuthors}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="기여자" FontSize="11"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#1C2128" CornerRadius="8" Padding="16,10" MinWidth="120">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalFiles}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource OrangeBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="핫 파일" FontSize="11"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 탭 컨텐츠 -->
        <TabControl Grid.Row="2" Background="{StaticResource BgBrush}">

            <!-- 히트맵 탭 -->
            <TabItem Header="🌿 커밋 히트맵">
                <ScrollViewer Background="{StaticResource BgBrush}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="연간 커밋 활동" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="HeatmapControl" ItemsSource="{Binding HeatmapData}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="12" Height="12" Margin="1" CornerRadius="2"
                                            ToolTip="{Binding Date}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#161B22"/>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 최근 커밋 목록 -->
                        <TextBlock Text="최근 커밋" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,24,0,12"/>
                        <DataGrid ItemsSource="{Binding RecentCommits}" MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="해시"    Binding="{Binding Hash}"    Width="70"/>
                                <DataGridTextColumn Header="작성자"  Binding="{Binding Author}"  Width="120"/>
                                <DataGridTextColumn Header="메시지"  Binding="{Binding Message}" Width="*"/>
                                <DataGridTextColumn Header="+추가"   Binding="{Binding Additions}" Width="60"/>
                                <DataGridTextColumn Header="-삭제"   Binding="{Binding Deletions}" Width="60"/>
                                <DataGridTextColumn Header="날짜"    Binding="{Binding When, StringFormat='yyyy-MM-dd'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 핫 파일 탭 -->
            <TabItem Header="🔥 핫 파일">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="가장 자주 변경된 파일 Top 20"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding HotFiles}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="파일 경로"    Binding="{Binding Path}"     Width="*"/>
                            <DataGridTextColumn Header="변경 횟수"    Binding="{Binding Changes}"  Width="90"/>
                            <DataGridTextColumn Header="추가 라인"    Binding="{Binding Additions}" Width="90"/>
                            <DataGridTextColumn Header="삭제 라인"    Binding="{Binding Deletions}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- 기여자 탭 -->
            <TabItem Header="👥 기여자">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="기여자별 커밋 통계"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding AuthorStats}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="이름"    Binding="{Binding Name}"      Width="160"/>
                            <DataGridTextColumn Header="이메일"  Binding="{Binding Email}"     Width="200"/>
                            <DataGridTextColumn Header="커밋 수" Binding="{Binding Commits}"   Width="80"/>
                            <DataGridTextColumn Header="추가"    Binding="{Binding Additions}" Width="80"/>
                            <DataGridTextColumn Header="삭제"    Binding="{Binding Deletions}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- 언어 분포 탭 -->
            <TabItem Header="🌐 언어 분포">
                <ScrollViewer Padding="16">
                    <StackPanel>
                        <TextBlock Text="확장자별 코드 라인 수"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding LanguageStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Extension}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{Binding Color}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Height="14" CornerRadius="3"
                                                HorizontalAlignment="Stretch" Margin="8,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#21262D"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Lines, StringFormat=N0}"
                                                   FontSize="11" Foreground="{StaticResource DimBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 키워드 탭 -->
            <TabItem Header="💬 키워드">
                <ScrollViewer Padding="16">
                    <StackPanel>
                        <TextBlock Text="커밋 메시지 자주 등장 단어"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding KeywordStats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#21262D" CornerRadius="4" Padding="10,5" Margin="4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Word}" FontSize="13"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Text="{Binding Count}" FontSize="11"
                                                       Foreground="{StaticResource DimBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource DimBrush}" FontSize="11" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Height="4"
                             Value="{Binding Progress}"
                             Background="#21262D" Foreground="{StaticResource GreenBrush}">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </Grid>
        </Border>
    </Grid>
</Window>
