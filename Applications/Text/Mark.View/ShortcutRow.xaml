<UserControl x:Class="MarkView.ShortcutRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root" Margin="0,2">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <!-- 키 배지 -->
    <Border Background="{StaticResource Surface2Brush}" CornerRadius="4"
            Padding="9,3" MinWidth="36" HorizontalAlignment="Left">
      <TextBlock Text="{Binding Key, ElementName=Root}"
                 FontFamily="Cascadia Code, Consolas, monospace"
                 FontSize="11" FontWeight="SemiBold"
                 Foreground="{StaticResource AccentBrush}"
                 HorizontalAlignment="Center"/>
    </Border>
    <!-- 설명 -->
    <TextBlock Grid.Column="1"
               Text="{Binding Desc, ElementName=Root}"
               FontSize="12"
               Foreground="{StaticResource TextBrush}"
               VerticalAlignment="Center"
               Margin="14,0,0,0"/>
  </Grid>
</UserControl>
