<Window x:Class="Stock.Fetch.WatchlistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Stock.Fetch.Converters"
        Title="관심 종목" Height="620" Width="760"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:SignBrushConverter x:Key="PnlBrush"
                                 Positive="{StaticResource BullBrush}"
                                 Negative="{StaticResource BearBrush}"
                                 Zero="{StaticResource FgMuted}"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="⭐ 관심 종목" FontSize="19" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
            <TextBlock Text="자산과 별개로 관심 종목의 현재가·등락율을 감시합니다. 미국 종목(TSLA·SOXL 등)도 등록 가능."
                       FontSize="11" Foreground="{StaticResource FgMuted}" Margin="0,3,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 모니터링 설정 -->
        <Border Grid.Row="1" Margin="0,14,0,0" Padding="12,10" CornerRadius="6" Background="#FF232323">
            <StackPanel>
                <WrapPanel>
                    <CheckBox x:Name="MonitorCheck" Content="모니터링 (트레이 상주)" VerticalAlignment="Center"
                              Margin="0,0,18,6" Click="Monitor_Click"/>
                    <TextBlock Text="폴링(초)" Style="{StaticResource FieldLbl}"/>
                    <TextBox x:Name="PollBox" Width="60" Margin="0,0,18,6"/>
                    <TextBlock Text="추세 조건(분:%)" Style="{StaticResource FieldLbl}"/>
                    <TextBox x:Name="RulesBox" Width="200" Margin="0,0,18,6"
                             ToolTip="기간:상승[:하락] 쉼표 구분. 예: 3:1:2 → 3분당 상승1%/하락2%, 5:2 → 5분당 ±2%(상승·하락 동일)"/>
                    <TextBlock Text="다이제스트(분·0=끔)" Style="{StaticResource FieldLbl}"/>
                    <TextBox x:Name="DigestBox" Width="60" Margin="0,0,18,6"/>
                    <CheckBox x:Name="YahooExtendedCheck" Content="미국 프리/애프터는 Yahoo로" VerticalAlignment="Center"
                              Margin="0,0,0,6" ToolTip="체크: 미국 확장시간(프리·애프터)엔 소스와 무관하게 Yahoo 사용. 해제: 항상 각 종목 소스."/>
                </WrapPanel>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource FgMuted}" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 헤더 + 버튼 -->
        <Grid Grid.Row="2" Margin="0,14,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="목록" Style="{StaticResource SectionHeader}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="🔄 현재가 갱신" Width="120" Margin="0,0,10,0" x:Name="RefreshBtn" Click="Refresh_Click"/>
                <Button Content="＋ 추가" Width="70" Margin="0,0,6,0" Click="Add_Click"/>
                <Button Content="✎ 수정" Width="70" Margin="0,0,6,0" Click="Edit_Click"/>
                <Button Content="🗑 삭제" Width="70" Margin="0,0,10,0" Click="Delete_Click"/>
                <Button Content="▲" Width="34" Margin="0,0,4,0" Click="MoveUp_Click" ToolTip="선택 종목을 위로"/>
                <Button Content="▼" Width="34" Click="MoveDown_Click" ToolTip="선택 종목을 아래로"/>
            </StackPanel>
        </Grid>

        <!-- 그리드 -->
        <DataGrid Grid.Row="3" x:Name="WatchGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  ColumnHeaderStyle="{StaticResource DarkColHeader}" CanUserAddRows="False"
                  SelectionMode="Extended" MouseDoubleClick="Edit_Click"
                  AllowDrop="True" PreviewMouseLeftButtonDown="WatchGrid_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="WatchGrid_PreviewMouseMove"
                  DragOver="WatchGrid_DragOver" Drop="WatchGrid_Drop">
            <DataGrid.Columns>
                <DataGridTextColumn Header="종목" Binding="{Binding Display}" Width="*" MinWidth="160"/>
                <DataGridTextColumn Header="시장" Binding="{Binding MarketLabel}" Width="60"/>
                <DataGridTextColumn Header="소스" Binding="{Binding SourceLabel}" Width="80"/>
                <DataGridTextColumn Header="조건" Binding="{Binding RulesLabel}" Width="200" MinWidth="140"/>
                <DataGridTextColumn Header="현재가" Binding="{Binding PriceText}" Width="130" ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="등락율" Binding="{Binding RateText}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource NumCell}">
                            <Setter Property="Foreground" Value="{Binding RateValue, Converter={StaticResource PnlBrush}}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 안내 -->
        <TextBlock Grid.Row="4" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource FgMuted}"
                   Text="※ 모니터링 시작 시 현재 수준을 1회 알린 뒤, 각 조건(예: 3분당 1%, 5분당 2%)별로 기준값 대비 변화 단위만큼 상승/하락하면 추세 알림을 보냅니다(방향 포함). 조건의 기간 안에 변동이 없으면 기준값을 현재값으로 재설정합니다. 종목별로 조건을 비우면 위 전역 조건을 사용합니다. 등락율은 전일 종가 대비. Yahoo 미국 시세는 약 15분 지연(실시간은 Finnhub·Alpaca·KIS). 비상장 기업은 조회 불가."/>

        <!-- 하단 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="닫기" Width="90" Style="{StaticResource AccentButton}" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
