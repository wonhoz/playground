<Window x:Class="OrbitRaid.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbit.Raid" Height="700" Width="1000"
        Background="#060612" Foreground="#E0E0E0"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252545"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#A064FF"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- 상단 HUD -->
        <Border Grid.Row="0" Background="#0A0A1C" BorderBrush="#1A1A3A" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblLevel" Text="Lv.1" FontSize="16" FontWeight="Bold"
                               Foreground="#A064FF" Margin="0,0,12,0"/>
                    <TextBlock x:Name="LblLevelTitle" Text="" FontSize="13" Foreground="#8888AA"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnPrev" Click="BtnPrev_Click" Margin="0,0,6,0" Padding="8,4">◀ 이전</Button>
                    <Button x:Name="BtnRestart" Click="BtnRestart_Click" Margin="0,0,6,0" Padding="8,4">↺ 다시하기</Button>
                    <Button x:Name="BtnNext" Click="BtnNext_Click" Margin="0,0,6,0" Padding="8,4">다음 ▶</Button>
                    <Rectangle Width="1" Fill="#333366" Margin="8,6"/>
                    <TextBlock Text="속도:" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="#666699" FontSize="11"/>
                    <Slider x:Name="SliderSpeed" Width="100" Minimum="1" Maximum="200" Value="10"
                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblSpeed" Text="x10" VerticalAlignment="Center" FontSize="11" Foreground="#A064FF"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblTime" Text="T+0d" FontSize="12" Foreground="#666699" Margin="0,0,16,0"/>
                    <TextBlock x:Name="LblStatus" Text="시뮬 대기" FontSize="12" Foreground="#8888AA"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 캔버스 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 시뮬레이션 캔버스 -->
            <Border Grid.Column="0" Background="#060612" ClipToBounds="True"
                    MouseDown="Canvas_MouseDown"
                    MouseMove="Canvas_MouseMove"
                    MouseWheel="Canvas_MouseWheel">
                <Canvas x:Name="SimCanvas"
                        SizeChanged="SimCanvas_SizeChanged">
                    <!-- 천체·플레이어·궤도선이 코드에서 동적으로 추가됨 -->
                </Canvas>
            </Border>

            <!-- 사이드 패널 -->
            <Border Grid.Column="1" Background="#0A0A1C" BorderBrush="#1A1A3A" BorderThickness="1,0,0,0">
                <StackPanel Margin="12,12">
                    <!-- 힌트 -->
                    <TextBlock Text="힌트" FontSize="11" Foreground="#555577" Margin="0,0,0,4"/>
                    <TextBlock x:Name="LblHint" Text="" FontSize="11" Foreground="#AAAACC"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- 천체 목록 -->
                    <TextBlock Text="천체 정보" FontSize="11" Foreground="#555577" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="BodyInfoList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="6,4" Background="#12122A" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#CCCCEE"/>
                                        <TextBlock Text="{Binding Info}" FontSize="10" Foreground="#666688"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 탐사선 속도 -->
                    <TextBlock Text="탐사선" FontSize="11" Foreground="#555577" Margin="0,12,0,4"/>
                    <TextBlock x:Name="LblPlayerSpeed" Text="속도: —" FontSize="11" Foreground="#50C8DC"/>
                    <TextBlock x:Name="LblPlayerDist" Text="목표까지: —" FontSize="11" Foreground="#AAAACC"/>

                    <!-- 조작 안내 -->
                    <TextBlock Text="조작" FontSize="11" Foreground="#555577" Margin="0,16,0,6"/>
                    <TextBlock Text="스페이스: 시뮬 시작/정지" FontSize="10" Foreground="#555577"/>
                    <TextBlock Text="마우스 휠: 줌" FontSize="10" Foreground="#555577"/>
                    <TextBlock Text="R: 레벨 재시작" FontSize="10" Foreground="#555577"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Background="#0A0A1C" BorderBrush="#1A1A3A" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar" Margin="12,0" VerticalAlignment="Center"
                       FontSize="10" Foreground="#444466"/>
        </Border>

        <!-- 결과 오버레이 -->
        <Border x:Name="ResultOverlay" Grid.Row="0" Grid.RowSpan="3"
                Visibility="Collapsed"
                Background="#AA060612">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="LblResultTitle" Text="" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="LblResultSub" Text="" FontSize="18" Foreground="#AAAACC"
                           HorizontalAlignment="Center" Margin="0,8,0,24"/>
                <Button x:Name="BtnResultAction" Click="BtnResultAction_Click"
                        Padding="24,10" FontSize="14" HorizontalAlignment="Center">다음 레벨</Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
