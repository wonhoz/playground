<UserControl x:Class="SysClean.Views.RegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 설명 -->
        <Border Grid.Row="0" Background="#1E2A1E" Padding="16,10" Margin="16,16,16,0"
                CornerRadius="6" BorderBrush="#2A4A2A" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="레지스트리 최적화" FontSize="14" FontWeight="SemiBold" Foreground="#66BB6A"/>
                <TextBlock Text="잘못된 레지스트리 항목을 검색합니다. 앱 경로, 공유 DLL, 제거 항목 등 유효하지 않은 참조를 찾아 삭제합니다."
                           FontSize="12" Foreground="#888" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 결과 목록 -->
        <ListView x:Name="IssueList" Grid.Row="1" Margin="16,12,16,0"
                  Background="#1E1E1E" BorderThickness="1" BorderBrush="#333"
                  SelectionMode="Multiple">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="카테고리" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#252525" CornerRadius="3" Padding="5,2" Margin="2,2">
                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#4FC3F7"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="설명" Width="440">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis"
                                           Margin="4,0" ToolTip="{Binding Description}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="레지스트리 키" Width="350">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding KeyPath}" Foreground="#888"
                                           FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding KeyPath}" Margin="4,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 진행률 -->
        <ProgressBar x:Name="PbProgress" Grid.Row="2" Height="3"
                     Background="#1A1A1A" Foreground="#66BB6A"
                     Margin="16,8,16,0" Visibility="Collapsed"/>

        <!-- 하단 액션 바 -->
        <Border Grid.Row="3" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,1,0,0"
                Padding="16,10" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TbStatus" Text="준비 — 스캔 버튼을 클릭하세요."
                               Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="TbCount" Text="" Foreground="#66BB6A"
                               FontSize="12" FontWeight="SemiBold" Margin="10,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="BtnScan" Content="🔍  레지스트리 스캔"
                        Click="BtnScan_Click" Margin="0,0,6,0"
                        Padding="14,7" FontSize="13"
                        Background="#1E4A6A" Foreground="#4FC3F7" BorderBrush="#2979FF"/>

                <Button Grid.Column="2" x:Name="BtnFix" Content="🔧  선택 항목 수정"
                        Click="BtnFix_Click" IsEnabled="False"
                        Padding="14,7" FontSize="13"
                        Background="#1B3A1F" Foreground="#66BB6A" BorderBrush="#388E3C"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
