<UserControl x:Class="Stock.Catch.Views.Controls.CandleChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF161620">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Canvas x:Name="PlotCanvas" ClipToBounds="True"/>
            <Canvas x:Name="OverlayCanvas" ClipToBounds="True" IsHitTestVisible="False"/>
            <Border x:Name="InfoBox" Visibility="Collapsed" IsHitTestVisible="False"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,20,0,0"
                    Background="#E61E1E2E" BorderBrush="#FF3A3A3A" BorderThickness="1"
                    CornerRadius="5" Padding="9,6">
                <TextBlock x:Name="InfoText" Foreground="#FFE0E0E0" FontSize="11.5" LineHeight="17"/>
            </Border>
            <TextBlock x:Name="EmptyHint" Text="조회하면 차트가 표시됩니다."
                       Foreground="#FF888888" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
        <ScrollBar x:Name="HScroll" Grid.Row="1" Orientation="Horizontal" Height="14"
                   Minimum="0" SmallChange="1" Visibility="Collapsed"
                   Scroll="HScroll_Scroll"/>
    </Grid>
</UserControl>
