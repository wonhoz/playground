<Window x:Class="Stock.Fetch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정" Height="720" Width="540"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,18,0,4"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,14,0">
                <!-- KIS -->
                <TextBlock Text="한국투자증권 OpenAPI 키" Style="{StaticResource Section}" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="KIS 소스·실시간 모니터링에 필요합니다. 네이버·Yahoo·다음 소스는 키 없이 동작합니다. 키는 이 PC의 %LocalAppData%에만 저장됩니다."/>
                <TextBlock Text="APP KEY" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="KeyBox" Margin="0,0,0,10"/>
                <TextBlock Text="APP SECRET" Style="{StaticResource FieldLbl}"/>
                <PasswordBox x:Name="SecretBox" Margin="0,0,0,10"/>
                <CheckBox x:Name="MockCheck" Content="모의투자 서버 사용 (테스트용 · 시세는 실전 권장)"/>

                <!-- 포트폴리오 경로 -->
                <TextBlock Text="자산 포트폴리오 저장 경로" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="매수/매도 기록(평단·실현손익)을 저장할 JSON 경로. Dropbox 등 동기화 폴더를 지정하면 어느 PC에서든 같은 자산 내역을 불러옵니다. 비워두면 문서\StockFetch\portfolio.json."/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PortfolioPathBox"/>
                    <Button Grid.Column="1" Content="찾기" Width="80" Margin="8,0,0,0" Click="BrowsePortfolio_Click"/>
                </Grid>

                <!-- 해외 실시간 시세 키 -->
                <TextBlock Text="해외 실시간 시세 키 (관심 종목 · 미국)" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="미국 종목 실시간 시세 소스입니다. 무료 키만 발급해 넣으면 됩니다(Yahoo는 키 없이 동작하나 약 15분 지연). 키는 이 PC의 %LocalAppData%에만 저장됩니다."/>
                <TextBlock Text="Finnhub API Key (finnhub.io · 실시간)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="FinnhubKeyBox" Margin="0,0,0,10"/>
                <TextBlock Text="Alpaca API Key ID (alpaca.markets · 실시간 IEX)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="AlpacaKeyIdBox" Margin="0,0,0,10"/>
                <TextBlock Text="Alpaca API Secret Key" Style="{StaticResource FieldLbl}"/>
                <PasswordBox x:Name="AlpacaSecretBox" Margin="0,0,0,10"/>

                <!-- Slack -->
                <TextBlock Text="Slack 알림" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="보유 종목이 평단 대비 임계값에 도달하면 Slack Incoming Webhook으로 알림을 보냅니다."/>
                <TextBlock Text="Webhook URL" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="SlackUrlBox" Margin="0,0,0,10"/>
                <TextBlock Text="채널 (예: #claude · 비우면 webhook 기본 채널)" Style="{StaticResource FieldLbl}"/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="SlackChannelBox"/>
                    <Button Grid.Column="1" x:Name="TestBtn" Content="테스트 전송" Width="100" Margin="8,0,0,0" Click="Test_Click"/>
                </Grid>
                <TextBlock x:Name="TestResult" Foreground="{StaticResource FgMuted}" FontSize="11" Margin="0,4,0,0"/>

                <!-- 모니터링 -->
                <TextBlock Text="보유 종목 모니터링" Style="{StaticResource Section}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="트레이 상주 상태로 보유 종목 현재가를 주기 조회해, 평단 대비 수익률이 임계값을 새로 넘을 때 알림합니다(엣지 트리거)."/>
                <CheckBox x:Name="MonitorCheck" Content="모니터링 활성화 (트레이 상주)" Margin="0,0,0,8"/>
                <CheckBox x:Name="MarketHoursCheck" Content="장 시간(평일 09:00~15:30)에만 조회" Margin="0,0,0,10"/>
                <TextBlock Text="폴링 주기 (초 · 최소 10)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="IntervalBox" Margin="0,0,0,10" Width="120" HorizontalAlignment="Left"/>
                <TextBlock Text="알림 임계값 (% · 쉼표 구분 · 상승/하락 양방향)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="ThresholdsBox" Margin="0,0,0,10"/>
                <TextBlock Text="시세 조회 실패 알림 (연속 N회 · 0=끔 · 보유·관심 공통)" Style="{StaticResource FieldLbl}"/>
                <TextBox x:Name="FailAlertBox" Width="120" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="취소" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="저장" Width="90" Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
