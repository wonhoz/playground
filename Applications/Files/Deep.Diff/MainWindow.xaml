<Window x:Class="DeepDiff.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DeepDiff.Views"
        Title="Deep.Diff" Height="760" Width="1280" MinHeight="500" MinWidth="800"
        Background="#0F0F1E" Foreground="#E8E8F0"
        WindowStartupLocation="CenterScreen"
        KeyDown="MainWindow_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 앱 헤더 -->
        <Border Grid.Row="0" Background="#0A0A1A" BorderBrush="#2E2E55" BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 로고 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="4" Background="#1E1E40"
                            BorderBrush="#5B8FFF" BorderThickness="1" Margin="0,0,10,0">
                        <Grid>
                            <Rectangle Width="7" Height="16" Fill="#5B8FFF" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                            <Rectangle Width="7" Height="16" Fill="#3FC878" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                            <TextBlock Text="⇔" FontSize="9" Foreground="#F0B030"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Deep" FontSize="18" FontWeight="Bold" Foreground="#5B8FFF" VerticalAlignment="Center"/>
                    <TextBlock Text="." FontSize="18" FontWeight="Bold" Foreground="#F0B030" VerticalAlignment="Center"/>
                    <TextBlock Text="Diff" FontSize="18" FontWeight="Bold" Foreground="#3FC878" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 탭 바 -->
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled" Margin="20,0">
                    <StackPanel x:Name="TabStrip" Orientation="Horizontal" VerticalAlignment="Stretch"/>
                </ScrollViewer>

                <!-- 새 탭 / 홈 버튼 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnNewTab" Content="+" FontSize="16" Width="32" Height="32"
                            ToolTip="새 비교 세션" Click="BtnNewTab_Click"
                            Background="Transparent" BorderBrush="#2E2E55"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 탭 내용 영역 -->
        <Border Grid.Row="1" x:Name="ContentArea" Background="#0F0F1E"/>
    </Grid>
</Window>
