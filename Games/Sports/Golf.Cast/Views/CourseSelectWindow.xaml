<Window x:Class="GolfCast.Views.CourseSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Golf.Cast — 코스 선택" Height="400" Width="380"
        Background="#1A2E1A" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="⛳ Golf.Cast" FontSize="24" FontWeight="Bold"
                       Foreground="#4CAF50" HorizontalAlignment="Center"/>
            <TextBlock Text="2D 미니골프" FontSize="12" Foreground="#888"
                       HorizontalAlignment="Center" Margin="0,4"/>
        </StackPanel>

        <!-- 안내 -->
        <TextBlock Grid.Row="1" Text="코스를 선택하세요:" FontSize="13"
                   Foreground="#E0E0E0" Margin="0,0,0,10"/>

        <!-- 코스 목록 -->
        <ListBox Grid.Row="2" x:Name="LstCourses"
                 Background="#243424" BorderBrush="#2E4A2E"
                 SelectionMode="Single" MouseDoubleClick="OnDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,2">
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#E0E0E0"/>
                        <TextBlock FontSize="11" Foreground="#888">
                            <Run Text="{Binding Level}"/>
                            <Run Text=" · 18홀"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 버튼 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" Padding="14,8" Margin="0,0,8,0"
                    Background="#243424" BorderBrush="#2E4A2E"
                    Foreground="#E0E0E0" Click="OnCancel">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="시작 ▶" Padding="14,8"
                    Background="#4CAF50" BorderBrush="#4CAF50"
                    Foreground="White" FontWeight="SemiBold" Click="OnStart">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
