<Window x:Class="WaveSurf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wave.Surf"
        Width="1200" Height="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0A1830"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Loaded="Window_Loaded">

    <Grid>
        <!-- ── 게임 캔버스 (전체 영역) ─────────────────────────────── -->
        <Canvas x:Name="GameCanvas"
                Background="#0A1830"
                ClipToBounds="True"
                Focusable="False">

            <!-- 하늘 그라디언트 -->
            <Rectangle x:Name="SkyRect" Canvas.Left="0" Canvas.Top="0">
                <Rectangle.Fill>
                    <LinearGradientBrush x:Name="SkyGrad" StartPoint="0,0" EndPoint="0,1">
                        <GradientStop x:Name="SkyGradTop" Color="#4AC8FF" Offset="0"/>
                        <GradientStop x:Name="SkyGradBot" Color="#0090D0" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 파도 수체 -->
            <Path x:Name="WavePath" Fill="#0080C8">
                <Path.Data>
                    <PathGeometry x:Name="WaveGeo"/>
                </Path.Data>
            </Path>

            <!-- 파도 거품 (상단 선) -->
            <Polyline x:Name="FoamLine"
                      Stroke="White" StrokeThickness="2.5"
                      StrokeLineJoin="Round" Opacity="0.75"/>

            <!-- 서퍼 그룹 (보드 + 몸통) -->
            <Canvas x:Name="SurferCanvas" Width="80" Height="80"
                    Canvas.Left="0" Canvas.Top="0">
                <!-- 서핑보드 -->
                <Ellipse x:Name="Board"
                         Width="58" Height="12"
                         Fill="#FFD040" Stroke="#C09020" StrokeThickness="1"
                         Canvas.Left="11" Canvas.Top="34"/>
                <!-- 다리 -->
                <Line x:Name="LegL" Stroke="#3A2010" StrokeThickness="3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      X1="34" Y1="34" X2="28" Y2="34"/>
                <Line x:Name="LegR" Stroke="#3A2010" StrokeThickness="3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      X1="46" Y1="34" X2="52" Y2="34"/>
                <!-- 몸통 -->
                <Line x:Name="Body" Stroke="#2080C0" StrokeThickness="4"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      X1="40" Y1="34" X2="40" Y2="20"/>
                <!-- 팔 왼쪽 -->
                <Line x:Name="ArmL" Stroke="#2080C0" StrokeThickness="3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      X1="40" Y1="24" X2="28" Y2="30"/>
                <!-- 팔 오른쪽 -->
                <Line x:Name="ArmR" Stroke="#2080C0" StrokeThickness="3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      X1="40" Y1="24" X2="52" Y2="30"/>
                <!-- 머리 -->
                <Ellipse x:Name="Head"
                         Width="14" Height="14"
                         Fill="#D2A878" Stroke="#8B5E3C" StrokeThickness="1"
                         Canvas.Left="33" Canvas.Top="6"/>
            </Canvas>

            <!-- 와이프아웃 물보라 파티클 (코드에서 동적 생성) -->

            <!-- ── HUD 오버레이 ──────────────────────────────────────── -->

            <!-- 점수 (중앙 상단) -->
            <TextBlock x:Name="TxtScore"
                       Text="0" FontSize="28" FontWeight="Bold"
                       Foreground="White" Opacity="0.9"
                       FontFamily="Consolas"
                       Canvas.Top="14"/>

            <!-- 콤보 (좌측 상단) -->
            <TextBlock x:Name="TxtCombo"
                       Text="" FontSize="16" FontWeight="Bold"
                       Foreground="#FFD040" Opacity="0.95"
                       Canvas.Left="18" Canvas.Top="16"/>

            <!-- 생존 시간 (우측 상단) -->
            <TextBlock x:Name="TxtTime"
                       Text="0:00" FontSize="16"
                       Foreground="White" Opacity="0.75"
                       Canvas.Top="18"/>

            <!-- 테마 이름 (우측 하단) -->
            <TextBlock x:Name="TxtTheme"
                       Text="🌴 열대" FontSize="12"
                       Foreground="White" Opacity="0.5"
                       Canvas.Bottom="10"/>

            <!-- 조작 힌트 (좌측 하단) -->
            <TextBlock x:Name="TxtHint"
                       Text="← → 균형 | 공중에서 ← → 회전 | T 테마 변경"
                       FontSize="11" Foreground="White" Opacity="0.45"
                       Canvas.Left="18" Canvas.Bottom="10"/>

            <!-- 묘기 공지 (중앙) -->
            <Border x:Name="TrickBanner"
                    Background="#99000010"
                    BorderBrush="#FFD040" BorderThickness="0,0,0,2"
                    Padding="20,8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtTrickName"
                               Text="" FontSize="22" FontWeight="Bold"
                               Foreground="#FFD040"/>
                    <TextBlock x:Name="TxtTrickScore"
                               Text="" FontSize="16" FontWeight="SemiBold"
                               Foreground="White" Margin="12,3,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
            </Border>

            <!-- 공중 묘기 미리보기 -->
            <TextBlock x:Name="TxtAirTrick"
                       Text="" FontSize="18" FontWeight="Bold"
                       Foreground="#80FFD040" Opacity="0.8"
                       Canvas.Bottom="60"/>

            <!-- 균형 게이지 (서퍼 하단) -->
            <Rectangle x:Name="BalanceBg"
                       Height="6" Width="80"
                       Fill="#40FFFFFF" RadiusX="3" RadiusY="3"/>
            <Rectangle x:Name="BalanceFill"
                       Height="6" Width="40"
                       Fill="#60FF40" RadiusX="3" RadiusY="3"/>

            <!-- 와이프아웃 메시지 -->
            <TextBlock x:Name="TxtWipeout"
                       Text="💦 와이프아웃!" FontSize="24" FontWeight="Bold"
                       Foreground="#80C0FF"
                       Visibility="Collapsed"/>

            <!-- ── 타이틀 화면 ─────────────────────────────────────── -->
            <Border x:Name="TitleScreen"
                    Background="#CC000818"
                    Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🏄 Wave.Surf" FontSize="52" FontWeight="Bold"
                               Foreground="#4AC8FF" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="물리 서핑 게임" FontSize="20"
                               Foreground="#A0D0FF" HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>
                    <TextBlock Text="← → 균형 잡기 · 파도 꼭대기에서 공중으로!" FontSize="14"
                               Foreground="#80A0C0" HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="공중에서 ← → 로 회전 · 360° 배수로 착지 = 클린 랜딩!" FontSize="14"
                               Foreground="#80A0C0" HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>
                    <Border Background="#0060A0" BorderBrush="#0090E0"
                            BorderThickness="2" CornerRadius="8"
                            Padding="40,14" HorizontalAlignment="Center"
                            Cursor="Hand" MouseLeftButtonDown="StartBtn_Click">
                        <TextBlock Text="Space 또는 클릭으로 시작" FontSize="18" FontWeight="Bold"
                                   Foreground="#A0E8FF" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="T — 테마 변경" FontSize="12"
                               Foreground="#406080" HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── 게임오버 화면 ───────────────────────────────────── -->
            <Border x:Name="GameOverScreen"
                    Background="#DD000818"
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="💦 와이프아웃!" FontSize="40" FontWeight="Bold"
                               Foreground="#80C0FF" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <TextBlock Text="최종 점수: " FontSize="22" Foreground="#A0C0E0"/>
                        <TextBlock x:Name="TxtFinalScore" Text="0" FontSize="22" FontWeight="Bold"
                                   Foreground="#FFD040"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="최대 콤보: " FontSize="16" Foreground="#708090"/>
                        <TextBlock x:Name="TxtFinalCombo" Text="0" FontSize="16"
                                   Foreground="#A0C8E0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                        <TextBlock Text="생존 시간: " FontSize="16" Foreground="#708090"/>
                        <TextBlock x:Name="TxtFinalTime" Text="0:00" FontSize="16"
                                   Foreground="#A0C8E0"/>
                    </StackPanel>
                    <Border Background="#0060A0" BorderBrush="#0090E0"
                            BorderThickness="2" CornerRadius="8"
                            Padding="40,14" HorizontalAlignment="Center"
                            Cursor="Hand" MouseLeftButtonDown="StartBtn_Click">
                        <TextBlock Text="다시 서핑! (Space)" FontSize="18" FontWeight="Bold"
                                   Foreground="#A0E8FF" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="📂 F1 — 캡처 폴더 열기" FontSize="11"
                               Foreground="#406080" HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

        </Canvas>
    </Grid>
</Window>
