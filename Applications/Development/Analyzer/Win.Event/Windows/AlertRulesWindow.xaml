<Window x:Class="WinEvent.Windows.AlertRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="알림 규칙 관리 — Win.Event"
        Width="680" Height="520"
        MinWidth="560" MinHeight="400"
        Background="#0D0D16"
        Foreground="#D0D0E0"
        FontFamily="Segoe UI"
        FontSize="12"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 규칙 목록 + 우측 편집 패널 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 목록 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox x:Name="LbRules" Grid.Row="0"
                         Background="#131320" BorderBrush="#2A2A3A" BorderThickness="1"
                         SelectionChanged="LbRules_SelectionChanged"
                         DisplayMemberPath="Name"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="+ 추가" Click="BtnAdd_Click" Padding="8,4" Margin="0,0,4,0"/>
                    <Button Content="✕ 삭제" Style="{StaticResource SecondaryBtn}"
                            Click="BtnDelete_Click" Padding="8,4"/>
                </StackPanel>
            </Grid>

            <!-- 편집 패널 -->
            <Border Grid.Column="2"
                    Background="#131320" BorderBrush="#2A2A3A" BorderThickness="1"
                    CornerRadius="6" Padding="16">
                <StackPanel x:Name="PanelEdit" IsEnabled="False">
                    <TextBlock Text="규칙 이름" Foreground="#888898" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtRuleName" Margin="0,0,0,12"
                             TextChanged="RuleField_Changed"/>

                    <TextBlock Text="레벨 (비워두면 모든 레벨)" Foreground="#888898" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbLevel" Margin="0,0,0,12"
                              SelectionChanged="RuleField_Changed">
                        <ComboBoxItem Content="(모든 레벨)" Tag="-1" IsSelected="True"/>
                        <ComboBoxItem Content="위험 (Critical)"    Tag="1"/>
                        <ComboBoxItem Content="오류 (Error)"       Tag="2"/>
                        <ComboBoxItem Content="경고 (Warning)"     Tag="3"/>
                        <ComboBoxItem Content="정보 (Information)" Tag="4"/>
                    </ComboBox>

                    <TextBlock Text="EventID (비워두면 모든 ID)" Foreground="#888898" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtRuleEventId" Margin="0,0,0,12"
                             TextChanged="RuleField_Changed"/>

                    <TextBlock Text="소스 패턴 (정규식 허용)" Foreground="#888898" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtRuleSource" Margin="0,0,0,12"
                             TextChanged="RuleField_Changed"/>

                    <TextBlock Text="메시지 패턴 (정규식 허용)" Foreground="#888898" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtRuleMessage" Margin="0,0,0,12"
                             TextChanged="RuleField_Changed"/>

                    <CheckBox x:Name="ChkRuleEnabled" Content="규칙 활성화"
                              IsChecked="True" Checked="RuleField_Changed" Unchecked="RuleField_Changed"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 설명 -->
        <TextBlock Grid.Row="1"
                   Text="💡 활성화된 규칙과 일치하는 이벤트가 실시간으로 도착하면 Toast 알림을 표시합니다."
                   Foreground="#606878" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>

        <!-- 저장/닫기 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="저장" Click="BtnSave_Click" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="닫기" Style="{StaticResource SecondaryBtn}"
                    Click="BtnClose_Click" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
