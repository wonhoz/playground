<Window x:Class="MarkView.SnippetManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="스닛펫 관리"
        Width="720" Height="520"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 헤더 -->
    <TextBlock Grid.Row="0" Text="스닛펫 관리"
               FontSize="14" FontWeight="Bold"
               Foreground="{StaticResource TextBrush}"
               Margin="0,0,0,12"/>

    <!-- 본문: 목록 + 편집 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 왼쪽: 스닛펫 목록 -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="5">
          <ListBox x:Name="SnippetList"
                   Background="{StaticResource SurfaceBrush}"
                   BorderThickness="0"
                   SelectionChanged="SnippetList_SelectionChanged"/>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
          <Button Content="+ 추가" Click="BtnAdd_Click"
                  Padding="10,5" Margin="0,0,4,0"
                  Style="{StaticResource {x:Type Button}}"/>
          <Button x:Name="BtnDelete" Content="삭제" Click="BtnDelete_Click"
                  Padding="10,5" IsEnabled="False"
                  Style="{StaticResource {x:Type Button}}"/>
        </StackPanel>
      </Grid>

      <!-- 구분선 -->
      <Border Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
              HorizontalAlignment="Center"/>

      <!-- 오른쪽: 편집 영역 -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="이름" FontSize="11"
                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
          <TextBox x:Name="TxtName" TextChanged="TxtName_TextChanged"/>
          <TextBlock Text="스닛펫 이름..." Foreground="#6888AA"
                     FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                     IsHitTestVisible="False" IsEnabled="False">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=TxtName}" Value="">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <TextBlock Grid.Row="2" VerticalAlignment="Top" Text="내용" FontSize="11"
                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtContent" Grid.Row="2"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Cascadia Code, Consolas, monospace"
                 FontSize="12"
                 Margin="0,18,0,0"
                 TextChanged="TxtContent_TextChanged"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
          <Button x:Name="BtnSave" Content="저장" Click="BtnSave_Click"
                  Padding="14,6" Margin="0,0,6,0"
                  IsEnabled="False"
                  Style="{StaticResource AccentButton}"/>
          <Button Content="닫기" Click="BtnClose_Click"
                  Padding="14,6"
                  Style="{StaticResource {x:Type Button}}"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>
