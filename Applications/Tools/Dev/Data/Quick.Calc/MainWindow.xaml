<Window x:Class="QuickCalc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuickCalc.ViewModels"
        Title="Quick.Calc"
        Width="820" Height="760"
        MinWidth="700" MinHeight="620"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        FontFamily="Consolas"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- 비트 버튼용 IeeePart → 배경색 컨버터 대신 DataTrigger 스타일 사용 -->
        <Style x:Key="BitBtnStyle" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="Height"  Value="18"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Margin"  Value="1,0"/>
        </Style>

        <!-- IEEE 비트 버튼: 파트별 색상 -->
        <Style x:Key="IeeeBitBtnSign" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="Height"  Value="18"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Margin"  Value="1,0"/>
            <Setter Property="BorderBrush" Value="#FF5060"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#4A0020"/>
                    <Setter Property="BorderBrush" Value="#FF5060"/>
                    <Setter Property="Foreground" Value="#FF5060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IeeeBitBtnExp" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="Height"  Value="18"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Margin"  Value="1,0"/>
            <Setter Property="BorderBrush" Value="#FF9040"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3A2A00"/>
                    <Setter Property="BorderBrush" Value="#FF9040"/>
                    <Setter Property="Foreground" Value="#FF9040"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IeeeBitBtnMan" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="Height"  Value="18"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Margin"  Value="1,0"/>
            <Setter Property="BorderBrush" Value="#3A7A50"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#0A3020"/>
                    <Setter Property="BorderBrush" Value="#50DC78"/>
                    <Setter Property="Foreground" Value="#50DC78"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 타이틀바 -->
            <RowDefinition Height="*"/>     <!-- 메인 -->
        </Grid.RowDefinitions>

        <!-- ── 커스텀 타이틀바 ──────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="🔢" FontSize="14" Margin="0,0,6,0"/>
                    <TextBlock Text="Quick.Calc" Foreground="{StaticResource FgBrush}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text=" — 프로그래머 계산기"
                               Foreground="{StaticResource Fg3Brush}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- pending op 표시 -->
                <TextBlock Grid.Column="1" Text="{Binding PendingOpDisplay}"
                           Foreground="{StaticResource OrangeBrush}" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="─" Width="40" Height="36" BorderThickness="0"
                            Background="Transparent" Click="MinimizeBtn_Click" ToolTip="최소화"/>
                    <Button Content="✕" Width="40" Height="36" BorderThickness="0"
                            Background="Transparent" Click="CloseBtn_Click" ToolTip="닫기"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 메인 컨텐츠 ───────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12,8,12,12">

                <!-- ① 진법 입력 섹션 (4행 수직 레이아웃) ─── -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- DEC -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="DEC"
                                   Foreground="{StaticResource GreenBrush}" FontSize="11"
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding DecText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="TxtDec" Height="32" FontSize="14"
                                 ToolTip="10진수 (부호 있는 정수)"/>

                        <!-- HEX -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="HEX"
                                   Foreground="{StaticResource AccentBrush}" FontSize="11"
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding HexText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="TxtHex" Height="32" FontSize="14"
                                 ToolTip="16진수 (0x 접두사 생략 가능)"/>

                        <!-- OCT -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="OCT"
                                   Foreground="{StaticResource OrangeBrush}" FontSize="11"
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding OctText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="TxtOct" Height="32" FontSize="14"
                                 ToolTip="8진수"/>

                        <!-- BIN -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="BIN"
                                   Foreground="{StaticResource Fg2Brush}" FontSize="11"
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="6" Grid.Column="1"
                                 Text="{Binding BinText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="TxtBin" Height="32" FontSize="14"
                                 ToolTip="2진수 (0b 접두사 생략, _ 구분자 허용)"/>
                    </Grid>
                </Border>

                <!-- ② 연산 버튼 + Word Size ──────────────── -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 비트 연산 버튼 -->
                        <WrapPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="AND" Width="58" Height="30" Margin="2"
                                    Command="{Binding AndCmd}" ToolTip="AND 연산 (= 버튼으로 적용)"/>
                            <Button Content="OR"  Width="58" Height="30" Margin="2"
                                    Command="{Binding OrCmd}" ToolTip="OR 연산"/>
                            <Button Content="XOR" Width="58" Height="30" Margin="2"
                                    Command="{Binding XorCmd}" ToolTip="XOR 연산"/>
                            <Button Content="NOT" Width="58" Height="30" Margin="2"
                                    Command="{Binding NotCmd}" ToolTip="비트 반전 (NOT)"/>
                            <Button Content="SHL" Width="58" Height="30" Margin="2"
                                    Command="{Binding ShlCmd}" ToolTip="왼쪽 시프트 (×2)"/>
                            <Button Content="SHR" Width="58" Height="30" Margin="2"
                                    Command="{Binding ShrCmd}" ToolTip="오른쪽 시프트 (÷2)"/>
                            <Button Content="2s" Width="58" Height="30" Margin="2"
                                    Command="{Binding TwosCmd}" ToolTip="2의 보수 (부호 반전)"/>
                            <Button Content="SEXT" Width="58" Height="30" Margin="2"
                                    Command="{Binding SignExtCmd}" ToolTip="부호 확장 → 64bit"/>
                            <Button Content="=" Width="58" Height="30" Margin="2"
                                    Command="{Binding EqualCmd}" ToolTip="이항 연산 적용"
                                    Background="#1A3A6A" Foreground="{StaticResource AccentBrush}"/>
                            <Button Content="CLR" Width="58" Height="30" Margin="2"
                                    Command="{Binding ClearCmd}" ToolTip="초기화 (0)"
                                    Background="#3A1010" Foreground="{StaticResource RedBrush}"/>
                        </WrapPanel>

                        <!-- Word Size -->
                        <StackPanel Grid.Column="2" Orientation="Vertical">
                            <TextBlock Text="Word" Foreground="{StaticResource Fg3Brush}"
                                       FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <UniformGrid Rows="2" Columns="2" Width="88">
                                <RadioButton Content=" 8" IsChecked="{Binding WS8}"  Margin="2"/>
                                <RadioButton Content="16" IsChecked="{Binding WS16}" Margin="2"/>
                                <RadioButton Content="32" IsChecked="{Binding WS32}" Margin="2"/>
                                <RadioButton Content="64" IsChecked="{Binding WS64}" Margin="2"/>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ③ 비트 레이아웃 (64비트 토글 버튼, 32+32 두 줄) ── -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="비트 레이아웃" Foreground="{StaticResource Fg3Brush}"
                                   FontSize="10" Margin="0,0,0,6"/>

                        <!-- 상위 32비트 (bit63~32) -->
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="63" Foreground="{StaticResource Fg3Brush}"
                                       FontSize="9" VerticalAlignment="Center"/>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding BitsHigh}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource BitBtnStyle}"
                                                      IsChecked="{Binding IsOn, Mode=TwoWay}"
                                                      Command="{Binding ToggleCommand}"
                                                      ToolTip="{Binding Index}">
                                            <TextBlock Text="{Binding Index}" FontSize="7"
                                                       Foreground="{StaticResource Fg3Brush}"/>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Grid.Column="2" Text="32" Foreground="{StaticResource Fg3Brush}"
                                       FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- 하위 32비트 (bit31~0) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="31" Foreground="{StaticResource Fg3Brush}"
                                       FontSize="9" VerticalAlignment="Center"/>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding BitsLow}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource BitBtnStyle}"
                                                      IsChecked="{Binding IsOn, Mode=TwoWay}"
                                                      Command="{Binding ToggleCommand}"
                                                      ToolTip="{Binding Index}">
                                            <TextBlock Text="{Binding Index}" FontSize="7"
                                                       Foreground="{StaticResource Fg3Brush}"/>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Grid.Column="2" Text="0" Foreground="{StaticResource Fg3Brush}"
                                       FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ④ IEEE 754 시각화 ─────────────────────── -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="IEEE 754 부동소수점" Foreground="{StaticResource Fg3Brush}"
                                   FontSize="10" Margin="0,0,0,6"/>

                        <!-- 범례 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="12" Height="12" Background="#4A0020"
                                    BorderBrush="#FF5060" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="부호(S)" Foreground="#FF5060" FontSize="10" Margin="0,0,12,0"/>
                            <Border Width="12" Height="12" Background="#3A2A00"
                                    BorderBrush="#FF9040" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="지수(E)" Foreground="#FF9040" FontSize="10" Margin="0,0,12,0"/>
                            <Border Width="12" Height="12" Background="#0A3020"
                                    BorderBrush="#50DC78" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="가수(M)" Foreground="#50DC78" FontSize="10"/>
                        </StackPanel>

                        <!-- Float32 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Float32" Foreground="{StaticResource OrangeBrush}"
                                           FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Ieee32Text}"
                                           Foreground="{StaticResource GreenBrush}" FontSize="11"/>
                            </StackPanel>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding IeeeBits32}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ContentControl>
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Setter Property="Content">
                                                        <Setter.Value>
                                                            <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                                          IsChecked="{Binding IsOn, Mode=TwoWay}"
                                                                          Command="{Binding ToggleCommand}"
                                                                          ToolTip="{Binding Index}">
                                                                <TextBlock Text="{Binding Index}" FontSize="7"
                                                                           Foreground="{StaticResource Fg3Brush}"/>
                                                            </ToggleButton>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ContentControl.Style>
                                        </ContentControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- 실제 IEEE32 비트 레이아웃: 부호/지수/가수 영역별 색상 구분 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>  <!-- S: 1bit -->
                                <ColumnDefinition Width="Auto"/>  <!-- E: 8bits -->
                                <ColumnDefinition Width="*"/>     <!-- M: 23bits -->
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="  bit 31→0" Foreground="{StaticResource Fg3Brush}"
                                           FontSize="9"/>
                            </StackPanel>

                            <!-- Sign -->
                            <Border Grid.Column="1" BorderBrush="#FF5060" BorderThickness="1"
                                    CornerRadius="4" Background="#200010" Padding="2" Margin="1,0">
                                <StackPanel>
                                    <TextBlock Text="S" Foreground="#FF5060" FontSize="9"
                                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <ToggleButton Style="{StaticResource IeeeBitBtnSign}"
                                                  IsChecked="{Binding IeeeBits32[0].IsOn, Mode=TwoWay}"
                                                  Command="{Binding IeeeBits32[0].ToggleCommand}">
                                        <TextBlock Text="31" FontSize="7"/>
                                    </ToggleButton>
                                </StackPanel>
                            </Border>

                            <!-- Exponent -->
                            <Border Grid.Column="2" BorderBrush="#FF9040" BorderThickness="1"
                                    CornerRadius="4" Background="#1E1800" Padding="2" Margin="1,0">
                                <StackPanel>
                                    <TextBlock Text="Exponent (8bit)" Foreground="#FF9040" FontSize="9"
                                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[1].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[1].ToggleCommand}">
                                            <TextBlock Text="30" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[2].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[2].ToggleCommand}">
                                            <TextBlock Text="29" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[3].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[3].ToggleCommand}">
                                            <TextBlock Text="28" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[4].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[4].ToggleCommand}">
                                            <TextBlock Text="27" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[5].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[5].ToggleCommand}">
                                            <TextBlock Text="26" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[6].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[6].ToggleCommand}">
                                            <TextBlock Text="25" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[7].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[7].ToggleCommand}">
                                            <TextBlock Text="24" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnExp}"
                                                      IsChecked="{Binding IeeeBits32[8].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[8].ToggleCommand}">
                                            <TextBlock Text="23" FontSize="7"/>
                                        </ToggleButton>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Mantissa -->
                            <Border Grid.Column="3" BorderBrush="#3A7A50" BorderThickness="1"
                                    CornerRadius="4" Background="#061810" Padding="2" Margin="1,0">
                                <StackPanel>
                                    <TextBlock Text="Mantissa (23bit)" Foreground="#50DC78" FontSize="9"
                                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <WrapPanel Orientation="Horizontal">
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[9].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[9].ToggleCommand}">
                                            <TextBlock Text="22" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[10].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[10].ToggleCommand}">
                                            <TextBlock Text="21" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[11].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[11].ToggleCommand}">
                                            <TextBlock Text="20" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[12].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[12].ToggleCommand}">
                                            <TextBlock Text="19" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[13].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[13].ToggleCommand}">
                                            <TextBlock Text="18" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[14].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[14].ToggleCommand}">
                                            <TextBlock Text="17" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[15].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[15].ToggleCommand}">
                                            <TextBlock Text="16" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[16].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[16].ToggleCommand}">
                                            <TextBlock Text="15" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[17].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[17].ToggleCommand}">
                                            <TextBlock Text="14" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[18].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[18].ToggleCommand}">
                                            <TextBlock Text="13" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[19].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[19].ToggleCommand}">
                                            <TextBlock Text="12" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[20].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[20].ToggleCommand}">
                                            <TextBlock Text="11" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[21].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[21].ToggleCommand}">
                                            <TextBlock Text="10" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[22].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[22].ToggleCommand}">
                                            <TextBlock Text="9" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[23].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[23].ToggleCommand}">
                                            <TextBlock Text="8" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[24].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[24].ToggleCommand}">
                                            <TextBlock Text="7" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[25].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[25].ToggleCommand}">
                                            <TextBlock Text="6" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[26].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[26].ToggleCommand}">
                                            <TextBlock Text="5" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[27].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[27].ToggleCommand}">
                                            <TextBlock Text="4" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[28].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[28].ToggleCommand}">
                                            <TextBlock Text="3" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[29].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[29].ToggleCommand}">
                                            <TextBlock Text="2" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[30].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[30].ToggleCommand}">
                                            <TextBlock Text="1" FontSize="7"/>
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource IeeeBitBtnMan}"
                                                      IsChecked="{Binding IeeeBits32[31].IsOn, Mode=TwoWay}"
                                                      Command="{Binding IeeeBits32[31].ToggleCommand}">
                                            <TextBlock Text="0" FontSize="7"/>
                                        </ToggleButton>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Float64 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Float64" Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Ieee64Text}"
                                           Foreground="{StaticResource GreenBrush}" FontSize="11"/>
                            </StackPanel>
                            <!-- Float64 간략 표시 (64비트 전체 색상 구분) -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="bit63=부호(빨강), bit62~52=지수(주황), bit51~0=가수(초록)"
                                           Foreground="{StaticResource Fg3Brush}" FontSize="9" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding IeeeBits64}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ToggleButton IsChecked="{Binding IsOn, Mode=TwoWay}"
                                                          Command="{Binding ToggleCommand}"
                                                          ToolTip="{Binding Index}"
                                                          MinWidth="12" Height="14" FontSize="7"
                                                          Padding="1" Margin="0,0,1,1">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                                        <Setter Property="BorderBrush" Value="#3A7A50"/>
                                                        <Setter Property="MinWidth" Value="12"/>
                                                        <Setter Property="Height" Value="14"/>
                                                        <Setter Property="FontSize" Value="7"/>
                                                        <Setter Property="Padding" Value="1"/>
                                                        <Setter Property="Margin" Value="0,0,1,1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IeeePart}" Value="Sign">
                                                                <Setter Property="BorderBrush" Value="#FF5060"/>
                                                                <Setter Property="Background" Value="#200010"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IeeePart}" Value="Exp">
                                                                <Setter Property="BorderBrush" Value="#FF9040"/>
                                                                <Setter Property="Background" Value="#1E1800"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                <Setter Property="Background" Value="#1A3A6A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ⑤ 계산 히스토리 ───────────────────────── -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,4"
                        MaxHeight="160">
                    <StackPanel>
                        <TextBlock Text="히스토리 (클릭으로 재사용)" Foreground="{StaticResource Fg3Brush}"
                                   FontSize="10" Margin="0,0,0,4"/>
                        <ListBox ItemsSource="{Binding History}"
                                 SelectedValuePath="Value"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MaxHeight="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Hex}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Dec}"
                                                   Foreground="{StaticResource GreenBrush}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Bin}"
                                                   Foreground="{StaticResource Fg3Brush}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.HistorySelectCmd, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            </ListBox.InputBindings>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- 하단 힌트 -->
                <TextBlock Foreground="{StaticResource Fg3Brush}" FontSize="10"
                           HorizontalAlignment="Right" Margin="0,2,4,0">
                    <Run Text="Win+K"/>
                    <Run Text=" 전역 단축키 | "/>
                    <Run Text="비트 클릭으로 직접 편집 | "/>
                    <Run Text="AND/OR/XOR 후 = 로 적용"/>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
