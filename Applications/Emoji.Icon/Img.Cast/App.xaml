<Application x:Class="ImgCast.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
  <Application.Resources>
    <SolidColorBrush x:Key="BgBrush"        Color="#1A1A1E"/>
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#252530"/>
    <SolidColorBrush x:Key="Surface2Brush"  Color="#2E2E3A"/>
    <SolidColorBrush x:Key="BorderBrush"    Color="#3A3A48"/>
    <SolidColorBrush x:Key="TextBrush"      Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SubTextBrush"   Color="#888899"/>
    <SolidColorBrush x:Key="AccentBrush"    Color="#29B6F6"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#163A52"/>
    <SolidColorBrush x:Key="DangerBrush"    Color="#FA6E6E"/>
  </Application.Resources>
</Application>
