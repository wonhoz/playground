<Window x:Class="Stock.Watch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock.Watch 설정" Height="600" Width="540"
        Background="#FF1A1A1A" FontFamily="Segoe UI, Malgun Gothic"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="18" Background="#FF1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="한국투자증권 (KIS) Open API" FontSize="15" FontWeight="Bold"/>
            <TextBlock Foreground="#FF888888" FontSize="11.5" TextWrapping="Wrap" Margin="0,4,0,0"
                       Text="KIS Developers(apiportal.koreainvestment.com)에서 발급한 APP KEY / APP SECRET을 입력하세요. 키는 이 PC의 %LocalAppData%에만 저장되며 소스 저장소에 포함되지 않습니다."/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="APP KEY" Margin="0,6,0,3"/>
                <TextBox x:Name="AppKeyBox"/>

                <TextBlock Text="APP SECRET" Margin="0,10,0,3"/>
                <PasswordBox x:Name="AppSecretBox"/>

                <CheckBox x:Name="MockCheck" Content="모의투자 서버 사용 (실전 대신 :29443)" Margin="0,12,0,0"/>

                <Separator Margin="0,16" Background="#FF3A3A3A"/>

                <TextBlock Text="Slack Incoming Webhook URL" FontWeight="Bold"/>
                <TextBlock Foreground="#FF888888" FontSize="11.5" TextWrapping="Wrap" Margin="0,4,0,4"
                           Text="Slack 앱 → Incoming Webhooks 활성화 → 채널 선택 후 발급된 https://hooks.slack.com/services/... URL을 붙여넣으세요."/>
                <TextBox x:Name="SlackBox"/>
                <Button x:Name="TestSlackBtn" Content="테스트 메시지 전송" HorizontalAlignment="Left" Margin="0,8,0,0" Padding="12,5"/>

                <Separator Margin="0,16" Background="#FF3A3A3A"/>

                <TextBlock Text="폴링 / 알림" FontWeight="Bold"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="시세 조회 주기 (초)" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="PollBox" HorizontalContentAlignment="Right"/>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="동일 알림 최소 간격 (초, 도배 방지)" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="CooldownBox" HorizontalContentAlignment="Right"/>
                </Grid>
                <CheckBox x:Name="MarketHoursCheck" Content="장 시간(평일 09:00~15:30)에만 감시" Margin="0,12,0,0"/>
                <CheckBox x:Name="RealtimeCheck" Content="WebSocket 실시간 체결가 사용 (장중 틱 즉시 반영)" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelBtn" Content="취소" Width="90" Margin="0,0,8,0"/>
            <Button x:Name="SaveBtn" Content="저장" Width="110" Style="{StaticResource AccentButton}"/>
        </StackPanel>
    </Grid>
</Window>
