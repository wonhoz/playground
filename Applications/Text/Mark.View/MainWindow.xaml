<Window x:Class="MarkView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:MarkView"
        Title="Mark.View"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        Background="{StaticResource BgBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        WindowStartupLocation="CenterScreen"
>


  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- 툴바 -->
      <RowDefinition Height="*"/>      <!-- 콘텐츠 -->
      <RowDefinition Height="Auto"/>   <!-- 상태바 -->
    </Grid.RowDefinitions>

    <!-- ══ 툴바 ══════════════════════════════════════════ -->
    <Border x:Name="ToolbarBorder" Grid.Row="0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>   <!-- 버튼 영역 -->
          <RowDefinition Height="Auto"/>   <!-- 서식 도구모음 -->
          <RowDefinition Height="Auto"/>   <!-- 찾기/바꾸기 바 -->
          <RowDefinition Height="3"/>      <!-- 로딩 바 -->
        </Grid.RowDefinitions>

        <!-- 서식 도구모음 (Grid Row 1 — 편집 모드) -->
        <Border x:Name="FormatBar" Grid.Row="1"
                Visibility="Collapsed"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="서식:" FontSize="10"
                       Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <Button Style="{StaticResource IconButton}" Tag="h1"
                    Click="FmtBtn_Click" ToolTip="H1 헤딩" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="H1" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="h2"
                    Click="FmtBtn_Click" ToolTip="H2 헤딩" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="H2" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="h3"
                    Click="FmtBtn_Click" ToolTip="H3 헤딩" Padding="6,3" Margin="0,0,4,0">
              <TextBlock Text="H3" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
            </Button>
            <Separator Width="1" Height="16" Margin="2,0" Background="{StaticResource BorderBrush}"/>
            <Button Style="{StaticResource IconButton}" Tag="bold"
                    Click="FmtBtn_Click" ToolTip="굵게 (Ctrl+B)" Padding="6,3" Margin="4,0,1,0">
              <TextBlock Text="B" FontSize="12" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="italic"
                    Click="FmtBtn_Click" ToolTip="기울임 (Ctrl+I)" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="I" FontSize="12" FontStyle="Italic"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="code"
                    Click="FmtBtn_Click" ToolTip="인라인 코드" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="`C`" FontSize="11" FontFamily="Cascadia Code, Consolas, monospace"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="codeblock"
                    Click="FmtBtn_Click" ToolTip="코드 블록" Padding="6,3" Margin="0,0,4,0">
              <TextBlock Text="```" FontSize="11" FontFamily="Cascadia Code, Consolas, monospace"/>
            </Button>
            <Separator Width="1" Height="16" Margin="2,0" Background="{StaticResource BorderBrush}"/>
            <Button Style="{StaticResource IconButton}" Tag="link"
                    Click="FmtBtn_Click" ToolTip="링크 삽입 (Ctrl+K)" Padding="6,3" Margin="4,0,1,0">
              <TextBlock Text="&#x1F517;" FontSize="12"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="quote"
                    Click="FmtBtn_Click" ToolTip="인용문" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="&#x276E;" FontSize="13" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="ul"
                    Click="FmtBtn_Click" ToolTip="목록 (unordered)" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="&#x2022;&#x2022;" FontSize="11"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="ol"
                    Click="FmtBtn_Click" ToolTip="번호 목록 (ordered)" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="1." FontSize="11"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Tag="hr"
                    Click="FmtBtn_Click" ToolTip="가로 구분선" Padding="6,3" Margin="0,0,1,0">
              <TextBlock Text="&#x2500;&#x2500;" FontSize="11"/>
            </Button>
            <Separator Width="1" Height="16" Margin="2,0" Background="{StaticResource BorderBrush}"/>
            <Button Style="{StaticResource IconButton}" Tag="table"
                    Click="FmtBtn_Click" ToolTip="표 삽입" Padding="6,3" Margin="4,0,1,0">
              <TextBlock Text="표" FontSize="11" FontWeight="SemiBold"/>
            </Button>
          </StackPanel>
        </Border>

        <!-- 찾기/바꾸기 바 (Grid Row 2) -->
        <Border x:Name="ReplaceBar" Grid.Row="2"
                Visibility="Collapsed"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="바꾸기:" FontSize="11"
                       Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtReplace" Width="160"
                     ToolTip="바꿀 내용"
                     KeyDown="TxtReplace_KeyDown">
              <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                  <Style.Triggers>
                    <Trigger Property="Text" Value="">
                      <Setter Property="Background">
                        <Setter.Value>
                          <VisualBrush Stretch="None" AlignmentX="Left">
                            <VisualBrush.Visual>
                              <TextBlock Text="  바꿀 내용..." Foreground="#6888AA"
                                         FontSize="12" VerticalAlignment="Center"/>
                            </VisualBrush.Visual>
                          </VisualBrush>
                        </Setter.Value>
                      </Setter>
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </TextBox.Style>
            </TextBox>
            <Button Style="{StaticResource IconButton}" Click="BtnReplace_Click"
                    ToolTip="바꾸기 (한 건)" Margin="6,0,2,0" Padding="8,4">
              <TextBlock Text="바꾸기" FontSize="11"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Click="BtnReplaceAll_Click"
                    ToolTip="모두 바꾸기" Margin="2,0,0,0" Padding="8,4">
              <TextBlock Text="모두" FontSize="11"/>
            </Button>
            <TextBlock x:Name="StatusReplace" FontSize="11"
                       Foreground="{StaticResource Accent2Brush}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       Visibility="Collapsed"/>
          </StackPanel>
        </Border>

        <!-- 로딩 바 (Grid Row 3 — WebView2 바깥이라 airspace 문제 없음) -->
        <!-- 외부: 항상 보이는 solid 그라디언트 바 -->
        <Border x:Name="LoadingBarTrack" Grid.Row="3" ClipToBounds="True" Visibility="Collapsed">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#204A9EF5" Offset="0"/>
              <GradientStop Color="#4A9EF5"   Offset="0.35"/>
              <GradientStop Color="#FFD700"   Offset="0.55"/>
              <GradientStop Color="#20FFD700" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
          <!-- 내부: 반짝이는 흰색 하이라이트 오버레이 -->
          <Border x:Name="LoadingBarIndicator" Width="120" Height="3"
                  HorizontalAlignment="Left">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="Transparent" Offset="0"/>
                <GradientStop Color="#80FFFFFF"   Offset="0.5"/>
                <GradientStop Color="Transparent" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <Border.RenderTransform>
              <TranslateTransform x:Name="LoadingBarTranslate" X="-120"/>
            </Border.RenderTransform>
          </Border>
        </Border>

        <!-- 버튼 영역 (Grid Row 0) -->
        <Grid Grid.Row="0" Margin="8,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽: 파일 버튼 -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                    HorizontalAlignment="Left">
          <Button Style="{StaticResource IconButton}" Click="BtnNew_Click"
                  ToolTip="새 파일 (Ctrl+N)" Margin="0,0,2,0" Padding="8,5">
            <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"/>
          </Button>
          <Button Style="{StaticResource IconButton}" Click="BtnOpen_Click"
                  ToolTip="열기 (Ctrl+O)" Margin="0,0,2,0" Padding="8,5">
            <TextBlock Text="&#x1F4C2;" FontSize="14"/>
          </Button>
          <Button Style="{StaticResource IconButton}" Click="BtnSave_Click"
                  ToolTip="저장 (Ctrl+S)" Margin="0,0,2,0" Padding="8,5">
            <TextBlock Text="&#x1F4BE;" FontSize="14"/>
          </Button>
          <Separator Width="1" Height="20" Margin="4,0" Background="{StaticResource BorderBrush}"/>
          <!-- 편집 모드 토글 -->
          <Button x:Name="BtnToggleEdit" Style="{StaticResource IconButton}"
                  Click="BtnToggleEdit_Click"
                  ToolTip="편집 모드 전환 (Ctrl+E)" Margin="0,0,2,0" Padding="8,5">
            <TextBlock x:Name="TxtEditIcon" Text="&#x270F;" FontSize="14"/>
          </Button>
          <!-- TOC 토글 -->
          <Button x:Name="BtnToc" Style="{StaticResource IconButton}"
                  Click="BtnToc_Click"
                  ToolTip="목차 패널 (Ctrl+T)" Margin="0,0,2,0" Padding="8,5">
            <TextBlock Text="&#x2630;" FontSize="14"/>
          </Button>
          <Separator Width="1" Height="20" Margin="4,0" Background="{StaticResource BorderBrush}"/>
          <!-- HTML 내보내기 -->
          <Button Style="{StaticResource IconButton}" Click="BtnExportHtml_Click"
                  ToolTip="HTML로 내보내기 (Ctrl+Shift+E)" Margin="0,0,2,0" Padding="8,5">
            <TextBlock Text="&#x1F4E4;" FontSize="14"/>
          </Button>
          <!-- PDF 내보내기 -->
          <Button Style="{StaticResource IconButton}" Click="BtnExportPdf_Click"
                  ToolTip="PDF로 내보내기 (Ctrl+P)" Margin="0,0,2,0" Padding="8,5">
            <TextBlock Text="&#x1F4CB;" FontSize="14"/>
          </Button>
          <!-- 새로고침 -->
          <Button Style="{StaticResource IconButton}" Click="BtnReload_Click"
                  ToolTip="새로고침 (F5)" Padding="8,5">
            <TextBlock Text="&#x21BB;" FontSize="14"/>
          </Button>
          <Separator Width="1" Height="20" Margin="4,0" Background="{StaticResource BorderBrush}"/>
          <!-- 집중 모드 -->
          <Button x:Name="BtnFocus" Style="{StaticResource IconButton}" Click="BtnFocus_Click"
                  ToolTip="집중 모드 (F11)" Padding="8,5">
            <TextBlock Text="&#x26F6;" FontSize="14"/>
          </Button>
          <!-- Word Wrap 토글 -->
          <Button x:Name="BtnWordWrap" Style="{StaticResource IconButton}" Click="BtnWordWrap_Click"
                  ToolTip="줄바꿈 토글 (Alt+Z)" Padding="8,5">
            <TextBlock x:Name="TxtWordWrapIcon" Text="&#x21A9;" FontSize="14"/>
          </Button>
        </StackPanel>

        <!-- 가운데: 앱 제목 (진짜 중앙) -->
        <TextBlock Grid.Column="1"
                   Text="Mark.View"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}"
                   VerticalAlignment="Center"/>

        <!-- 오른쪽: 테마 + 찾기 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                    HorizontalAlignment="Right">
          <!-- 테마 선택 -->
          <ComboBox x:Name="CmbTheme" Width="110" Height="28"
                    ToolTip="색상 테마 선택"
                    SelectionChanged="CmbTheme_SelectionChanged"
                    Margin="0,0,6,0">
            <ComboBoxItem Content="다크 (기본)" Tag="dark" IsSelected="True"/>
            <ComboBoxItem Content="GitHub Dark" Tag="github-dark"/>
            <ComboBoxItem Content="Nord" Tag="nord"/>
            <ComboBoxItem Content="Dracula" Tag="dracula"/>
            <ComboBoxItem Content="Sepia" Tag="sepia"/>
            <ComboBoxItem Content="라이트" Tag="light"/>
          </ComboBox>
          <Separator Width="1" Height="20" Margin="0,0,6,0" Background="{StaticResource BorderBrush}"/>
          <!-- 단축키 도움말 -->
          <Button Style="{StaticResource IconButton}" Click="BtnHelp_Click"
                  ToolTip="단축키 도움말 (F1)" Margin="0,0,6,0" Padding="8,5">
            <TextBlock Text="?" FontSize="13" FontWeight="SemiBold"/>
          </Button>
          <Grid Width="160">
            <TextBox x:Name="TxtFind"
                     ToolTip="찾기 (Ctrl+F)"
                     TextChanged="TxtFind_TextChanged"
                     KeyDown="TxtFind_KeyDown"/>
            <TextBlock Text="&#x1F50D; 찾기..." Foreground="#6888AA"
                       FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                       IsHitTestVisible="False" IsEnabled="False">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Text, ElementName=TxtFind}" Value="">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
          <!-- 이전/다음 찾기 버튼 -->
          <Button Style="{StaticResource IconButton}" Click="BtnFindPrev_Click"
                  ToolTip="이전 결과 (Shift+Enter)" Margin="2,0,0,0" Padding="6,5">
            <TextBlock Text="&#x25B2;" FontSize="10"/>
          </Button>
          <Button Style="{StaticResource IconButton}" Click="BtnFindNext_Click"
                  ToolTip="다음 결과 (Enter)" Margin="1,0,0,0" Padding="6,5">
            <TextBlock Text="&#x25BC;" FontSize="10"/>
          </Button>
        </StackPanel>
        </Grid><!-- /buttons Grid -->
      </Grid><!-- /outer toolbar Grid -->
    </Border>

    <!-- ══ 메인 콘텐츠 ═══════════════════════════════════ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="TocColumn" Width="0" MinWidth="0" MaxWidth="500"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*" MinWidth="300"/>
      </Grid.ColumnDefinitions>

      <!-- TOC 패널 -->
      <Border x:Name="TocPanel"
              Grid.Column="0"
              Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,1,0"
              Visibility="Collapsed">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top"
                     Text="목차" FontSize="12" FontWeight="SemiBold"
                     Foreground="{StaticResource TextDimBrush}"
                     Padding="12,8"/>
          <ListBox x:Name="TocList"
                   Background="Transparent"
                   BorderThickness="0"
                   SelectionChanged="TocList_SelectionChanged"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Foreground"  Value="{StaticResource TextDimBrush}"/>
                <Setter Property="Padding"     Value="12,5"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>
        </DockPanel>
      </Border>

      <GridSplitter x:Name="TocSplitter"
                    Grid.Column="1"
                    Width="4" HorizontalAlignment="Stretch"
                    Visibility="Collapsed"
                    DragCompleted="TocSplitter_DragCompleted"/>

      <!-- 탭 + 편집/뷰 영역 -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- 탭바 -->
          <RowDefinition Height="*"/>     <!-- 본문 -->
        </Grid.RowDefinitions>

        <!-- 탭바 (커스텀) -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="TabBar" Orientation="Horizontal"/>
          </ScrollViewer>
        </Border>

        <!-- 빈 상태 -->
        <Border x:Name="EmptyState" Grid.Row="1"
                Background="{StaticResource BgBrush}"
                Visibility="Visible">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="&#x1F4DD;" FontSize="48" HorizontalAlignment="Center"
                       Margin="0,0,0,12" Foreground="{StaticResource TextDimBrush}"/>
            <TextBlock Text="Mark.View" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Markdown 뷰어 및 에디터" FontSize="13"
                       Foreground="{StaticResource TextDimBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,24"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button Style="{StaticResource AccentButton}"
                      Click="BtnOpen_Click" Margin="0,0,8,0" Padding="16,8">
                <TextBlock><Run Text="&#x1F4C2; "/>파일 열기</TextBlock>
              </Button>
              <Button Click="BtnNew_Click" Padding="16,8">
                <TextBlock><Run Text="+ "/>새 파일</TextBlock>
              </Button>
            </StackPanel>
            <TextBlock Text="또는 파일을 여기에 끌어다 놓으세요" FontSize="11"
                       Foreground="{StaticResource TextDimBrush}"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>

            <!-- 최근 파일 목록 -->
            <Border x:Name="RecentFilesPanel" Visibility="Collapsed"
                    Margin="0,24,0,0" MaxWidth="400">
              <StackPanel>
                <TextBlock Text="최근 파일" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDimBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <!-- 최근 파일 검색 -->
                <Grid Width="240" Margin="0,0,0,8" HorizontalAlignment="Center">
                  <TextBox x:Name="TxtRecentSearch"
                           TextChanged="TxtRecentSearch_TextChanged"/>
                  <TextBlock Text="&#x1F50D; 파일 검색..." Foreground="#6888AA"
                             FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                             IsHitTestVisible="False" IsEnabled="False">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Text, ElementName=TxtRecentSearch}" Value="">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>
                <ItemsControl x:Name="RecentFilesList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border x:Name="RecentItemBorder" Padding="10,6" Cursor="Hand"
                              Background="Transparent"
                              MouseLeftButtonDown="RecentFile_Click"
                              MouseEnter="RecentFile_MouseEnter"
                              MouseLeave="RecentFile_MouseLeave"
                              CornerRadius="6">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="📌 " FontSize="11"
                                         Visibility="{Binding IsPinned, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                         Foreground="{StaticResource AccentBrush}"/>
                              <TextBlock Text="{Binding FileName}" FontSize="12"
                                         Foreground="{StaticResource TextBrush}"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Directory}" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                          <Button Grid.Column="1" Style="{StaticResource IconButton}"
                                  Click="PinFile_Click"
                                  Tag="{Binding FullPath}"
                                  ToolTip="즐겨찾기 고정/해제"
                                  Padding="5,3" Margin="4,0,0,0">
                            <TextBlock Text="{Binding PinIcon}" FontSize="11"/>
                          </Button>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- 뷰/편집 본문 -->
        <Grid x:Name="ContentArea" Grid.Row="1" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="EditorColumn" Width="0" MinWidth="0"/>
            <ColumnDefinition x:Name="SplitterColumn" Width="0"/>
            <ColumnDefinition x:Name="ViewerColumn" Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- 편집기 -->
          <Border Grid.Column="0"
                  Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="0,0,1,0">
            <TextBox x:Name="Editor"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="#060E1A"
                     Foreground="#D8E8F8"
                     BorderThickness="0"
                     Padding="16"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     FontSize="13"
                     CaretBrush="#4A9EF5"
                     SelectionBrush="#4A9EF5"
                     TextChanged="Editor_TextChanged"
                     KeyDown="Editor_KeyDown"/>
          </Border>

          <GridSplitter x:Name="EditorSplitter"
                        Grid.Column="1"
                        Width="4" HorizontalAlignment="Stretch"
                        DragCompleted="EditorSplitter_DragCompleted"/>

          <!-- 뷰어 (WebView2) -->
          <wv2:WebView2 x:Name="Viewer"
                        Grid.Column="2"/>
        </Grid>
      </Grid>
    </Grid>

    <!-- ══ 상태바 ═════════════════════════════════════════ -->
    <Border x:Name="StatusBarBorder" Grid.Row="2"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,4">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
          <TextBlock x:Name="StatusPath"
                     Text="파일을 열어주세요"
                     FontSize="11"
                     Foreground="{StaticResource TextDimBrush}"
                     VerticalAlignment="Center"
                     Cursor="Hand"
                     ToolTip="클릭하여 파일 위치 열기"
                     MouseLeftButtonDown="StatusPath_MouseLeftButtonDown"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <TextBlock x:Name="StatusFind"
                     FontSize="11"
                     Foreground="{StaticResource Accent2Brush}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"
                     Visibility="Collapsed"/>
          <TextBlock x:Name="StatusWords"
                     FontSize="11"
                     Foreground="{StaticResource TextDimBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"/>
          <TextBlock x:Name="StatusLines"
                     FontSize="11"
                     Foreground="{StaticResource TextDimBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"/>
          <TextBlock x:Name="StatusCursor"
                     FontSize="11"
                     Foreground="{StaticResource TextDimBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"
                     Visibility="Collapsed"/>
          <TextBlock x:Name="StatusUndo"
                     Text="↩" FontSize="11"
                     Foreground="{StaticResource TextDimBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Visibility="Collapsed"
                     ToolTip="실행 취소 가능 (Ctrl+Z)"/>
          <TextBlock x:Name="StatusMode"
                     FontSize="11"
                     Foreground="{StaticResource AccentBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
