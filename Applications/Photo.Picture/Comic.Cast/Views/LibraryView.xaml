<UserControl x:Class="ComicCast.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:ComicCast.Views"
             Background="{StaticResource Bg1}">

    <UserControl.Resources>
        <v:BoolToVisConverter x:Key="BoolToVis"/>
        <v:BoolToVisConverter x:Key="BoolToVisInv" Invert="True"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Grid Grid.Row="0" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" Margin="0,0,8,0"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Tag="만화 검색...">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="만화 검색..." Foreground="#555566"
                                                           FontSize="13" Margin="10,5"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Button Grid.Column="1" Margin="0,0,6,0" Content="폴더 추가"
                    Command="{Binding AddFolderCommand}"
                    Style="{StaticResource AccentButton}"/>
            <Button Grid.Column="2" Margin="0,0,6,0" Content="새로 고침"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource BoolToVisInv}}"/>
            <Button Grid.Column="3" Content="WebP 변환"
                    Command="{Binding ConvertWebpCommand}"/>
        </Grid>

        <!-- 스캔 진행 표시 -->
        <Border Grid.Row="0" Margin="12,0" VerticalAlignment="Bottom"
                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Height="3"/>
        </Border>

        <!-- 책 목록 (WrapPanel) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Books}"
                          Margin="8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Margin="6"
                                Background="{StaticResource Bg2}"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="8"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.AddFolderCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <!-- 커버 -->
                                <Border Height="220" CornerRadius="7,7,0,0" ClipToBounds="True">
                                    <Grid>
                                        <!-- 커버 없을 때 배경 -->
                                        <Rectangle Fill="{StaticResource Bg0}"/>
                                        <TextBlock Text="📖" FontSize="40"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Cover, Converter={StaticResource BoolToVisInv}}"/>
                                        <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                               Visibility="{Binding Cover, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>
                                <!-- 메타 -->
                                <StackPanel Margin="8,6,8,8">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                               FontSize="12" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Title}"/>
                                    <TextBlock Text="{Binding SeriesInfo}" FontSize="11"
                                               Foreground="{StaticResource FgSub}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,4"/>
                                    <!-- 읽기 진행 바 -->
                                    <Grid>
                                        <ProgressBar Value="{Binding ReadPercent}" Maximum="100"
                                                     Height="4"/>
                                    </Grid>
                                    <TextBlock Text="{Binding PageInfo}" FontSize="10"
                                               Foreground="{StaticResource FgSub}" Margin="0,3,0,0"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 빈 상태 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Books.Count, Converter={StaticResource BoolToVisInv}}">
            <TextBlock Text="📚" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="만화 폴더를 추가하거나 파일을 드래그하세요."
                       Foreground="{StaticResource FgSub}" HorizontalAlignment="Center"/>
            <Button Content="폴더 추가" Margin="0,16,0,0" HorizontalAlignment="Center"
                    Command="{Binding AddFolderCommand}" Style="{StaticResource AccentButton}"
                    Padding="24,10"/>
        </StackPanel>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Background="{StaticResource Bg0}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid Margin="12,5">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FgSub}"
                           FontSize="12"/>
                <!-- WebP 변환 진행 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsConverting, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="12" Foreground="{StaticResource FgSub}" Margin="0,0,8,0">
                        <Run Text="{Binding ConvertProgress, Mode=OneWay}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding ConvertTotal, Mode=OneWay}"/>
                        <Run Text="p 변환 중"/>
                    </TextBlock>
                    <ProgressBar Width="120" Height="6"
                                 Value="{Binding ConvertProgress, Mode=OneWay}"
                                 Maximum="{Binding ConvertTotal, Mode=OneWay}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
