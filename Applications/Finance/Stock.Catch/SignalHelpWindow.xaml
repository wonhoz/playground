<Window x:Class="Stock.Catch.SignalHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="시그널 도움말" Height="720" Width="640"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock" BasedOn="{StaticResource Body}">
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="FontSize" Value="11.5"/>
        </Style>
        <Style x:Key="Cell" TargetType="TextBlock" BasedOn="{StaticResource Body}">
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellHead" TargetType="TextBlock" BasedOn="{StaticResource Cell}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📖 시그널 도움말" FontSize="19" FontWeight="Bold"
                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,4"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,14,0">

                <TextBlock Style="{StaticResource H1}" Text="시그널 종류와 순서 (신뢰도 사다리)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="☀ 개장 브리핑 — 매 거래일 첫 폴링(09:05경) 1회. 갭·일봉추세로 오늘 분위기 요약.&#10;📈 바닥 반등 시그널 (1차) — 급락 → 볼린저 하단 터치 → 밴드 복귀 + RSI 상승 전환 + 거래량 급증. 관찰 시작 신호. 개장 급락으로 20-밴드가 넓어져 두 번째 저점(이중 바닥)을 놓치지 않도록 짧은 볼린저(10)도 병행합니다.&#10;↗ 반등 지속 (직후 양봉) — 1차 직후 첫 봉이 양봉이면 +1분 만에 오는 조기 확인 힌트(1분봉 전용).&#10;🔥 강력 확인 / ✅ 반등 확인 / ⚠ 약한 확인 (2차 골든크로스) — MA5가 MA20을 상향 돌파. 등급은 1차 이후 상승률(모멘텀)로 결정: 🔥 ≥2.0% · ✅ ≥0.8% · ⚠ 미달(횡보성 크로스, 관망).&#10;📉 고점 경고 — 상단 밴드워킹 + RSI 과매수 후 이탈(익절 검토). 🔻 데드크로스 — 하락 확인.&#10;🔁 전환 확인 (교차) — 고점 경고 후 15분 내 반대 짝 종목(레버리지↔인버스)의 반등 확인(✅🔥)이 따라오면 발화. 실측(14일·27건): 30분 내 1% 이상 하락 93% · 평균 −4.1% — 보유 중이면 가장 강한 매도 신호. 관심 종목 편집의 '반대 짝 코드'로 켭니다."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="실측(3종목×14일 · GC 110건): 🔥 등급일수록 건당 기대수익 단조 증가(0.8~1.5% +0.11 → 2.5%+ +0.41%/건). 진짜 반등은 골든크로스가 5~9분 내 따라오고, 직후 양봉도 3/4 동반."/>

                <TextBlock Style="{StaticResource H1}" Text="⭐ 종합 판정 단계 (알림 2번째 줄)"/>
                <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6" Margin="0,2,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#FF232323" CornerRadius="6,6,0,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource CellHead}" Text="판정"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource CellHead}" Text="조건"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource CellHead}" Text="실측 근거 (14일×3종목)"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Cell}" Text="🌟🌟🌟🌟🌟 진입 적기"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Cell}" Text="🚀 GC 후 2분 추세 지속 확인"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource Cell}" Text="승률 90% (즉시진입 57%)"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Cell}" Text="⭐⭐⭐⭐ 최상 · 즉시 주목"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Cell}" Text="🔥 강력 GC / ✅ GC + VWAP 위"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource Cell}" Text="63%·+4.6% / 71%·낙폭 −0.97%"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource Cell}" Text="⭐⭐⭐ 좋음"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource Cell}" Text="✅ GC (VWAP 아래) — 2분 확인 후 진입"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource Cell}" Text="승률 ~50%"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource Cell}" Text="⭐⭐ 주목"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource Cell}" Text="↗ 직후양봉 / 📈 반등+다이버전스"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Style="{StaticResource Cell}" Text="44% / 이후 GC 승률 67%"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource Cell}" Text="⭐ 관찰"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource Cell}" Text="📈 반등 1차 — 확인 대기"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Style="{StaticResource Cell}" Text="승률 50% (진입은 🚀에서)"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource Cell}" Text="(별 없음) 참고"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource Cell}" Text="⚠ 약한 GC (횡보성) — 무시 가능"/>
                        <TextBlock Grid.Row="6" Grid.Column="2" Style="{StaticResource Cell}" Text="승률 49% · 수익폭 열위"/>
                    </Grid>
                </Border>
                <TextBlock Style="{StaticResource Muted}"
                           Text="승률 = 시그널 이후 30분 내 ±1% 선도달 기준. 고점 경고는 '⚠️ 경계 — 익절 검토', 데드크로스는 '🔻 하락 확인 — 정리/관망'으로 표시됩니다. 지표 상세(RSI·%b·거래량·컨텍스트)는 트레이 메뉴 [시그널 로그 폴더]의 일자별 CSV와 분봉 시그널 분석 창에서 확인하세요."/>

                <TextBlock Style="{StaticResource H1}" Text="🚀 진입 적기 — GC에 무작정 들어가지 말 것"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="🔥/✅ 골든크로스는 '확인'이지 '진입 신호'가 아닙니다. 실측(14일 GC 114건): GC 즉시 진입은 승률 57%·오탐율 16%인데, GC 후 2분이 지나도 종가가 GC 가격 이상이면(🚀 진입 적기) 승률 82%·오탐 2%, 3분이면 90%·0%로 급등합니다. 특히 🔥는 급반등 꼭대기에서 뜨면 즉시 오탐율이 38%로 가장 위험(2분 확인 시 13%). 그래서 🔥/✅가 떠도 1~3분 추세를 더 보고, 🚀 진입 적기 알림이 오면 그때 들어가는 것이 안전합니다."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="🚀는 GC 후 2봉(기본) 뒤 종가가 GC 가격 이상일 때만 발화하고, 그 사이 하락하면 조용히 취소됩니다(진입 부적합 = 오탐 회피). 07-03 KODEX레버: 09:39 🔥(꼭대기)는 🚀 없이 걸러지고, 진짜 저점 후 10:04 🔥 → 10:06 🚀만 통과(+8% 상승)."/>
                <TextBlock Style="{StaticResource Body}"
                           Text="⚠ 역추세 경고 — 🚀 진입 적기라도 MA20·MA60이 둘 다 아직 하락 중이면 '하락하는 이평으로의 역추세 반등'이라 실패가 잦습니다. 실측(66건): MA20·60 정렬(둘 다 상승) 진입은 순상승 75%·큰 낙폭 0%인데, 둘 다 하락 중이면 48%·낙폭 −1.42%·−2% 이상 하락 27.6%. 07-06 KODEX레버 10:19 🚀(MA20 −0.15·MA60 −0.22)가 바로 이 함정으로 −1.9%↓ — 반면 같은 종목·같은 날 SK하이닉스 레버리지 13:16 🚀는 MA20이 +0.10으로 살아나 정상(+4.6%). 역추세 🚀엔 판정줄에 '⚠ 역추세'와 함께 손절선이 −3%로 넓게 표기됩니다 — 굳이 무리하지 말고 MA20이 고개를 들 때까지 기다리는 편이 낫습니다."/>

                <TextBlock Style="{StaticResource H1}" Text="📦 진입 권장 — 박스 상단 돌파 (흔들림 통과 확인)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="GC/🚀 직후에도 바로 들어가면 흔들림(초기 −1~2%)을 견뎌야 합니다. 대신 GC 직후 3봉으로 '박스'(고가·저가)를 만들고, 이후 봉이 박스 안에서 흔들리는 동안 계속 박스를 넓히며 추적하다가 종가가 박스 상단(그동안의 최고가)을 돌파하는 순간 '📦 진입 권장'을 보냅니다 — 즉 흔들림을 통과하고 방향이 위로 확정된 자리입니다. 실측(15일 GC 134건): GC 즉시 진입은 순상승 41%·낙폭≤−2% 28%인데, 박스 상단 돌파 진입은 순상승 49%·16%로 승률↑·큰 낙폭 위험이 절반. 07-07 SK레버는 14:23 GC 후 서킷 여파로 19,705까지 흔들린 뒤 14:29 박스 상단 돌파(📦)가 바로 +11% 자리였습니다."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="박스는 최대 20봉(≈20분)까지 추적하고 그 안에 상단 돌파가 없으면 폐기합니다(김샘). 박스 하단 이탈은 알리지 않습니다 — 실측상 하단 이탈의 73%는 오히려 흔들기 바닥이라 겁줄 필요가 없기 때문. 손절선은 박스 하단(무효선)으로 함께 표기됩니다. GC·🚀를 '준비', 📦를 '방아쇠'로 쓰면 흔들림을 훨씬 덜 견딥니다."/>

                <TextBlock Style="{StaticResource H1}" Text="종목별 위험도 (GC 즉시진입 오탐율 · 14일 실측)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="오탐율 = 골든크로스 후 3분 내 −1% 하락 도달 비율. 높을수록 🚀 진입 적기를 꼭 기다려야 합니다.&#10;⚠ 조심(오탐 잦음): SK하이닉스 레버리지 30% · 삼성전기 25% · SK스퀘어 25%.&#10;△ 보통: KODEX 레버리지 13% · SK하이닉스 인버스 11% · 삼성전자 레버리지 8%.&#10;○ 안전(즉시성 높음): SK하이닉스 본주 0% · 삼성전자 인버스 0% · 삼성전자 0%."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="'조심' 종목은 🔥가 떠도 반드시 🚀 진입 적기까지 기다리거나 1~3분 캔들을 눈으로 확인하세요. 레버리지·고변동일수록 첫 반등이 되돌려지는 경우가 잦습니다."/>

                <TextBlock Style="{StaticResource H1}" Text="📿 이동평균 리본 밀집도 — '버티기 쉬운 자리' 판별"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="5·20·60·120 이동평균선이 서로 가까이 모여 있을수록(리본 밀집) 그 자리에서 진입하면 이후 낙폭(버텨야 할 폭)이 작습니다. 반대로 리본이 넓게 벌어진 자리(개장 급락 캐스케이드 등)의 반등/GC는 진입 후 크게 흔들립니다. 실측(전 종목·14일 반등/GC 549건): 밀집 하위1/3(스프레드 중앙 0.8%) 평균 낙폭 −0.77% vs 분산 상위1/3(중앙 4.0%) −2.40% — 3배 차이. 07-06 SK하이닉스 레버리지도 오전 급락 GC(11:03·리본 5.1%)는 −5.9%로 데인 반면, 오후 최적점(13:10~14:40·리본 0.8~2.7%)은 낙폭 −0.1~−1.0%·상승 +3.6~+6.0%."/>
                <TextBlock Style="{StaticResource Body}"
                           Text="컨텍스트 줄에 '리본 X.X%(밀집/보통/분산)'로, 알림 2번째 줄엔 밀집(≤1.5%)이면 '리본 밀집(낙폭 작음)', 분산(≥3.0%)이면 '⚠ 리본 분산(낙폭 주의)'로 표기됩니다. 밀집 = 손절 −2%에 걸릴 확률이 낮아 버티기 편한 자리, 분산 = 진입 자제하거나 손절 여유를 더 두세요."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="주의: 밀집이 '큰 상승'을 뜻하진 않습니다(밀집=저변동이라 상승폭도 대체로 작음, 상관 r=+0.33은 오히려 분산일수록 변동이 큼). 리본은 '방향'이 아니라 '진입 후 흔들림(리스크)'을 읽는 지표입니다. 또한 MA120이 서려면 약 120분이 필요해 대략 11시 이전 시그널엔 표기되지 않습니다(그 시간대는 변동이 커 특히 🚀 진입 적기까지 대기 권장)."/>

                <TextBlock Style="{StaticResource H1}" Text="🎯 고신뢰 반등만 — 애매한 알림 자동 억제 (합류 게이트)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="'애매할 때 무리하게 들어가지 말고 확실할 때만' — 바닥 반등 1차(📈)·직후 양봉(↗) 중 낙폭 위험이 큰 자리는 알림을 보내지 않습니다. 억제 대상: ① 리본 분산(5/20/60/120 스프레드 ≥3%) 또는 ② 역추세(MA20·MA60 동시 하락) + VWAP 아래(추격) 자리. 실측(15일 반등 711건): 이 애매 케이스는 낙폭≤−2%가 34%(리본 분산만 보면 절반이 −2% 급락)인 반면, 게이트를 통과한 자리는 22%로 절반 수준이고 순상승도 더 높습니다. 결과적으로 반등 알림이 약 1/3로 줄어 '진짜 확실한 것'에 집중됩니다."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="중요: 억제되는 건 '반등 1차 알림'뿐이고 내부 추적은 그대로 이어집니다 — 그 자리가 진짜라면 뒤이어 확정되는 🔥/✅ 골든크로스·🚀 진입 적기·📦 진입 권장 알림은 억제 없이 정상 발화합니다. 즉 '진입 신호'는 하나도 놓치지 않으면서 '애매한 관찰 알림'만 걷어냅니다. (config.json의 ReboundHighConvictionGate=false로 끄면 모든 반등 알림 + ⚠ 태그 표기 방식으로 돌아갑니다.) 참고로 MA60/120이 서기 전(≈오전 10~11시 이전)의 이른 반등은 게이트 사각지대라 특히 🚀까지 기다리는 편이 안전합니다."/>

                <TextBlock Style="{StaticResource H1}" Text="[N분] 타임프레임"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="접두 없음=1분봉(초단기), [3분]/[5분]/[10분]/[15분]=1분봉을 롤링(convolution) 집계한 거시 봉. 매 1분 갱신되며 멀리서 본 볼린저·RSI로 같은 로직을 독립 판정합니다. 상위 타임프레임일수록 시그널이 드물고 질이 높습니다(실측: 5분봉 🔥 평균 +1.49%/건)."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="여러 타임프레임이 같은 시각에 동시 발화하면(예: 1·5·10분 동시 🔥) 최상급 — 07-03 10:05 +9.7% 케이스의 시그니처."/>

                <TextBlock Style="{StaticResource H1}" Text="컨텍스트 줄 용어 (3번째 줄)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="갭 — 전일 정규장 종가 → 오늘 시초가 등락(밤사이 변동).&#10;당일 — 오늘 시초가 대비 시그널 시점 등락(장중 흐름 · 전일 대비 아님).&#10;저점比 — 오늘 장중 최저가 대비 반등률. 낮을수록 바닥 초입(한 자릿수 = 갓 반등), 20%+ = 이미 많이 오른 뒤.&#10;VWAP 위/아래 — 당일 거래량 가중 평균가(기관 평균 단가 근사) 대비 위치와 이격. 확인GC(✅🔥)가 VWAP 위면 실측 승률 71%·평균 낙폭 −0.97%(아래면 46%·−2.19%).&#10;리본 — 5/20/60/120 이동평균 스프레드%(밀집/보통/분산). 밀집일수록 진입 후 낙폭이 작아 버티기 쉽습니다(위 '📿 이동평균 리본 밀집도' 참고). MA120 형성 전(≈11시 이전)엔 생략.&#10;다이버전스 — 가격은 신저가인데 RSI는 저점을 높임(하락 힘 소진 힌트). 반등 근거 줄에 표시.&#10;일봉추세 — 직전 완성 일봉 11일의 래더 추세점수(−1~+1). RSI 레벨·기울기·이격도·최근수익률 합성. −1.00 = 직전 폭락."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="⭐ 최고 수익 프로필: 당일 큰 음수(폭락) + 저점比 한 자릿수(V바닥 초입) + 일봉추세 음수(전일 급락). 반대로 당일 크게 양수 + 저점比 20%+ 는 고점 추격 위험. VWAP·일봉추세는 강등이 아닌 참고 정보입니다 — 대박 반등(07-03 10:05 🔥 +6.73%)은 오히려 추세 −1.00·VWAP 아래에서 나왔습니다. VWAP 위 확인GC는 낙폭이 얕아 손절 걸릴 확률이 낮다는 뜻으로 읽으세요."/>

                <TextBlock Style="{StaticResource H1}" Text="운용 가이드 (실측 기반)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="1) ☀ 브리핑에서 '전일 급락 대세 — V바닥 관찰 구간'이면 그날 집중.&#10;2) 📈 1차는 관찰만 → ↗ 직후 양봉은 힌트 → 🔥/✅ 골든크로스는 '확인'(아직 진입 X) → 🚀 진입 적기(2~3분 지속 확인) 또는 📦 진입 권장(박스 상단 돌파·흔들림 통과)에서 진입(⚠는 관망). 특히 📦는 흔들림을 견디지 않고 방향이 위로 확정된 뒤 들어가는 자리라 낙폭 위험이 절반.&#10;3) 멀티 타임프레임 동시 🔥 + 본주·레버리지 동시 발화 = 최상급 후보. 단 '조심' 종목은 🚀까지 대기.&#10;4) 진입 후 20~25분은 지켜볼 것 — 실측: 🚀 진입 시 +1% 익절 기회 78%·+0.5% 89%, 평균 고점 도달이 ~23분. 진입 직후 −1~2% 흔들려도 성급히 던지면 이후 큰 상승을 놓칩니다(못 버티는 게 패의 주범).&#10;5) 안 오르는 경우의 신호: ⚠ 흔들림 주의(VWAP 깊은 약세, 하락 추세 진행 중) 또는 ⚠ 리본 분산(5/20/60/120이 넓게 벌어짐, ≥3%)이면 진입 후 낙폭이 커 버티기 어려움 — 실측 평균 저점 −2.2%(VWAP 위는 −0.6%), 리본 분산 −2.4%(밀집 −0.77%). 리본 밀집(≤1.5%) 자리가 손절 안 걸리고 버티기 가장 편합니다. 폭락일(본주 급등)엔 인버스 진입 역행 주의. 참고로 폭락 후(당일 −5%↓) 반등은 도달률 최고(81%), 저점比 높은 것 자체는 위험 아님.&#10;6) 손절선(실측): 일반 진입 −2%, ⚠ 흔들림 주의·⚠ 역추세(MA20·60 동시 하락) 진입 −3%까지 각오. 승리의 대부분이 도달 전 −1~2%(흔들림 주의는 −3%)만 흔들린 뒤 반등 — −2%(흔들림 −3%)에서 손절하면 결국 오를 것의 90%+ 보존, 그 밑으로 빠지면 방향 오류 확률↑. 🚀 알림에 손절가가 함께 표기됩니다.&#10;7) 청산은 본인 판단 — '적더라도 익절은 옳다'. MA5 이탈 마감이 모멘텀 소진 참고선.&#10;8) 🔁 전환 확인은 보유 종목 매도 타이밍(반대 짝 반등 확인)."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="이 규칙의 실측(42일): 수익은 폭락 후 V반등 날에 집중(07-03 +17.2%), 평범한 날은 본전권(−0.5% 손절 캡). 며칠에 하나 확실한 것만 잡는 구조입니다."/>

                <TextBlock Style="{StaticResource H1}" Text="☕🌙 프리·애프터장 흐름 형태 (세션 요약)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="프리(08:00~08:50)·애프터(15:40~20:00) 세션 등락 궤적을 형태로 분류해 요약 끝에 붙입니다. 본주·저변동처럼 분봉 시그널이 드문 종목은 '이전까지 장 흐름'을 이 형태로 읽어 판단하세요."/>
                <TextBlock Style="{StaticResource Body}"
                           Text="📈 선형 상승 — 꾸준한 매수세, 추세 지속 가능성. 눌림 시 진입 관점.&#10;📉 선형 하락 — 꾸준한 매도세, 반등 전엔 관망.&#10;🚀 제곱형 상승(후반 가속) — 뒤로 갈수록 급등, 모멘텀 강함. 단 막판 과열이면 급반전 주의.&#10;🌙 로그형 상승(초반 급→감속) — 초반 치솟고 힘 빠짐. 상단권이면 익절·추격 자제, 개장 초 급등 후 흔한 형태.&#10;🔻 제곱형 하락(후반 가속) — 낙폭이 커지는 중, 바닥 미확인. 섣부른 저가매수 금물.&#10;🧊 로그형 하락(초반 급락→감속) — 급락 후 낙폭 둔화, 저점 다지기 가능성(V 전조).&#10;✅ V자 반등 — 저점 딛고 상승 전환, 매수 관점 우호.&#10;⚠️ 역V(고점 찍고 하락) — 고점 소진 후 밀림, 매도/관망.&#10;〰️ 등락 반복(Z) — 방향성 약함, 관망. ➡️ 횡보 — 진폭 작음(0.4%p 미만), 재료 대기."/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="형태는 세션 내 등락율 시계열의 곡률(직선 대비 오목/볼록)·최저·최고 위치·방향 전환 횟수로 추정한 근사입니다. '분위기 참고'용이며 매매 신호가 아닙니다 — 특히 저변동 종목의 방향감을 잡는 데 활용하세요."/>

                <TextBlock Style="{StaticResource H1}" Text="설정 권장값 (실측 튜닝)"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="RSI 과매도 상한 35 · 거래량 배수 1.5 · 거래량 창 10봉 · 밴드워킹 상한 7 · %b 회복 하한 0.15 · GC 모멘텀 0.8% · 강력🔥 2.0% · 쿨다운 15분 · 확인 창 20분 · 타임프레임 1,3,5,10,15"/>
                <TextBlock Style="{StaticResource Muted}"
                           Text="쿨다운·확인 창은 타임프레임에 비례해 자동 스케일됩니다(예: 5분봉 쿨다운 = 15×5분). 일봉추세·갭은 종목별 자동 계산이라 별도 설정이 없습니다.&#10;폴링은 적응형: 📈 1차 후 확인 창(20분) 동안 20초(다이버전스·↗ 직후양봉이면 15초)로 자동 단축, GC 확인(등급 무관)·창 만료 시 기본 주기로 복귀합니다 — 분봉은 1분에 1개 완성되므로 상시 단축은 낭비이고, 확인 순간의 포착 지연만 줄입니다."/>

                <TextBlock Style="{StaticResource H1}" Text="알림이 안 올 때 체크리스트"/>
                <TextBlock Style="{StaticResource Body}"
                           Text="① 관심 종목 모니터링 ON(트레이 상주) ② 종목별 '바닥 반등/고점 경고' 체크(국내·비지수만) ③ KIS 키 설정 ④ 평일 09:05~15:40(분봉 시그널) · 시그널은 봉 완성 후 다음 폴링에 도착(최대 ~1분 지연)"/>

            </StackPanel>
        </ScrollViewer>

