<Window x:Class="Brush.Scale.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Brush.Scale"
        Title="Brush.Scale — AI 이미지 업스케일러"
        Width="1100" Height="720" MinWidth="800" MinHeight="560"
        Background="#1A1A2E"
        AllowDrop="True">

  <Window.Resources>
    <!-- 색상 -->
    <SolidColorBrush x:Key="BgBrush"     Color="#1A1A2E"/>
    <SolidColorBrush x:Key="PanelBrush"  Color="#16213E"/>
    <SolidColorBrush x:Key="CardBrush"   Color="#0F3460"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#E94560"/>
    <SolidColorBrush x:Key="TextBrush"   Color="#E0E0E0"/>
    <SolidColorBrush x:Key="DimBrush"    Color="#888888"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#333355"/>

    <!-- 버튼 스타일 -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
      <Setter Property="Background"   Value="#E94560"/>
      <Setter Property="Foreground"   Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"      Value="18,8"/>
      <Setter Property="FontSize"     Value="13"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#FF5A7A"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Background" Value="#444466"/>
                <Setter Property="Foreground" Value="#666688"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
      <Setter Property="Background" Value="#2A2A4A"/>
      <Setter Property="Foreground" Value="#C0C0E0"/>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
      <Setter Property="Background"          Value="#1E1E3A"/>
      <Setter Property="Foreground"          Value="#E0E0E0"/>
      <Setter Property="BorderBrush"         Value="#333355"/>
      <Setter Property="BorderThickness"     Value="1"/>
      <Setter Property="Padding"             Value="8,5"/>
      <Setter Property="FontSize"            Value="12"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <Border x:Name="bd" Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="5">
                <Grid>
                  <ContentPresenter x:Name="contentPresenter"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    Margin="8,5,30,5"
                                    VerticalAlignment="Center"/>
                  <Path x:Name="arrow" HorizontalAlignment="Right" Margin="0,0,10,0"
                        VerticalAlignment="Center" Fill="#888888"
                        Data="M0,0 L6,6 L12,0 Z"/>
                </Grid>
              </Border>
              <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Border Background="#1E1E3A" BorderBrush="#333355" BorderThickness="1"
                        CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}">
                  <ScrollViewer MaxHeight="200">
                    <ItemsPresenter/>
                  </ScrollViewer>
                </Border>
              </Popup>
              <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                            Background="Transparent" BorderThickness="0"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="BorderBrush" Value="#E94560"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
      <Setter Property="Background"  Value="#1E1E3A"/>
      <Setter Property="Foreground"  Value="#E0E0E0"/>
      <Setter Property="Padding"     Value="10,6"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2A2A5A"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#E94560"/>
          <Setter Property="Foreground" Value="White"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Slider -->
    <Style TargetType="Slider">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid>
              <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Background="Transparent" BorderThickness="0" Height="4">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#E94560" CornerRadius="2" Height="4"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Background="Transparent" BorderThickness="0" Height="4">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#333355" CornerRadius="2" Height="4"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Width="14" Height="14">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="#E94560" Stroke="#FF7090" StrokeThickness="1"/>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ScrollBar -->
    <Style TargetType="ScrollBar">
      <Setter Property="Width" Value="6"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid>
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border Background="#444466" CornerRadius="3" Margin="1"/>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
      <Setter Property="Background"      Value="#1E1E3A"/>
      <Setter Property="Foreground"      Value="#E0E0E0"/>
      <Setter Property="BorderBrush"     Value="#333355"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,5"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="CaretBrush"      Value="#E94560"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="#E94560"/>
        </Trigger>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="#E94560"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- ProgressBar -->
    <Style TargetType="ProgressBar">
      <Setter Property="Height"     Value="4"/>
      <Setter Property="Background" Value="#333355"/>
      <Setter Property="Foreground" Value="#E94560"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="2">
              <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                      CornerRadius="2" HorizontalAlignment="Left"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 섹션 레이블 -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground"  Value="#888888"/>
      <Setter Property="FontSize"    Value="10"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
      <Setter Property="Margin"      Value="0,0,0,6"/>
      <Setter Property="Text"        Value="SECTION"/>
    </Style>

    <!-- 경고 배너 -->
    <Style x:Key="WarnBanner" TargetType="Border">
      <Setter Property="Background"     Value="#3A1A00"/>
      <Setter Property="BorderBrush"    Value="#E94560"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"   Value="5"/>
      <Setter Property="Padding"        Value="10,6"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="290"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── 좌측 패널 ───────────────────────────────────────────────────── -->
    <Border Grid.Column="0" Background="#16213E" BorderBrush="#333355" BorderThickness="0,0,1,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

          <!-- 타이틀 -->
          <TextBlock Text="Brush.Scale" FontSize="20" FontWeight="Bold"
                     Foreground="#E94560" Margin="0,8,0,4"/>
          <TextBlock Text="AI 오프라인 이미지 업스케일러" FontSize="11"
                     Foreground="#888888" Margin="0,0,0,20"/>

          <!-- 열기 버튼 -->
          <Button x:Name="BtnOpen" Content="이미지 열기" Style="{StaticResource PrimaryBtn}"
                  Click="BtnOpen_Click" Margin="0,0,0,8"/>
          <Button x:Name="BtnPaste" Content="클립보드 붙여넣기 (Ctrl+V)" Style="{StaticResource SecondaryBtn}"
                  Click="BtnPaste_Click" Margin="0,0,0,20"/>

          <!-- 모델 선택 -->
          <TextBlock Style="{StaticResource SectionLabel}" Text="AI 모델"/>
          <ComboBox x:Name="CbModel"
                    ItemsSource="{Binding Models}"
                    SelectedItem="{Binding SelectedModel}"
                    DisplayMemberPath="DisplayName"
                    Margin="0,0,0,6"/>

          <!-- 모델 없음 경고 -->
          <Border Style="{StaticResource WarnBanner}"
                  Visibility="{Binding ModelNotAvailable, Converter={x:Static local:BoolToVisibility.Instance}}"
                  Margin="0,0,0,6">
            <StackPanel>
              <TextBlock Text="모델 파일이 없습니다." Foreground="#FFA060" FontSize="11" FontWeight="SemiBold"/>
              <TextBlock Text="아래 버튼으로 폴더를 열고 ONNX 파일을 배치하세요." Foreground="#CC8040" FontSize="10" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="모델 폴더 열기" Style="{StaticResource SecondaryBtn}"
                    Click="BtnOpenModelDir_Click" Grid.Column="0" FontSize="11"/>
            <Button Content="새로고침" Style="{StaticResource SecondaryBtn}"
                    Click="BtnRefreshModels_Click" Grid.Column="1" Margin="6,0,0,0" FontSize="11"/>
          </Grid>

          <!-- 배율 -->
          <TextBlock Style="{StaticResource SectionLabel}" Text="업스케일 배율"/>
          <ComboBox ItemsSource="{Binding ScaleFactors}"
                    SelectedItem="{Binding ScaleFactor}"
                    Margin="0,0,0,20">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="{Binding}"/><Run Text="x"/>
                </TextBlock>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <!-- 출력 형식 -->
          <TextBlock Style="{StaticResource SectionLabel}" Text="출력 형식"/>
          <ComboBox ItemsSource="{Binding OutputFormats}"
                    SelectedItem="{Binding SelectedFormat}"
                    DisplayMemberPath="DisplayName"
                    Margin="0,0,0,8"/>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="JPEG 품질: " Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding JpegQuality}" Foreground="#E94560" FontSize="11"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
          </StackPanel>
          <Slider Minimum="60" Maximum="100" Value="{Binding JpegQuality}"
                  TickFrequency="5" IsSnapToTickEnabled="True"
                  Margin="0,0,0,20"/>

          <!-- 실행 버튼 -->
          <Button x:Name="BtnRun" Content="업스케일 실행" Style="{StaticResource PrimaryBtn}"
                  Click="BtnRun_Click" IsEnabled="{Binding IsIdle}" Margin="0,0,0,8"/>
          <Button x:Name="BtnSave" Content="결과 저장" Style="{StaticResource SecondaryBtn}"
                  Click="BtnSave_Click" IsEnabled="{Binding HasResult}" Margin="0,0,0,20"/>

          <Separator Background="#333355" Margin="0,0,0,16"/>

          <!-- 배치 모드 -->
          <TextBlock Style="{StaticResource SectionLabel}" Text="배치 모드"/>

          <TextBlock Text="입력 폴더" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding BatchInputDir}" IsReadOnly="True" Grid.Column="0"/>
            <Button Content="..." Style="{StaticResource SecondaryBtn}" Padding="10,5"
                    Click="BtnBatchIn_Click" Grid.Column="1" Margin="4,0,0,0"/>
          </Grid>

          <TextBlock Text="출력 폴더" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding BatchOutputDir}" IsReadOnly="True" Grid.Column="0"/>
            <Button Content="..." Style="{StaticResource SecondaryBtn}" Padding="10,5"
                    Click="BtnBatchOut_Click" Grid.Column="1" Margin="4,0,0,0"/>
          </Grid>

          <TextBlock Text="출력 파일명 패턴" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
          <TextBox Text="{Binding OutputPattern}" Margin="0,0,0,4"/>
          <TextBlock Text="{}{name} = 원본 파일명,  {scale} = 배율" Foreground="#666688"
                     FontSize="10" Margin="0,0,0,12"/>

          <Button Content="배치 실행" Style="{StaticResource PrimaryBtn}"
                  Click="BtnBatch_Click" IsEnabled="{Binding IsIdle}" Margin="0,0,0,8"/>
          <Button Content="취소" Style="{StaticResource SecondaryBtn}"
                  Command="{Binding CancelCommand}" Margin="0,0,0,16"/>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ── 우측 뷰어 ──────────────────────────────────────────────────── -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- 비교 뷰어 -->
      <Grid Grid.Row="0" x:Name="ViewerGrid" Background="#0D0D1A"
            MouseMove="Viewer_MouseMove" MouseLeave="Viewer_MouseLeave"
            ClipToBounds="True">

        <!-- 드롭 힌트 -->
        <StackPanel x:Name="DropHint" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasImage, Converter={x:Static local:BoolToCollapsed.Instance}}">
          <TextBlock Text="⬆" FontSize="48" Foreground="#333355" HorizontalAlignment="Center"/>
          <TextBlock Text="이미지를 여기에 드래그하거나" FontSize="16" Foreground="#444466"
                     HorizontalAlignment="Center" Margin="0,12,0,4"/>
          <TextBlock Text="Ctrl+V 로 클립보드 이미지를 붙여넣기" FontSize="13" Foreground="#333355"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="JPG · PNG · WebP · BMP · TIFF" FontSize="11" Foreground="#2A2A4A"
                     HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- 원본 이미지 (전체) -->
        <Image x:Name="ImgOriginal" Source="{Binding OriginalBitmap}"
               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="{Binding HasImage, Converter={x:Static local:BoolToVisibility.Instance}}"/>

        <!-- 결과 이미지 (슬라이더 왼쪽 영역만 클리핑) -->
        <Image x:Name="ImgResult" Source="{Binding ResultBitmap}"
               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="{Binding HasResult, Converter={x:Static local:BoolToVisibility.Instance}}">
          <Image.Clip>
            <RectangleGeometry x:Name="ResultClip"/>
          </Image.Clip>
        </Image>

        <!-- 슬라이더 라인 -->
        <Rectangle x:Name="SliderLine" Width="2" Fill="#E94560"
                   VerticalAlignment="Stretch" HorizontalAlignment="Left"
                   Visibility="{Binding HasResult, Converter={x:Static local:BoolToVisibility.Instance}}"
                   IsHitTestVisible="False"/>

        <!-- 슬라이더 핸들 -->
        <Ellipse x:Name="SliderHandle" Width="32" Height="32"
                 Fill="#E94560" Stroke="White" StrokeThickness="2"
                 VerticalAlignment="Center" HorizontalAlignment="Left"
                 Visibility="{Binding HasResult, Converter={x:Static local:BoolToVisibility.Instance}}"
                 IsHitTestVisible="False"/>

        <!-- 라벨 -->
        <TextBlock x:Name="LabelBefore" Text="원본" Foreground="White" FontSize="12" FontWeight="SemiBold"
                   Background="#80000000" Padding="8,3"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,16,0"
                   Visibility="{Binding HasResult, Converter={x:Static local:BoolToVisibility.Instance}}"/>
        <TextBlock x:Name="LabelAfter" Text="업스케일" Foreground="White" FontSize="12" FontWeight="SemiBold"
                   Background="#80E94560" Padding="8,3"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,12,0,0"
                   Visibility="{Binding HasResult, Converter={x:Static local:BoolToVisibility.Instance}}"/>

        <!-- 처리 중 오버레이 -->
        <Border Background="#CC0D0D1A"
                Visibility="{Binding IsBusy, Converter={x:Static local:BoolToVisibility.Instance}}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="업스케일 처리 중..." Foreground="#E94560" FontSize="16"
                       FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <ProgressBar Value="{Binding Progress}" Maximum="100" Width="280" Height="6"/>
            <TextBlock Text="{Binding Progress, StringFormat={}{0:F0}%}" Foreground="#888888"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- 하단 상태바 -->
      <Border Grid.Row="1" Background="#12122A" BorderBrush="#333355" BorderThickness="0,1,0,0"
              Padding="16,6">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="{Binding StatusText}" Foreground="#888888" FontSize="11"
                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
          <TextBlock Grid.Column="1" Foreground="#666688" FontSize="11" VerticalAlignment="Center">
            <Run Text="{Binding InputFileName}"/>
            <Run Text=" → "/>
            <Run Text="{Binding ResultInfo}"/>
          </TextBlock>
        </Grid>
      </Border>
    </Grid>

  </Grid>
</Window>
