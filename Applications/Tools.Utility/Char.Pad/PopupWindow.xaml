<Window x:Class="CharPad.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Char.Pad"
        Width="560" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#000000"/>
    </Window.Effect>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 헤더 -->
                <RowDefinition Height="Auto"/>   <!-- 검색 -->
                <RowDefinition Height="Auto"/>   <!-- 탭 -->
                <RowDefinition Height="*"/>      <!-- 문자 그리드 -->
                <RowDefinition Height="Auto"/>   <!-- 상태바 -->
            </Grid.RowDefinitions>

            <!-- ── 헤더 ── -->
            <Grid Grid.Row="0" Margin="16,12,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⌨ Char.Pad"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Width="28" Height="28"
                        Content="✕" FontSize="11"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        Click="CloseBtn_Click"
                        ToolTip="닫기 (Esc)"/>
            </Grid>

            <!-- ── 검색 ── -->
            <Grid Grid.Row="1" Margin="12,10,12,0">
                <TextBox x:Name="SearchBox"
                         Height="34"
                         Text=""
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"/>
                <TextBlock x:Name="SearchPlaceholder"
                           Text="🔍  문자 이름으로 검색… (예: arrow, copyright, 😀)"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="Segoe UI" FontSize="12"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>

            <!-- ── 카테고리 탭 ── -->
            <ScrollViewer Grid.Row="2" Margin="12,8,12,0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TabPanel" Orientation="Horizontal" Height="32">
                    <!-- 탭은 코드에서 동적 생성 -->
                </StackPanel>
            </ScrollViewer>

            <!-- ── 문자 그리드 ── -->
            <ScrollViewer Grid.Row="3" Margin="12,8,12,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="CharGrid"
                           Orientation="Horizontal"
                           ItemWidth="52" ItemHeight="52"/>
            </ScrollViewer>

            <!-- ── 상태바 ── -->
            <Border Grid.Row="4"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="14,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="Win+Shift+;"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
